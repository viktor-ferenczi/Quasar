@inject AgentRegistry Registry
@inject QuasarConfigProfileCatalog ConfigProfiles
@inject ISnackbar Snackbar
@inject IDialogService DialogService

@{
    IReadOnlyList<string> modDownloadFailures = Runtime is null
        ? Array.Empty<string>()
        : Runtime.ModDownloadFailures;
}

@if (modDownloadFailures.Count > 0)
{
    <MudAlert Severity="Severity.Error" Variant="Variant.Outlined" Dense="true" Class="mb-3">
        <MudText Typo="Typo.subtitle2">Mod download failed during world initialization.</MudText>
        @foreach (var failure in modDownloadFailures.Take(5))
        {
            <MudText Typo="Typo.caption">@failure</MudText>
        }
        @if (modDownloadFailures.Count > 5)
        {
            <MudText Typo="Typo.caption">+@(modDownloadFailures.Count - 5) more in server logs.</MudText>
        }
    </MudAlert>
}

@if (Agent?.Snapshot is null)
{
    <MudAlert Severity="Severity.Info" Variant="Variant.Outlined" Dense="true">
        @GetWaitingText()
    </MudAlert>

    <MudStack Row="true" Wrap="Wrap.Wrap" Spacing="1" Class="mb-3">
        <MudChip T="string" Variant="Variant.Outlined">State @(Runtime?.State.ToString() ?? "Stopped")</MudChip>
        @if (Runtime?.ProcessId is int processId)
        {
            <MudChip T="string" Variant="Variant.Outlined">PID @processId</MudChip>
        }
        @if (Runtime?.StartedAtUtc is DateTimeOffset started)
        {
            <MudChip T="string" Variant="Variant.Outlined">Uptime @FormatDuration((int)Math.Max(0, (DateTimeOffset.UtcNow - started).TotalSeconds))</MudChip>
        }
        @if (!string.IsNullOrWhiteSpace(Server?.CpuAffinity))
        {
            <MudChip T="string" Variant="Variant.Outlined" Icon="@Icons.Material.Filled.Memory">Affinity @Server.CpuAffinity</MudChip>
        }
    </MudStack>

}
else
{
    var pluginLoadSummary = GetPluginLoadSummary();

    <MudStack Row="true" Wrap="Wrap.Wrap" Spacing="1" Class="mb-3">
        <MudChip T="string" Variant="Variant.Outlined">Players @Agent.Snapshot.Metrics.PlayersOnline/@GetMaxPlayers()</MudChip>
        <MudChip T="string" Variant="Variant.Outlined">Sim @Agent.Snapshot.Metrics.SimSpeed.ToString("0.00")</MudChip>
        <MudChip T="string" Variant="Variant.Outlined">CPU @Agent.Snapshot.Metrics.ServerCpuLoadPercent.ToString("0.0")%</MudChip>
        <MudChip T="string" Variant="Variant.Outlined">PCU @Agent.Snapshot.Metrics.UsedPcu/@Agent.Snapshot.Metrics.TotalPcu</MudChip>
        <MudChip T="string" Variant="Variant.Outlined">Mods @Agent.Snapshot.Metrics.ModsLoaded</MudChip>
        <MudChip T="string" Variant="Variant.Outlined" Color="@GetPluginLoadColor(pluginLoadSummary)">Plugins @GetPluginLoadText(pluginLoadSummary)</MudChip>
        <MudChip T="string" Variant="Variant.Outlined">Uptime @FormatDuration(Agent.Snapshot.Metrics.UptimeSeconds)</MudChip>
        @if (GetSaveChipText() is { Length: > 0 } saveChipText)
        {
            <MudTooltip Text="@GetSaveTooltipText()">
                <MudChip T="string"
                         Variant="Variant.Outlined"
                         Color="@GetSaveChipColor()"
                         Icon="@Icons.Material.Filled.Save">
                    @saveChipText
                </MudChip>
            </MudTooltip>
        }
        @if (!string.IsNullOrWhiteSpace(Server?.CpuAffinity))
        {
            <MudChip T="string" Variant="Variant.Outlined" Icon="@Icons.Material.Filled.Memory">Affinity @Server.CpuAffinity</MudChip>
        }
    </MudStack>

    <MudStack Row="true" Spacing="1" Class="mb-3">
        <MudButton Variant="Variant.Filled" Color="Color.Primary" OnClick="@(() => SendCommandAsync(ServerCommandType.Refresh))" Disabled="@(!Agent.IsConnected)">
            Refresh
        </MudButton>
        <MudButton Variant="Variant.Filled" Color="Color.Info" OnClick="@(() => SendCommandAsync(ServerCommandType.SaveWorld))" Disabled="@(!CanSaveWorld)">
            Save
        </MudButton>
    </MudStack>

    <MudText Typo="Typo.subtitle2" Class="mb-2">Send Chat</MudText>
    @* Align to the top: the outlined text field reserves space below its input box for
       helper text, so AlignItems.End would push the button below the visible input. *@
    <MudStack Row="true" AlignItems="AlignItems.Start" Spacing="1" Class="mb-3">
        <MudTextField @bind-Value="_chatText"
                      Label="Broadcast message"
                      Variant="Variant.Outlined"
                      FullWidth="true"
                      Immediate="true"
                      OnKeyDown="HandleChatKeyDownAsync"
                      Disabled="@(!Agent.IsConnected)" />
        <MudButton Variant="Variant.Filled" Color="Color.Success" Class="mt-3" Style="height: 40px;" OnClick="SendChatAsync" Disabled="@(!Agent.IsConnected || string.IsNullOrWhiteSpace(_chatText))">
            Send
        </MudButton>
    </MudStack>

    <MudDivider Class="mb-3" />

    <MudText Typo="Typo.subtitle2" Class="mb-2">Players</MudText>
    <MudTable T="PlayerSnapshot" Dense="true" Hover="true" Items="Agent.Snapshot.Players">
        <HeaderContent>
            <MudTh>Steam ID</MudTh>
            <MudTh>Service</MudTh>
            <MudTh>Faction</MudTh>
            <MudTh>Role</MudTh>
            <MudTh>Ping</MudTh>
            <MudTh>Name</MudTh>
            <MudTh Class="quasar-actions-column"><span class="quasar-visually-hidden">Actions</span></MudTh>
        </HeaderContent>
        <RowTemplate>
            <MudTd DataLabel="Steam ID">
                <MudText Typo="Typo.body2" Class="mono">@context.SteamId</MudText>
            </MudTd>
            <MudTd DataLabel="Service">
                <MudChip T="string" Size="Size.Small" Variant="Variant.Outlined">@GetServiceLabel(context.ServiceName)</MudChip>
            </MudTd>
            <MudTd DataLabel="Faction">@context.FactionTag</MudTd>
            <MudTd DataLabel="Role">@GetRoleLabel(context)</MudTd>
            <MudTd DataLabel="Ping">@context.PingMs</MudTd>
            <MudTd DataLabel="Name">
                <MudText Typo="Typo.body2">@TextSanitizer.CleanGameText(context.DisplayName)</MudText>
                @if (GetPlatformName(context) is { Length: > 0 } platformName)
                {
                    <MudText Typo="Typo.caption">Platform: @platformName</MudText>
                }
            </MudTd>
            <MudTd DataLabel="" Class="quasar-actions-column">
                <MudTooltip Text="Player actions">
                    <MudMenu Dense="true"
                             Icon="@Icons.Material.Filled.MoreVert"
                             OpenChanged="@(open => _menuOpen = open)"
                             AnchorOrigin="Origin.BottomRight"
                             TransformOrigin="Origin.TopRight">
                        <MudMenuItem Disabled="true">Set role</MudMenuItem>
                        @foreach (var promoteLevel in PromoteLevels)
                        {
                            <MudMenuItem Disabled="@IsCurrentPromoteLevel(context, promoteLevel)"
                                         OnClick="@(() => SendPlayerCommandAsync(ServerCommandType.SetPlayerPromoteLevel, context.SteamId, promoteLevel))">
                                @promoteLevel
                            </MudMenuItem>
                        }
                        <MudDivider />
                        <MudMenuItem OnClick="@(() => SendPlayerCommandAsync(ServerCommandType.KickPlayer, context.SteamId))">Kick</MudMenuItem>
                        <MudMenuItem OnClick="@(() => SendPlayerCommandAsync(ServerCommandType.BanPlayer, context.SteamId))">Ban</MudMenuItem>
                    </MudMenu>
                </MudTooltip>
            </MudTd>
        </RowTemplate>
    </MudTable>

    <MudDivider Class="my-3" />

    <MudText Typo="Typo.subtitle2" Class="mb-2">Recent Chat</MudText>
    <div class="chat-list">
        @foreach (var message in Agent.Snapshot.RecentChat.OrderByDescending(item => item.TimestampTicksUtc).Take(12))
        {
            <div class="chat-row">
                <MudText Typo="Typo.caption" Class="mono">@FormatTimestamp(message.TimestampTicksUtc)</MudText>
                <MudText Typo="Typo.body2"><strong>@FormatChatAuthor(message)</strong>: @TextSanitizer.CleanGameText(message.Content)</MudText>
            </div>
        }
    </div>

    <MudDivider Class="my-3" />

    @if (Agent.CommandResults.Count > 0)
    {
        <MudDivider Class="my-3" />
        <MudText Typo="Typo.subtitle2" Class="mb-2">Recent Command Results</MudText>
        @foreach (var result in Agent.CommandResults.Take(6))
        {
            <MudAlert Dense="true" Severity="@(result.Success ? Severity.Success : Severity.Error)" Variant="Variant.Outlined" Class="mb-2">
                @result.Message
            </MudAlert>
        }
    }
}

@code
{
    private static readonly string[] PromoteLevels = ["None", "Scripter", "Moderator", "SpaceMaster", "Admin"];

    [Parameter]
    public DedicatedServerDefinition? Server { get; set; }

    [Parameter]
    public DedicatedServerRuntimeSnapshot? Runtime { get; set; }

    [Parameter]
    public AgentRuntimeState? Agent { get; set; }

    private string _chatText = string.Empty;

    private DedicatedServerProcessState ProcessState => Runtime?.State ?? DedicatedServerProcessState.Stopped;

    private bool IsUnstable => ProcessState is DedicatedServerProcessState.Starting
        or DedicatedServerProcessState.Stopping
        or DedicatedServerProcessState.Restarting;

    private bool CanSaveWorld => Agent?.IsConnected == true && !IsUnstable;

    // True while a player's action menu is open. The parent re-renders this panel on every
    // live snapshot; doing so under an open menu would close it, so we hold renders until the
    // menu is dismissed (click outside / Escape / selection close it natively).
    private bool _menuOpen;

    // Skip live-update renders while a menu is open so the popup is not torn down underneath it.
    protected override bool ShouldRender() => !_menuOpen;

    private async Task HandleChatKeyDownAsync(KeyboardEventArgs args)
    {
        if (args.Key == "Enter")
            await SendChatAsync();
    }

    private async Task SendChatAsync()
    {
        if (Agent is null)
            return;

        var text = _chatText.Trim();
        if (string.IsNullOrWhiteSpace(text))
            return;

        await SendCommandAsync(ServerCommandType.SendChat, text);
        _chatText = string.Empty;
    }

    private Task SendPlayerCommandAsync(ServerCommandType commandType, long steamId, string text = "")
    {
        return SendCommandAsync(commandType, text, steamId);
    }

    private async Task SendCommandAsync(ServerCommandType commandType, string text = "", long? steamId = null)
    {
        if (Agent is null)
            return;

        if (RequiresPlayerCommandConfirmation(commandType) &&
            !await ConfirmPlayerCommandAsync(commandType, steamId))
        {
            return;
        }

        try
        {
            await Registry.SendCommandAsync(new ServerCommandEnvelope
            {
                UniqueName = Agent.UniqueNameKey,
                AgentId = Agent.AgentId,
                ServerId = Agent.ServerKey,
                CommandType = commandType,
                Text = text,
                SteamId = steamId,
            });

            Snackbar.Add($"{commandType} sent to {Agent.ServerDisplayName}.", Severity.Info);
        }
        catch (Exception exception)
        {
            Snackbar.Add(exception.Message, Severity.Error);
        }
    }

    private async Task<bool> ConfirmPlayerCommandAsync(ServerCommandType commandType, long? steamId)
    {
        var action = commandType switch
        {
            ServerCommandType.KickPlayer => "Kick",
            ServerCommandType.BanPlayer => "Ban",
            _ => commandType.ToString(),
        };
        var confirmed = await DialogService.ShowMessageBoxAsync(
            $"{action} player?",
            steamId is null
                ? $"{action} this player?"
                : $"{action} player {steamId.Value}?",
            yesText: action,
            cancelText: "Cancel");

        return confirmed == true;
    }

    private static bool RequiresPlayerCommandConfirmation(ServerCommandType commandType) =>
        commandType is ServerCommandType.KickPlayer or ServerCommandType.BanPlayer;

    private static string FormatDuration(int totalSeconds)
    {
        if (totalSeconds <= 0)
            return "0s";

        var duration = TimeSpan.FromSeconds(totalSeconds);
        if (duration.TotalHours >= 1)
            return $"{(int)duration.TotalHours}h {duration.Minutes}m";
        if (duration.TotalMinutes >= 1)
            return $"{duration.Minutes}m {duration.Seconds}s";

        return $"{duration.Seconds}s";
    }

    private string? GetSaveChipText()
    {
        var metrics = Agent?.Snapshot?.Metrics;
        if (metrics is null)
            return null;

        if (metrics.IsSaveInProgress)
            return "Save in progress";

        if (metrics.LastWorldSaveUtc is not { } lastSaveUtc)
            return null;

        var localTime = lastSaveUtc.ToLocalTime().ToString("HH:mm:ss");
        if (metrics.UnsavedGameTimeSeconds is long unsavedSeconds && unsavedSeconds > 0)
            return $"Saved {localTime} · Unsaved {FormatMinuteSecondDuration(unsavedSeconds)}";

        return $"Saved {localTime}";
    }

    private string GetSaveTooltipText()
    {
        var metrics = Agent?.Snapshot?.Metrics;
        if (metrics is null)
            return string.Empty;

        if (metrics.IsSaveInProgress)
            return "World save in progress.";

        if (metrics.LastWorldSaveUtc is not { } lastSaveUtc)
            return string.Empty;

        var savedAt = lastSaveUtc.ToLocalTime().ToString("yyyy-MM-dd HH:mm:ss");
        if (metrics.UnsavedGameTimeSeconds is long unsavedSeconds)
        {
            return $"Latest world save: {savedAt}. Unsaved game progress: {FormatMinuteSecondDuration(unsavedSeconds)}.";
        }

        return $"Latest world save: {savedAt}.";
    }

    private Color GetSaveChipColor()
    {
        var metrics = Agent?.Snapshot?.Metrics;
        return metrics?.IsSaveInProgress == true ? Color.Info : Color.Default;
    }

    private static string FormatMinuteSecondDuration(long totalSeconds)
    {
        if (totalSeconds <= 0)
            return "00:00";

        var minutes = totalSeconds / 60;
        var seconds = totalSeconds % 60;
        return $"{minutes:00}:{seconds:00}";
    }

    private int GetMaxPlayers()
    {
        var configuredMaxPlayers = GetServerConfigProfile()?.SessionSettings.MaxPlayers;

        if (configuredMaxPlayers is > 0)
            return configuredMaxPlayers.GetValueOrDefault();

        return Agent?.Snapshot?.Metrics.MaxPlayers ?? 0;
    }

    private QuasarConfigProfile? GetServerConfigProfile()
    {
        if (string.IsNullOrWhiteSpace(Server?.ConfigProfileId))
            return null;

        return ConfigProfiles.GetProfile(Server.ConfigProfileId);
    }

    private (int Loaded, int? Total) GetPluginLoadSummary()
    {
        var snapshot = Agent?.Snapshot;
        var profile = GetServerConfigProfile();
        if (profile is null)
            return (snapshot?.Metrics.PluginsLoaded ?? 0, null);

        var configuredPlugins = profile.Plugins
            .Where(plugin => !string.IsNullOrWhiteSpace(plugin.PluginId))
            .ToList();
        var total = configuredPlugins.Count;
        if (total == 0)
            return (0, 0);

        var runtimePlugins = snapshot?.Plugins;
        if (runtimePlugins is null || runtimePlugins.Count == 0)
            return (Math.Min(snapshot?.Metrics.PluginsLoaded ?? 0, total), total);

        var loadedKeys = new HashSet<string>(StringComparer.OrdinalIgnoreCase);
        foreach (var plugin in runtimePlugins.Where(plugin => plugin.IsLoaded))
        {
            AddPluginMatchKeys(loadedKeys, plugin.PluginId);
            AddPluginMatchKeys(loadedKeys, plugin.DisplayName);
        }

        var loaded = configuredPlugins.Count(plugin => IsConfiguredPluginLoaded(plugin, loadedKeys));
        return (loaded, total);
    }

    private static bool IsConfiguredPluginLoaded(QuasarPluginSelection plugin, HashSet<string> loadedKeys)
    {
        if (ContainsPluginMatchKey(loadedKeys, plugin.PluginId))
            return true;

        return ContainsPluginMatchKey(loadedKeys, plugin.DisplayName);
    }

    private static bool ContainsPluginMatchKey(HashSet<string> keys, string value)
    {
        foreach (var key in GetPluginMatchKeys(value))
        {
            if (keys.Contains(key))
                return true;
        }

        return false;
    }

    private static void AddPluginMatchKeys(HashSet<string> keys, string value)
    {
        foreach (var key in GetPluginMatchKeys(value))
            keys.Add(key);
    }

    private static IEnumerable<string> GetPluginMatchKeys(string? value)
    {
        if (string.IsNullOrWhiteSpace(value))
            yield break;

        var trimmed = value.Trim();
        yield return trimmed;

        var normalized = trimmed.Replace('\\', '/').TrimEnd('/');
        var slash = normalized.LastIndexOf('/');
        var fileName = slash >= 0 ? normalized[(slash + 1)..] : normalized;
        if (!string.IsNullOrWhiteSpace(fileName))
        {
            yield return fileName;

            var extension = Path.GetExtension(fileName);
            if (!string.IsNullOrEmpty(extension))
                yield return fileName[..^extension.Length];
        }

        if (slash > 0)
        {
            var parent = normalized[..slash].TrimEnd('/');
            var parentSlash = parent.LastIndexOf('/');
            var parentName = parentSlash >= 0 ? parent[(parentSlash + 1)..] : parent;
            if (!string.IsNullOrWhiteSpace(parentName))
                yield return parentName;
        }
    }

    private static string GetPluginLoadText((int Loaded, int? Total) summary) =>
        summary.Total is int total ? $"{summary.Loaded}/{total}" : summary.Loaded.ToString();

    private static Color GetPluginLoadColor((int Loaded, int? Total) summary) =>
        summary.Total is int total && summary.Loaded != total
            ? Color.Warning
            : Color.Default;

    private static string FormatTimestamp(long ticksUtc)
    {
        if (ticksUtc <= 0)
            return string.Empty;

        return new DateTime(ticksUtc, DateTimeKind.Utc).ToLocalTime().ToString("HH:mm:ss");
    }

    private static string FormatChatAuthor(ChatMessageSnapshot message)
    {
        if (IsServerMessage(message))
            return "Server";

        var author = TextSanitizer.CleanGameText(message.AuthorName);
        return string.IsNullOrWhiteSpace(author) ? message.SteamId.ToString() : author;
    }

    private static bool IsServerMessage(ChatMessageSnapshot message)
    {
        return message.IsServerMessage ||
               message.SteamId <= 0 ||
               IsServerAuthorName(message.AuthorName);
    }

    private static bool IsServerAuthorName(string authorName)
    {
        var normalized = TextSanitizer.CleanGameText(authorName).Trim();
        return string.Equals(normalized, "Good.bot", StringComparison.OrdinalIgnoreCase) ||
               string.Equals(normalized, "Server", StringComparison.OrdinalIgnoreCase);
    }

    private static string GetServiceLabel(string? serviceName)
    {
        return string.IsNullOrWhiteSpace(serviceName) ? "Unknown" : serviceName.Trim();
    }

    private string GetWaitingText()
    {
        if (Runtime?.State is DedicatedServerProcessState.Starting or DedicatedServerProcessState.Restarting)
            return "Starting. Waiting for Quasar.Agent and first game snapshot.";

        if (Runtime?.State == DedicatedServerProcessState.Stopping)
            return "Stopping. Save and shutdown in progress.";

        if (Runtime?.State is DedicatedServerProcessState.Crashed or DedicatedServerProcessState.Faulted)
            return Runtime.LastMessage;

        if (Runtime?.State == DedicatedServerProcessState.Running && Agent?.Snapshot is null)
            return "Connecting. Waiting for Quasar.Agent to reconnect.";

        return "No live game snapshot. Start the server to see metrics, players, and chat.";
    }

    private static string GetPlatformName(PlayerSnapshot player)
    {
        var displayName = TextSanitizer.CleanGameText(player.DisplayName);
        var platformName = TextSanitizer.CleanGameText(player.PlatformDisplayName);
        return string.IsNullOrWhiteSpace(platformName) ||
               string.Equals(platformName, displayName, StringComparison.Ordinal)
            ? string.Empty
            : platformName;
    }

    private static string GetRoleLabel(PlayerSnapshot player)
    {
        var promoteLevel = player.PromoteLevel?.Trim();
        if (!string.IsNullOrWhiteSpace(promoteLevel) &&
            !string.Equals(promoteLevel, "None", StringComparison.OrdinalIgnoreCase))
        {
            return promoteLevel;
        }

        return player.IsAdmin ? "Admin" : "Player";
    }

    private static bool IsCurrentPromoteLevel(PlayerSnapshot player, string promoteLevel) =>
        string.Equals(GetRoleLabel(player), promoteLevel, StringComparison.OrdinalIgnoreCase) ||
        (string.Equals(promoteLevel, "None", StringComparison.OrdinalIgnoreCase) &&
         string.Equals(GetRoleLabel(player), "Player", StringComparison.OrdinalIgnoreCase));
}
