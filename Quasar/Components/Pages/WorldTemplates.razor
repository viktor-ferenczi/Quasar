@page "/world-templates"
@implements IDisposable
@inject QuasarWorldTemplateCatalog WorldTemplateCatalog
@inject ISnackbar Snackbar
@inject IDialogService DialogService

<PageTitle>World Templates</PageTitle>

<MudGrid>
    <MudItem xs="12" xl="5">
        <MudPaper Class="pa-4 summary-card">
            <MudText Typo="Typo.h6" GutterBottom="true">Import World Template</MudText>

            <MudStack Spacing="2">
                <MudTextField @bind-Value="_name" Label="Template name" Variant="Variant.Outlined" />
                <MudTextField @bind-Value="_description" Label="Description" Variant="Variant.Outlined" Lines="3" Sizing="InputSizing.Auto" MaxLines="10000" />
                <MudStack Row="true" Spacing="1" AlignItems="AlignItems.Start">
                    <MudTextField
                        @bind-Value="_sourcePath"
                        Label="Source world path"
                        Variant="Variant.Outlined"
                        Class="flex-grow-1"
                        HelperText="Absolute path to an existing SE save folder containing Sandbox.sbc. Quasar copies all files into managed storage." />
                    <MudButton Variant="Variant.Outlined"
                               Color="Color.Default"
                               StartIcon="@Icons.Material.Filled.FolderOpen"
                               Class="world-template-browse-button"
                               OnClick="OpenFolderPickerAsync">
                        Browse
                    </MudButton>
                </MudStack>

                <MudStack Row="true" Spacing="1">
                    <MudButton
                        Variant="Variant.Filled"
                        Color="Color.Primary"
                        OnClick="ImportAsync"
                        Disabled="_importing">
                        @(_importing ? "Importing…" : "Import")
                    </MudButton>
                    <MudButton Variant="Variant.Outlined" Color="Color.Default" OnClick="ResetForm">Clear</MudButton>
                </MudStack>
            </MudStack>
        </MudPaper>
    </MudItem>

    <MudItem xs="12" xl="7">
        <MudPaper Class="pa-4 server-card">
            <MudText Typo="Typo.h6" GutterBottom="true">World Templates</MudText>
            
            <div>
                <MudText Typo="Typo.body2" Class="mb-4">Reusable world templates. Import an existing Space Engineers save folder and select it when creating a server. Quasar copies template world data into the server on first launch.</MudText>
            </div>

            @if (Templates.Count == 0)
            {
                <MudAlert Severity="Severity.Info" Variant="Variant.Outlined">
                    No world templates yet. Import a save folder to create a template.
                </MudAlert>
            }
            else
            {
                <MudTable T="WorldTemplateRow" Dense="true" Hover="true" Items="Templates">
                    <HeaderContent>
                        <MudTh><MudTableSortLabel SortBy="new Func<WorldTemplateRow, object>(x => x.Template.Name)">Name</MudTableSortLabel></MudTh>
                        <MudTh><MudTableSortLabel SortBy="new Func<WorldTemplateRow, object>(x => x.Template.Description)">Description</MudTableSortLabel></MudTh>
                        <MudTh><MudTableSortLabel SortBy="new Func<WorldTemplateRow, object>(x => x.FileSizeMb)">Size</MudTableSortLabel></MudTh>
                        <MudTh><MudTableSortLabel SortBy="new Func<WorldTemplateRow, object>(x => x.Template.UpdatedAtUtc)">Updated</MudTableSortLabel></MudTh>
                        <MudTh></MudTh>
                    </HeaderContent>
                    <RowTemplate>
                        <MudTd DataLabel="Name">@context.Template.Name</MudTd>
                        <MudTd DataLabel="Description">@context.Template.Description</MudTd>
                        <MudTd DataLabel="Size">
                            @if (context.WorldExists)
                            {
                                <MudText Typo="Typo.caption">@context.FileSizeMb MB</MudText>
                            }
                            else
                            {
                                <MudChip T="string" Color="Color.Warning" Variant="Variant.Outlined" Size="Size.Small">missing</MudChip>
                            }
                        </MudTd>
                        <MudTd DataLabel="Updated">@context.Template.UpdatedAtUtc.LocalDateTime.ToString("g")</MudTd>
                        <MudTd Style="text-align: right;">
                            <MudButton Variant="Variant.Text" Size="Size.Small" OnClick="@(() => CloneAsync(context))" Disabled="@(!context.WorldExists || _importing)">Clone</MudButton>
                            <MudButton Variant="Variant.Text" Size="Size.Small" Color="Color.Error" OnClick="@(() => DeleteAsync(context.Template))">Delete</MudButton>
                        </MudTd>
                    </RowTemplate>
                </MudTable>
            }
        </MudPaper>
    </MudItem>
</MudGrid>

@code
{
    private string _name = string.Empty;
    private string _description = string.Empty;
    private string _sourcePath = string.Empty;
    private bool _importing;

    private sealed record WorldTemplateRow(
        QuasarWorldTemplate Template,
        bool WorldExists,
        long FileSizeMb);

    private IReadOnlyList<WorldTemplateRow> Templates =>
        WorldTemplateCatalog.GetTemplates()
            .Select(p =>
            {
                var worldDir = WorldTemplateCatalog.GetWorldDirectory(p.WorldTemplateId);
                var exists = Directory.Exists(worldDir);
                var sizeMb = exists
                    ? (long)Math.Round(new DirectoryInfo(worldDir).GetFiles("*", SearchOption.AllDirectories).Sum(f => f.Length) / 1048576.0)
                    : 0;
                return new WorldTemplateRow(p, exists, sizeMb);
            })
            .ToList();

    protected override void OnInitialized()
    {
        WorldTemplateCatalog.Changed += HandleChanged;
    }

    public void Dispose()
    {
        WorldTemplateCatalog.Changed -= HandleChanged;
    }

    private async Task ImportAsync()
    {
        if (string.IsNullOrWhiteSpace(_name))
        {
            Snackbar.Add("Template name is required.", Severity.Warning);
            return;
        }

        if (string.IsNullOrWhiteSpace(_sourcePath))
        {
            Snackbar.Add("Source world path is required.", Severity.Warning);
            return;
        }

        _importing = true;
        try
        {
            await WorldTemplateCatalog.ImportAsync(_name, _description, _sourcePath);
            Snackbar.Add($"World template '{_name}' imported.", Severity.Success);
            ResetForm();
        }
        catch (Exception ex)
        {
            Snackbar.Add(ex.Message, Severity.Error);
        }
        finally
        {
            _importing = false;
        }
    }

    private async Task CloneAsync(WorldTemplateRow row)
    {
        var sourceDir = WorldTemplateCatalog.GetWorldDirectory(row.Template.WorldTemplateId);
        var newName = $"{row.Template.Name} (Copy)";
        _importing = true;
        try
        {
            await WorldTemplateCatalog.ImportAsync(newName, row.Template.Description, sourceDir);
            Snackbar.Add($"World template '{newName}' created.", Severity.Success);
        }
        catch (Exception ex)
        {
            Snackbar.Add(ex.Message, Severity.Error);
        }
        finally
        {
            _importing = false;
        }
    }

    private async Task OpenFolderPickerAsync()
    {
        var parameters = new DialogParameters
        {
            [nameof(FolderPickerDialog.InitialPath)] = _sourcePath,
        };

        var dialog = await DialogService.ShowAsync<FolderPickerDialog>(
            "Pick world folder",
            parameters,
            new DialogOptions { CloseOnEscapeKey = true, MaxWidth = MaxWidth.Medium, FullWidth = true });

        var result = await dialog.Result;
        if (result is { Canceled: false, Data: string path })
            _sourcePath = path;
    }

    private async Task DeleteAsync(QuasarWorldTemplate template)
    {
        var confirmed = await DialogService.ShowMessageBoxAsync(
            "Delete world template?",
            $"'{template.Name}' will be permanently removed along with its imported world files. This cannot be undone.",
            yesText: "Delete",
            cancelText: "Cancel");

        if (confirmed != true)
            return;

        await WorldTemplateCatalog.DeleteAsync(template.WorldTemplateId);
        Snackbar.Add("World template deleted.", Severity.Info);
    }

    private void ResetForm()
    {
        _name = string.Empty;
        _description = string.Empty;
        _sourcePath = string.Empty;
    }

    private void HandleChanged() => _ = InvokeAsync(StateHasChanged);
}
