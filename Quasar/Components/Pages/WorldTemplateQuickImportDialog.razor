<MudDialog>
    <DialogContent>
        <MudForm @ref="_form" @bind-IsValid="_formIsValid">
        <MudStack Spacing="3">
            <MudText Typo="Typo.body2">
                Import an existing Space Engineers save folder as a reusable world template, then select it in the server editor.
            </MudText>

            <MudTextField
                @bind-Value="_name"
                Label="Template name"
                Variant="Variant.Outlined"
                Immediate="true"
                AutoFocus="true"
                Required="true"
                RequiredError="Template name required." />

            <MudTextField
                @bind-Value="_description"
                Label="Description"
                Variant="Variant.Outlined"
                Immediate="true"
                Lines="2" />

            <MudStack Row="true" Spacing="1" AlignItems="AlignItems.Start">
                <MudTextField
                    @bind-Value="_sourcePath"
                    Label="Source world path"
                    Variant="Variant.Outlined"
                    Immediate="true"
                    Class="flex-grow-1"
                    Required="true"
                    RequiredError="Source world path required."
                    HelperText="Absolute path to an existing SE save folder containing Sandbox.sbc." />
                <MudButton Variant="Variant.Outlined"
                           Color="Color.Default"
                           StartIcon="@Icons.Material.Filled.FolderOpen"
                           Class="world-template-browse-button"
                           OnClick="OpenFolderPickerAsync">
                    Browse
                </MudButton>
            </MudStack>
        </MudStack>
        </MudForm>
    </DialogContent>
    <DialogActions>
        <MudButton Variant="Variant.Text" Color="Color.Default" OnClick="Cancel" Disabled="@_importing">Cancel</MudButton>
        <MudButton Variant="Variant.Filled" Color="Color.Primary" OnClick="ImportAsync" Disabled="@_importing">
            @(_importing ? "Importing..." : "Import World Template")
        </MudButton>
    </DialogActions>
</MudDialog>

@code
{
    [CascadingParameter]
    private IMudDialogInstance MudDialog { get; set; } = default!;

    [Inject]
    private QuasarWorldTemplateCatalog WorldTemplates { get; set; } = default!;

    [Inject]
    private ISnackbar Snackbar { get; set; } = default!;

    [Inject]
    private IDialogService DialogService { get; set; } = default!;

    private MudForm? _form;
    private bool _formIsValid;
    private string _name = string.Empty;
    private string _description = string.Empty;
    private string _sourcePath = string.Empty;
    private bool _importing;

    private void Cancel()
    {
        MudDialog.Cancel();
    }

    private async Task OpenFolderPickerAsync()
    {
        var parameters = new DialogParameters
        {
            [nameof(FolderPickerDialog.InitialPath)] = _sourcePath,
        };

        var dialog = await DialogService.ShowAsync<FolderPickerDialog>(
            "Pick world folder",
            parameters,
            new DialogOptions { CloseOnEscapeKey = true, MaxWidth = MaxWidth.Medium, FullWidth = true });

        var result = await dialog.Result;
        if (result is { Canceled: false, Data: string path })
            _sourcePath = path;
    }

    private async Task ImportAsync()
    {
        await _form!.ValidateAsync();
        if (!_formIsValid)
            return;

        _importing = true;
        try
        {
            var template = await WorldTemplates.ImportAsync(_name.Trim(), _description?.Trim() ?? string.Empty, _sourcePath.Trim());
            MudDialog.Close(DialogResult.Ok(template));
        }
        catch (Exception exception)
        {
            Snackbar.Add(exception.Message, Severity.Error);
        }
        finally
        {
            _importing = false;
        }
    }
}
