@page "/players"
@implements IDisposable
@inject AgentRegistry Registry
@inject DedicatedServerCatalog ServerCatalog
@inject KnownPlayerCatalog KnownPlayers
@inject ISnackbar Snackbar
@inject IDialogService DialogService

<PageTitle>Players</PageTitle>

<div>
    <MudText Typo="Typo.h5" Class="mb-2">Known Players</MudText>
    <MudText Typo="Typo.body2" Class="mb-4">Known players observed per server, with client service and Steam/member id retained for moderation.</MudText>
</div>

<MudStack Row="true" Wrap="Wrap.Wrap" AlignItems="AlignItems.Center" Justify="Justify.SpaceBetween" Spacing="2" Class="mb-4">
    <MudStack Row="true" Wrap="Wrap.Wrap" AlignItems="AlignItems.Center" Spacing="2">
        <MudSelect T="string"
                   Label="Server"
                   @bind-Value="_serverFilter"
                   Variant="Variant.Outlined"
                   Dense="true"
                   Style="min-width: 14rem;">
            <MudSelectItem T="string" Value="@AllServersFilter">All servers</MudSelectItem>
            @foreach (var option in ServerFilterOptions)
            {
                <MudSelectItem T="string" Value="@option.Value">@option.Label</MudSelectItem>
            }
        </MudSelect>

        <MudSelect T="string"
                   Label="Type"
                   @bind-Value="_typeFilter"
                   Variant="Variant.Outlined"
                   Dense="true"
                   Style="min-width: 10rem;">
            @foreach (var option in PlayerTypeOptions)
            {
                <MudSelectItem T="string" Value="@option.Value">@option.Label</MudSelectItem>
            }
        </MudSelect>

        <MudTextField @bind-Value="_searchText"
                      Label="Search players"
                      Variant="Variant.Outlined"
                      Adornment="Adornment.Start"
                      AdornmentIcon="@Icons.Material.Filled.Search"
                      Clearable="true"
                      Immediate="true"
                      Style="min-width: 16rem;" />

        <MudButton Variant="Variant.Outlined"
                   Color="Color.Error"
                   StartIcon="@Icons.Material.Filled.DeleteSweep"
                   OnClick="CleanSelectedServerAsync"
                   Disabled="@(!CanCleanSelectedServer)">
            Clean Server
        </MudButton>

        <MudButton Variant="Variant.Outlined"
                   Color="Color.Error"
                   StartIcon="@Icons.Material.Filled.DeleteSweep"
                   OnClick="CleanAllAsync"
                   Disabled="@(KnownPlayerViews.Count == 0)">
            Clean All
        </MudButton>
    </MudStack>

    <MudStack Row="true" Wrap="Wrap.Wrap" AlignItems="AlignItems.Center" Spacing="2">
        <MudNumericField T="int"
                         Label="Auto clear after"
                         Value="_retentionDays"
                         ValueChanged="@(value => _retentionDays = value)"
                         Variant="Variant.Outlined"
                         Min="@KnownPlayerCatalog.MinRetentionDays"
                         Max="@KnownPlayerCatalog.MaxRetentionDays"
                         Step="1"
                         Immediate="true"
                         HelperText="days since last seen"
                         Style="width: 11rem;" />
        <MudButton Variant="Variant.Filled"
                   Color="Color.Primary"
                   StartIcon="@Icons.Material.Filled.Save"
                   OnClick="SaveRetentionDaysAsync"
                   Disabled="@(!_retentionDaysDirty)">
            Save
        </MudButton>
    </MudStack>
</MudStack>

<MudStack Row="true" Wrap="Wrap.Wrap" AlignItems="AlignItems.Center" Spacing="2" Class="mb-4">
    <MudChip T="string" Variant="Variant.Outlined">Known @KnownPlayerViews.Count</MudChip>
    <MudChip T="string" Variant="Variant.Outlined">Online @KnownPlayerViews.Count(player => player.IsOnline)</MudChip>
    @if (HasActiveFilter)
    {
        <MudChip T="string" Variant="Variant.Outlined">Shown @FilteredPlayers.Count</MudChip>
    }
</MudStack>

<MudPaper Class="pa-4 server-card players-list-card">
    <MudStack Spacing="2" Class="mb-4 players-list-stack">
        @if (KnownPlayerViews.Count == 0)
        {
            <MudAlert Severity="Severity.Info" Variant="Variant.Outlined">
                No known players yet. Quasar records players after they appear in a live server snapshot.
            </MudAlert>
        }
        else if (FilteredPlayers.Count == 0)
        {
            <MudAlert Severity="Severity.Info" Variant="Variant.Outlined">
                No players match the current filters.
            </MudAlert>
        }
        else
        {
            <MudTable T="KnownPlayerView" Dense="true" Hover="true" Breakpoint="Breakpoint.Md" Items="FilteredPlayers" Class="players-table">
                <HeaderContent>
                    <MudTh><MudTableSortLabel SortBy="new Func<KnownPlayerView, object>(x => x.ServerDisplayName)">Server</MudTableSortLabel></MudTh>
                    <MudTh><MudTableSortLabel SortBy="new Func<KnownPlayerView, object>(x => GetPlayerName(x.Record))">Player</MudTableSortLabel></MudTh>
                    <MudTh><MudTableSortLabel SortBy="new Func<KnownPlayerView, object>(x => GetServiceLabel(x.Record.ServiceName))">Service</MudTableSortLabel></MudTh>
                    <MudTh><MudTableSortLabel SortBy="new Func<KnownPlayerView, object>(x => x.Record.SteamId)">Steam ID</MudTableSortLabel></MudTh>
                    <MudTh><MudTableSortLabel SortBy="new Func<KnownPlayerView, object>(x => x.Record.FactionTag)">Faction</MudTableSortLabel></MudTh>
                    <MudTh><MudTableSortLabel SortBy="new Func<KnownPlayerView, object>(x => GetRoleLabel(x.Record))">Role</MudTableSortLabel></MudTh>
                    <MudTh><MudTableSortLabel SortBy="new Func<KnownPlayerView, object>(x => x.Record.LastSeenUtc)">Last Seen</MudTableSortLabel></MudTh>
                    <MudTh><MudTableSortLabel SortBy="new Func<KnownPlayerView, object>(x => x.IsOnline)">Status</MudTableSortLabel></MudTh>
                    <MudTh></MudTh>
                </HeaderContent>
                <RowTemplate>
                    <MudTd DataLabel="Server">
                        <MudText Typo="Typo.body2">@context.ServerDisplayName</MudText>
                        <MudText Typo="Typo.caption">@context.Record.UniqueName</MudText>
                    </MudTd>
                    <MudTd DataLabel="Player">
                        <MudText Typo="Typo.body2">@GetPlayerName(context.Record)</MudText>
                        @if (GetPlatformName(context.Record) is { Length: > 0 } platformName)
                        {
                            <MudText Typo="Typo.caption">Platform: @platformName</MudText>
                        }
                    </MudTd>
                    <MudTd DataLabel="Service">
                        <MudChip T="string" Size="Size.Small" Variant="Variant.Outlined">@GetServiceLabel(context.Record.ServiceName)</MudChip>
                    </MudTd>
                    <MudTd DataLabel="Steam ID">
                        <MudText Typo="Typo.body2" Class="mono">@context.Record.SteamId</MudText>
                    </MudTd>
                    <MudTd DataLabel="Faction">@context.Record.FactionTag</MudTd>
                    <MudTd DataLabel="Role">@GetRoleLabel(context.Record)</MudTd>
                    <MudTd DataLabel="Last Seen">@FormatLastSeen(context.Record.LastSeenUtc)</MudTd>
                    <MudTd DataLabel="Status">
                        <MudStack Row="true" Wrap="Wrap.Wrap" Spacing="1">
                            <MudChip T="string" Size="Size.Small" Color="@(context.IsOnline ? Color.Success : Color.Default)">
                                @(context.IsOnline ? "online" : "offline")
                            </MudChip>
                            @if (context.Record.IsBanned)
                            {
                                <MudChip T="string" Size="Size.Small" Color="Color.Error">banned</MudChip>
                            }
                            @if (context.IsKickCooldownActive)
                            {
                                <MudChip T="string" Size="Size.Small" Color="Color.Warning">kicked (@(context.KickCooldownRemainingSeconds)s)</MudChip>
                            }
                            @if (!context.CanModerate)
                            {
                                <MudChip T="string" Size="Size.Small" Variant="Variant.Outlined">agent offline</MudChip>
                            }
                        </MudStack>
                    </MudTd>
                    <MudTd Style="text-align: right;">
                        <MudMenu Dense="true"
                                 Icon="@Icons.Material.Filled.MoreVert"
                                 Disabled="@(!context.CanModerate)"
                                 OpenChanged="@(open => _menuOpen = open)"
                                 AnchorOrigin="Origin.BottomRight"
                                 TransformOrigin="Origin.TopRight">
                            <MudMenuItem Disabled="true">Set role</MudMenuItem>
                            @foreach (var promoteLevel in PromoteLevels)
                            {
                                <MudMenuItem Disabled="@IsCurrentPromoteLevel(context.Record, promoteLevel)"
                                             OnClick="@(() => SendPlayerCommandAsync(context, ServerCommandType.SetPlayerPromoteLevel, promoteLevel))">
                                    @promoteLevel
                                </MudMenuItem>
                            }
                            <MudDivider />
                            <MudMenuItem Disabled="@(!context.IsOnline)"
                                         OnClick="@(() => SendPlayerCommandAsync(context, ServerCommandType.KickPlayer))">
                                Kick
                            </MudMenuItem>
                            <MudMenuItem Disabled="@(!context.IsKickCooldownActive)"
                                         OnClick="@(() => SendPlayerCommandAsync(context, ServerCommandType.ClearKickCooldown))">
                                Clear kick cooldown
                            </MudMenuItem>
                            <MudMenuItem OnClick="@(() => SendPlayerCommandAsync(context, context.Record.IsBanned ? ServerCommandType.UnbanPlayer : ServerCommandType.BanPlayer))">
                                @(context.Record.IsBanned ? "Unban" : "Ban")
                            </MudMenuItem>
                        </MudMenu>
                    </MudTd>
                </RowTemplate>
            </MudTable>
        }

        @code
        {
            private static readonly string[] PromoteLevels = ["None", "Scripter", "Moderator", "SpaceMaster", "Admin"];
            private const string AllServersFilter = "";
            private const string PlayerTypeAll = "all";
            private const string PlayerTypeOnline = "online";
            private const string PlayerTypeOffline = "offline";
            private const string PlayerTypeBanned = "banned";
            private const string PlayerTypeKicked = "kicked";

            private static readonly PlayerFilterOption[] PlayerTypeOptions =
            [
                new(PlayerTypeAll, "All"),
                new(PlayerTypeOnline, "Online"),
                new(PlayerTypeOffline, "Offline"),
                new(PlayerTypeBanned, "Banned"),
                new(PlayerTypeKicked, "Kick cooldown"),
            ];

            private string _serverFilter = AllServersFilter;
            private string _typeFilter = PlayerTypeAll;
            private string _searchText = string.Empty;
            private int _retentionDays = KnownPlayerCatalog.DefaultRetentionDays;
            private int _savedRetentionDays = KnownPlayerCatalog.DefaultRetentionDays;

            // True while a row's action menu is open. The live data feed keeps pushing updates;
            // re-rendering the table underneath an open menu would close it, so we hold renders
            // until the menu is dismissed (click outside / Escape / selection close it natively).
            private bool _menuOpen;

            private IReadOnlyList<KnownPlayerView> KnownPlayerViews => BuildKnownPlayerViews();

            private List<PlayerFilterOption> ServerFilterOptions => BuildServerFilterOptions();

            private List<KnownPlayerView> FilteredPlayers => KnownPlayerViews
                .Where(MatchesFilters)
                .ToList();

            private bool HasActiveFilter =>
                !string.IsNullOrWhiteSpace(_serverFilter) ||
                !string.Equals(_typeFilter, PlayerTypeAll, StringComparison.OrdinalIgnoreCase) ||
                !string.IsNullOrWhiteSpace(_searchText);

            private bool CanCleanSelectedServer =>
                !string.IsNullOrWhiteSpace(_serverFilter) &&
                KnownPlayerViews.Any(MatchesServerFilter);

            private bool _retentionDaysDirty => _retentionDays != _savedRetentionDays;

            protected override void OnInitialized()
            {
                _savedRetentionDays = KnownPlayers.RetentionDays;
                _retentionDays = _savedRetentionDays;
                Registry.Changed += HandleChanged;
                ServerCatalog.Changed += HandleChanged;
                KnownPlayers.Changed += HandleChanged;
            }

            public void Dispose()
            {
                Registry.Changed -= HandleChanged;
                ServerCatalog.Changed -= HandleChanged;
                KnownPlayers.Changed -= HandleChanged;
            }

            // Skip live-update renders while a menu is open so the popup is not torn down underneath it.
            protected override bool ShouldRender() => !_menuOpen;

            private List<KnownPlayerView> BuildKnownPlayerViews()
            {
                var agents = Registry.GetAgents();

                // Names configured for each server in Quasar, keyed by unique name. Preferred
                // over the agent's in-game server name so the list shows what the operator named
                // the server rather than ConfigDedicated.ServerName / "Space Engineers {pid}".
                var configuredServerNames = ServerCatalog.GetServers()
                    .ToDictionary(server => server.UniqueName, server => server.DisplayName, StringComparer.OrdinalIgnoreCase);

                var connectedAgentsByServer = agents
                    .Where(agent => agent.IsConnected)
                    .GroupBy(agent => agent.UniqueNameKey, StringComparer.OrdinalIgnoreCase)
                    .ToDictionary(group => group.Key, group => group.First(), StringComparer.OrdinalIgnoreCase);

                var onlinePlayers = agents
                    .Where(agent => agent.IsConnected && agent.Snapshot is not null)
                    .SelectMany(agent => agent.Snapshot!.Players.Select(player => new
                    {
                        Agent = agent,
                        Player = player,
                        PlayerKey = BuildPlayerKey(agent.UniqueNameKey, player.SteamId),
                    }))
                    .ToDictionary(item => item.PlayerKey, item => item.Player, StringComparer.OrdinalIgnoreCase);

                // Kicked players are offline, so they arrive in a separate snapshot collection.
                // Convert each remaining cooldown into an absolute expiry so the countdown keeps
                // ticking down on the client between the ~1s snapshot refreshes.
                var now = DateTimeOffset.UtcNow;
                var kickCooldowns = agents
                    .Where(agent => agent.IsConnected && agent.Snapshot is not null)
                    .SelectMany(agent => agent.Snapshot!.KickedPlayers.Select(kicked => new
                    {
                        PlayerKey = BuildPlayerKey(agent.UniqueNameKey, kicked.SteamId),
                        ExpiresUtc = now.AddMilliseconds(kicked.RemainingCooldownMs),
                    }))
                    .ToDictionary(item => item.PlayerKey, item => item.ExpiresUtc, StringComparer.OrdinalIgnoreCase);

                return KnownPlayers.GetPlayers()
                    .Select(record =>
                    {
                        connectedAgentsByServer.TryGetValue(record.UniqueName, out var agent);
                        onlinePlayers.TryGetValue(record.PlayerKey, out var onlinePlayer);
                        var kickCooldownExpiresUtc = kickCooldowns.TryGetValue(record.PlayerKey, out var expires)
                            ? expires
                            : (DateTimeOffset?)null;
                        configuredServerNames.TryGetValue(record.UniqueName, out var configuredServerName);

                        return new KnownPlayerView
                        {
                            Record = record,
                            Agent = agent,
                            OnlinePlayer = onlinePlayer,
                            KickCooldownExpiresUtc = kickCooldownExpiresUtc,
                            ConfiguredServerName = configuredServerName,
                        };
                    })
                    .OrderByDescending(view => view.IsOnline)
                    .ThenBy(view => view.ServerDisplayName, StringComparer.OrdinalIgnoreCase)
                    .ThenBy(view => GetPlayerName(view.Record), StringComparer.OrdinalIgnoreCase)
                    .ThenBy(view => view.Record.SteamId)
                    .ToList();
            }

            private List<PlayerFilterOption> BuildServerFilterOptions()
            {
                var options = new Dictionary<string, string>(StringComparer.OrdinalIgnoreCase);
                foreach (var server in ServerCatalog.GetServers())
                {
                    var uniqueName = NormalizeFilterValue(server.UniqueName);
                    if (string.IsNullOrWhiteSpace(uniqueName))
                        continue;

                    options[uniqueName] = string.IsNullOrWhiteSpace(server.DisplayName)
                        ? uniqueName
                        : server.DisplayName.Trim();
                }

                foreach (var view in KnownPlayerViews)
                {
                    var uniqueName = NormalizeFilterValue(view.Record.UniqueName);
                    if (string.IsNullOrWhiteSpace(uniqueName) || options.ContainsKey(uniqueName))
                        continue;

                    options[uniqueName] = view.ServerDisplayName;
                }

                return options
                    .Select(pair => new PlayerFilterOption(pair.Key, pair.Value))
                    .OrderBy(option => option.Label, StringComparer.OrdinalIgnoreCase)
                    .ThenBy(option => option.Value, StringComparer.OrdinalIgnoreCase)
                    .ToList();
            }

            private bool MatchesFilters(KnownPlayerView view) =>
                MatchesServerFilter(view) &&
                MatchesTypeFilter(view) &&
                MatchesSearch(view);

            private bool MatchesServerFilter(KnownPlayerView view)
            {
                if (string.IsNullOrWhiteSpace(_serverFilter))
                    return true;

                return string.Equals(
                    NormalizeFilterValue(view.Record.UniqueName),
                    NormalizeFilterValue(_serverFilter),
                    StringComparison.OrdinalIgnoreCase);
            }

            private bool MatchesTypeFilter(KnownPlayerView view)
            {
                return _typeFilter switch
                {
                    PlayerTypeOnline => view.IsOnline,
                    PlayerTypeOffline => !view.IsOnline,
                    PlayerTypeBanned => view.Record.IsBanned,
                    PlayerTypeKicked => view.IsKickCooldownActive,
                    _ => true,
                };
            }

            private bool MatchesSearch(KnownPlayerView view)
            {
                var search = _searchText?.Trim();
                if (string.IsNullOrWhiteSpace(search))
                    return true;

                return Contains(view.Record.ServerName, search)
                       || Contains(view.Record.UniqueName, search)
                       || Contains(GetPlayerName(view.Record), search)
                       || Contains(GetPlatformName(view.Record), search)
                       || Contains(view.Record.ServiceName, search)
                       || Contains(view.Record.FactionTag, search)
                       || view.Record.SteamId.ToString().Contains(search, StringComparison.OrdinalIgnoreCase);
            }

            private async Task SaveRetentionDaysAsync()
            {
                try
                {
                    var removed = await KnownPlayers.SetRetentionDaysAsync(_retentionDays);
                    _savedRetentionDays = KnownPlayers.RetentionDays;
                    _retentionDays = _savedRetentionDays;

                    var message = removed > 0
                        ? $"Known player auto-clear set to {_savedRetentionDays} days. Removed {removed} expired players."
                        : $"Known player auto-clear set to {_savedRetentionDays} days.";
                    Snackbar.Add(message, Severity.Success);
                }
                catch (Exception exception)
                {
                    Snackbar.Add($"Failed to save known player cleanup setting: {exception.Message}", Severity.Error);
                }
            }

            private async Task CleanSelectedServerAsync()
            {
                var uniqueName = NormalizeFilterValue(_serverFilter);
                if (string.IsNullOrWhiteSpace(uniqueName))
                    return;

                var serverName = GetSelectedServerDisplayName();
                var confirmed = await DialogService.ShowMessageBoxAsync(
                    "Clean server known players?",
                    $"Remove all saved known players for '{serverName}'? Live players will be recorded again on the next snapshot.",
                    yesText: "Clean Server",
                    cancelText: "Cancel");
                if (confirmed != true)
                    return;

                try
                {
                    var removed = await KnownPlayers.CleanServerAsync(uniqueName);
                    Snackbar.Add($"Removed {removed} known players for {serverName}.", Severity.Success);
                }
                catch (Exception exception)
                {
                    Snackbar.Add($"Failed to clean known players: {exception.Message}", Severity.Error);
                }
            }

            private async Task CleanAllAsync()
            {
                var confirmed = await DialogService.ShowMessageBoxAsync(
                    "Clean all known players?",
                    "Remove all saved known players from every server? Live players will be recorded again on the next snapshot.",
                    yesText: "Clean All",
                    cancelText: "Cancel");
                if (confirmed != true)
                    return;

                try
                {
                    var removed = await KnownPlayers.CleanAllAsync();
                    Snackbar.Add($"Removed {removed} known players.", Severity.Success);
                }
                catch (Exception exception)
                {
                    Snackbar.Add($"Failed to clean known players: {exception.Message}", Severity.Error);
                }
            }

            private async Task SendPlayerCommandAsync(KnownPlayerView view, ServerCommandType commandType, string text = "")
            {
                if (view.Agent is null)
                {
                    Snackbar.Add($"Server '{view.Record.UniqueName}' is not connected.", Severity.Error);
                    return;
                }

                if (RequiresPlayerCommandConfirmation(commandType) &&
                    !await ConfirmPlayerCommandAsync(view, commandType))
                {
                    return;
                }

                try
                {
                    await Registry.SendCommandAsync(new ServerCommandEnvelope
                    {
                        UniqueName = view.Agent.UniqueNameKey,
                        AgentId = view.Agent.AgentId,
                        ServerId = view.Agent.ServerKey,
                        CommandType = commandType,
                        Text = text,
                        SteamId = view.Record.SteamId,
                    });

                    Snackbar.Add($"{commandType} sent for {GetPlayerName(view.Record)} ({view.Record.SteamId}).", Severity.Info);
                }
                catch (Exception exception)
                {
                    Snackbar.Add(exception.Message, Severity.Error);
                }
            }

            private async Task<bool> ConfirmPlayerCommandAsync(KnownPlayerView view, ServerCommandType commandType)
            {
                var action = commandType switch
                {
                    ServerCommandType.KickPlayer => "Kick",
                    ServerCommandType.BanPlayer => "Ban",
                    _ => commandType.ToString(),
                };
                var playerName = GetPlayerName(view.Record);
                var target = string.IsNullOrWhiteSpace(playerName)
                    ? view.Record.SteamId.ToString()
                    : $"{playerName} ({view.Record.SteamId})";
                var confirmed = await DialogService.ShowMessageBoxAsync(
                    $"{action} player?",
                    $"{action} {target}?",
                    yesText: action,
                    cancelText: "Cancel");

                return confirmed == true;
            }

            private static bool RequiresPlayerCommandConfirmation(ServerCommandType commandType) =>
                commandType is ServerCommandType.KickPlayer or ServerCommandType.BanPlayer;

            private void HandleChanged()
            {
                _ = InvokeAsync(() =>
                {
                    var currentRetentionDays = KnownPlayers.RetentionDays;
                    if (!_retentionDaysDirty)
                        _retentionDays = currentRetentionDays;

                    _savedRetentionDays = currentRetentionDays;
                    StateHasChanged();
                });
            }

            private static bool Contains(string? value, string search)
            {
                return !string.IsNullOrWhiteSpace(value)
                       && value.Contains(search, StringComparison.OrdinalIgnoreCase);
            }

            private static string GetPlayerName(KnownPlayerRecord record)
            {
                var displayName = TextSanitizer.CleanGameText(record.DisplayName);
                return string.IsNullOrWhiteSpace(displayName)
                    ? record.SteamId.ToString()
                    : displayName;
            }

            private static string GetPlatformName(KnownPlayerRecord record)
            {
                var platformName = TextSanitizer.CleanGameText(record.PlatformDisplayName);
                return string.IsNullOrWhiteSpace(platformName) ||
                       string.Equals(platformName, GetPlayerName(record), StringComparison.Ordinal)
                    ? string.Empty
                    : platformName;
            }

            private static string GetRoleLabel(KnownPlayerRecord record)
            {
                var promoteLevel = record.PromoteLevel?.Trim();
                if (!string.IsNullOrWhiteSpace(promoteLevel) &&
                    !string.Equals(promoteLevel, "None", StringComparison.OrdinalIgnoreCase))
                {
                    return promoteLevel;
                }

                return record.IsAdmin ? "Admin" : "Player";
            }

            private static bool IsCurrentPromoteLevel(KnownPlayerRecord record, string promoteLevel) =>
                string.Equals(GetRoleLabel(record), promoteLevel, StringComparison.OrdinalIgnoreCase) ||
                (string.Equals(promoteLevel, "None", StringComparison.OrdinalIgnoreCase) &&
                 string.Equals(GetRoleLabel(record), "Player", StringComparison.OrdinalIgnoreCase));

            private static string GetServiceLabel(string? serviceName)
            {
                return string.IsNullOrWhiteSpace(serviceName) ? "Unknown" : serviceName.Trim();
            }

            private static string FormatLastSeen(DateTimeOffset value)
            {
                if (value == default)
                    return "never";

                return value.ToLocalTime().ToString("yyyy-MM-dd HH:mm");
            }

            private string GetSelectedServerDisplayName()
            {
                var selected = NormalizeFilterValue(_serverFilter);
                if (string.IsNullOrWhiteSpace(selected))
                    return "selected server";

                return ServerFilterOptions
                           .FirstOrDefault(option => string.Equals(option.Value, selected, StringComparison.OrdinalIgnoreCase))
                           ?.Label
                       ?? selected;
            }

            private static string NormalizeFilterValue(string? value) =>
                value?.Trim() ?? string.Empty;

            private static string BuildPlayerKey(string uniqueName, long steamId)
            {
                return $"{uniqueName?.Trim() ?? string.Empty}::{steamId}";
            }

            private sealed record PlayerFilterOption(string Value, string Label);

            private sealed class KnownPlayerView
            {
                public KnownPlayerRecord Record { get; init; } = new();

                public AgentRuntimeState? Agent { get; init; }

                public PlayerSnapshot? OnlinePlayer { get; init; }

                // Name configured for this server in Quasar (DedicatedServerDefinition.DisplayName),
                // or null when no matching server definition exists. Preferred over the agent's
                // in-game server name.
                public string? ConfiguredServerName { get; init; }

                // Absolute time the server's kick cooldown expires for this player, or null when
                // the player is not currently on a kick cooldown. Derived from the live snapshot.
                public DateTimeOffset? KickCooldownExpiresUtc { get; init; }

                public bool IsOnline => OnlinePlayer is not null;

                public bool IsKickCooldownActive => KickCooldownExpiresUtc is { } expires && expires > DateTimeOffset.UtcNow;

                public int KickCooldownRemainingSeconds => KickCooldownExpiresUtc is { } expires
                    ? Math.Max(0, (int)Math.Ceiling((expires - DateTimeOffset.UtcNow).TotalSeconds))
                    : 0;

                public bool CanModerate => Agent?.IsConnected == true;

                public string ServerDisplayName => !string.IsNullOrWhiteSpace(ConfiguredServerName)
                    ? ConfiguredServerName
                    : !string.IsNullOrWhiteSpace(Agent?.ServerDisplayName)
                        ? Agent.ServerDisplayName
                        : !string.IsNullOrWhiteSpace(Record.ServerName)
                            ? Record.ServerName
                            : Record.UniqueName;
            }
        }
    </MudStack>
</MudPaper>
