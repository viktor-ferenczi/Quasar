@page "/"
@implements IDisposable
@inject AgentRegistry Registry
@inject DedicatedServerCatalog ServerCatalog
@inject DedicatedServerSupervisor Supervisor
@inject QuasarConfigProfileCatalog ConfigProfiles
@inject QuasarWorldTemplateCatalog WorldTemplates
@inject ManagedRuntimeWarmupService RuntimeWarmup
@inject IDialogService DialogService
@inject ISnackbar Snackbar

<PageTitle>Dashboard</PageTitle>

<MudStack Row="true" Wrap="Wrap.Wrap" AlignItems="AlignItems.Center" Justify="Justify.SpaceBetween" Spacing="2" Class="mb-2">
    <div>
        <MudText Typo="Typo.h5" Class="mb-2">Dashboard</MudText>        
    </div>
    @if (!ShowSetupWizard)
    {
        <MudButton Variant="Variant.Outlined" Color="Color.Primary" StartIcon="@Icons.Material.Filled.RestartAlt" OnClick="ShowSetupWizardAgain">
            Restart Setup Wizard
        </MudButton>
    }
</MudStack>

@if (ShowSetupWizard)
{
    <MudPaper Class="pa-4 summary-card mb-6">
        <MudStack Spacing="3">
            <MudStack Row="true" Wrap="Wrap.Wrap" AlignItems="AlignItems.Center" Justify="Justify.SpaceBetween" Spacing="2">
                <div>
                    <MudText Typo="Typo.h6">First Setup</MudText>
                    <MudText Typo="Typo.body2">Stay on dashboard. Create templates, create server, launch server, then watch the agent attach here.</MudText>
                </div>
                <MudButton Variant="Variant.Outlined" Color="Color.Default" StartIcon="@Icons.Material.Filled.Close" OnClick="HideSetupWizard">
                    Hide Wizard
                </MudButton>
            </MudStack>

            <MudAlert Severity="Severity.Info" Variant="Variant.Outlined">
                @GetNextSetupHint()
            </MudAlert>

            <MudProgressLinear Value="@SetupProgressPercent" Color="Color.Primary" Class="my-2" />
            <MudText Typo="Typo.caption">@GetSetupProgressText()</MudText>

            <div class="setup-wizard-steps">
                @if (CurrentSetupStep == 0)
                {
                <div class="setup-wizard-step">
                    <MudStack Spacing="2">
                        <MudStack Row="true" Wrap="Wrap.Wrap" AlignItems="AlignItems.Center" Justify="Justify.SpaceBetween" Spacing="2">
                            <MudStack Spacing="0" Class="setup-wizard-copy">
                                <MudStack Row="true" Wrap="Wrap.Wrap" AlignItems="AlignItems.Center" Spacing="1">
                                    <MudText Typo="Typo.subtitle2">Create config template</MudText>
                                    <MudChip T="string" Variant="Variant.Outlined" Color="@(ConfigProfileCount > 0 ? Color.Success : Color.Info)" Size="Size.Small">
                                        @(ConfigProfileCount > 0 ? "Done" : "Recommended")
                                    </MudChip>
                                </MudStack>
                                <MudText Typo="Typo.body2">
                                    @if (ConfigProfileCount > 0)
                                    {
                                        @($"{ConfigProfileCount} config template(s) ready for reuse.")
                                    }
                                    else
                                    {
                                        @("Optional helper. Save reusable world rules, plugins, and mods before server creation.")
                                    }
                                </MudText>
                            </MudStack>

                            <MudStack Row="true" Wrap="Wrap.Wrap" Spacing="1" Class="setup-wizard-actions">
                                <MudButton Variant="@(ConfigProfileCount > 0 ? Variant.Outlined : Variant.Filled)"
                                           Color="@(ConfigProfileCount > 0 ? Color.Default : Color.Primary)"
                                           StartIcon="@Icons.Material.Filled.Tune"
                                           OnClick="OpenCreateConfigProfileDialogAsync">
                                    @(ConfigProfileCount > 0 ? "Add Config Template" : "Create Config Template")
                                </MudButton>
                            </MudStack>
                        </MudStack>

                        @if (ConfigProfilesPreview.Count > 0)
                        {
                            <MudStack Row="true" Wrap="Wrap.Wrap" Spacing="1">
                                @foreach (var template in ConfigProfilesPreview)
                                {
                                    <MudChip T="string" Variant="Variant.Outlined">@template.Name</MudChip>
                                }
                                @if (ConfigProfileCount > ConfigProfilesPreview.Count)
                                {
                                    <MudChip T="string" Variant="Variant.Outlined">+@(ConfigProfileCount - ConfigProfilesPreview.Count) more</MudChip>
                                }
                            </MudStack>
                        }

                        <MudStack Row="true" Spacing="1">
                            <MudButton Variant="Variant.Text" Color="Color.Default" OnClick="SkipCurrentSetupStep">Skip for now</MudButton>
                        </MudStack>
                    </MudStack>
                </div>
                }

                @if (CurrentSetupStep == 1)
                {
                <div class="setup-wizard-step">
                    <MudStack Spacing="2">
                        <MudStack Row="true" Wrap="Wrap.Wrap" AlignItems="AlignItems.Center" Justify="Justify.SpaceBetween" Spacing="2">
                            <MudStack Spacing="0" Class="setup-wizard-copy">
                                <MudStack Row="true" Wrap="Wrap.Wrap" AlignItems="AlignItems.Center" Spacing="1">
                                    <MudText Typo="Typo.subtitle2">Import world template</MudText>
                                    <MudChip T="string" Variant="Variant.Outlined" Color="@(WorldTemplateCount > 0 ? Color.Success : Color.Default)" Size="Size.Small">
                                        @(WorldTemplateCount > 0 ? "Done" : "Optional")
                                    </MudChip>
                                </MudStack>
                                <MudText Typo="Typo.body2">
                                    @if (WorldTemplateCount > 0)
                                    {
                                        @($"{WorldTemplateCount} world template(s) ready to seed server worlds on first launch.")
                                    }
                                    else
                                    {
                                        @("Optional helper. Import a world template if first launch should seed the server world folder automatically.")
                                    }
                                </MudText>
                            </MudStack>

                            <MudStack Row="true" Wrap="Wrap.Wrap" Spacing="1" Class="setup-wizard-actions">
                                <MudButton Variant="@(WorldTemplateCount > 0 ? Variant.Outlined : Variant.Filled)"
                                           Color="@(WorldTemplateCount > 0 ? Color.Default : Color.Primary)"
                                           StartIcon="@Icons.Material.Filled.Public"
                                           OnClick="OpenImportWorldTemplateDialogAsync">
                                    @(WorldTemplateCount > 0 ? "Add World Template" : "Import World Template")
                                </MudButton>
                            </MudStack>
                        </MudStack>

                        @if (WorldTemplatesPreview.Count > 0)
                        {
                            <MudStack Row="true" Wrap="Wrap.Wrap" Spacing="1">
                                @foreach (var template in WorldTemplatesPreview)
                                {
                                    <MudChip T="string" Variant="Variant.Outlined">@template.Name</MudChip>
                                }
                                @if (WorldTemplateCount > WorldTemplatesPreview.Count)
                                {
                                    <MudChip T="string" Variant="Variant.Outlined">+@(WorldTemplateCount - WorldTemplatesPreview.Count) more</MudChip>
                                }
                            </MudStack>
                        }

                        <MudStack Row="true" Spacing="1">
                            <MudButton Variant="Variant.Text" Color="Color.Default" OnClick="SkipCurrentSetupStep">Skip for now</MudButton>
                        </MudStack>
                    </MudStack>
                </div>
                }

                @if (CurrentSetupStep == 2)
                {
                <div class="setup-wizard-step">
                    <MudStack Spacing="2">
                        <MudStack Row="true" Wrap="Wrap.Wrap" AlignItems="AlignItems.Center" Justify="Justify.SpaceBetween" Spacing="2">
                            <MudStack Spacing="0" Class="setup-wizard-copy">
                                <MudStack Row="true" Wrap="Wrap.Wrap" AlignItems="AlignItems.Center" Spacing="1">
                                    <MudText Typo="Typo.subtitle2">Create server</MudText>
                                    <MudChip T="string" Variant="Variant.Outlined" Color="@(ConfiguredServerCount > 0 ? Color.Success : Color.Warning)" Size="Size.Small">
                                        @(ConfiguredServerCount > 0 ? "Done" : "Required")
                                    </MudChip>
                                </MudStack>
                                <MudText Typo="Typo.body2">
                                    @if (ConfiguredServerCount > 0)
                                    {
                                        @($"{ConfiguredServerCount} server definition(s) saved on dashboard.")
                                    }
                                    else
                                    {
                                        @("Required. Define identity, template assignments, runtime policy, restart policy, health policy here.")
                                    }
                                </MudText>
                            </MudStack>

                            <MudStack Row="true" Wrap="Wrap.Wrap" Spacing="1" Class="setup-wizard-actions">
                                <MudButton Variant="@(ConfiguredServerCount > 0 ? Variant.Outlined : Variant.Filled)"
                                           Color="@(ConfiguredServerCount > 0 ? Color.Default : Color.Primary)"
                                           StartIcon="@Icons.Material.Filled.Storage"
                                           OnClick="OpenCreateServerDialogAsync">
                                    @(ConfiguredServerCount > 0 ? "Add Server" : "Create Server")
                                </MudButton>
                            </MudStack>
                        </MudStack>

                        @if (Servers.Count > 0)
                        {
                            <MudStack Spacing="1" Class="setup-wizard-status-list">
                                @foreach (var server in Servers.Take(4))
                                {
                                    <div class="setup-wizard-status-row">
                                        <MudStack Spacing="0" Class="setup-wizard-copy">
                                            <MudText Typo="Typo.body2" Class="mono">@server.UniqueName</MudText>
                                            <MudText Typo="Typo.caption">@GetServerSetupSummary(server)</MudText>
                                        </MudStack>
                                        <MudStack Row="true" Wrap="Wrap.Wrap" Spacing="1">
                                            <MudChip T="string" Variant="Variant.Outlined" Color="@GetSetupStateColor(server.UniqueName)">
                                                @GetSetupStateText(server.UniqueName)
                                            </MudChip>
                                        </MudStack>
                                    </div>
                                }
                            </MudStack>
                        }
                    </MudStack>
                </div>
                }

                @if (CurrentSetupStep == 3)
                {
                <div class="setup-wizard-step">
                    <MudStack Spacing="2">
                        <MudStack Row="true" Wrap="Wrap.Wrap" AlignItems="AlignItems.Center" Justify="Justify.SpaceBetween" Spacing="2">
                            <MudStack Spacing="0" Class="setup-wizard-copy">
                                <MudStack Row="true" Wrap="Wrap.Wrap" AlignItems="AlignItems.Center" Spacing="1">
                                    <MudText Typo="Typo.subtitle2">Start server</MudText>
                                    <MudChip T="string" Variant="Variant.Outlined" Color="@(RunningServerCount > 0 ? Color.Success : Color.Warning)" Size="Size.Small">
                                        @(RunningServerCount > 0 ? "Done" : "Required")
                                    </MudChip>
                                </MudStack>
                                <MudText Typo="Typo.body2">
                                    @if (RunningServerCount > 0)
                                    {
                                        @($"{RunningServerCount} server(s) launching or running now.")
                                    }
                                    else if (ConfiguredServerCount == 0)
                                    {
                                        @("Create server first. Launch buttons appear here after save.")
                                    }
                                    else
                                    {
                                        @("Required. Launch saved server here. Quasar prepares runtime and starts server from dashboard.")
                                    }
                                </MudText>
                            </MudStack>

                            <MudStack Row="true" Wrap="Wrap.Wrap" Spacing="1" Class="setup-wizard-actions">
                                @if (StartableServers.Count == 0)
                                {
                                    <MudButton Variant="Variant.Outlined"
                                               Color="Color.Default"
                                               Disabled="true"
                                               StartIcon="@Icons.Material.Filled.PlayArrow">
                                        @(ConfiguredServerCount == 0 ? "Create Server First" : "All Servers Running")
                                    </MudButton>
                                }
                                else
                                {
                                    @foreach (var server in StartableServers)
                                    {
                                        <MudButton Variant="Variant.Filled"
                                                   Color="Color.Primary"
                                                   StartIcon="@Icons.Material.Filled.PlayArrow"
                                                   OnClick="@(() => StartAsync(server.UniqueName))">
                                            Start @server.UniqueName
                                        </MudButton>
                                    }
                                }
                            </MudStack>
                        </MudStack>
                    </MudStack>
                </div>
                }

                @if (CurrentSetupStep == 4)
                {
                <div class="setup-wizard-step">
                    <MudStack Spacing="2">
                        <MudStack Row="true" Wrap="Wrap.Wrap" AlignItems="AlignItems.Center" Justify="Justify.SpaceBetween" Spacing="2">
                            <MudStack Spacing="0" Class="setup-wizard-copy">
                                <MudStack Row="true" Wrap="Wrap.Wrap" AlignItems="AlignItems.Center" Spacing="1">
                                    <MudText Typo="Typo.subtitle2">Wait for Quasar.Agent</MudText>
                                    <MudChip T="string" Variant="Variant.Outlined" Color="@(ConnectedAgentCount > 0 ? Color.Success : Color.Warning)" Size="Size.Small">
                                        @(ConnectedAgentCount > 0 ? "Done" : "Waiting")
                                    </MudChip>
                                </MudStack>
                                <MudText Typo="Typo.body2">
                                    @if (ConnectedAgentCount > 0)
                                    {
                                        @($"{ConnectedAgentCount} connected agent(s) reporting live server data.")
                                    }
                                    else if (RunningServerCount == 0)
                                    {
                                        @("No running server yet. Launch one above, then dashboard watches attach here.")
                                    }
                                    else
                                    {
                                        @("Dashboard watching live attach now. Keep page open while Quasar.Agent connects.")
                                    }
                                </MudText>
                            </MudStack>

                        </MudStack>

                        @if (LaunchedServers.Count > 0)
                        {
                            <MudStack Spacing="1" Class="setup-wizard-status-list">
                                @foreach (var server in LaunchedServers)
                                {
                                    <div class="setup-wizard-status-row">
                                        <MudStack Spacing="0" Class="setup-wizard-copy">
                                            <MudText Typo="Typo.body2" Class="mono">@server.UniqueName</MudText>
                                            <MudText Typo="Typo.caption">@GetSetupRuntimeSummary(server.UniqueName)</MudText>
                                        </MudStack>
                                        <MudStack Row="true" Wrap="Wrap.Wrap" Spacing="1">
                                            <MudChip T="string" Variant="Variant.Outlined" Color="@GetSetupStateColor(server.UniqueName)">
                                                @GetSetupStateText(server.UniqueName)
                                            </MudChip>
                                            <MudChip T="string" Variant="Variant.Outlined" Color="@GetSetupAgentColor(server.UniqueName)">
                                                @GetSetupAgentText(server.UniqueName)
                                            </MudChip>
                                        </MudStack>
                                    </div>
                                }
                            </MudStack>
                        }
                    </MudStack>
                </div>
                }

                @if (CurrentSetupStep > 0)
                {
                    <MudStack Row="true" Spacing="1" Class="mt-1">
                        <MudButton Variant="Variant.Text" Color="Color.Default" StartIcon="@Icons.Material.Filled.ArrowBack" OnClick="GoToPreviousSetupStep">Back</MudButton>
                    </MudStack>
                }
            </div>
        </MudStack>
    </MudPaper>
}

@if (ProblemBanner is not null)
{
    <MudAlert Severity="@ProblemBanner.Value.Severity" Variant="Variant.Filled" Class="mb-4">
        @ProblemBanner.Value.Message
    </MudAlert>
}

@if (RuntimeWarmupSnapshot.State is ManagedRuntimeWarmupState.Running or ManagedRuntimeWarmupState.Failed)
{
    <MudAlert Severity="@(RuntimeWarmupSnapshot.State == ManagedRuntimeWarmupState.Failed ? Severity.Warning : Severity.Info)"
              Variant="Variant.Outlined"
              Class="mb-4">
        @RuntimeWarmupSnapshot.Message
    </MudAlert>
}

<MudGrid Class="mb-4">
    <MudItem xs="12" sm="6" lg="3">
        <MudPaper Class="pa-4 summary-card">
            <MudText Typo="Typo.overline">Online Servers</MudText>
            <MudText Typo="Typo.h4">@OnlineServerCount</MudText>
        </MudPaper>
    </MudItem>
    <MudItem xs="12" sm="6" lg="3">
        <MudPaper Class="pa-4 summary-card">
            <MudText Typo="Typo.overline">Players Online</MudText>
            <MudText Typo="Typo.h4">@PlayersOnline</MudText>
        </MudPaper>
    </MudItem>
    <MudItem xs="12" sm="6" lg="3">
        <MudPaper Class="@GetProblemCardClass(WarningServerCount, false)">
            <MudText Typo="Typo.overline">Health Warnings</MudText>
            <MudText Typo="Typo.h4">@WarningServerCount</MudText>
        </MudPaper>
    </MudItem>
    <MudItem xs="12" sm="6" lg="3">
        <MudPaper Class="@GetProblemCardClass(UnhealthyServerCount, true)">
            <MudText Typo="Typo.overline">Errors</MudText>
            <MudText Typo="Typo.h4">@UnhealthyServerCount</MudText>
        </MudPaper>
    </MudItem>
</MudGrid>

@if (Servers.Count == 0)
{
    @if (!ShowSetupWizard)
    {
        <MudAlert Severity="Severity.Info" Variant="Variant.Outlined">
            No servers configured yet. Create a server to manage a Space Engineers dedicated server.
        </MudAlert>
    }
}
else
{
    <MudGrid>
        @foreach (var server in Servers)
        {
            <MudItem xs="12" xl="6">
                <ServerCard Server="@server"
                            Runtime="@GetRuntime(server.UniqueName)"
                            Agent="@GetAgent(server.UniqueName)"
                            StartRequested="StartAsync"
                            StopRequested="StopAsync"
                            RestartRequested="RestartAsync" />
            </MudItem>
        }
    </MudGrid>
}

@code
{
    private IReadOnlyList<AgentRuntimeState> Agents => Registry.GetAgents();
    private IReadOnlyList<DedicatedServerDefinition> Servers => ServerCatalog.GetServers();
    private IReadOnlyList<DedicatedServerRuntimeSnapshot> RuntimeSnapshotList => Supervisor.GetSnapshots();
    private ManagedRuntimeWarmupSnapshot RuntimeWarmupSnapshot => RuntimeWarmup.GetSnapshot();
    private IReadOnlyDictionary<string, DedicatedServerRuntimeSnapshot> RuntimeSnapshots => Supervisor
        .GetSnapshots()
        .ToDictionary(snapshot => snapshot.UniqueName, StringComparer.OrdinalIgnoreCase);

    private IReadOnlyList<QuasarConfigProfile> ConfigProfilesPreview => ConfigProfiles.GetProfiles().Take(3).ToList();
    private IReadOnlyList<QuasarWorldTemplate> WorldTemplatesPreview => WorldTemplates.GetTemplates().Take(3).ToList();
    private IReadOnlyList<DedicatedServerDefinition> StartableServers => Servers.Where(server => !IsRunning(server.UniqueName)).ToList();
    private IReadOnlyList<DedicatedServerDefinition> LaunchedServers => Servers.Where(server => IsRunning(server.UniqueName)).ToList();

    private int ConnectedAgentCount => Agents.Count(agent => agent.IsConnected);

    private int OnlineServerCount => Servers.Count(server => IsOpen(server.UniqueName));

    private int PlayersOnline => Servers
        .Select(server => GetAgent(server.UniqueName))
        .Where(agent => agent?.IsConnected == true)
        .Sum(agent => agent?.Snapshot?.Metrics.PlayersOnline ?? 0);

    private int ConfiguredServerCount => Servers.Count;

    private int RunningServerCount => RuntimeSnapshotList.Count(snapshot =>
        snapshot.State is DedicatedServerProcessState.Starting
            or DedicatedServerProcessState.Running
            or DedicatedServerProcessState.Restarting
            or DedicatedServerProcessState.Stopping);

    private int WarningServerCount => RuntimeSnapshotList.Count(snapshot =>
        snapshot.HealthState == DedicatedServerHealthState.Warning);

    private int UnhealthyServerCount => RuntimeSnapshotList.Count(snapshot =>
        snapshot.HealthState == DedicatedServerHealthState.Unhealthy ||
        snapshot.State is DedicatedServerProcessState.Crashed or DedicatedServerProcessState.Faulted);

    private (Severity Severity, string Message)? ProblemBanner
    {
        get
        {
            var error = RuntimeSnapshotList.FirstOrDefault(snapshot =>
                snapshot.HealthState == DedicatedServerHealthState.Unhealthy ||
                snapshot.State is DedicatedServerProcessState.Crashed or DedicatedServerProcessState.Faulted);
            if (error is not null)
                return (Severity.Error, $"{error.UniqueName}: {FirstNonEmpty(error.HealthSummary, error.LastMessage, "Server needs attention.")}");

            var warning = RuntimeSnapshotList.FirstOrDefault(snapshot => snapshot.HealthState == DedicatedServerHealthState.Warning);
            if (warning is not null)
                return (Severity.Warning, $"{warning.UniqueName}: {FirstNonEmpty(warning.HealthSummary, warning.LastMessage, "Health warning.")}");

            return null;
        }
    }

    private int ConfigProfileCount => ConfigProfiles.GetProfiles().Count;

    private int WorldTemplateCount => WorldTemplates.GetTemplates().Count;

    private bool _setupWizardRequested;
    private bool _setupWizardDismissed;
    private bool _setupWizardActive;
    private readonly HashSet<int> _skippedSetupSteps = new();
    private int? _setupStepOverride;

    private bool IsSetupStepComplete(int index) => index switch
    {
        0 => ConfigProfileCount > 0 || _skippedSetupSteps.Contains(0),
        1 => WorldTemplateCount > 0 || _skippedSetupSteps.Contains(1),
        2 => ConfiguredServerCount > 0,
        3 => RunningServerCount > 0,
        4 => ConnectedAgentCount > 0,
        _ => true,
    };

    private int CurrentSetupStep
    {
        get
        {
            if (_setupStepOverride is int forced)
                return Math.Clamp(forced, 0, 4);

            for (var i = 0; i < 5; i++)
                if (!IsSetupStepComplete(i))
                    return i;

            return 4;
        }
    }

    private int SetupProgressPercent
    {
        get
        {
            var completed = 0;
            for (var i = 0; i < 5; i++)
                if (IsSetupStepComplete(i))
                    completed++;

            return completed * 100 / 5;
        }
    }

    private void SkipCurrentSetupStep()
    {
        var step = CurrentSetupStep;
        _skippedSetupSteps.Add(step);
        _setupStepOverride = null;
    }

    private void GoToPreviousSetupStep()
    {
        var step = CurrentSetupStep;
        if (step == 0)
            return;

        _skippedSetupSteps.Remove(step - 1);
        _setupStepOverride = step - 1;
    }

    // The wizard opens automatically only while no dedicated server has been created yet.
    // Server existence is the authoritative, persisted signal, so once the first server
    // exists the wizard never opens automatically again - it can still be reopened with the
    // "Restart Setup Wizard" button. Once shown it stays visible for the rest of the session
    // so the remaining steps (start server, attach agent) can be followed even after the
    // first server is created.
    private bool ShowSetupWizard =>
        (_setupWizardActive || _setupWizardRequested) && !_setupWizardDismissed;

    private void ShowSetupWizardAgain()
    {
        _setupWizardRequested = true;
        _setupWizardDismissed = false;
    }

    private void HideSetupWizard()
    {
        _setupWizardRequested = false;
        _setupWizardActive = false;
        _setupWizardDismissed = true;
    }

    protected override void OnInitialized()
    {
        Registry.Changed += HandleRegistryChanged;
        ServerCatalog.Changed += HandleRegistryChanged;
        Supervisor.Changed += HandleRegistryChanged;
        ConfigProfiles.Changed += HandleRegistryChanged;
        WorldTemplates.Changed += HandleRegistryChanged;
        RuntimeWarmup.Changed += HandleRegistryChanged;

        // Auto-open the first-setup wizard until the first server has been created.
        _setupWizardActive = ConfiguredServerCount == 0;
    }

    public void Dispose()
    {
        Registry.Changed -= HandleRegistryChanged;
        ServerCatalog.Changed -= HandleRegistryChanged;
        Supervisor.Changed -= HandleRegistryChanged;
        ConfigProfiles.Changed -= HandleRegistryChanged;
        WorldTemplates.Changed -= HandleRegistryChanged;
        RuntimeWarmup.Changed -= HandleRegistryChanged;
    }

    private void HandleRegistryChanged()
    {
        _ = InvokeAsync(StateHasChanged);
    }

    private string GetSetupProgressText()
    {
        var completed = 0;
        for (var i = 0; i < 5; i++)
            if (IsSetupStepComplete(i))
                completed++;

        return $"Step {Math.Min(CurrentSetupStep + 1, 5)} of 5 · {completed}/5 complete";
    }

    private string GetNextSetupHint()
    {
        if (ConfiguredServerCount == 0)
        {
            if (ConfigProfileCount == 0 && WorldTemplateCount == 0)
                return "Optional: create config template or import world template here first. Then create first server below.";

            return "Next: create first server below. No page switch needed.";
        }

        if (RunningServerCount == 0)
            return "Next: start saved server below. Quasar handles runtime prep on launch.";

        if (ConnectedAgentCount == 0)
            return "Last step: wait here for Quasar.Agent attach. Dashboard updates live when server reports in.";

        return "Setup complete. Dashboard now stays focused on live running servers.";
    }

    private Task OpenCreateConfigProfileDialogAsync() =>
        ShowFullScreenPageDialogAsync<ConfigsPageDialog>("Config Templates");

    private Task OpenImportWorldTemplateDialogAsync() =>
        ShowFullScreenPageDialogAsync<WorldTemplatesPageDialog>("World Templates");

    private Task OpenCreateServerDialogAsync() =>
        ShowFullScreenPageDialogAsync<ServersPageDialog>("Servers");

    private async Task ShowFullScreenPageDialogAsync<TDialog>(string title) where TDialog : ComponentBase
    {
        var options = new DialogOptions
        {
            CloseOnEscapeKey = true,
            FullScreen = true,
        };

        var dialog = await DialogService.ShowAsync<TDialog>(title, new DialogParameters(), options);
        await dialog.Result;
    }

    private async Task StartAsync(string uniqueName)
    {
        try
        {
            await Supervisor.SetGoalStateAsync(uniqueName, DedicatedServerGoalState.On);
            Snackbar.Add($"Start requested for '{uniqueName}'.", Severity.Success);
        }
        catch (Exception exception)
        {
            Snackbar.Add(exception.Message, Severity.Error);
        }
    }

    private async Task StopAsync(string uniqueName)
    {
        try
        {
            await Supervisor.SetGoalStateAsync(uniqueName, DedicatedServerGoalState.Off);
            Snackbar.Add($"Stop requested for '{uniqueName}'.", Severity.Warning);
        }
        catch (Exception exception)
        {
            Snackbar.Add(exception.Message, Severity.Error);
        }
    }

    private async Task RestartAsync(string uniqueName)
    {
        try
        {
            await Supervisor.RestartServerAsync(uniqueName);
            Snackbar.Add($"Restart requested for '{uniqueName}'.", Severity.Info);
        }
        catch (Exception exception)
        {
            Snackbar.Add(exception.Message, Severity.Error);
        }
    }

    private bool IsRunning(string uniqueName)
    {
        var state = GetRuntime(uniqueName)?.State ?? DedicatedServerProcessState.Stopped;
        return state is DedicatedServerProcessState.Starting
            or DedicatedServerProcessState.Running
            or DedicatedServerProcessState.Restarting
            or DedicatedServerProcessState.Stopping;
    }

    private DedicatedServerRuntimeSnapshot? GetRuntime(string uniqueName)
    {
        RuntimeSnapshots.TryGetValue(uniqueName, out var runtime);
        return runtime;
    }

    private AgentRuntimeState? GetAgent(string uniqueName)
    {
        return Agents
            .Where(agent => agent.IsConnected)
            .FirstOrDefault(agent => string.Equals(agent.UniqueNameKey, uniqueName, StringComparison.OrdinalIgnoreCase));
    }

    private bool IsOpen(string uniqueName)
    {
        var runtime = GetRuntime(uniqueName);
        var agent = GetAgent(uniqueName);
        return runtime?.State == DedicatedServerProcessState.Running &&
               agent?.IsConnected == true &&
               agent.Snapshot is not null;
    }

    private static string GetProblemCardClass(int count, bool error) =>
        count <= 0
            ? "pa-4 summary-card"
            : error
                ? "pa-4 summary-card summary-card-error"
                : "pa-4 summary-card summary-card-warning";

    private static string FirstNonEmpty(params string[] values) =>
        values.FirstOrDefault(value => !string.IsNullOrWhiteSpace(value)) ?? string.Empty;

    private string GetServerSetupSummary(DedicatedServerDefinition server)
    {
        var configProfileName = string.IsNullOrWhiteSpace(server.ConfigProfileId)
            ? "No config template"
            : ConfigProfiles.GetProfile(server.ConfigProfileId)?.Name ?? $"Missing config: {server.ConfigProfileId}";

        var worldTemplateName = string.IsNullOrWhiteSpace(server.WorldTemplateId)
            ? "No world template"
            : WorldTemplates.GetTemplate(server.WorldTemplateId)?.Name ?? $"Missing world: {server.WorldTemplateId}";

        return $"{configProfileName} | {worldTemplateName}";
    }

    private string GetSetupRuntimeSummary(string uniqueName)
    {
        var runtime = GetRuntime(uniqueName);
        if (runtime is null)
            return "No runtime snapshot yet.";

        if (runtime.AgentAttached)
            return "Agent attached. Live dashboard data ready.";

        if (runtime.ProcessId is int processId)
            return $"Process {processId} running. Waiting for Quasar.Agent attach.";

        return "Launch requested. Waiting for process and agent.";
    }

    private string GetSetupStateText(string uniqueName)
    {
        return (GetRuntime(uniqueName)?.State ?? DedicatedServerProcessState.Stopped)
            .ToString()
            .ToLowerInvariant();
    }

    private Color GetSetupStateColor(string uniqueName)
    {
        var state = GetRuntime(uniqueName)?.State ?? DedicatedServerProcessState.Stopped;
        return state switch
        {
            DedicatedServerProcessState.Running => Color.Success,
            DedicatedServerProcessState.Starting => Color.Info,
            DedicatedServerProcessState.Restarting => Color.Warning,
            DedicatedServerProcessState.Stopping => Color.Warning,
            DedicatedServerProcessState.Crashed => Color.Error,
            DedicatedServerProcessState.Faulted => Color.Error,
            _ => Color.Default,
        };
    }

    private string GetSetupAgentText(string uniqueName)
    {
        var runtime = GetRuntime(uniqueName);
        if (runtime is null)
            return "not attached";

        return runtime.AgentAttached ? "attached" : "waiting";
    }

    private Color GetSetupAgentColor(string uniqueName)
    {
        var runtime = GetRuntime(uniqueName);
        if (runtime is null)
            return Color.Default;

        return runtime.AgentAttached ? Color.Success : Color.Warning;
    }

}
