@inject FileBrowserService Browser

<MudDialog>
    <TitleContent>
        <MudStack Row="true" AlignItems="AlignItems.Center" Spacing="1">
            <MudIconButton Icon="@Icons.Material.Filled.Close" Color="Color.Default" OnClick="Cancel" title="Cancel" />
            <MudText Typo="Typo.h6">@DialogTitle</MudText>
        </MudStack>
    </TitleContent>
    <DialogContent>
        <MudStack Spacing="2" Style="min-width: 480px;">
            <MudStack Row="true" Spacing="1" AlignItems="AlignItems.Center">
                <MudTextField @bind-Value="_currentPath"
                              Variant="Variant.Outlined"
                              Immediate="false"
                              Label="Path"
                              Class="mono flex-grow-1"
                              OnKeyDown="HandlePathKeyDownAsync"
                              OnAdornmentClick="Navigate"
                              Adornment="Adornment.End"
                              AdornmentIcon="@Icons.Material.Filled.Refresh" />
                <MudButton Variant="Variant.Outlined" OnClick="Navigate">Go</MudButton>
                <MudIconButton Icon="@Icons.Material.Filled.ArrowUpward" title="Up" OnClick="GoUp" />
            </MudStack>

            <MudCheckBox T="bool" Value="_showHidden" ValueChanged="HandleShowHiddenChanged" Label="Show hidden folders" Dense="true" />

            <MudTextField @bind-Value="_entrySearch"
                          Label="Filter current folder"
                          Variant="Variant.Outlined"
                          Immediate="true"
                          Adornment="Adornment.Start"
                          AdornmentIcon="@Icons.Material.Filled.Search" />

            @if (_shortcuts.Count > 0)
            {
                <MudStack Row="true" Wrap="Wrap.Wrap" Spacing="1">
                    @foreach (var shortcut in _shortcuts)
                    {
                        <MudChip T="string" Variant="Variant.Outlined" Size="Size.Small" OnClick="@(() => NavigateTo(shortcut.FullPath))">
                            @shortcut.Label
                        </MudChip>
                    }
                </MudStack>
            }

            <MudStack Row="true" Wrap="Wrap.Wrap" AlignItems="AlignItems.Center" Spacing="0" Class="folder-picker-breadcrumbs">
                @foreach (var crumb in _breadcrumbs)
                {
                    var isCurrent = string.Equals(crumb.FullPath, _currentPath, StringComparison.OrdinalIgnoreCase);
                    <MudButton Variant="Variant.Text"
                               Size="Size.Small"
                               Disabled="@isCurrent"
                               Class="folder-picker-breadcrumb"
                               OnClick="@(() => NavigateTo(crumb.FullPath))">
                        @crumb.Label
                    </MudButton>
                }
            </MudStack>

            @if (!string.IsNullOrWhiteSpace(_error))
            {
                <MudAlert Severity="Severity.Warning" Variant="Variant.Outlined" Dense="true">@_error</MudAlert>
            }
            else if (RequireWorldFolder && FileBrowserService.IsWorldFolder(_currentPath))
            {
                <MudAlert Severity="Severity.Success" Variant="Variant.Outlined" Dense="true">
                    Sandbox.sbc found. Click "Use this folder" to select it.
                </MudAlert>
            }

            <MudList T="FileBrowserEntry" Dense="true" Style="max-height: 320px; overflow-y: auto;">
                @foreach (var entry in FilteredEntries)
                {
                    <MudListItem T="FileBrowserEntry" OnClick="@(() => NavigateTo(entry.FullPath))">
                        <MudStack Row="true" Spacing="1" AlignItems="AlignItems.Center">
                            <MudIcon Icon="@(entry.IsWorldFolder ? Icons.Material.Filled.Public : Icons.Material.Filled.Folder)"
                                     Color="@(entry.IsWorldFolder ? Color.Success : Color.Default)"
                                     Size="Size.Small" />
                            <MudText Typo="Typo.body2">@entry.Name</MudText>
                            @if (entry.IsWorldFolder)
                            {
                                <MudChip T="string" Size="Size.Small" Color="Color.Success" Variant="Variant.Outlined">world</MudChip>
                            }
                        </MudStack>
                    </MudListItem>
                }
            </MudList>
        </MudStack>
    </DialogContent>
    <DialogActions>
        <MudButton Variant="Variant.Text" Color="Color.Default" OnClick="Cancel">Cancel</MudButton>
        <MudButton Variant="Variant.Filled"
                   Color="Color.Primary"
                   Disabled="@(!CanUseCurrentFolder)"
                   OnClick="UseCurrent">
            Use this folder
        </MudButton>
    </DialogActions>
</MudDialog>

@code
{
    [CascadingParameter]
    private IMudDialogInstance MudDialog { get; set; } = default!;

    [Parameter]
    public string? InitialPath { get; set; }

    [Parameter]
    public string DialogTitle { get; set; } = "Pick world folder";

    [Parameter]
    public bool RequireWorldFolder { get; set; } = true;

    [Parameter]
    public IReadOnlyList<FileBrowserShortcut> AdditionalShortcuts { get; set; } = Array.Empty<FileBrowserShortcut>();

    private string _currentPath = string.Empty;
    private string _error = string.Empty;
    private string _entrySearch = string.Empty;
    private IReadOnlyList<FileBrowserEntry> _entries = Array.Empty<FileBrowserEntry>();
    private IReadOnlyList<FileBrowserBreadcrumb> _breadcrumbs = Array.Empty<FileBrowserBreadcrumb>();
    private IReadOnlyList<FileBrowserShortcut> _shortcuts = Array.Empty<FileBrowserShortcut>();
    private bool _showHidden;
    private bool CanUseCurrentFolder =>
        string.IsNullOrWhiteSpace(_error) &&
        Directory.Exists(_currentPath) &&
        (!RequireWorldFolder || FileBrowserService.IsWorldFolder(_currentPath));

    private List<FileBrowserEntry> FilteredEntries
    {
        get
        {
            var search = _entrySearch.Trim();
            return _entries
                .Where(entry => string.IsNullOrEmpty(search) ||
                    entry.Name.Contains(search, StringComparison.OrdinalIgnoreCase))
                .ToList();
        }
    }

    protected override void OnInitialized()
    {
        _shortcuts = BuildShortcuts();
        var seed = string.IsNullOrWhiteSpace(InitialPath) ? Environment.GetFolderPath(Environment.SpecialFolder.UserProfile) : InitialPath;
        NavigateTo(seed);
    }

    private IReadOnlyList<FileBrowserShortcut> BuildShortcuts()
    {
        var shortcuts = new List<FileBrowserShortcut>();
        var seenPaths = new HashSet<string>(StringComparer.OrdinalIgnoreCase);

        foreach (var shortcut in Browser.GetShortcuts().Concat(AdditionalShortcuts))
        {
            if (string.IsNullOrWhiteSpace(shortcut.FullPath) || !Directory.Exists(shortcut.FullPath))
                continue;

            var fullPath = Path.GetFullPath(shortcut.FullPath);
            if (seenPaths.Add(fullPath))
                shortcuts.Add(shortcut with { FullPath = fullPath });
        }

        return shortcuts;
    }

    private void NavigateTo(string path)
    {
        try
        {
            var resolved = FileBrowserService.ResolvePath(path);
            if (!string.Equals(resolved, _currentPath, StringComparison.OrdinalIgnoreCase))
                _entrySearch = string.Empty;

            _entries = Browser.ListDirectories(resolved, _showHidden);
            _breadcrumbs = FileBrowserService.GetBreadcrumbs(resolved);
            _currentPath = resolved;
            _error = string.Empty;
        }
        catch (Exception exception)
        {
            _error = exception.Message;
        }
    }

    private void Navigate() => NavigateTo(_currentPath);

    private async Task HandlePathKeyDownAsync(KeyboardEventArgs args)
    {
        if (args.Key == "Enter")
            Navigate();

        await Task.CompletedTask;
    }

    private Task HandleShowHiddenChanged(bool value)
    {
        _showHidden = value;
        Navigate();
        return Task.CompletedTask;
    }

    private void GoUp()
    {
        var parent = Directory.GetParent(_currentPath);
        if (parent is not null)
            NavigateTo(parent.FullName);
    }

    private void Cancel() => MudDialog.Cancel();

    private void UseCurrent() => MudDialog.Close(DialogResult.Ok(_currentPath));
}
