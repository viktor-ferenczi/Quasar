@page "/settings/updates"
@attribute [Authorize(Policy = QuasarPolicyNames.CanManageSecurity)]
@implements IDisposable
@inject QuasarUpdateService UpdateService
@inject QuasarUpdateOptions Options
@inject WebServiceOptions WebOptions
@inject ISnackbar Snackbar
@inject IDialogService DialogService

<PageTitle>Updates</PageTitle>

<MudStack Spacing="3">
    <MudStack Row="true" AlignItems="AlignItems.Center" Spacing="2">
        <MudText Typo="Typo.h5">Updates</MudText>
        <MudSpacer />
        <MudButton Variant="Variant.Outlined"
                   Color="Color.Primary"
                   StartIcon="@Icons.Material.Filled.Upgrade"
                   Disabled="_busy"
                   OnClick="CheckNowAsync">
            Check now
        </MudButton>
    </MudStack>

    <MudAlert Severity="@GetStatusSeverity()" Variant="Variant.Outlined">
        @_snapshot.Message
    </MudAlert>

    @if (_snapshot.AppSettingsConflict)
    {
        <MudAlert Severity="Severity.Warning" Variant="Variant.Outlined">
            appsettings.json could not be merged automatically. Resolve the conflict markers below, or force the release defaults.
        </MudAlert>

        <MudPaper Class="pa-4">
            <MudStack Spacing="2">
                <MudText Typo="Typo.h6">appsettings.json conflict</MudText>
                @if (!string.IsNullOrWhiteSpace(_snapshot.AppSettingsConflictPath))
                {
                    <MudText Typo="Typo.caption">@_snapshot.AppSettingsConflictPath</MudText>
                }
                <MudTextField T="string"
                              @bind-Value="_appSettingsConflictText"
                              Label="appsettings.json"
                              Variant="Variant.Outlined"
                              Lines="18"
                              Sizing="InputSizing.Auto"
                              MaxLines="10000"
                              FullWidth="true"
                              Disabled="_busy"
                              Immediate="true" />
                <MudStack Row="true" Spacing="2">
                    <MudButton Variant="Variant.Filled"
                               Color="Color.Primary"
                               StartIcon="@Icons.Material.Filled.Save"
                               Disabled="_busy || string.IsNullOrWhiteSpace(_appSettingsConflictText)"
                               OnClick="SaveAppSettingsResolutionAsync">
                        Save resolution
                    </MudButton>
                    <MudButton Variant="Variant.Outlined"
                               Color="Color.Warning"
                               StartIcon="@Icons.Material.Filled.PriorityHigh"
                               Disabled="_busy || _snapshot.Web is null"
                               OnClick="ForceReleaseAppSettingsAsync">
                        Force release defaults
                    </MudButton>
                </MudStack>
            </MudStack>
        </MudPaper>
    }

    @if (_includePrerelease)
    {
        <MudAlert Severity="Severity.Error" Variant="Variant.Filled">
            Prerelease updates are enabled. This should not be used by regular users. Builds from this stream may be unstable, may require manual recovery, and may update both the UI worker and Bootstrap launcher.
        </MudAlert>
    }

    <MudGrid>
        <MudItem xs="12" md="6">
            <MudPaper Class="pa-4" Style="height:100%">
                <MudStack Spacing="3">
                    <MudText Typo="Typo.h6">Quasar UI</MudText>
                    <MudText Typo="Typo.body2">
                        Current version: <strong>@_snapshot.CurrentVersion</strong>
                    </MudText>

                    @if (_snapshot.WebReleases.Count == 0)
                    {
                        <MudText Typo="Typo.body2">No UI releases detected.</MudText>
                    }
                    else
                    {
                        <MudSelect T="string"
                                   Value="_selectedWebVersion"
                                   ValueChanged="HandleSelectedWebVersionChanged"
                                   Label="Version to install"
                                   Variant="Variant.Outlined"
                                   Disabled="_busy">
                            @foreach (var release in _snapshot.WebReleases)
                            {
                                <MudSelectItem T="string" Value="@release.Version">@FormatWebReleaseOption(release)</MudSelectItem>
                            }
                        </MudSelect>

                        @if (_snapshot.Web is not null)
                        {
                            <MudTable Items="new[] { _snapshot.Web }" Dense="true" Hover="true">
                                <HeaderContent>
                                    <MudTh>Version</MudTh>
                                    <MudTh>Asset</MudTh>
                                    <MudTh>Status</MudTh>
                                </HeaderContent>
                                <RowTemplate>
                                    <MudTd DataLabel="Version">@context.Version</MudTd>
                                    <MudTd DataLabel="Asset">@context.AssetName</MudTd>
                                    <MudTd DataLabel="Status">@FormatWebReleaseStatus(context)</MudTd>
                                </RowTemplate>
                            </MudTable>

                            @if (!string.IsNullOrWhiteSpace(_snapshot.Web.StagedDirectory))
                            {
                                <MudText Typo="Typo.caption">Staged at @_snapshot.Web.StagedDirectory</MudText>
                            }
                        }

                        <MudStack Row="true" Spacing="2">
                            <MudButton Variant="Variant.Outlined"
                                       Color="Color.Primary"
                                       StartIcon="@Icons.Material.Filled.Download"
                                       Disabled="_busy || _snapshot.Web is null || _snapshot.Web.IsStaged || _snapshot.Web.IsCurrent"
                                       OnClick="StageAsync">
                                Stage
                            </MudButton>
                            <MudButton Variant="Variant.Filled"
                                       Color="Color.Warning"
                                       StartIcon="@Icons.Material.Filled.RestartAlt"
                                       Disabled="_busy || _snapshot.Web is null || !_snapshot.Web.IsStaged || _snapshot.Web.IsCurrent"
                                       OnClick="ActivateAsync">
                                Activate
                            </MudButton>
                        </MudStack>
                    }
                </MudStack>
            </MudPaper>
        </MudItem>

        <MudItem xs="12" md="6">
            <MudPaper Class="pa-4" Style="height:100%">
                <MudStack Spacing="3">
                    <MudText Typo="Typo.h6">Bootstrap</MudText>
                    <MudText Typo="Typo.body2">
                        Bootstrap updates are installed automatically by the launcher when a newer primary Quasar release is available.
                    </MudText>
                    <MudText Typo="Typo.body2">
                        Current version: <strong>@FormatBootstrapVersion()</strong>
                    </MudText>

                    @if (_snapshot.Bootstrap is null)
                    {
                        <MudText Typo="Typo.body2">No bootstrap update detected.</MudText>
                    }
                    else
                    {
                        <MudTable Items="new[] { _snapshot.Bootstrap }" Dense="true" Hover="true">
                            <HeaderContent>
                                <MudTh>Version</MudTh>
                                <MudTh>Asset</MudTh>
                                <MudTh>Action</MudTh>
                            </HeaderContent>
                            <RowTemplate>
                                <MudTd DataLabel="Version">@context.Version</MudTd>
                                <MudTd DataLabel="Asset">@context.AssetName</MudTd>
                                <MudTd DataLabel="Action">Automatic launcher restart</MudTd>
                            </RowTemplate>
                        </MudTable>
                    }
                </MudStack>
            </MudPaper>
        </MudItem>

        <MudItem xs="12">
            <MudPaper Class="pa-4">
                <MudStack Spacing="2">
                    <MudText Typo="Typo.h6">Source</MudText>
                    <MudText Typo="Typo.body2">
                        GitHub: @Options.Owner/@Options.Repository
                    </MudText>
                    <MudText Typo="Typo.body2">
                        Check interval: @Options.CheckInterval.TotalMinutes.ToString("0") min
                    </MudText>
                    <MudText Typo="Typo.body2">
                        Release stream: @(_includePrerelease ? "stable and prerelease" : "stable only")
                    </MudText>
                    <MudSwitch T="bool"
                               Value="_includePrerelease"
                               ValueChanged="HandleIncludePrereleaseChanged"
                               Disabled="_busy"
                               Color="Color.Error"
                               Label="Include prerelease versions" />
                    <MudAlert Severity="Severity.Warning" Variant="Variant.Outlined" Dense="true">
                        Prerelease versions are for testing only and should not be used by regular users.
                    </MudAlert>
                    <MudCheckBox T="bool"
                                 Value="_autoStageWebUpdates"
                                 ValueChanged="HandleAutoStageWebUpdatesChanged"
                                 Disabled="_busy"
                                 Label="Automatically stage UI updates after checks" />
                    <MudText Typo="Typo.caption">
                        Turn this off to only queue detected versions, then stage and activate the selected version manually.
                    </MudText>
                    <MudText Typo="Typo.body2">
                        Last check: @(FormatTimestamp(_snapshot.LastCheckedUtc))
                    </MudText>
                    <MudText Typo="Typo.body2">
                        UI asset: @Options.WebAssetName
                    </MudText>
                    <MudText Typo="Typo.body2">
                        Bootstrap asset: @Options.BootstrapAssetName
                    </MudText>
                </MudStack>
            </MudPaper>
        </MudItem>
    </MudGrid>
</MudStack>

@code {
    private QuasarUpdateSnapshot _snapshot = new();
    private bool _busy;
    private bool _includePrerelease;
    private bool _autoStageWebUpdates = true;
    private string _selectedWebVersion = string.Empty;
    private string _appSettingsConflictText = string.Empty;

    protected override void OnInitialized()
    {
        _snapshot = UpdateService.GetSnapshot();
        _includePrerelease = Options.IncludePrerelease;
        _autoStageWebUpdates = Options.AutoStageWebUpdates;
        _selectedWebVersion = _snapshot.SelectedWebVersion;
        UpdateService.Changed += OnUpdatesChanged;
        if (_snapshot.AppSettingsConflict)
            _ = LoadAppSettingsConflictAsync();
    }

    public void Dispose()
    {
        UpdateService.Changed -= OnUpdatesChanged;
    }

    private void OnUpdatesChanged() => _ = InvokeAsync(() =>
    {
        _snapshot = UpdateService.GetSnapshot();
        _includePrerelease = Options.IncludePrerelease;
        _autoStageWebUpdates = Options.AutoStageWebUpdates;
        _selectedWebVersion = _snapshot.SelectedWebVersion;
        if (!_snapshot.AppSettingsConflict)
            _appSettingsConflictText = string.Empty;
        StateHasChanged();
        if (_snapshot.AppSettingsConflict)
            _ = LoadAppSettingsConflictAsync();
    });

    private async Task CheckNowAsync()
    {
        await RunBusyAsync(
            () => UpdateService.CheckNowAsync(),
            "Update check complete.",
            "Update check failed");
    }

    private async Task StageAsync()
    {
        _busy = true;
        try
        {
            await UpdateService.StageWebUpdateAsync();
            _snapshot = UpdateService.GetSnapshot();
            if (_snapshot.AppSettingsConflict)
            {
                await LoadAppSettingsConflictAsync();
                Snackbar.Add("appsettings.json needs manual conflict resolution before activation.", Severity.Warning);
            }
            else
            {
                Snackbar.Add("Quasar UI update staged.", Severity.Success);
            }
        }
        catch (Exception exception)
        {
            Snackbar.Add($"Failed staging update: {exception.Message}", Severity.Error);
        }
        finally
        {
            _busy = false;
        }
    }

    private async Task ActivateAsync()
    {
        await RunBusyAsync(
            () => UpdateService.ActivateStagedWebUpdateAsync(),
            "Quasar UI update activation requested. The page will reconnect shortly.",
            "Failed activating update");
    }

    private async Task HandleSelectedWebVersionChanged(string? version)
    {
        version ??= string.Empty;
        if (string.Equals(version, _selectedWebVersion, StringComparison.OrdinalIgnoreCase))
            return;

        _selectedWebVersion = version;
        _busy = true;
        try
        {
            await UpdateService.SelectWebReleaseAsync(version);
            _snapshot = UpdateService.GetSnapshot();
        }
        catch (Exception exception)
        {
            Snackbar.Add($"Failed selecting version: {exception.Message}", Severity.Error);
        }
        finally
        {
            _busy = false;
        }
    }

    private async Task HandleIncludePrereleaseChanged(bool value)
    {
        if (value == _includePrerelease)
            return;

        var previous = _includePrerelease;
        if (value)
        {
            var confirmed = await DialogService.ShowMessageBoxAsync(
                "Enable prerelease updates?",
                "Prerelease updates are for testing only and should not be used by regular users. They may be unstable, may require manual recovery, and may update both the UI worker and Bootstrap launcher.",
                yesText: "Enable prereleases",
                cancelText: "Cancel");

            if (confirmed != true)
            {
                _includePrerelease = previous;
                return;
            }
        }

        _includePrerelease = value;
        _busy = true;
        try
        {
            await UpdateService.SetIncludePrereleaseAsync(value);
            await UpdateService.CheckNowAsync();
            _snapshot = UpdateService.GetSnapshot();
            Snackbar.Add(value ? "Prerelease updates enabled." : "Prerelease updates disabled.", value ? Severity.Warning : Severity.Success);
        }
        catch (Exception exception)
        {
            _includePrerelease = previous;
            Snackbar.Add($"Failed updating release stream: {exception.Message}", Severity.Error);
        }
        finally
        {
            _busy = false;
        }
    }

    private async Task HandleAutoStageWebUpdatesChanged(bool value)
    {
        if (value == _autoStageWebUpdates)
            return;

        var previous = _autoStageWebUpdates;
        _autoStageWebUpdates = value;
        _busy = true;
        try
        {
            await UpdateService.SetAutoStageWebUpdatesAsync(value);
            _snapshot = UpdateService.GetSnapshot();
            Snackbar.Add(value ? "Automatic UI staging enabled." : "Manual UI staging enabled.", Severity.Success);
        }
        catch (Exception exception)
        {
            _autoStageWebUpdates = previous;
            Snackbar.Add($"Failed updating staging mode: {exception.Message}", Severity.Error);
        }
        finally
        {
            _busy = false;
        }
    }

    private async Task LoadAppSettingsConflictAsync()
    {
        try
        {
            _appSettingsConflictText = await UpdateService.ReadAppSettingsConflictTextAsync();
            await InvokeAsync(StateHasChanged);
        }
        catch (Exception exception)
        {
            Snackbar.Add($"Failed loading appsettings.json conflict: {exception.Message}", Severity.Error);
        }
    }

    private async Task SaveAppSettingsResolutionAsync()
    {
        await RunBusyAsync(
            () => UpdateService.ResolveAppSettingsConflictAsync(_appSettingsConflictText),
            "appsettings.json conflict resolved.",
            "Failed saving appsettings.json");
    }

    private async Task ForceReleaseAppSettingsAsync()
    {
        var confirmed = await DialogService.ShowMessageBoxAsync(
            "Force release appsettings.json?",
            "This discards local appsettings.json values for the staged update and uses the release defaults.",
            yesText: "Force defaults",
            cancelText: "Cancel");

        if (confirmed != true)
            return;

        await RunBusyAsync(
            () => UpdateService.StageWebUpdateAsync(forceAppSettingsOverride: true),
            "Release appsettings.json staged.",
            "Failed forcing release appsettings.json");
    }

    private async Task RunBusyAsync(Func<Task> action, string successMessage, string failurePrefix)
    {
        _busy = true;
        try
        {
            await action();
            _snapshot = UpdateService.GetSnapshot();
            Snackbar.Add(successMessage, Severity.Success);
        }
        catch (Exception exception)
        {
            Snackbar.Add($"{failurePrefix}: {exception.Message}", Severity.Error);
        }
        finally
        {
            _busy = false;
        }
    }

    private Severity GetStatusSeverity() => _snapshot.Status switch
    {
        _ when _snapshot.AppSettingsConflict => Severity.Warning,
        QuasarUpdateStatus.Failed => Severity.Error,
        QuasarUpdateStatus.Staged => Severity.Success,
        QuasarUpdateStatus.UpdateQueued or QuasarUpdateStatus.Staging or QuasarUpdateStatus.Activating => Severity.Info,
        _ => _snapshot.Enabled ? Severity.Normal : Severity.Warning,
    };

    private static string FormatTimestamp(DateTimeOffset? timestamp) =>
        timestamp is null ? "never" : timestamp.Value.ToLocalTime().ToString("yyyy-MM-dd HH:mm:ss");

    private string FormatBootstrapVersion() =>
        string.IsNullOrWhiteSpace(_snapshot.CurrentBootstrapVersion)
            ? "not managed by Bootstrap"
            : _snapshot.CurrentBootstrapVersion;

    private static string FormatWebReleaseOption(QuasarUpdateCandidate release)
    {
        var badges = new List<string>();
        if (release.IsCurrent)
            badges.Add("current");
        else if (release.IsNewer)
            badges.Add("newer");
        else
            badges.Add("rollback");

        if (release.IsPrerelease)
            badges.Add("prerelease");

        if (release.IsStaged)
            badges.Add("staged");

        return $"{release.Version} ({string.Join(", ", badges)})";
    }

    private static string FormatWebReleaseStatus(QuasarUpdateCandidate release)
    {
        if (release.IsCurrent)
            return "Current";

        if (release.IsStaged)
            return release.IsNewer ? "Staged update" : "Staged rollback";

        return release.IsNewer ? "Ready to download" : "Rollback available";
    }
}
