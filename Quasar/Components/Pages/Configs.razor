    private void SetPluginSelection(QuasarPluginCatalogEntry entry, bool selected)
    {
        if (_editor is null)
            return;

        if (selected && !QuasarPluginCatalogService.IsManualSelectionAllowed(entry.PluginId))
        {
            Snackbar.Add("This plugin is managed automatically by Magnetar and cannot be selected manually.", Severity.Info);
            return;
        }

        if (selected && entry.Hidden)
        {
            var message = entry.IsLocalDevFolder
                ? "Enable the dev folder source before selecting it in a config profile."
                : "This plugin is hidden in MagnetarHub and cannot be selected manually.";
            Snackbar.Add(message, Severity.Info);
            return;
        }

        var existing = _editor.Plugins.FirstOrDefault(plugin =>
            string.Equals(plugin.PluginId, entry.PluginId, StringComparison.OrdinalIgnoreCase));

        if (selected)
        {
            if (existing is null)
            {
                _editor.Plugins.Add(new QuasarPluginSelection
                {
                    PluginId = entry.PluginId,
                    DisplayName = string.IsNullOrWhiteSpace(entry.FriendlyName) ? entry.PluginId : entry.FriendlyName,
                });
                _editor.Plugins = _editor.Plugins
                    .OrderBy(plugin => plugin.DisplayName, StringComparer.OrdinalIgnoreCase)
                    .ToList();
            }
        }
        else if (existing is not null)
        {
            _editor.Plugins.Remove(existing);
        }
    }

    private void RemovePlugin(string pluginId)
    {
        if (_editor is null)
            return;

        _editor.Plugins.RemoveAll(plugin => string.Equals(plugin.PluginId, pluginId, StringComparison.OrdinalIgnoreCase));
    }

    private void AddCustomPlugin()
    {
        if (_editor is null)
