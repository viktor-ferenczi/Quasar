@page "/instances"
@implements IDisposable
@inject DedicatedServerInstanceCatalog InstanceCatalog
@inject DedicatedServerSupervisor Supervisor
@inject AgentRegistry Registry
@inject QuasarConfigProfileCatalog ConfigProfiles
@inject QuasarWorldTemplateCatalog WorldTemplates
@inject IDialogService DialogService
@inject WebServiceOptions Options
@inject ISnackbar Snackbar

<PageTitle>Instances</PageTitle>

<MudText Typo="Typo.h4" GutterBottom="true">Instances</MudText>
<MudText Typo="Typo.body2" Class="mb-4">Persistent headless DS instance definitions owned by Quasar. Quasar now uses these definitions to launch, stop, and restart processes, while Quasar.Agent attaches after the server comes up.</MudText>

<MudPaper Class="pa-4 server-card">
    <MudStack Row="true" Wrap="Wrap.Wrap" AlignItems="AlignItems.Center" Justify="Justify.SpaceBetween" Spacing="2" Class="mb-4">
        <div>
            <MudText Typo="Typo.h6">Configured Instances</MudText>
            <MudText Typo="Typo.body2">Create the full instance definition in one dialog, then manage lifecycle from the list.</MudText>
        </div>
        <MudStack Row="true" Wrap="Wrap.Wrap" AlignItems="AlignItems.Center" Spacing="1">
            <MudChip T="string" Variant="Variant.Outlined">@($"{InstanceDefinitions.Count} instance(s)")</MudChip>
            <MudButton Variant="Variant.Filled" Color="Color.Primary" StartIcon="@Icons.Material.Filled.Add" OnClick="OpenCreateDialogAsync">
                Create Instance
            </MudButton>
        </MudStack>
    </MudStack>

    @if (InstanceDefinitions.Count == 0)
    {
        <MudAlert Severity="Severity.Info" Variant="Variant.Outlined">
            No instances defined yet.
        </MudAlert>
    }
    else
    {
        <MudTable T="DedicatedServerInstanceDefinition" Dense="true" Hover="true" Breakpoint="Breakpoint.Md" Items="InstanceDefinitions">
            <HeaderContent>
                <MudTh>Status</MudTh>
                <MudTh>Unique Name</MudTh>
                <MudTh>Config</MudTh>
                <MudTh>Process</MudTh>
                <MudTh>Agent</MudTh>
                <MudTh>Health</MudTh>
                <MudTh></MudTh>
            </HeaderContent>
            <RowTemplate>
                <MudTd DataLabel="Status">
                    <MudChip T="string" Color="@GetStateColor(context.UniqueName)" Variant="Variant.Outlined">
                        @GetStateText(context.UniqueName)
                    </MudChip>
                </MudTd>
                <MudTd DataLabel="Unique Name" Class="mono">@context.UniqueName</MudTd>
                <MudTd DataLabel="Config">@GetConfigProfileName(context.ConfigProfileId)</MudTd>
                <MudTd DataLabel="Process" Class="mono">@GetProcessDisplay(context.UniqueName)</MudTd>
                <MudTd DataLabel="Agent">@GetAttachmentStatus(context.UniqueName)</MudTd>
                <MudTd DataLabel="Health">
                    <MudChip T="string" Color="@GetHealthColor(context.UniqueName)" Variant="Variant.Outlined" title="@GetHealthSummary(context.UniqueName)">
                        @GetHealthText(context.UniqueName)
                    </MudChip>
                    @if (!string.IsNullOrWhiteSpace(GetHealthSummary(context.UniqueName)))
                    {
                        <MudText Typo="Typo.caption" Class="d-block mt-1">@GetHealthSummary(context.UniqueName)</MudText>
                    }
                    @if (!string.IsNullOrWhiteSpace(GetHealthScoreDetail(context.UniqueName)))
                    {
                        <MudText Typo="Typo.caption" Class="d-block">@GetHealthScoreDetail(context.UniqueName)</MudText>
                    }
                </MudTd>
                <MudTd Style="text-align: right;">
                    <MudStack Row="true" Wrap="Wrap.Wrap" Justify="Justify.FlexEnd" Spacing="0">
                        @if (context.GoalState == DedicatedServerInstanceGoalState.On)
                        {
                            <MudButton Variant="Variant.Text" Size="Size.Small" Color="Color.Warning" OnClick="@(() => StopAsync(context.UniqueName))">Stop</MudButton>
                            @if (IsRunning(context.UniqueName))
                            {
                                <MudButton Variant="Variant.Text" Size="Size.Small" Color="Color.Primary" OnClick="@(() => RestartAsync(context.UniqueName))">Restart</MudButton>
                            }
                        }
                        else
                        {
                            <MudButton Variant="Variant.Text" Size="Size.Small" Color="Color.Success" OnClick="@(() => StartAsync(context.UniqueName))">Start</MudButton>
                        }
                        <MudIconButton Size="Size.Small" Icon="@Icons.Material.Filled.Terminal" Color="Color.Default" title="Show console output" OnClick="@(() => OpenConsoleDialogAsync(context.UniqueName))" />
                        <MudButton Variant="Variant.Text" Size="Size.Small" OnClick="@(() => OpenCloneDialogAsync(context))">Clone</MudButton>
                        <MudButton Variant="Variant.Text" Size="Size.Small" OnClick="@(() => OpenEditDialogAsync(context))">Edit</MudButton>
                        <MudButton Variant="Variant.Text" Size="Size.Small" Color="Color.Error" OnClick="@(() => DeleteAsync(context.UniqueName))">Delete</MudButton>
                    </MudStack>
                </MudTd>
            </RowTemplate>
        </MudTable>
    }
</MudPaper>

@code
{
    private IReadOnlyList<DedicatedServerInstanceDefinition> InstanceDefinitions => InstanceCatalog.GetInstances();

    private IReadOnlyDictionary<string, DedicatedServerInstanceRuntimeSnapshot> RuntimeSnapshots => Supervisor
        .GetSnapshots()
        .ToDictionary(snapshot => snapshot.UniqueName, StringComparer.OrdinalIgnoreCase);

    protected override void OnInitialized()
    {
        InstanceCatalog.Changed += HandleChanged;
        Supervisor.Changed += HandleChanged;
        Registry.Changed += HandleChanged;
        ConfigProfiles.Changed += HandleChanged;
        WorldTemplates.Changed += HandleChanged;
    }

    public void Dispose()
    {
        InstanceCatalog.Changed -= HandleChanged;
        Supervisor.Changed -= HandleChanged;
        Registry.Changed -= HandleChanged;
        ConfigProfiles.Changed -= HandleChanged;
        WorldTemplates.Changed -= HandleChanged;
    }

    private async Task OpenCreateDialogAsync()
    {
        var definition = await ShowEditorDialogAsync(CreateBlank(), isEditing: false);
        if (definition is null)
            return;

        await SaveDefinitionAsync(definition, "Instance created.");
    }

    private async Task OpenCloneDialogAsync(DedicatedServerInstanceDefinition definition)
    {
        var cloned = definition.Clone();
        cloned.UniqueName = $"{definition.UniqueName}-copy";
        cloned.OriginalUniqueName = string.Empty;
        var created = await ShowEditorDialogAsync(cloned, isEditing: false);
        if (created is null)
            return;

        await SaveDefinitionAsync(created, "Instance cloned.");
    }

    private async Task OpenEditDialogAsync(DedicatedServerInstanceDefinition definition)
    {
        var updated = await ShowEditorDialogAsync(definition, isEditing: true);
        if (updated is null)
            return;

        await SaveDefinitionAsync(updated, "Instance saved.");
    }

    private async Task OpenConsoleDialogAsync(string uniqueName)
    {
        var parameters = new DialogParameters
        {
            [nameof(InstanceConsoleDialog.UniqueName)] = uniqueName,
        };

        var options = new DialogOptions
        {
            CloseOnEscapeKey = true,
            FullWidth = true,
            MaxWidth = MaxWidth.Large,
        };

        await DialogService.ShowAsync<InstanceConsoleDialog>($"Console — {uniqueName}", parameters, options);
    }

    private async Task<DedicatedServerInstanceDefinition?> ShowEditorDialogAsync(DedicatedServerInstanceDefinition definition, bool isEditing)
    {
        var parameters = new DialogParameters
        {
            [nameof(InstanceEditorDialog.Definition)] = definition.Clone(),
            [nameof(InstanceEditorDialog.IsEditing)] = isEditing,
            [nameof(InstanceEditorDialog.UniqueNameLocked)] = isEditing && IsRunning(definition.UniqueName),
        };

        var options = new DialogOptions
        {
            CloseOnEscapeKey = true,
            FullWidth = true,
            MaxWidth = MaxWidth.ExtraLarge,
        };

        var dialog = await DialogService.ShowAsync<InstanceEditorDialog>(isEditing ? "Edit Instance" : "Create Instance", parameters, options);
        var result = await dialog.Result;
        if (result is null || result.Canceled || result.Data is not DedicatedServerInstanceDefinition updated)
            return null;

        return updated;
    }

    private async Task SaveDefinitionAsync(DedicatedServerInstanceDefinition definition, string successMessage)
    {
        var previousUniqueName = definition.OriginalUniqueName;
        if (!string.IsNullOrWhiteSpace(previousUniqueName) &&
            !string.Equals(previousUniqueName, definition.UniqueName, StringComparison.OrdinalIgnoreCase) &&
            IsRunning(previousUniqueName))
        {
            Snackbar.Add("Stop the instance before renaming it.", Severity.Warning);
            return;
        }

        try
        {
            await InstanceCatalog.UpsertAsync(definition);
            Snackbar.Add(successMessage, Severity.Success);
        }
        catch (Exception exception)
        {
            Snackbar.Add(exception.Message, Severity.Error);
        }
    }

    private async Task StartAsync(string uniqueName)
    {
        try
        {
            await Supervisor.SetGoalStateAsync(uniqueName, DedicatedServerInstanceGoalState.On);
            Snackbar.Add("Instance start requested.", Severity.Success);
        }
        catch (Exception exception)
        {
            Snackbar.Add(exception.Message, Severity.Error);
        }
    }

    private async Task StopAsync(string uniqueName)
    {
        try
        {
            await Supervisor.SetGoalStateAsync(uniqueName, DedicatedServerInstanceGoalState.Off);
            Snackbar.Add("Instance stop requested.", Severity.Info);
        }
        catch (Exception exception)
        {
            Snackbar.Add(exception.Message, Severity.Error);
        }
    }

    private async Task RestartAsync(string uniqueName)
    {
        try
        {
            await Supervisor.RestartInstanceAsync(uniqueName);
            Snackbar.Add("Instance restart requested.", Severity.Info);
        }
        catch (Exception exception)
        {
            Snackbar.Add(exception.Message, Severity.Error);
        }
    }

    private async Task DeleteAsync(string uniqueName)
    {
        if (IsRunning(uniqueName))
        {
            Snackbar.Add("Stop the instance before deleting its definition.", Severity.Warning);
            return;
        }

        await InstanceCatalog.DeleteAsync(uniqueName);
        Snackbar.Add("Instance removed.", Severity.Info);
    }

    private string GetAttachmentStatus(string uniqueName)
    {
        var runtime = GetRuntime(uniqueName);
        if (runtime is null)
            return "not attached";

        return runtime.AgentAttached ? "attached" : "not attached";
    }

    private string GetProcessDisplay(string uniqueName)
    {
        var runtime = GetRuntime(uniqueName);
        return runtime?.ProcessId?.ToString() ?? "stopped";
    }

    private string GetConfigProfileName(string configProfileId)
    {
        if (string.IsNullOrWhiteSpace(configProfileId))
            return "-";

        return ConfigProfiles.GetProfile(configProfileId)?.Name ?? $"Missing: {configProfileId}";
    }

    private string GetStateText(string uniqueName)
    {
        var runtime = GetRuntime(uniqueName);
        return runtime?.State.ToString().ToLowerInvariant() ?? "stopped";
    }

    private Color GetStateColor(string uniqueName)
    {
        var state = GetRuntime(uniqueName)?.State ?? DedicatedServerInstanceProcessState.Stopped;
        return state switch
        {
            DedicatedServerInstanceProcessState.Running => Color.Success,
            DedicatedServerInstanceProcessState.Starting => Color.Info,
            DedicatedServerInstanceProcessState.Restarting => Color.Warning,
            DedicatedServerInstanceProcessState.Stopping => Color.Warning,
            DedicatedServerInstanceProcessState.Crashed => Color.Error,
            DedicatedServerInstanceProcessState.Faulted => Color.Error,
            _ => Color.Default,
        };
    }

    private string GetHealthText(string uniqueName)
    {
        var health = GetRuntime(uniqueName)?.HealthState ?? DedicatedServerInstanceHealthState.Unknown;
        return health.ToString().ToLowerInvariant();
    }

    private string GetHealthSummary(string uniqueName)
    {
        return GetRuntime(uniqueName)?.HealthSummary ?? string.Empty;
    }

    private string GetHealthScoreDetail(string uniqueName)
    {
        var runtime = GetRuntime(uniqueName);
        if (runtime?.SimulationProgressScore is null ||
            runtime.SimulationProgressWindowSeconds is null ||
            runtime.SimulationFramesAdvanced is null)
        {
            return string.Empty;
        }

        return $"frame score {runtime.SimulationProgressScore.Value:0.00} over {runtime.SimulationProgressWindowSeconds.Value}s ({runtime.SimulationFramesAdvanced.Value} frames)";
    }

    private Color GetHealthColor(string uniqueName)
    {
        var health = GetRuntime(uniqueName)?.HealthState ?? DedicatedServerInstanceHealthState.Unknown;
        return health switch
        {
            DedicatedServerInstanceHealthState.Healthy => Color.Success,
            DedicatedServerInstanceHealthState.Warning => Color.Warning,
            DedicatedServerInstanceHealthState.Unhealthy => Color.Error,
            _ => Color.Default,
        };
    }

    private bool IsRunning(string uniqueName)
    {
        var state = GetRuntime(uniqueName)?.State ?? DedicatedServerInstanceProcessState.Stopped;
        return state is DedicatedServerInstanceProcessState.Starting
            or DedicatedServerInstanceProcessState.Running
            or DedicatedServerInstanceProcessState.Restarting
            or DedicatedServerInstanceProcessState.Stopping;
    }

    private DedicatedServerInstanceRuntimeSnapshot? GetRuntime(string uniqueName)
    {
        RuntimeSnapshots.TryGetValue(uniqueName, out var runtime);
        return runtime;
    }

    private void HandleChanged()
    {
        _ = InvokeAsync(StateHasChanged);
    }

    private DedicatedServerInstanceDefinition CreateBlank()
    {
        var healthMonitoringEnabled = !Options.DisableInstanceHealthMonitoring;
        return new DedicatedServerInstanceDefinition
        {
            GoalState = DedicatedServerInstanceGoalState.Off,
            EnableHealthMonitoring = healthMonitoringEnabled,
            AutoRestartOnUnhealthy = healthMonitoringEnabled,
            AgentStartupGraceSeconds = 180,
            AgentHeartbeatTimeoutSeconds = 20,
            SimulationProgressWindowSeconds = 30,
            MinimumSimulationProgressScore = 0.05f,
            WarnAfterUptimeHours = 12,
            RestartDelaySeconds = 5,
            RestartOnCrash = true,
        };
    }
}
