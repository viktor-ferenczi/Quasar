    private static IReadOnlyList<AnalyticsChartPoint> BuildSeriesPoints(
        IReadOnlyList<MetricSample> samples,
        MetricDefinition definition,
        long gapThresholdSeconds)
    {
        if (samples.Count == 0)
            return [];

        var points = new List<AnalyticsChartPoint>(samples.Count);
        long? previousTimestamp = null;

        foreach (var sample in samples)
        {
            if (previousTimestamp is { } previous &&
                sample.TimestampUnixSeconds - previous > gapThresholdSeconds)
            {
                var gapTimestamp = previous + Math.Max(1, Math.Min(gapThresholdSeconds, (sample.TimestampUnixSeconds - previous) / 2));
                points.Add(new AnalyticsChartPoint(ToLocalDateTime(gapTimestamp), null));
            }

            points.Add(new AnalyticsChartPoint(
                ToLocalDateTime(sample.TimestampUnixSeconds),
                TrySelectDecimal(definition, sample)));

            previousTimestamp = sample.TimestampUnixSeconds;
        }

        return points;
    }

    private static decimal? TrySelectDecimal(MetricDefinition definition, MetricSample sample)
    {
        if (!definition.IsAvailable(sample))
            return null;

        var value = definition.Selector(sample);
        return double.IsFinite(value) ? (decimal)value : null;
    }

    private static DateTime ToLocalDateTime(long timestampUnixSeconds) =>
        DateTimeOffset.FromUnixTimeSeconds(timestampUnixSeconds).LocalDateTime;

    private static long ResolveGapThresholdSeconds(IReadOnlyList<MetricSample> samples)
    {
        const long expectedSeconds = 2;
        var medianIntervalSeconds = ResolveMedianIntervalSeconds(samples);
        var cadenceSeconds = Math.Max(expectedSeconds, medianIntervalSeconds);

        // Avoid tiny synthetic gap rows caused by sample jitter; keep a gap point only for
        // clearly meaningful discontinuities.
        return Math.Max(cadenceSeconds * 3, cadenceSeconds + Math.Max(1, cadenceSeconds / 2));
    }

    private static long ResolveMedianIntervalSeconds(IReadOnlyList<MetricSample> samples)
    {
        if (samples.Count < 2)
            return 0;

        var deltas = new List<long>(samples.Count - 1);
        for (var i = 1; i < samples.Count; i++)
        {
            var delta = samples[i].TimestampUnixSeconds - samples[i - 1].TimestampUnixSeconds;
            if (delta > 0)
                deltas.Add(delta);
        }

        if (deltas.Count == 0)
            return 0;

        deltas.Sort();
        return deltas[deltas.Count / 2];
    }

    private static int ResolveYAxisDecimals(MetricDefinition definition)
    {
        return definition.Key switch
        {
            "simspeed" => 3,
            "cpu" or "memory" or "frametime" => 1,
            _ => 0,
        };
    }

    private static decimal? ResolveYAxisMax(MetricDefinition definition)
    {
        return definition.Key switch
        {
            "frametime" => 100,
            _ => null,
        };
    }

    private string ResolveChartHeight(AnalyticsPanelConfig panel)
    {
        var rowHeight = Math.Max(180, _config.RowHeightPx);
        var rowSpan = Math.Max(1, panel.RowSpan);
        var chartHeight = Math.Max(280, (rowHeight * rowSpan) - 88);
        return chartHeight.ToString(System.Globalization.CultureInfo.InvariantCulture);
    }

    private string ResolveDisplayName(string uniqueName)
    {
        return _serverOptions.FirstOrDefault(option =>
                   string.Equals(option.UniqueName, uniqueName, StringComparison.OrdinalIgnoreCase))
               ?.DisplayName ?? uniqueName;
    }

    private string ResolveMetricTitle(string key)
    {
        return MetricDefinitions.FirstOrDefault(metric => string.Equals(metric.Key, key, StringComparison.OrdinalIgnoreCase))
               ?.Title ?? key;
    }

    private static string ResolveTimeLabelFormat(long spanSeconds)
    {
        if (spanSeconds <= 24 * 3600)
            return "HH:mm";

        if (spanSeconds <= 7 * 86400)
            return "MM-dd HH:mm";

        return "MM-dd";
    }

    private static string ResolveTooltipTimeFormat(long spanSeconds)
    {
        if (spanSeconds <= 24 * 3600)
            return "yyyy-MM-dd HH:mm:ss";

        return "yyyy-MM-dd HH:mm";
    }

    private static AnalyticsViewConfig NormalizeConfig(AnalyticsViewConfig? config)
    {
        var normalized = config ?? CreateDefaultConfig();
        normalized.SelectedRangeKey = RangeOptions.Any(option => string.Equals(option.Key, normalized.SelectedRangeKey, StringComparison.OrdinalIgnoreCase))
            ? normalized.SelectedRangeKey
            : "1h";
        normalized.GridColumns = Math.Clamp(normalized.GridColumns <= 0 ? 2 : normalized.GridColumns, 1, 6);
        normalized.GridRows = Math.Clamp(normalized.GridRows <= 0 ? 4 : normalized.GridRows, 1, 12);
        normalized.RowHeightPx = Math.Clamp(normalized.RowHeightPx <= 0 ? 320 : normalized.RowHeightPx, 180, 960);
        normalized.MaxVisibleServersForCharts = normalized.MaxVisibleServersForCharts <= 0 ? 6 : normalized.MaxVisibleServersForCharts;
        normalized.MaxVisibleServersForCharts = Math.Clamp(normalized.MaxVisibleServersForCharts, 1, 40);
        normalized.AutoRefreshSeconds = normalized.AutoRefreshSeconds switch
        {
            0 or 5 or 15 or 30 or 60 => normalized.AutoRefreshSeconds,
            _ => 0,
        };

        var panels = (normalized.Panels ?? [])
            .ToDictionary(panel => panel.Key, StringComparer.OrdinalIgnoreCase);
        normalized.Panels = CreateDefaultPanels()
            .Select(panel =>
            {
                if (!panels.TryGetValue(panel.Key, out var existing))
                    return panel;

                return new AnalyticsPanelConfig
                {
                    Key = panel.Key,
                    Visible = existing.Visible,
                    Order = Math.Clamp(existing.Order, 0, 99),
                    ColumnSpan = Math.Clamp(existing.ColumnSpan, 1, normalized.GridColumns),
                    RowSpan = Math.Clamp(existing.RowSpan, 1, Math.Max(1, normalized.GridRows)),
                };
            })
            .OrderBy(panel => panel.Order)
            .ToList();

        normalized.SelectedUniqueNames ??= [];
        return normalized;
    }

    private static AnalyticsViewConfig CreateDefaultConfig()
    {
        return new AnalyticsViewConfig
        {
            Panels = CreateDefaultPanels(),
        };
    }

    private static List<AnalyticsPanelConfig> CreateDefaultPanels()
    {
        return MetricDefinitions
            .Select((metric, index) => new AnalyticsPanelConfig
            {
                Key = metric.Key,
                Visible = true,
                Order = index,
                ColumnSpan = 1,
                RowSpan = 1,
            })
            .ToList();
    }

