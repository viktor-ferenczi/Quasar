@implements IAsyncDisposable
@inject DedicatedServerCatalog ServerCatalog
@inject IJSRuntime JS

<MudDialog>
    <DialogContent>
        <MudTabs Elevation="0" Rounded="true" ApplyEffectsToContainer="true" TabPanelsClass="pt-3" @bind-ActivePanelIndex="_activeTabIndex">
            <MudTabPanel Text="Server log" Icon="@Icons.Material.Filled.Terminal">
                <MudStack Row="true" AlignItems="AlignItems.Center" Justify="Justify.SpaceBetween" Class="mb-2">
                    <MudStack Row="true" AlignItems="AlignItems.Center" Spacing="2" Class="quasar-log-selector-row">
                        <MudSelect T="string"
                                   Label="Log file"
                                   Value="_serverLogSelection"
                                   ValueChanged="HandleServerLogSelectionChanged"
                                   Variant="Variant.Outlined"
                                   Margin="Margin.Dense"
                                   Dense="true"
                                   Class="quasar-log-file-select">
                            <MudSelectItem T="string" Value="@LatestLogSelection">Most recent</MudSelectItem>
                            @foreach (var option in _serverLogOptions)
                            {
                                <MudSelectItem T="string" Value="@option.FileName">@option.Label</MudSelectItem>
                            }
                        </MudSelect>
                        <MudStack Spacing="0">
                            <MudText Typo="Typo.body2" Class="mud-text-secondary">@ServerLogStatusText()</MudText>
                            <CopyablePath Value="@_serverLogPath" />
                        </MudStack>
                    </MudStack>
                    <MudStack Row="true" Spacing="1">
                        <MudTooltip Text="Download full server log">
                            <MudIconButton Icon="@Icons.Material.Filled.Download"
                                           OnClick="DownloadServerLogAsync"
                                           Disabled="@(!_serverLogLoaded || _serverLogMissing)"
                                           Size="Size.Small" />
                        </MudTooltip>
                        <MudTooltip Text="Shortcuts in this dialog: Ctrl or Alt + PageUp/PageDown rolls 250 lines; Ctrl or Alt + Home/End jumps to the oldest or newest lines.">
                            <MudIcon Icon="@Icons.Material.Filled.Keyboard" Size="Size.Small" Color="Color.Default" />
                        </MudTooltip>
                        <MudButton Variant="Variant.Text" Size="Size.Small" StartIcon="@Icons.Material.Filled.Search" OnClick="ShowServerLogExceptionsAsync">Exceptions</MudButton>
                        <MudButton Variant="Variant.Text" Size="Size.Small" StartIcon="@Icons.Material.Filled.Refresh" OnClick="RefreshServerLogAsync" Disabled="@(!CanRefreshServerLog)">Refresh</MudButton>
                    </MudStack>
                </MudStack>

                @if (_serverLogMissing)
                {
                    <MudAlert Severity="Severity.Info" Variant="Variant.Outlined">
                        Start the server at least once so Space Engineers Dedicated Server can write its log.
                    </MudAlert>
                }
                else if (!string.IsNullOrEmpty(_serverLogError))
                {
                    <MudAlert Severity="Severity.Error" Variant="Variant.Outlined">@_serverLogError</MudAlert>
                }
                else
                {
                    <div id="@_scrollContainerId" class="quasar-console-output" tabindex="0">
                        @foreach (var line in _serverLogLines)
                        {
                            <div class="quasar-log-line">@line</div>
                        }
                    </div>
                }
            </MudTabPanel>

            <MudTabPanel Text="Magnetar info log" Icon="@Icons.Material.Filled.Description">
                <MudStack Row="true" AlignItems="AlignItems.Center" Justify="Justify.SpaceBetween" Class="mb-2">
                    <MudStack Row="true" AlignItems="AlignItems.Center" Spacing="2" Class="quasar-log-selector-row">
                        <MudSelect T="string"
                                   Label="Log file"
                                   Value="_infoLogSelection"
                                   ValueChanged="HandleInfoLogSelectionChanged"
                                   Variant="Variant.Outlined"
                                   Margin="Margin.Dense"
                                   Dense="true"
                                   Class="quasar-log-file-select">
                            <MudSelectItem T="string" Value="@LatestLogSelection">Most recent</MudSelectItem>
                            @foreach (var option in _infoLogOptions)
                            {
                                <MudSelectItem T="string" Value="@option.FileName">@option.Label</MudSelectItem>
                            }
                        </MudSelect>
                        <MudStack Spacing="0">
                            <MudText Typo="Typo.body2" Class="mud-text-secondary">@InfoLogStatusText()</MudText>
                            <CopyablePath Value="@_infoLogPath" />
                        </MudStack>
                    </MudStack>
                    <MudStack Row="true" Spacing="1">
                        <MudTooltip Text="Download info log">
                            <MudIconButton Icon="@Icons.Material.Filled.Download"
                                           OnClick="DownloadInfoLogAsync"
                                           Disabled="@(!_infoLogLoaded || _infoLogMissing)"
                                           Size="Size.Small" />
                        </MudTooltip>
                        <MudButton Variant="Variant.Text" Size="Size.Small" StartIcon="@Icons.Material.Filled.Search" OnClick="ShowInfoLogExceptionsAsync">Exceptions</MudButton>
                        <MudButton Variant="Variant.Text" Size="Size.Small" StartIcon="@Icons.Material.Filled.Refresh" OnClick="RefreshInfoLogAsync" Disabled="@(!CanRefreshInfoLog)">Refresh</MudButton>
                    </MudStack>
                </MudStack>

                @if (_infoLogMissing)
                {
                    <MudAlert Severity="Severity.Info" Variant="Variant.Outlined">
                        Start the server at least once so Magnetar can write its log. Plugin startup exceptions appear here.
                    </MudAlert>
                }
                else if (!string.IsNullOrEmpty(_infoLogError))
                {
                    <MudAlert Severity="Severity.Error" Variant="Variant.Outlined">@_infoLogError</MudAlert>
                }
                else
                {
                    <div id="@_infoLogScrollContainerId" class="quasar-console-output">
                        <pre class="quasar-info-log-pre">@_infoLogContent</pre>
                    </div>
                }
            </MudTabPanel>
        </MudTabs>
    </DialogContent>
    <DialogActions>
        <MudButton Variant="Variant.Filled" Color="Color.Primary" OnClick="Close">Close</MudButton>
    </DialogActions>
</MudDialog>

<style>
    .quasar-console-output {
        height: 60vh;
        overflow-y: auto;
        outline: none;
        background: var(--mud-palette-background);
        border: 1px solid var(--mud-palette-divider);
        border-radius: 4px;
        padding: 8px 12px;
        font-family: ui-monospace, SFMono-Regular, Menlo, Consolas, monospace;
        font-size: 0.8125rem;
        line-height: 1.45;
        white-space: normal;
        word-break: break-word;
    }

    .quasar-console-output:focus {
        border-color: var(--mud-palette-primary);
    }

    .quasar-info-log-pre {
        margin: 0;
        white-space: pre-wrap;
        word-break: break-word;
        font: inherit;
        color: var(--mud-palette-text-primary);
    }

    .quasar-log-line {
        min-height: 1.45em;
        white-space: pre-wrap;
        word-break: break-word;
        color: var(--mud-palette-text-primary);
    }

    .quasar-log-selector-row {
        min-width: 0;
    }

    .quasar-log-file-select {
        width: min(34vw, 360px);
        min-width: 260px;
    }

    @@media (max-width: 720px) {
        .quasar-log-selector-row {
            flex-wrap: wrap;
        }

        .quasar-log-file-select {
            width: 100%;
            min-width: 0;
        }
    }

</style>

@code
{
    private const int ServerLogWindowLines = 500;
    private const int ServerLogRolloverLines = 250;
    private const int ServerLogRolloverThresholdPx = 96;
    private const int InfoLogTailBytes = 256 * 1024;
    private const int InfoLogExceptionSearchBytes = 4 * 1024 * 1024;
    private const int InfoLogExceptionContextLines = 50;
    private const int InfoLogExceptionMatchLimit = 10;
    private const int ServerLogTabIndex = 0;
    private const int InfoLogTabIndex = 1;
    private const string LatestLogSelection = "__latest__";
    private static readonly TimeSpan LogAutoRefreshInterval = TimeSpan.FromSeconds(5);

    [CascadingParameter]
    private IMudDialogInstance MudDialog { get; set; } = default!;

    [Parameter]
    public string UniqueName { get; set; } = string.Empty;

    private readonly string _scrollContainerId = $"quasar-console-{Guid.NewGuid():N}";
    private readonly string _infoLogScrollContainerId = $"quasar-info-log-{Guid.NewGuid():N}";

    private int _activeTabIndex;
    private int _renderedTabIndex = -1;
    private IReadOnlyList<string> _serverLogLines = Array.Empty<string>();
    private string _serverLogPath = string.Empty;
    private string _serverLogSelection = LatestLogSelection;
    private IReadOnlyList<LogFileOption> _serverLogOptions = Array.Empty<LogFileOption>();
    private int _serverLogLineCount;
    private bool _serverLogTruncated;
    private bool _serverLogMissing;
    private string? _serverLogError;
    private bool _serverLogLoaded;
    private bool _serverLogScrollPending;
    private bool _serverLogRolloverBusy;
    private int _serverLogWindowStart;
    private long _serverLogReadOffset;
    private string _serverLogMode = "tail";
    private bool _serverLogInteropDirty = true;
    private bool _serverLogInteropAttached;
    private DotNetObjectReference<ServerConsoleDialog>? _serverLogInteropRef;
    private string _infoLogContent = string.Empty;
    private string _infoLogPath = string.Empty;
    private string _infoLogSelection = LatestLogSelection;
    private IReadOnlyList<LogFileOption> _infoLogOptions = Array.Empty<LogFileOption>();
    private int _infoLogLineCount;
    private bool _infoLogTruncated;
    private bool _infoLogMissing;
    private string? _infoLogError;
    private bool _infoLogLoaded;
    private bool _infoLogScrollPending;
    private long _infoLogReadOffset;
    private string _infoLogMode = "tail";
    private CancellationTokenSource? _autoRefreshCts;
    private Task? _autoRefreshTask;
    private string ServerLogDownloadHref => BuildLogDownloadHref("server", _serverLogSelection);
    private string InfoLogDownloadHref => BuildLogDownloadHref("magnetar", _infoLogSelection);
    private bool IsWatchingLatestServerLog => IsLatestLogSelection(_serverLogSelection);
    private bool IsWatchingLatestInfoLog => IsLatestLogSelection(_infoLogSelection);
    private bool CanRefreshServerLog => IsWatchingLatestServerLog;
    private bool CanRefreshInfoLog => IsWatchingLatestInfoLog;

    protected override void OnInitialized()
    {
        _serverLogPath = ResolveSelectedServerLogPath();
        _infoLogPath = ResolveSelectedInfoLogPath();
        StartAutoRefreshLoop();
    }

    private void StartAutoRefreshLoop()
    {
        _autoRefreshCts = new CancellationTokenSource();
        _autoRefreshTask = Task.Run(() => AutoRefreshLoopAsync(_autoRefreshCts.Token));
    }

    private async Task AutoRefreshLoopAsync(CancellationToken cancellationToken)
    {
        try
        {
            using var timer = new PeriodicTimer(LogAutoRefreshInterval);
            while (await timer.WaitForNextTickAsync(cancellationToken))
            {
                await InvokeAsync(() => RefreshActiveLogTailAsync(cancellationToken));
            }
        }
        catch (OperationCanceledException)
        {
        }
        catch (ObjectDisposedException)
        {
        }
        catch (InvalidOperationException)
        {
        }
    }

    private async Task RefreshActiveLogTailAsync(CancellationToken cancellationToken)
    {
        if (cancellationToken.IsCancellationRequested)
            return;

        if (_activeTabIndex == ServerLogTabIndex && _serverLogLoaded && IsWatchingLatestServerLog)
        {
            await RefreshServerLogTailAsync(reloadOnReset: true);
            return;
        }

        if (_activeTabIndex == InfoLogTabIndex && _infoLogLoaded && IsWatchingLatestInfoLog)
            await RefreshInfoLogTailAsync(reloadOnReset: true);
    }

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        var tabChanged = _renderedTabIndex != _activeTabIndex;
        _renderedTabIndex = _activeTabIndex;

        if (_activeTabIndex == ServerLogTabIndex)
        {
            if (!_serverLogLoaded)
            {
                await LoadServerLogAsync();
                return;
            }

            if (_serverLogInteropDirty)
                await AttachServerLogInteropAsync();

            if (tabChanged || _serverLogScrollPending)
            {
                _serverLogScrollPending = false;
                await ScrollToBottomAsync(_scrollContainerId);
            }
            return;
        }

        if (_activeTabIndex == InfoLogTabIndex)
        {
            await DetachServerLogInteropAsync();

            if (!_infoLogLoaded)
            {
                await LoadInfoLogAsync();
                return;
            }

            if (tabChanged || _infoLogScrollPending)
            {
                _infoLogScrollPending = false;
                await ScrollToBottomAsync(_infoLogScrollContainerId);
            }
            return;
        }
    }

    private async Task ScrollToBottomAsync(string containerId)
    {
        try
        {
            await JS.InvokeVoidAsync("quasarConfigs.scrollToBottom", containerId);
        }
        catch (JSDisconnectedException)
        {
        }
    }

    private async Task<bool> IsScrolledNearBottomAsync(string containerId)
    {
        try
        {
            return await JS.InvokeAsync<bool>("quasarConfigs.isScrolledNearBottom", containerId, 48);
        }
        catch (JSDisconnectedException)
        {
            return true;
        }
    }

    private async Task RefreshServerLogAsync()
    {
        if (!IsWatchingLatestServerLog)
            return;

        if (_serverLogLoaded && _serverLogMode == "tail")
        {
            await RefreshServerLogTailAsync(reloadOnReset: true);
            return;
        }

        await LoadServerLogAsync();
    }

    private async Task DownloadServerLogAsync()
    {
        var fileName = string.IsNullOrWhiteSpace(_serverLogPath)
            ? "SpaceEngineersDedicated.log"
            : Path.GetFileName(_serverLogPath);
        await JS.InvokeVoidAsync("quasarConfigs.downloadFile", ServerLogDownloadHref, fileName);
    }

    private async Task HandleServerLogSelectionChanged(string value)
    {
        _serverLogSelection = NormalizeLogSelection(value);
        _serverLogLoaded = false;
        _serverLogMode = "tail";
        await LoadServerLogAsync();
    }

    private async Task ShowServerLogExceptionsAsync()
    {
        await LoadServerLogExceptionsAsync();
    }

    private async Task LoadServerLogAsync()
    {
        _serverLogPath = ResolveSelectedServerLogPath();

        try
        {
            if (!File.Exists(_serverLogPath))
            {
                _serverLogMissing = true;
                _serverLogLines = Array.Empty<string>();
                _serverLogLineCount = 0;
                _serverLogTruncated = false;
                _serverLogError = null;
                _serverLogMode = "tail";
                _serverLogWindowStart = 0;
                _serverLogReadOffset = 0;
            }
            else
            {
                var window = await ReadLatestLineWindowAsync(_serverLogPath, ServerLogWindowLines);
                _serverLogLines = window.Lines;
                _serverLogLineCount = window.TotalLineCount;
                _serverLogWindowStart = window.StartLine;
                _serverLogReadOffset = window.FileLength;
                _serverLogTruncated = false;
                _serverLogMissing = false;
                _serverLogError = null;
                _serverLogMode = "tail";
            }
        }
        catch (Exception exception)
        {
            _serverLogError = exception.Message;
            _serverLogLines = Array.Empty<string>();
            _serverLogLineCount = 0;
            _serverLogTruncated = false;
            _serverLogMissing = false;
            _serverLogMode = "tail";
            _serverLogWindowStart = 0;
            _serverLogReadOffset = 0;
        }

        _serverLogLoaded = true;
        _serverLogScrollPending = true;
        _serverLogInteropDirty = true;
        await InvokeAsync(StateHasChanged);
    }

    private async Task RefreshServerLogTailAsync(bool reloadOnReset)
    {
        if (_serverLogMode != "tail" || !IsWatchingLatestServerLog)
            return;

        var latestPath = ResolveSelectedServerLogPath();
        if (!string.Equals(latestPath, _serverLogPath, StringComparison.OrdinalIgnoreCase))
        {
            if (reloadOnReset)
                await LoadServerLogAsync();
            return;
        }

        if (!File.Exists(_serverLogPath))
        {
            if (reloadOnReset)
                await LoadServerLogAsync();
            return;
        }

        if (_serverLogMissing)
        {
            if (reloadOnReset)
                await LoadServerLogAsync();
            return;
        }

        if (!string.IsNullOrEmpty(_serverLogError))
        {
            if (reloadOnReset)
                await LoadServerLogAsync();
            return;
        }

        if (_serverLogRolloverBusy)
            return;

        // When viewing an older window, do not mutate the DOM every tick. Moving
        // to newer lines will read the requested window and refresh counts.
        if (CanLoadNewerServerLogLines)
            return;

        try
        {
            var update = await ReadAppendedLinesAsync(_serverLogPath, _serverLogReadOffset);
            if (update.Reset)
            {
                if (reloadOnReset)
                    await LoadServerLogAsync();
                return;
            }

            _serverLogReadOffset = update.FileLength;
            if (update.Lines.Count == 0)
                return;

            var shouldScroll = await IsScrolledNearBottomAsync(_scrollContainerId);
            var lines = _serverLogLines
                .Concat(update.Lines)
                .TakeLast(ServerLogWindowLines)
                .ToArray();

            _serverLogLineCount += update.Lines.Count;
            _serverLogLines = lines;
            _serverLogWindowStart = Math.Max(0, _serverLogLineCount - _serverLogLines.Count);
            _serverLogMissing = false;
            _serverLogError = null;
            _serverLogInteropDirty = true;
            _serverLogScrollPending = shouldScroll;

            await InvokeAsync(StateHasChanged);
        }
        catch (Exception exception)
        {
            _serverLogError = exception.Message;
            await InvokeAsync(StateHasChanged);
        }
    }

    [JSInvokable]
    public async Task<ServerLogWindowMoveResult> RequestServerLogWindowShiftAsync(int direction)
    {
        var deltaLines = direction < 0 ? -ServerLogRolloverLines : ServerLogRolloverLines;
        return await MoveServerLogWindowAsync(deltaLines, 0.5);
    }

    [JSInvokable]
    public async Task<ServerLogWindowMoveResult> RequestServerLogWindowJumpAsync(int direction)
    {
        var targetStart = direction < 0
            ? 0
            : Math.Max(0, _serverLogLineCount - ServerLogWindowLines);

        return await MoveServerLogWindowToAsync(targetStart, direction < 0 ? 0 : 1);
    }

    private async Task<ServerLogWindowMoveResult> MoveServerLogWindowAsync(int deltaLines, double scrollRatio)
    {
        if (!File.Exists(_serverLogPath))
            return BuildServerLogMoveResult(false, scrollRatio);

        var maxStart = Math.Max(0, _serverLogLineCount - ServerLogWindowLines);
        var requestedStart = Math.Clamp(_serverLogWindowStart + deltaLines, 0, maxStart);
        return await MoveServerLogWindowToAsync(requestedStart, scrollRatio);
    }

    private async Task<ServerLogWindowMoveResult> MoveServerLogWindowToAsync(int requestedStart, double scrollRatio)
    {
        if (_serverLogMode != "tail" ||
            _serverLogMissing ||
            !string.IsNullOrEmpty(_serverLogError) ||
            _serverLogRolloverBusy ||
            !File.Exists(_serverLogPath))
            return BuildServerLogMoveResult(false, scrollRatio);

        var maxStart = Math.Max(0, _serverLogLineCount - ServerLogWindowLines);
        requestedStart = Math.Clamp(requestedStart, 0, maxStart);
        if (requestedStart == _serverLogWindowStart)
            return BuildServerLogMoveResult(false, scrollRatio);

        _serverLogRolloverBusy = true;
        try
        {
            var window = await ReadLineWindowAsync(_serverLogPath, requestedStart, ServerLogWindowLines);
            _serverLogLines = window.Lines;
            _serverLogLineCount = window.TotalLineCount;
            _serverLogWindowStart = window.StartLine;
            _serverLogReadOffset = window.FileLength;
            _serverLogInteropDirty = true;
        }
        finally
        {
            _serverLogRolloverBusy = false;
        }

        await InvokeAsync(StateHasChanged);
        return BuildServerLogMoveResult(true, scrollRatio);
    }

    private async Task LoadServerLogExceptionsAsync()
    {
        _serverLogPath = ResolveSelectedServerLogPath();

        try
        {
            if (!File.Exists(_serverLogPath))
            {
                _serverLogMissing = true;
                _serverLogLines = Array.Empty<string>();
                _serverLogLineCount = 0;
                _serverLogTruncated = false;
                _serverLogError = null;
                _serverLogMode = "exceptions";
                _serverLogWindowStart = 0;
            }
            else
            {
                var tail = await ReadTailAsync(_serverLogPath, InfoLogExceptionSearchBytes);
                SetServerLogTextWindow(ExtractExceptionBlocks(tail.Text, tail.Truncated, "server log"));
                _serverLogTruncated = tail.Truncated;
                _serverLogReadOffset = tail.FileLength;
                _serverLogMissing = false;
                _serverLogError = null;
                _serverLogMode = "exceptions";
            }
        }
        catch (Exception exception)
        {
            _serverLogError = exception.Message;
            _serverLogLines = Array.Empty<string>();
            _serverLogLineCount = 0;
            _serverLogTruncated = false;
            _serverLogMissing = false;
            _serverLogMode = "exceptions";
            _serverLogWindowStart = 0;
        }

        _serverLogLoaded = true;
        _serverLogScrollPending = true;
        _serverLogInteropDirty = true;
        await InvokeAsync(StateHasChanged);
    }

    private async Task RefreshInfoLogAsync()
    {
        if (!IsWatchingLatestInfoLog)
            return;

        if (_infoLogLoaded && _infoLogMode == "tail")
        {
            await RefreshInfoLogTailAsync(reloadOnReset: true);
            return;
        }

        await LoadInfoLogAsync();
    }

    private async Task DownloadInfoLogAsync()
    {
        var fileName = string.IsNullOrWhiteSpace(_infoLogPath)
            ? "info.log"
            : Path.GetFileName(_infoLogPath);
        await JS.InvokeVoidAsync("quasarConfigs.downloadFile", InfoLogDownloadHref, fileName);
    }

    private async Task HandleInfoLogSelectionChanged(string value)
    {
        _infoLogSelection = NormalizeLogSelection(value);
        _infoLogLoaded = false;
        _infoLogMode = "tail";
        await LoadInfoLogAsync();
    }

    private async Task ShowInfoLogExceptionsAsync()
    {
        await LoadInfoLogExceptionsAsync();
    }

    private async Task LoadInfoLogAsync()
    {
        _infoLogPath = ResolveSelectedInfoLogPath();

        try
        {
            if (!File.Exists(_infoLogPath))
            {
                _infoLogMissing = true;
                _infoLogContent = string.Empty;
                _infoLogLineCount = 0;
                _infoLogTruncated = false;
                _infoLogError = null;
                _infoLogMode = "tail";
                _infoLogReadOffset = 0;
            }
            else
            {
                var tail = await ReadTailAsync(_infoLogPath, InfoLogTailBytes);
                SetInfoLogTailContent(tail.Text, tail.Truncated);
                _infoLogReadOffset = tail.FileLength;
                _infoLogMissing = false;
                _infoLogError = null;
                _infoLogMode = "tail";
            }
        }
        catch (Exception exception)
        {
            _infoLogError = exception.Message;
            _infoLogContent = string.Empty;
            _infoLogLineCount = 0;
            _infoLogTruncated = false;
            _infoLogMissing = false;
            _infoLogMode = "tail";
            _infoLogReadOffset = 0;
        }

        _infoLogLoaded = true;
        _infoLogScrollPending = true;
        await InvokeAsync(StateHasChanged);
    }

    private async Task RefreshInfoLogTailAsync(bool reloadOnReset)
    {
        if (_infoLogMode != "tail" || !IsWatchingLatestInfoLog)
            return;

        var latestPath = ResolveSelectedInfoLogPath();
        if (!string.Equals(latestPath, _infoLogPath, StringComparison.OrdinalIgnoreCase))
        {
            if (reloadOnReset)
                await LoadInfoLogAsync();
            return;
        }

        if (!File.Exists(_infoLogPath))
        {
            if (reloadOnReset)
                await LoadInfoLogAsync();
            return;
        }

        if (_infoLogMissing)
        {
            if (reloadOnReset)
                await LoadInfoLogAsync();
            return;
        }

        if (!string.IsNullOrEmpty(_infoLogError))
        {
            if (reloadOnReset)
                await LoadInfoLogAsync();
            return;
        }

        try
        {
            var update = await ReadAppendedTextAsync(_infoLogPath, _infoLogReadOffset);
            if (update.Reset)
            {
                if (reloadOnReset)
                    await LoadInfoLogAsync();
                return;
            }

            _infoLogReadOffset = update.FileLength;
            if (string.IsNullOrEmpty(update.Text))
                return;

            var shouldScroll = await IsScrolledNearBottomAsync(_infoLogScrollContainerId);
            SetInfoLogTailContent(_infoLogContent + update.Text, _infoLogTruncated);
            _infoLogMissing = false;
            _infoLogError = null;
            _infoLogScrollPending = shouldScroll;

            await InvokeAsync(StateHasChanged);
        }
        catch (Exception exception)
        {
            _infoLogError = exception.Message;
            await InvokeAsync(StateHasChanged);
        }
    }

    private async Task LoadInfoLogExceptionsAsync()
    {
        _infoLogPath = ResolveSelectedInfoLogPath();

        try
        {
            if (!File.Exists(_infoLogPath))
            {
                _infoLogMissing = true;
                _infoLogContent = string.Empty;
                _infoLogLineCount = 0;
                _infoLogTruncated = false;
                _infoLogError = null;
                _infoLogMode = "exceptions";
            }
            else
            {
                var tail = await ReadTailAsync(_infoLogPath, InfoLogExceptionSearchBytes);
                _infoLogContent = ExtractExceptionBlocks(tail.Text, tail.Truncated, "info log");
                _infoLogTruncated = tail.Truncated;
                _infoLogReadOffset = tail.FileLength;
                _infoLogLineCount = CountLines(_infoLogContent);
                _infoLogMissing = false;
                _infoLogError = null;
                _infoLogMode = "exceptions";
            }
        }
        catch (Exception exception)
        {
            _infoLogError = exception.Message;
            _infoLogContent = string.Empty;
            _infoLogLineCount = 0;
            _infoLogTruncated = false;
            _infoLogMissing = false;
            _infoLogMode = "exceptions";
        }

        _infoLogLoaded = true;
        _infoLogScrollPending = true;
        await InvokeAsync(StateHasChanged);
    }

    private void SetServerLogTextWindow(string text)
    {
        var lines = SplitLines(text);
        _serverLogLineCount = lines.Count;
        _serverLogWindowStart = Math.Max(0, lines.Count - ServerLogWindowLines);
        _serverLogLines = lines
            .Skip(_serverLogWindowStart)
            .Take(ServerLogWindowLines)
            .ToArray();
    }

    private void SetInfoLogTailContent(string text, bool alreadyTruncated)
    {
        _infoLogContent = TrimInfoLogTailContent(text, out var truncated);
        _infoLogTruncated = alreadyTruncated || truncated;
        _infoLogLineCount = CountLines(_infoLogContent);
    }

    private static string TrimInfoLogTailContent(string text, out bool truncated)
    {
        truncated = false;
        if (text.Length <= InfoLogTailBytes)
            return text;

        truncated = true;
        var start = text.Length - InfoLogTailBytes;
        var nextLine = text.IndexOf('\n', start);
        if (nextLine >= 0 && nextLine + 1 < text.Length)
            start = nextLine + 1;

        return text[start..];
    }

    private static async Task<LogTailSnapshot> ReadTailAsync(string path, int maxBytes)
    {
        await using var stream = new FileStream(
            path,
            FileMode.Open,
            FileAccess.Read,
            FileShare.ReadWrite | FileShare.Delete);

        var fileLength = stream.Length;
        var truncated = false;
        if (fileLength > maxBytes)
        {
            stream.Seek(-maxBytes, SeekOrigin.End);
            truncated = true;
        }

        using var reader = new StreamReader(stream);
        if (truncated)
        {
            // Drop the partial first line so output starts at a clean boundary.
            await reader.ReadLineAsync();
        }

        var text = await reader.ReadToEndAsync();
        return new LogTailSnapshot(text, truncated, fileLength);
    }

    private static async Task<ServerLogAppend> ReadAppendedLinesAsync(string path, long startOffset)
    {
        await using var stream = new FileStream(
            path,
            FileMode.Open,
            FileAccess.Read,
            FileShare.ReadWrite | FileShare.Delete);

        var fileLength = stream.Length;
        if (startOffset > fileLength)
            return new ServerLogAppend(Array.Empty<string>(), fileLength, Reset: true);

        if (startOffset == fileLength)
            return new ServerLogAppend(Array.Empty<string>(), fileLength, Reset: false);

        stream.Seek(Math.Max(0, startOffset), SeekOrigin.Begin);
        using var reader = new StreamReader(stream);

        var lines = new List<string>();
        string? line;
        while ((line = await reader.ReadLineAsync()) is not null)
            lines.Add(line);

        return new ServerLogAppend(lines, fileLength, Reset: false);
    }

    private static async Task<LogTextAppend> ReadAppendedTextAsync(string path, long startOffset)
    {
        await using var stream = new FileStream(
            path,
            FileMode.Open,
            FileAccess.Read,
            FileShare.ReadWrite | FileShare.Delete);

        var fileLength = stream.Length;
        if (startOffset > fileLength)
            return new LogTextAppend(string.Empty, fileLength, Reset: true);

        if (startOffset == fileLength)
            return new LogTextAppend(string.Empty, fileLength, Reset: false);

        stream.Seek(Math.Max(0, startOffset), SeekOrigin.Begin);
        using var reader = new StreamReader(stream);
        return new LogTextAppend(await reader.ReadToEndAsync(), fileLength, Reset: false);
    }

    private static async Task<ServerLogLineWindow> ReadLatestLineWindowAsync(string path, int maxLines)
    {
        await using var stream = new FileStream(
            path,
            FileMode.Open,
            FileAccess.Read,
            FileShare.ReadWrite | FileShare.Delete);
        using var reader = new StreamReader(stream);

        var lines = new Queue<string>(maxLines + 1);
        var totalLines = 0;
        string? line;
        while ((line = await reader.ReadLineAsync()) is not null)
        {
            totalLines++;
            lines.Enqueue(line);
            if (lines.Count > maxLines)
                lines.Dequeue();
        }

        return new ServerLogLineWindow(lines.ToArray(), Math.Max(0, totalLines - lines.Count), totalLines, stream.Length);
    }

    private static async Task<ServerLogLineWindow> ReadLineWindowAsync(string path, int startLine, int maxLines)
    {
        var window = await ReadLineWindowCoreAsync(path, startLine, maxLines);
        var normalizedStart = Math.Clamp(startLine, 0, Math.Max(0, window.TotalLineCount - maxLines));
        return normalizedStart == startLine
            ? window
            : await ReadLineWindowCoreAsync(path, normalizedStart, maxLines);
    }

    private static async Task<ServerLogLineWindow> ReadLineWindowCoreAsync(string path, int startLine, int maxLines)
    {
        await using var stream = new FileStream(
            path,
            FileMode.Open,
            FileAccess.Read,
            FileShare.ReadWrite | FileShare.Delete);
        using var reader = new StreamReader(stream);

        var lines = new List<string>(maxLines);
        var currentLine = 0;
        string? line;
        while ((line = await reader.ReadLineAsync()) is not null)
        {
            if (currentLine >= startLine && lines.Count < maxLines)
                lines.Add(line);

            currentLine++;
        }

        return new ServerLogLineWindow(lines, startLine, currentLine, stream.Length);
    }

    private static int CountLines(string text)
    {
        if (string.IsNullOrEmpty(text))
            return 0;

        var count = 1;
        foreach (var c in text)
        {
            if (c == '\n')
                count++;
        }

        if (text.EndsWith('\n'))
            count--;

        return count;
    }

    private static IReadOnlyList<string> SplitLines(string text)
    {
        if (string.IsNullOrEmpty(text))
            return Array.Empty<string>();

        return text.Replace("\r\n", "\n").Split('\n');
    }

    private string InfoLogStatusText()
    {
        if (_infoLogMissing)
            return "Magnetar info log not found yet.";

        var status = _infoLogMode == "exceptions"
            ? $"{_infoLogLineCount} line(s) from exception excerpts{(_infoLogTruncated ? " (searched log tail)" : string.Empty)}"
            : $"{_infoLogLineCount} line(s){(_infoLogTruncated ? " (tail only)" : string.Empty)}";

        return IsWatchingLatestInfoLog
            ? status
            : $"Viewing archived file; refresh disabled. {status}";
    }

    private string ServerLogStatusText()
    {
        if (_serverLogMissing)
            return "Dedicated Server log not found yet.";

        if (_serverLogMode == "exceptions")
        {
            var exceptionStatus = $"{_serverLogLineCount} line(s) from exception excerpts{(_serverLogTruncated ? " (searched log tail)" : string.Empty)}";
            return IsWatchingLatestServerLog
                ? exceptionStatus
                : $"Viewing archived file; refresh disabled. {exceptionStatus}";
        }

        if (_serverLogLineCount == 0)
            return IsWatchingLatestServerLog
                ? "0 line(s)"
                : "Viewing archived file; refresh disabled. 0 line(s)";

        var endLine = _serverLogWindowStart + _serverLogLines.Count;
        var status = $"Showing {_serverLogWindowStart + 1}-{endLine} of {_serverLogLineCount} line(s)";
        return IsWatchingLatestServerLog
            ? status
            : $"Viewing archived file; refresh disabled. {status}";
    }

    private async Task AttachServerLogInteropAsync()
    {
        if (_serverLogMode != "tail" || _serverLogMissing || !string.IsNullOrEmpty(_serverLogError))
        {
            await DetachServerLogInteropAsync();
            return;
        }

        try
        {
            _serverLogInteropRef ??= DotNetObjectReference.Create(this);
            await JS.InvokeVoidAsync(
                "quasarConfigs.attachRolloverLog",
                _scrollContainerId,
                _serverLogInteropRef,
                new ServerLogRolloverOptions
                {
                    Threshold = ServerLogRolloverThresholdPx,
                    CanLoadOlder = CanLoadOlderServerLogLines,
                    CanLoadNewer = CanLoadNewerServerLogLines,
                });
            _serverLogInteropAttached = true;
            _serverLogInteropDirty = false;
        }
        catch (JSDisconnectedException)
        {
        }
    }

    private async Task DetachServerLogInteropAsync()
    {
        if (!_serverLogInteropAttached)
            return;

        try
        {
            await JS.InvokeVoidAsync("quasarConfigs.detachRolloverLog", _scrollContainerId);
        }
        catch (JSDisconnectedException)
        {
        }

        _serverLogInteropAttached = false;
        _serverLogInteropDirty = true;
    }

    private bool CanLoadOlderServerLogLines => _serverLogMode == "tail" && _serverLogWindowStart > 0;

    private bool CanLoadNewerServerLogLines =>
        _serverLogMode == "tail" && _serverLogWindowStart + _serverLogLines.Count < _serverLogLineCount;

    private ServerLogWindowMoveResult BuildServerLogMoveResult(bool shifted, double scrollRatio) =>
        new()
        {
            Shifted = shifted,
            CanLoadOlder = CanLoadOlderServerLogLines,
            CanLoadNewer = CanLoadNewerServerLogLines,
            ScrollRatio = scrollRatio,
        };

    private string ResolveSelectedServerLogPath()
    {
        var appDataPath = ResolveDedicatedServerAppDataPath();
        _serverLogOptions = EnumerateLogFiles(appDataPath, "SpaceEngineersDedicated*.log");
        return ResolveSelectedLogPath(
            appDataPath,
            _serverLogOptions,
            _serverLogSelection,
            "SpaceEngineersDedicated*.log");
    }

    private string ResolveSelectedInfoLogPath()
    {
        var appDataPath = ResolveMagnetarAppDataPath();
        _infoLogOptions = EnumerateLogFiles(appDataPath, "info*.log");
        return ResolveSelectedLogPath(
            appDataPath,
            _infoLogOptions,
            _infoLogSelection,
            "info*.log");
    }

    private string ResolveDedicatedServerAppDataPath()
    {
        var configuredPath = ServerCatalog.GetServer(UniqueName)?.DedicatedServerAppDataPath;
        return string.IsNullOrWhiteSpace(configuredPath)
            ? MagnetarPaths.GetQuasarServerDedicatedServerAppDataDirectory(UniqueName)
            : configuredPath.Trim();
    }

    private string ResolveMagnetarAppDataPath()
    {
        var configuredPath = ServerCatalog.GetServer(UniqueName)?.MagnetarAppDataPath;
        return string.IsNullOrWhiteSpace(configuredPath)
            ? MagnetarPaths.GetQuasarServerMagnetarAppDataDirectory(UniqueName)
            : configuredPath.Trim();
    }

    private static IReadOnlyList<LogFileOption> EnumerateLogFiles(string appDataPath, string searchPattern)
    {
        try
        {
            if (!Directory.Exists(appDataPath))
                return Array.Empty<LogFileOption>();

            return Directory.EnumerateFiles(appDataPath, searchPattern, SearchOption.TopDirectoryOnly)
                .Select(path =>
                {
                    var file = new FileInfo(path);
                    return new LogFileOption(
                        file.FullName,
                        file.Name,
                        FormatLogFileOption(file),
                        file.LastWriteTimeUtc);
                })
                .OrderByDescending(option => option.LastWriteTimeUtc)
                .ThenByDescending(option => option.FileName, StringComparer.OrdinalIgnoreCase)
                .ToArray();
        }
        catch
        {
            return Array.Empty<LogFileOption>();
        }
    }

    private static string ResolveSelectedLogPath(
        string appDataPath,
        IReadOnlyList<LogFileOption> options,
        string selection,
        string missingPattern)
    {
        if (IsLatestLogSelection(selection))
            return options.FirstOrDefault()?.Path ?? Path.Combine(appDataPath, missingPattern);

        var selected = options.FirstOrDefault(option =>
            string.Equals(option.FileName, selection, StringComparison.OrdinalIgnoreCase));
        if (selected is not null)
            return selected.Path;

        return IsSafeLogFileName(selection)
            ? Path.Combine(appDataPath, selection)
            : Path.Combine(appDataPath, missingPattern);
    }

    private static string NormalizeLogSelection(string value)
    {
        return string.IsNullOrWhiteSpace(value)
            ? LatestLogSelection
            : value;
    }

    private static bool IsLatestLogSelection(string selection) =>
        string.Equals(selection, LatestLogSelection, StringComparison.Ordinal);

    private static bool IsSafeLogFileName(string fileName)
    {
        return !string.IsNullOrWhiteSpace(fileName) &&
               string.Equals(fileName, Path.GetFileName(fileName), StringComparison.Ordinal) &&
               fileName.IndexOfAny(Path.GetInvalidFileNameChars()) < 0;
    }

    private string BuildLogDownloadHref(string logKind, string selection)
    {
        var href = $"/api/servers/{Uri.EscapeDataString(UniqueName)}/logs/{logKind}/download";
        return IsLatestLogSelection(selection)
            ? href
            : $"{href}?name={Uri.EscapeDataString(selection)}";
    }

    private static string FormatLogFileOption(FileInfo file)
    {
        var localTime = file.LastWriteTime.ToString("yyyy-MM-dd HH:mm:ss");
        return $"{file.Name} ({localTime}, {FormatByteCount(file.Length)})";
    }

    private static string FormatByteCount(long bytes)
    {
        const double KiB = 1024;
        const double MiB = KiB * 1024;

        if (bytes >= MiB)
            return $"{bytes / MiB:0.0} MiB";

        if (bytes >= KiB)
            return $"{bytes / KiB:0.0} KiB";

        return $"{bytes} B";
    }

    private static string ExtractExceptionBlocks(string text, bool truncated, string logName)
    {
        var lines = text.Replace("\r\n", "\n").Split('\n');
        var matches = lines
            .Select((line, index) => (line, index))
            .Where(item => item.line.Contains("Exception", StringComparison.OrdinalIgnoreCase))
            .Select(item => item.index)
            .TakeLast(InfoLogExceptionMatchLimit)
            .ToList();

        if (matches.Count == 0)
        {
            return truncated
                ? $"No lines containing \"Exception\" found in the searched {logName} tail."
                : $"No lines containing \"Exception\" found in {logName}.";
        }

        var ranges = new List<(int Start, int End)>();
        foreach (var index in matches)
        {
            var start = index;
            var end = Math.Min(lines.Length - 1, index + InfoLogExceptionContextLines);
            if (ranges.Count > 0 && start <= ranges[^1].End + 1)
            {
                var previous = ranges[^1];
                ranges[^1] = (previous.Start, Math.Max(previous.End, end));
            }
            else
            {
                ranges.Add((start, end));
            }
        }

        var output = new List<string>();
        if (truncated)
            output.Add($"Searched latest {InfoLogExceptionSearchBytes / (1024 * 1024)} MB of {logName}.");

        for (var rangeIndex = 0; rangeIndex < ranges.Count; rangeIndex++)
        {
            var (start, end) = ranges[rangeIndex];
            if (output.Count > 0)
                output.Add(string.Empty);

            output.Add($"--- Exception excerpt {rangeIndex + 1} (line {start + 1} of searched text) ---");
            for (var i = start; i <= end; i++)
                output.Add(lines[i]);
        }

        return string.Join(Environment.NewLine, output);
    }

    private void Close() => MudDialog.Close();

    public async ValueTask DisposeAsync()
    {
        _autoRefreshCts?.Cancel();
        if (_autoRefreshTask is not null)
        {
            try
            {
                await _autoRefreshTask;
            }
            catch (OperationCanceledException)
            {
            }
        }

        _autoRefreshCts?.Dispose();
        await DetachServerLogInteropAsync();
        _serverLogInteropRef?.Dispose();
    }

