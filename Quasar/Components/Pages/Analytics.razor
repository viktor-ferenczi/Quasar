    private sealed class ChartModel(string RenderKey, string Title, string Subtitle, List<AnalyticsChartSeries> Series, ApexCharts.ApexChartOptions<AnalyticsChartPoint> Options, string Height, string LayoutStyle, decimal XMin, decimal XMax, AnalyticsPanelConfig Panel)
    {
        public string RenderKey { get; } = RenderKey;
        public string Title { get; private set; } = Title;
        public string Subtitle { get; private set; } = Subtitle;
        public List<AnalyticsChartSeries> Series { get; } = Series;
        public ApexCharts.ApexChartOptions<AnalyticsChartPoint> Options { get; set; } = Options;
        public string Height { get; private set; } = Height;
        public string LayoutStyle { get; private set; } = LayoutStyle;
        public decimal XMin { get; private set; } = XMin;
        public decimal XMax { get; private set; } = XMax;
        public AnalyticsPanelConfig Panel { get; private set; } = Panel;
        public ApexChart<AnalyticsChartPoint>? ChartRef { get; set; }

        public void Update(
            string title,
            string subtitle,
            List<AnalyticsChartSeries> series,
            ApexCharts.ApexChartOptions<AnalyticsChartPoint> options,
            string height,
            string layoutStyle,
            decimal xMin,
            decimal xMax,
            AnalyticsPanelConfig panel)
        {
            Title = title;
            Subtitle = subtitle;
            Options = options;
            Height = height;
            LayoutStyle = layoutStyle;
            XMin = xMin;
            XMax = xMax;
            Panel = panel;

            var existingSeries = Series.ToDictionary(item => item.Name, StringComparer.OrdinalIgnoreCase);
            Series.Clear();
            foreach (var item in series)
            {
                if (existingSeries.TryGetValue(item.Name, out var existing))
                {
                    existing.ReplacePoints(item.Points);
                    Series.Add(existing);
                }
                else
                {
                    Series.Add(item);
                }
            }
        }
    }

    private readonly record struct SeriesTransformCacheKey(string Server, string Metric, long FromUnix, long ToUnix);

    private sealed class AnalyticsChartSeries(string Name, IEnumerable<AnalyticsChartPoint> Points)
    {
        public string Name { get; } = Name;

        public List<AnalyticsChartPoint> Points { get; } = Points.ToList();

        public void ReplacePoints(IEnumerable<AnalyticsChartPoint> points)
        {
            Points.Clear();
            Points.AddRange(points);
        }
    }

    private sealed record AnalyticsChartPoint(DateTime Timestamp, decimal? Value);
}
