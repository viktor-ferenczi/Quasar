<MudDialog>
    <TitleContent>
        <MudStack Row="true" AlignItems="AlignItems.Center" Spacing="1">
            <MudIconButton Icon="@Icons.Material.Filled.Close" Color="Color.Default" OnClick="Cancel" title="Discard changes" />
            <MudText Typo="Typo.h6">@(_isEditing ? "Edit Instance" : "Create Instance")</MudText>
        </MudStack>
    </TitleContent>
    <DialogContent>
        <div class="instance-editor-dialog-content">
        <MudForm @ref="_form" @bind-IsValid="_formIsValid">
        <MudStack Spacing="3">
            <MudText Typo="Typo.body2">
                Define the full Quasar-managed instance here. Create and edit use the same workflow so paths, launch settings, and health policy stay in one place.
            </MudText>

            <section>
                <MudText Typo="Typo.subtitle2" Class="mb-2">Identity</MudText>
                <MudGrid>
                    <MudItem xs="12" md="6">
                        <MudTextField
                            T="string"
                            Value="_editor.DisplayName"
                            ValueChanged="HandleDisplayNameChanged"
                            Label="Display name"
                            Variant="Variant.Outlined"
                            Immediate="true"
                            AutoFocus="@(!_isEditing)"
                            Required="true"
                            RequiredError="Display name required."
                            HelperText="Friendly name shown in lists and dashboards." />
                    </MudItem>
                    <MudItem xs="12" md="6">
                        <MudTextField
                            T="string"
                            Value="_editor.UniqueName"
                            ValueChanged="HandleIdentifierChanged"
                            Label="Identifier"
                            Variant="Variant.Outlined"
                            Immediate="true"
                            Disabled="@_isEditing"
                            Class="mono"
                            Required="true"
                            RequiredError="Identifier required."
                            Validation="@(new Func<string, string?>(ValidateUniqueNameField))"
                            HelperText="@GetUniqueNameHelperText()" />
                    </MudItem>
                    <MudItem xs="12" md="6">
                        <MudNumericField T="int"
                                         Value="_editor.ServerPort"
                                         ValueChanged="HandlePortChanged"
                                         Label="Listen port"
                                         Variant="Variant.Outlined"
                                         Min="1"
                                         Max="65535"
                                         Required="true"
                                         RequiredError="Listen port required."
                                         Validation="@(new Func<int, string?>(ValidatePortField))"
                                         HelperText="UDP port for clients. Default 27016. Must be unique across local instances." />
                    </MudItem>
                    <MudItem xs="12" md="6">
                        <MudTextField @bind-Value="_editor.ServerIP"
                                      Label="Listen IP"
                                      Variant="Variant.Outlined"
                                      HelperText="0.0.0.0 listens on all interfaces. Set a specific IP to bind to one NIC." />
                    </MudItem>
                    <MudItem xs="12" md="6">
                        <MudStack Row="true" Wrap="Wrap.Wrap" AlignItems="AlignItems.Start" Spacing="1">
                            <MudSelect T="string"
                                       @bind-Value="_editor.ConfigProfileId"
                                       Label="Config template"
                                       Variant="Variant.Outlined"
                                       HelperText="Reusable world, plugin, and mod preset from Configs page."
                                       Class="instance-editor-template-select"
                                       PopoverClass="instance-editor-select-popover"
                                       ListClass="instance-editor-select-list">
                                <MudSelectItem T="string" Value="@string.Empty">(No config template)</MudSelectItem>
                                @foreach (var template in ConfigProfiles.GetProfiles())
                                {
                                    <MudSelectItem T="string" Value="@template.ConfigProfileId">@template.Name</MudSelectItem>
                                }
                            </MudSelect>
                            @if (string.IsNullOrWhiteSpace(_editor.ConfigProfileId))
                            {
                                <MudTooltip Text="Create a config template without leaving this dialog">
                                    <MudButton Variant="Variant.Outlined" Color="Color.Primary" StartIcon="@Icons.Material.Filled.Add" OnClick="OpenCreateConfigProfileDialogAsync">
                                        New Template
                                    </MudButton>
                                </MudTooltip>
                            }
                        </MudStack>
                    </MudItem>
                    <MudItem xs="12" md="6">
                        <MudStack Row="true" Wrap="Wrap.Wrap" AlignItems="AlignItems.Start" Spacing="1">
                            <MudSelect T="string"
                                       @bind-Value="_editor.WorldTemplateId"
                                       Label="World template"
                                       Variant="Variant.Outlined"
                                       HelperText="Blueprint world copied into instance world path on first launch if world directory does not already exist."
                                       Class="instance-editor-template-select"
                                       PopoverClass="instance-editor-select-popover"
                                       ListClass="instance-editor-select-list">
                                <MudSelectItem T="string" Value="@string.Empty">(No world template)</MudSelectItem>
                                @foreach (var template in WorldTemplates.GetTemplates())
                                {
                                    <MudSelectItem T="string" Value="@template.WorldTemplateId">@template.Name</MudSelectItem>
                                }
                            </MudSelect>
                            @if (string.IsNullOrWhiteSpace(_editor.WorldTemplateId))
                            {
                                <MudTooltip Text="Import world template without leaving this dialog">
                                    <MudButton Variant="Variant.Outlined" Color="Color.Primary" StartIcon="@Icons.Material.Filled.Add" OnClick="OpenImportWorldTemplateDialogAsync">
                                        New Template
                                    </MudButton>
                                </MudTooltip>
                            }
                        </MudStack>
                    </MudItem>
                </MudGrid>
            </section>

            <MudDivider />

            <section>
                <MudExpansionPanels MultiExpansion="true" Elevation="0" Outlined="true" Dense="true">
                    <MudExpansionPanel Expanded="@_restartPolicyExpanded" ExpandedChanged="HandleRestartPolicyExpandedChanged">
                        <TitleContent>
                            <MudStack Row="true" Wrap="Wrap.Wrap" AlignItems="AlignItems.Center" Justify="Justify.SpaceBetween" Class="w-100">
                                <MudStack Spacing="0">
                                    <MudText Typo="Typo.subtitle2">Restart Policy</MudText>
                                    <MudText Typo="Typo.caption">Crash recovery and retry behavior for managed instance.</MudText>
                                </MudStack>
                            </MudStack>
                        </TitleContent>
                        <ChildContent>
                            <MudGrid>
                                <MudItem xs="12" md="4">
                                    <MudNumericField T="int" @bind-Value="_editor.RestartDelaySeconds" Label="Restart delay (seconds)" Variant="Variant.Outlined" Min="0" />
                                </MudItem>
                                <MudItem xs="12" md="4">
                                    <MudNumericField T="int" @bind-Value="_editor.MaxRestartAttempts" Label="Max restart attempts (0 = unlimited)" Variant="Variant.Outlined" Min="0" />
                                </MudItem>
                                <MudItem xs="12" md="4" Class="d-flex align-center">
                                    <MudCheckBox @bind-Value="_editor.RestartOnCrash" Label="Restart when process crashes" />
                                </MudItem>
                                <MudItem xs="12" md="6">
                                    <MudTextField @bind-Value="_editor.DailyRestartTimeLocal"
                                                  Label="Restart schedule (HH:mm, server local time)"
                                                  Variant="Variant.Outlined"
                                                  Placeholder="e.g. 04:00 08:00 12:00"
                                                  Validation="@(new Func<string, string?>(ValidateRestartSchedule))"
                                                  HelperText="Leave blank to disable. Accepts multiple times separated by spaces, commas, or new lines." />
                                </MudItem>
                                <MudItem xs="12" md="6">
                                    <MudTextField @bind-Value="_editor.MaximumUptime"
                                                  Label="Maximum uptime (HH:mm)"
                                                  Variant="Variant.Outlined"
                                                  Placeholder="e.g. 06:00"
                                                  Validation="@(new Func<string, string?>(ValidateMaximumUptime))"
                                                  HelperText="Leave blank to disable. Restarts once process uptime reaches this duration." />
                                </MudItem>
                                <MudItem xs="12">
                                    <MudCheckBox @bind-Value="_editor.AvoidSimultaneousScheduledRestarts"
                                                 Label="Avoid restarting more than one server at once for scheduled or maximum-uptime restarts" />
                                </MudItem>
                            </MudGrid>
                        </ChildContent>
                    </MudExpansionPanel>

                    <MudExpansionPanel Expanded="@_healthPolicyExpanded" ExpandedChanged="HandleHealthPolicyExpandedChanged">
                        <TitleContent>
                            <MudStack Row="true" Wrap="Wrap.Wrap" AlignItems="AlignItems.Center" Justify="Justify.SpaceBetween" Class="w-100">
                                <MudStack Spacing="0">
                                    <MudText Typo="Typo.subtitle2">Health Policy</MudText>
                                    <MudText Typo="Typo.caption">Agent heartbeat, simulation progress, uptime, and recovery thresholds.</MudText>
                                </MudStack>
                            </MudStack>
                        </TitleContent>
                        <ChildContent>
                            <MudGrid>
                                <MudItem xs="12" md="6" lg="4">
                                    <MudCheckBox @bind-Value="_editor.EnableHealthMonitoring" Label="Enable health monitoring" />
                                </MudItem>
                                <MudItem xs="12" md="6" lg="4">
                                    <MudCheckBox @bind-Value="_editor.AutoRestartOnUnhealthy" Label="Auto-restart when unhealthy" Disabled="@(!_editor.EnableHealthMonitoring)" />
                                </MudItem>
                                <MudItem xs="12" md="6" lg="4">
                                    <MudNumericField T="int" @bind-Value="_editor.AgentStartupGraceSeconds" Label="Agent startup grace (seconds)" Variant="Variant.Outlined" Min="0" />
                                </MudItem>
                                <MudItem xs="12" md="6" lg="4">
                                    <MudNumericField T="int" @bind-Value="_editor.AgentHeartbeatTimeoutSeconds" Label="Agent heartbeat timeout (seconds)" Variant="Variant.Outlined" Min="1" />
                                </MudItem>
                                <MudItem xs="12" md="6" lg="4">
                                    <MudNumericField T="int" @bind-Value="_editor.SimulationProgressWindowSeconds" Label="Simulation frame window (seconds)" Variant="Variant.Outlined" Min="1" />
                                </MudItem>
                                <MudItem xs="12" md="6" lg="4">
                                    <MudNumericField T="decimal"
                                                     Value="MinimumSimulationRateEditorValue"
                                                     ValueChanged="HandleMinimumSimulationRateChanged"
                                                     Label="Minimum average simulation rate"
                                                     Variant="Variant.Outlined"
                                                     Min="0m"
                                                     Max="1m"
                                                     Step="0.1m"
                                                     Format="0.###"
                                                     HelperText="Rate = frames advanced / (seconds * 60). 1.00 = full sim speed." />
                                </MudItem>
                                <MudItem xs="12" md="6">
                                    <MudNumericField T="int"
                                                     @bind-Value="_editor.WarnAfterUptimeHours"
                                                     Label="Warn after uptime (hours)"
                                                     Variant="Variant.Outlined"
                                                     Min="0"
                                                     HelperText="Shows a dashboard health warning after process uptime exceeds this value. 0 disables it." />
                                </MudItem>
                            </MudGrid>
                        </ChildContent>
                    </MudExpansionPanel>

                    <MudExpansionPanel Expanded="@_runtimeExpanded" ExpandedChanged="HandleRuntimeExpandedChanged">
                        <TitleContent>
                            <MudStack Row="true" Wrap="Wrap.Wrap" AlignItems="AlignItems.Center" Justify="Justify.SpaceBetween" Class="w-100">
                                <MudStack Spacing="0">
                                    <MudText Typo="Typo.subtitle2">Runtime</MudText>
                                    <MudText Typo="Typo.caption">Advanced overrides for Quasar-managed paths and launch behavior.</MudText>
                                </MudStack>
                                <MudChip T="string" Color="Color.Warning" Variant="Variant.Outlined" Size="Size.Small">Advanced</MudChip>
                            </MudStack>
                        </TitleContent>
                        <ChildContent>
                            <MudAlert Severity="Severity.Warning" Variant="Variant.Outlined" Dense="true" Class="mb-3">
                                Advanced. Leave these blank unless you need to override Quasar's managed runtime defaults.
                            </MudAlert>
                            <MudGrid>
                                <MudItem xs="12" md="6">
                                    <MudTextField
                                        @bind-Value="_editor.ExecutablePath"
                                        Label="Launcher executable path"
                                        Variant="Variant.Outlined"
                                        HelperText="Leave blank and Quasar will auto-download and manage the Magnetar install." />
                                </MudItem>
                                <MudItem xs="12" md="6">
                                    <MudTextField
                                        @bind-Value="_editor.WorkingDirectory"
                                        Label="Working directory"
                                        Variant="Variant.Outlined"
                                        HelperText="Leave blank to use the Magnetar install directory automatically." />
                                </MudItem>
                                <MudItem xs="12" md="6">
                                    <MudTextField
                                        @bind-Value="_editor.DedicatedServerAppDataPath"
                                        Label="DS app-data path"
                                        Variant="Variant.Outlined"
                                        HelperText="@($"Space Engineers Dedicated Server data (-path). Default: {GetDefaultDedicatedServerAppDataPath()}")" />
                                </MudItem>
                                <MudItem xs="12" md="6">
                                    <MudTextField
                                        @bind-Value="_editor.MagnetarAppDataPath"
                                        Label="Magnetar app-data path"
                                        Variant="Variant.Outlined"
                                        HelperText="@($"Magnetar templates and sources (-config). Default: {GetDefaultMagnetarAppDataPath()}")" />
                                </MudItem>
                                <MudItem xs="12" md="6">
                                    <MudTextField
                                        @bind-Value="_editor.WorldPath"
                                        Label="World path"
                                        Variant="Variant.Outlined"
                                        HelperText="@($"Must be an existing SE save folder containing Sandbox.sbc. Default (auto-created on first DS boot): {GetDefaultWorldPath()}")" />
                                </MudItem>
                                <MudItem xs="12" md="6">
                                    <MudTextField
                                        @bind-Value="_editor.ConfigFilePath"
                                        Label="Rendered DS config path"
                                        Variant="Variant.Outlined"
                                        HelperText="@($"Quasar writes the rendered SpaceEngineers-Dedicated.cfg here. Default: {GetDefaultConfigFilePath()}")" />
                                </MudItem>
                                <MudItem xs="12" md="6">
                                    <MudSelect T="DedicatedServerProcessPriority"
                                               @bind-Value="_editor.StartupProcessPriority"
                                               Label="Startup process priority"
                                               Variant="Variant.Outlined"
                                               HelperText="Applied after process start. Linux uses nice level.">
                                        @foreach (var priority in ProcessPriorities)
                                        {
                                            <MudSelectItem T="DedicatedServerProcessPriority" Value="@priority">@FormatPriority(priority)</MudSelectItem>
                                        }
                                    </MudSelect>
                                </MudItem>
                                <MudItem xs="12" md="6">
                                    <MudSelect T="DedicatedServerProcessPriority"
                                               @bind-Value="_editor.ReadyProcessPriority"
                                               Label="Ready process priority"
                                               Variant="Variant.Outlined"
                                               HelperText="Applied when agent snapshot confirms the server is open.">
                                        @foreach (var priority in ProcessPriorities)
                                        {
                                            <MudSelectItem T="DedicatedServerProcessPriority" Value="@priority">@FormatPriority(priority)</MudSelectItem>
                                        }
                                    </MudSelect>
                                </MudItem>
                                <MudItem xs="12">
                                    <MudTextField
                                        @bind-Value="_editor.LaunchArguments"
                                        Label="Launch arguments"
                                        Variant="Variant.Outlined"
                                        Lines="3"
                                        HelperText="Tokens: {uniqueName} {configPath} {quasarBaseUrl} {nodeId} {dsAppDataPath} {magnetarAppDataPath} {ds64Path} {worldPath}. Quasar enforces -noconsole, -path, -config, and -ds64 for managed instances." />
                                </MudItem>
                            </MudGrid>
                        </ChildContent>
                    </MudExpansionPanel>
                </MudExpansionPanels>
            </section>
        </MudStack>
        </MudForm>
        </div>
    </DialogContent>
    <DialogActions>
        <MudButton Variant="Variant.Text" Color="Color.Default" OnClick="Cancel">Cancel</MudButton>
        <MudButton Variant="Variant.Filled" Color="Color.Primary" OnClick="SaveAsync">@(_isEditing ? "Save Changes" : "Create Instance")</MudButton>
    </DialogActions>
</MudDialog>

@code
{
    [CascadingParameter]
    private IMudDialogInstance MudDialog { get; set; } = default!;

    [Inject]
    private QuasarConfigProfileCatalog ConfigProfiles { get; set; } = default!;

    [Inject]
    private QuasarWorldTemplateCatalog WorldTemplates { get; set; } = default!;

    [Inject]
    private DedicatedServerInstanceCatalog InstanceCatalog { get; set; } = default!;

    [Inject]
    private IDialogService DialogService { get; set; } = default!;

    private MudForm? _form;
    private bool _formIsValid;
    private bool _identifierManuallyEdited;

    [Parameter]
    public DedicatedServerInstanceDefinition Definition { get; set; } = new();

    [Parameter]
    public bool IsEditing { get; set; }

    [Parameter]
    public bool UniqueNameLocked { get; set; }

    private static readonly System.Text.RegularExpressions.Regex UniqueNameRegex = new("^[a-zA-Z0-9_-]+$", System.Text.RegularExpressions.RegexOptions.Compiled);

    private DedicatedServerInstanceDefinition _editor = new();
    private bool _isEditing;
    private bool _restartPolicyExpanded;
    private bool _healthPolicyExpanded;
    private bool _runtimeExpanded;
    private static readonly DedicatedServerProcessPriority[] ProcessPriorities =
    [
        DedicatedServerProcessPriority.Low,
        DedicatedServerProcessPriority.BelowNormal,
        DedicatedServerProcessPriority.Normal,
        DedicatedServerProcessPriority.AboveNormal,
        DedicatedServerProcessPriority.High,
    ];

    protected override void OnInitialized()
    {
        _editor = Definition.Clone();
        _isEditing = IsEditing;
        _restartPolicyExpanded = _isEditing;
        _healthPolicyExpanded = _isEditing;
        _runtimeExpanded = _isEditing;

        if (string.IsNullOrWhiteSpace(_editor.DisplayName) && !string.IsNullOrWhiteSpace(_editor.UniqueName))
            _editor.DisplayName = _editor.UniqueName;

        _identifierManuallyEdited = _isEditing || !string.IsNullOrWhiteSpace(_editor.UniqueName);
    }

    private void HandleDisplayNameChanged(string value)
    {
        _editor.DisplayName = value ?? string.Empty;

        if (_isEditing || _identifierManuallyEdited)
            return;

        _editor.UniqueName = SlugifyForIdentifier(_editor.DisplayName);
    }

    private void HandleIdentifierChanged(string value)
    {
        _editor.UniqueName = value ?? string.Empty;
        _identifierManuallyEdited = true;
    }

    private void HandlePortChanged(int value)
    {
        _editor.ServerPort = value;
    }

    private decimal MinimumSimulationRateEditorValue =>
        Math.Round((decimal)_editor.MinimumSimulationProgressScore, 3);

    private void HandleMinimumSimulationRateChanged(decimal value)
    {
        _editor.MinimumSimulationProgressScore = (float)Math.Clamp(value, 0m, 1m);
    }

    private static string? ValidateRestartSchedule(string? value)
    {
        if (string.IsNullOrWhiteSpace(value))
            return null;

        var tokens = value
            .Split([' ', ',', ';', '\n', '\r', '\t'], StringSplitOptions.RemoveEmptyEntries | StringSplitOptions.TrimEntries);
        if (tokens.Length == 0)
            return null;

        foreach (var token in tokens)
        {
            var parts = token.Split(':');
            if (parts.Length != 2 ||
                !int.TryParse(parts[0], out var hour) || hour is < 0 or > 23 ||
                !int.TryParse(parts[1], out var minute) || minute is < 0 or > 59)
            {
                return "Use HH:mm values from 00:00 to 23:59.";
            }
        }

        return null;
    }

    private static string? ValidateMaximumUptime(string? value)
    {
        if (string.IsNullOrWhiteSpace(value))
            return null;

        var parts = value.Trim().Split(':');
        if (parts.Length != 2 ||
            !int.TryParse(parts[0], out var hours) || hours < 0 ||
            !int.TryParse(parts[1], out var minutes) || minutes is < 0 or > 59 ||
            (hours == 0 && minutes == 0))
        {
            return "Use HH:mm duration, for example 06:00.";
        }

        return null;
    }

    private string? ValidatePortField(int value)
    {
        if (value < 1 || value > 65535)
            return "Port must be between 1 and 65535.";

        var originalUniqueName = _editor.OriginalUniqueName?.Trim() ?? string.Empty;
        var conflict = InstanceCatalog.GetInstances().FirstOrDefault(instance =>
            instance.ServerPort == value &&
            !string.Equals(instance.UniqueName, originalUniqueName, StringComparison.OrdinalIgnoreCase));

        return conflict is null ? null : $"Port already used by instance '{conflict.UniqueName}'.";
    }

    private static string SlugifyForIdentifier(string source)
    {
        if (string.IsNullOrWhiteSpace(source))
            return string.Empty;

        var trimmed = source.Trim().ToLowerInvariant();
        var builder = new System.Text.StringBuilder(trimmed.Length);
        char lastAppended = '\0';

        foreach (var ch in trimmed)
        {
            char mapped;
            if (char.IsLetterOrDigit(ch))
            {
                mapped = ch;
            }
            else if (ch is '-' or '_' || char.IsWhiteSpace(ch))
            {
                mapped = '-';
            }
            else
            {
                continue;
            }

            if (mapped == '-' && lastAppended == '-')
                continue;

            builder.Append(mapped);
            lastAppended = mapped;
        }

        return builder.ToString().Trim('-');
    }

    private void Cancel()
    {
        MudDialog.Cancel();
    }

    private async Task SaveAsync()
    {
        await _form!.ValidateAsync();
        if (!_formIsValid)
            return;

        MudDialog.Close(DialogResult.Ok(_editor.Clone()));
    }

    private async Task OpenCreateConfigProfileDialogAsync()
    {
        var dialog = await DialogService.ShowAsync<ConfigProfileQuickCreateDialog>(
            "New Config Template",
            new DialogParameters(),
            new DialogOptions
            {
                CloseOnEscapeKey = true,
                FullWidth = true,
                MaxWidth = MaxWidth.Small,
            });

        var result = await dialog.Result;
        if (result is null || result.Canceled || result.Data is not QuasarConfigProfile template)
            return;

        _editor.ConfigProfileId = template.ConfigProfileId;
        await InvokeAsync(StateHasChanged);
    }

    private async Task OpenImportWorldTemplateDialogAsync()
    {
        var dialog = await DialogService.ShowAsync<WorldTemplateQuickImportDialog>(
            "Import World Template",
            new DialogParameters(),
            new DialogOptions
            {
                CloseOnEscapeKey = true,
                FullWidth = true,
                MaxWidth = MaxWidth.Medium,
            });

        var result = await dialog.Result;
        if (result is null || result.Canceled || result.Data is not QuasarWorldTemplate template)
            return;

        _editor.WorldTemplateId = template.WorldTemplateId;
        await InvokeAsync(StateHasChanged);
    }

    private Task HandleRestartPolicyExpandedChanged(bool expanded)
    {
        _restartPolicyExpanded = expanded;
        return Task.CompletedTask;
    }

    private Task HandleHealthPolicyExpandedChanged(bool expanded)
    {
        _healthPolicyExpanded = expanded;
        return Task.CompletedTask;
    }

    private Task HandleRuntimeExpandedChanged(bool expanded)
    {
        _runtimeExpanded = expanded;
        return Task.CompletedTask;
    }

    private string GetDefaultWorldPath()
    {
        var dsPath = string.IsNullOrWhiteSpace(_editor.DedicatedServerAppDataPath)
            ? GetDefaultDedicatedServerAppDataPath()
            : _editor.DedicatedServerAppDataPath;

        var worldName = GetUniqueNamePreview();

        foreach (var ch in Path.GetInvalidFileNameChars())
            worldName = worldName.Replace(ch, '-');

        return Path.Combine(dsPath, "Saves", worldName);
    }

    private string GetDefaultConfigFilePath()
    {
        var dsPath = string.IsNullOrWhiteSpace(_editor.DedicatedServerAppDataPath)
            ? GetDefaultDedicatedServerAppDataPath()
            : _editor.DedicatedServerAppDataPath;

        return Path.Combine(dsPath, "SpaceEngineers-Dedicated.cfg");
    }

    private string GetDefaultDedicatedServerAppDataPath()
    {
        return Path.Combine(GetDefaultInstanceDirectory(), "DedicatedServer");
    }

    private string GetDefaultMagnetarAppDataPath()
    {
        return Path.Combine(GetDefaultInstanceDirectory(), "Magnetar");
    }

    private string GetDefaultInstanceDirectory()
    {
        return Path.Combine(MagnetarPaths.GetQuasarInstancesDirectory(), GetUniqueNamePreview());
    }

    private string GetUniqueNamePreview()
    {
        return string.IsNullOrWhiteSpace(_editor.UniqueName)
            ? "<unique-name>"
            : _editor.UniqueName.Trim();
    }

    private string GetUniqueNameHelperText() =>
        UniqueNameLocked
            ? "Stop instance before renaming. Allowed: letters, numbers, underscore, hyphen. Used as canonical identity and Magnetars subdirectory name."
            : "Required. Allowed: letters, numbers, underscore, hyphen. Used as canonical identity and Magnetars subdirectory name.";

    private static string FormatPriority(DedicatedServerProcessPriority priority) => priority switch
    {
        DedicatedServerProcessPriority.Low => "Low",
        DedicatedServerProcessPriority.BelowNormal => "Below normal",
        DedicatedServerProcessPriority.AboveNormal => "Above normal",
        DedicatedServerProcessPriority.High => "High",
        _ => "Normal",
    };

    private string? ValidateUniqueNameField(string? value)
    {
        if (string.IsNullOrEmpty(value))
            return null;

        var trimmed = value.Trim();
        if (!UniqueNameRegex.IsMatch(trimmed))
            return "Only letters, numbers, underscore, and hyphen are allowed.";

        var originalUniqueName = _editor.OriginalUniqueName?.Trim() ?? string.Empty;
        var duplicateExists = InstanceCatalog.GetInstances().Any(instance =>
            string.Equals(instance.UniqueName, trimmed, StringComparison.OrdinalIgnoreCase) &&
            !string.Equals(instance.UniqueName, originalUniqueName, StringComparison.OrdinalIgnoreCase));

        return duplicateExists ? $"An instance named '{trimmed}' already exists." : null;
    }
}
