            DisplayName = _newModName.Trim(),
        });
        _editor.Mods = _editor.Mods
            .OrderBy(mod => mod.DisplayName, StringComparer.OrdinalIgnoreCase)
            .ThenBy(mod => mod.WorkshopId)
            .ToList();
        _newModName = string.Empty;
        _newModWorkshopId = 0;
    }

    private async Task RemoveDeadModsAsync()
    {
        if (_editor is null)
            return;

        if (_editor.Mods.Count == 0)
        {
            Snackbar.Add("No selected mods to check.", Severity.Info);
            return;
        }

        _deadModCleanupRunning = true;
        _deadModCleanupSummary = string.Empty;
        _deadModCleanupRemoved = [];

        try
        {
            var result = await WorkshopMods.CheckAvailabilityAsync(_editor.Mods);
            _deadModCleanupRemoved = result.UnavailableMods.ToList();

            if (_deadModCleanupRemoved.Count == 0)
            {
                _deadModCleanupSummary = $"Checked {result.CheckedCount} selected mod(s). No dead mods found.";
                Snackbar.Add("No dead mods found.", Severity.Info);
                return;
            }

            var unavailableIds = _deadModCleanupRemoved
                .Select(mod => mod.WorkshopId)
                .ToHashSet();

            _editor.Mods = _editor.Mods
                .Where(mod => !unavailableIds.Contains(mod.WorkshopId))
                .OrderBy(mod => mod.DisplayName, StringComparer.OrdinalIgnoreCase)
                .ThenBy(mod => mod.WorkshopId)
                .ToList();

            _deadModCleanupSummary =
                $"Removed {_deadModCleanupRemoved.Count} dead mod(s) from {result.CheckedCount} checked. Save the profile to persist the change.";
            Snackbar.Add($"Removed {_deadModCleanupRemoved.Count} dead mod(s). Save profile to persist.", Severity.Success);
        }
        catch (Exception exception)
        {
            _deadModCleanupSummary = $"Dead mod check failed: {exception.Message}";
            Snackbar.Add(_deadModCleanupSummary, Severity.Error);
        }
        finally
        {
            _deadModCleanupRunning = false;
            await InvokeAsync(StateHasChanged);
        }
    }

