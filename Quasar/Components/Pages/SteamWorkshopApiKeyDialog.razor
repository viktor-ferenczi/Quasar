@using MudBlazor

<MudDialog>
    <DialogContent>
        <MudStack Spacing="2">
            <MudText Typo="Typo.body2">
                Store the Steam Web API key used by Quasar server-side for Workshop search.
            </MudText>
            <MudAlert Severity="Severity.Info" Variant="Variant.Outlined" Dense="true">
                <MudStack Spacing="1">
                    <MudText Typo="Typo.body2">Generate or find the key on Steam's developer page.</MudText>
                    <MudLink Href="https://steamcommunity.com/dev/apikey"
                             Target="_blank"
                             Underline="Underline.Always"
                             Color="Color.Primary"
                             Typo="Typo.subtitle1"
                             Style="font-weight: 700;">
                        Open Steam Web API key page
                    </MudLink>
                </MudStack>
            </MudAlert>
            <MudText Typo="Typo.body2" Color="Color.Secondary">
                @StorageProtectionDescription
            </MudText>
            <MudTextField
                @bind-Value="_webApiKey"
                Label="Steam Web API key"
                Variant="Variant.Outlined"
                InputType="InputType.Password"
                Immediate="true"
                Adornment="Adornment.Start"
                AdornmentIcon="@Icons.Material.Filled.Key" />
        </MudStack>
    </DialogContent>
    <DialogActions>
        <MudButton Variant="Variant.Text" Color="Color.Default" OnClick="Cancel">Cancel</MudButton>
        <MudButton Variant="Variant.Filled" Color="Color.Primary" OnClick="Save" Disabled="@string.IsNullOrWhiteSpace(_webApiKey)">Save</MudButton>
    </DialogActions>
</MudDialog>

@code
{
    [CascadingParameter]
    private IMudDialogInstance MudDialog { get; set; } = default!;

    [Parameter]
    public string CurrentWebApiKey { get; set; } = string.Empty;

    private string _webApiKey = string.Empty;

    private static string StorageProtectionDescription =>
        $"After saving, Quasar stores an encrypted value in {System.IO.Path.GetFileName(MagnetarPaths.GetQuasarWorkshopOptionsPath())} under {GetPlatformStorageLocation()}. " +
        "It can be decrypted only by this Quasar installation while its local Data Protection keyring is intact. " +
        GetPlatformFileProtectionDescription();

    protected override void OnInitialized()
    {
        _webApiKey = CurrentWebApiKey;
    }

    private void Cancel()
    {
        MudDialog.Cancel();
    }

    private void Save()
    {
        var key = _webApiKey.Trim();
        if (string.IsNullOrWhiteSpace(key))
            return;

        MudDialog.Close(DialogResult.Ok(key));
    }

    private static string GetPlatformStorageLocation()
    {
        if (OperatingSystem.IsWindows())
            return "the Quasar install directory, or QUASAR_DATA_DIR when that override is set";

        if (OperatingSystem.IsLinux() || OperatingSystem.IsMacOS())
            return "the Quasar install directory, or QUASAR_DATA_DIR when that override is set";

        return "the Quasar data directory, or QUASAR_DATA_DIR when that override is set";
    }

    private static string GetPlatformFileProtectionDescription()
    {
        if (OperatingSystem.IsWindows())
            return "Windows access is controlled by the current account's profile ACLs.";

        if (OperatingSystem.IsLinux() || OperatingSystem.IsMacOS())
            return "On this platform Quasar also restricts the credentials file to owner read/write permissions (0600) when the filesystem supports it.";

        return "Restrict access to the Quasar data directory with the host operating system's file permissions.";
    }
}
