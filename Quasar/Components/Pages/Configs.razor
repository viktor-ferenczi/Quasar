    private static string FilterNumericListInput(string? value) =>
        value is null ? string.Empty : new string(value.Where(c => char.IsDigit(c) || c is ',' or ';' or ' ' or '\n' or '\r' or '\t').ToArray());

    private static bool MatchesSearchTerms(string searchText, params string[] values)
    {
        if (string.IsNullOrWhiteSpace(searchText))
            return true;

        var blob = string.Join(' ', values.Where(value => !string.IsNullOrWhiteSpace(value)));
        return searchText
            .Split(' ', StringSplitOptions.RemoveEmptyEntries | StringSplitOptions.TrimEntries)
            .All(term => blob.Contains(term, StringComparison.OrdinalIgnoreCase));
    }

    private List<ulong> ParseUnsignedLongList(string? value, string label)
    {
        var valid = new List<ulong>();
        var invalid = new List<string>();

        foreach (var token in SplitListTokens(value))
        {
            if (ulong.TryParse(token, out var parsed) && parsed > 0)
            {
                valid.Add(parsed);
                continue;
            }

            invalid.Add(token);
        }

        if (invalid.Count > 0)
            Snackbar.Add($"Ignored invalid {label} ID values: {string.Join(", ", invalid.Take(3))}{(invalid.Count > 3 ? "..." : string.Empty)}", Severity.Warning);

        return valid
            .Distinct()
            .OrderBy(item => item)
            .ToList();
    }

    private static List<string> SplitListTokens(string? value)
    {
        if (string.IsNullOrWhiteSpace(value))
            return [];

        return value
            .Split([',', ';', '\r', '\n', '\t', ' '], StringSplitOptions.RemoveEmptyEntries | StringSplitOptions.TrimEntries)
            .Where(token => !string.IsNullOrWhiteSpace(token))
            .ToList();
    }

    private static string SummarizeWarnings(IReadOnlyList<string> warnings)
    {
        var preview = warnings.Take(2).ToList();
        var summary = string.Join(" ", preview);
        if (warnings.Count > preview.Count)
            summary = $"{summary} (+{warnings.Count - preview.Count} more)";

        return summary;
    }

    private static int ToIntOrDefault(double? value, int fallback) =>
        value is null ? fallback : Convert.ToInt32(value.Value);

    private static double ToDoubleOrDefault(double? value, double fallback) =>
        value ?? fallback;
}
