    private async Task BrowseBackupDirectoryAsync()
    {
        var dialog = await DialogService.ShowAsync<FolderPickerDialog>(
            "Pick backup folder",
            new DialogParameters
            {
                [nameof(FolderPickerDialog.InitialPath)] = GetBackupDirectoryBrowseInitialPath(),
                [nameof(FolderPickerDialog.DialogTitle)] = "Pick backup folder",
                [nameof(FolderPickerDialog.RequireWorldFolder)] = false,
                [nameof(FolderPickerDialog.AdditionalShortcuts)] = GetBackupDirectoryShortcuts(),
            },
            new DialogOptions { CloseOnEscapeKey = true, MaxWidth = MaxWidth.Medium, FullWidth = true });

        var result = await dialog.Result;
        if (result is { Canceled: false, Data: string path })
            _backupDirectoryDraft = path;
    }

    private async Task UseDefaultBackupDirectoryAsync()
