@page "/backup"
@attribute [Authorize(Policy = QuasarPolicyNames.CanManageSecurity)]
@using Quasar.Services.Backup
@implements IDisposable
@inject QuasarBackupService BackupService
@inject QuasarBackupSettingsService BackupSettingsService
@inject AutomaticBackupService AutomaticBackup
@inject DedicatedServerCatalog ServerCatalog
@inject WebServiceOptions WebServiceOptions
@inject ISnackbar Snackbar
@inject IDialogService DialogService

<PageTitle>Backup</PageTitle>

<MudText Typo="Typo.h5" Class="mb-2">Backup</MudText>
<MudText Typo="Typo.body2" Class="mb-4">
    Save and restore all of Quasar's own configuration as a single ZIP file, stamped with the
    Quasar version it was taken from (currently <strong>@WebServiceOptions.Version</strong>).
</MudText>

<MudGrid>
    <MudItem xs="12" md="6">
        <MudPaper Class="pa-4" Style="height:100%">
            <MudStack Spacing="3">
                <MudText Typo="Typo.h6">Create &amp; restore</MudText>
                <MudText Typo="Typo.body2">
                    A backup contains all Quasar configurations (server configs, Config profiles, world
                    templates, Discord, branding, players, security/RBAC and more). <b>No world state is
                        backed up. Please use the world backup below for save files, and the server backup for
                        non-cache Dedicated Server and Magnetar app data.</b>
                </MudText>

                <MudButton Href="/api/backup/download"
                           Variant="Variant.Filled"
                           Color="Color.Primary"
                           StartIcon="@Icons.Material.Filled.Download">
                    Back up Quasar configuration to file
                </MudButton>

                <MudDivider />

                <MudText Typo="Typo.subtitle2">Restore</MudText>
                <MudText Typo="Typo.body2">
                    Restoring <strong>merges</strong> the configuration backup into the current configuration:
                    items are matched by ID, so configs, templates and servers with new IDs are added while
                    matching IDs are overwritten. For a clean restore, delete Quasar's configs first, then restore.
                    Restoring the configuration does not change game data. You can restore the servers one by one.
                </MudText>
                <MudFileUpload T="IBrowserFile" Accept=".zip" FilesChanged="RestoreFromUploadAsync" Disabled="_busy">
                    <CustomContent Context="upload">
                        <MudButton Variant="Variant.Outlined"
                                   StartIcon="@Icons.Material.Filled.Restore"
                                   Disabled="_busy"
                                   OnClick="@(() => upload.OpenFilePickerAsync())">
                            Restore Quasar configuration from file…
                        </MudButton>
                    </CustomContent>
                </MudFileUpload>

                @if (_lastReport is not null)
                {
                    <MudAlert Severity="@(_lastReport.Success ? Severity.Success : Severity.Error)" Dense="true">
                        @_lastReport.Message
                        @if (_lastReport.Success && _lastReport.RestartRecommended)
                        {
                            <text> Restart Quasar to be sure every component reloads.</text>
                        }
                    </MudAlert>
                }
            </MudStack>
        </MudPaper>
    </MudItem>

    <MudItem xs="12" md="6">
        <MudPaper Class="pa-4" Style="height:100%">
            <MudStack Spacing="2">
                <MudText Typo="Typo.h6">Version compatibility</MudText>
                <MudText Typo="Typo.body2">
                    Backups follow semantic versioning:
                </MudText>
                <MudList T="string" Dense="true" Class="pl-2">
                    <MudListItem T="string" Icon="@Icons.Material.Filled.CheckCircle" IconColor="Color.Success">
                        Same major.minor version restores in full; patch versions are compatible both ways.
                    </MudListItem>
                    <MudListItem T="string" Icon="@Icons.Material.Filled.Upgrade" IconColor="Color.Info">
                        Older backups are upgraded through a forward migration path when one is available.
                    </MudListItem>
                    <MudListItem T="string" Icon="@Icons.Material.Filled.Block" IconColor="Color.Error">
                        Restoring a backup from a newer major.minor version is not supported (no downgrade).
                    </MudListItem>
                </MudList>
                <MudText Typo="Typo.caption">
                    Note: data-protection keys are not included, so a restored Steam Workshop API key must be
                    re-entered when moving the backup to a different machine.
                </MudText>
            </MudStack>
        </MudPaper>
    </MudItem>

    <MudItem xs="12">
        <MudPaper Class="pa-4">
            <MudStack Spacing="3">
                <MudText Typo="Typo.h6">Server &amp; world backups</MudText>
                <MudText Typo="Typo.body2">
                    Server backups include Quasar's server definition plus non-cache Dedicated Server and Magnetar app
                    data. World backups restore only world files and keep the current server/world config intact. World
                    backups can be taken while a server is running; when Space Engineers has a world <code>Backup</code>
                    folder, Quasar uses the latest valid snapshot from it.
                </MudText>

                @if (_servers.Count == 0)
                {
                    <MudAlert Severity="Severity.Info" Variant="Variant.Outlined">No servers configured yet.</MudAlert>
                }
                else
                {
                    <MudTable Items="_servers" Hover="true" Dense="true">
                        <HeaderContent>
                            <MudTh><MudTableSortLabel SortBy="new Func<DedicatedServerDefinition, object>(x => x.DisplayName)">Server</MudTableSortLabel></MudTh>
                            <MudTh><MudTableSortLabel SortBy="new Func<DedicatedServerDefinition, object>(x => x.UniqueName)">Unique name</MudTableSortLabel></MudTh>
                            <MudTh Style="text-align:right">Actions</MudTh>
                        </HeaderContent>
                        <RowTemplate>
                            @{
                                var latestServerBackup = FindLatestBackup(context.UniqueName, QuasarBackupKind.Server);
                                var latestWorldBackup = FindLatestBackup(context.UniqueName, QuasarBackupKind.World);
                            }
                            <MudTd DataLabel="Server">@context.DisplayName</MudTd>
                            <MudTd DataLabel="Unique name"><code>@context.UniqueName</code></MudTd>
                            <MudTd Style="text-align:right">
                                <MudStack Row="true" Wrap="Wrap.Wrap" Spacing="1" Justify="Justify.FlexEnd">
                                    <MudButton Variant="Variant.Filled"
                                               Color="Color.Primary"
                                               Size="Size.Small"
                                               StartIcon="@Icons.Material.Filled.Inventory2"
                                               OnClick="@(() => MakeServerBackupNowAsync(context.UniqueName))"
                                               Disabled="_busy">
                                        Back up server
                                    </MudButton>
                                    <MudButton Variant="Variant.Outlined"
                                               Color="Color.Primary"
                                               Size="Size.Small"
                                               StartIcon="@Icons.Material.Filled.Restore"
                                               OnClick="@(() => RestoreLatestServerBackupAsync(context.UniqueName))"
                                               Disabled="@(_busy || latestServerBackup is null)">
                                        Restore server
                                    </MudButton>
                                    <MudButton Variant="Variant.Filled"
                                               Color="Color.Secondary"
                                               Size="Size.Small"
                                               StartIcon="@Icons.Material.Filled.Public"
                                               OnClick="@(() => MakeWorldBackupNowAsync(context.UniqueName))"
                                               Disabled="_busy">
                                        Back up world
                                    </MudButton>
                                    <MudButton Variant="Variant.Outlined"
                                               Color="Color.Secondary"
                                               Size="Size.Small"
                                               StartIcon="@Icons.Material.Filled.RestorePage"
                                               OnClick="@(() => RestoreLatestWorldBackupAsync(context.UniqueName))"
                                               Disabled="@(_busy || latestWorldBackup is null)">
                                        Restore world
                                    </MudButton>
                                </MudStack>
                            </MudTd>
                        </RowTemplate>
                    </MudTable>
                }

                <MudDivider />

                <MudText Typo="Typo.h6">Automatic backups</MudText>
                <MudText Typo="Typo.body2">
                    Configure independent automatic backup rules. Server and world rules run for every configured
                    server and prune retained backups per server.
                </MudText>

                <MudExpansionPanels MultiExpansion="true">
                    <MudExpansionPanel Text="Quasar config" Expanded="@_settings.Configuration.Enabled">
                        <MudStack Spacing="3">
                            <MudSwitch @bind-Value="_settings.Configuration.Enabled" Color="Color.Primary" Label="Enable Quasar config backups" />
                            <MudGrid>
                                <MudItem xs="12" sm="6" md="3">
                                    <MudSelect T="BackupFrequency" @bind-Value="_settings.Configuration.Frequency" Label="Frequency"
                                               Variant="Variant.Outlined" Disabled="!_settings.Configuration.Enabled">
                                        <MudSelectItem T="BackupFrequency" Value="BackupFrequency.Hourly">Hourly</MudSelectItem>
                                        <MudSelectItem T="BackupFrequency" Value="BackupFrequency.Daily">Daily</MudSelectItem>
                                        <MudSelectItem T="BackupFrequency" Value="BackupFrequency.Weekly">Weekly</MudSelectItem>
                                    </MudSelect>
                                </MudItem>
                                @if (_settings.Configuration.Frequency != BackupFrequency.Hourly)
                                {
                                    <MudItem xs="12" sm="6" md="3">
                                        <MudTimePicker Label="Time of day" @bind-Time="_configurationTimeOfDay"
                                                       Variant="Variant.Outlined" Disabled="!_settings.Configuration.Enabled" />
                                    </MudItem>
                                }
                                @if (_settings.Configuration.Frequency == BackupFrequency.Weekly)
                                {
                                    <MudItem xs="12" sm="6" md="3">
                                        <MudSelect T="DayOfWeek" @bind-Value="_settings.Configuration.DayOfWeek" Label="Day of week"
                                                   Variant="Variant.Outlined" Disabled="!_settings.Configuration.Enabled">
                                            @foreach (var day in Enum.GetValues<DayOfWeek>())
                                            {
                                                <MudSelectItem T="DayOfWeek" Value="day">@day</MudSelectItem>
                                            }
                                        </MudSelect>
                                    </MudItem>
                                }
                                <MudItem xs="12" sm="6" md="3">
                                    <MudNumericField T="int" @bind-Value="_settings.Configuration.RetentionCount" Label="Keep last N backups"
                                                     Min="QuasarBackupSettings.MinRetentionCount"
                                                     Max="QuasarBackupSettings.MaxRetentionCount"
                                                     Variant="Variant.Outlined" Disabled="!_settings.Configuration.Enabled" />
                                </MudItem>
                            </MudGrid>
                        </MudStack>
                    </MudExpansionPanel>

                    <MudExpansionPanel Text="Servers" Expanded="@_settings.Server.Enabled">
                        <MudStack Spacing="3">
                            <MudSwitch @bind-Value="_settings.Server.Enabled" Color="Color.Primary" Label="Enable server backups" />
                            <MudGrid>
                                <MudItem xs="12" sm="6" md="3">
                                    <MudSelect T="BackupFrequency" @bind-Value="_settings.Server.Frequency" Label="Frequency"
                                               Variant="Variant.Outlined" Disabled="!_settings.Server.Enabled">
                                        <MudSelectItem T="BackupFrequency" Value="BackupFrequency.Hourly">Hourly</MudSelectItem>
                                        <MudSelectItem T="BackupFrequency" Value="BackupFrequency.Daily">Daily</MudSelectItem>
                                        <MudSelectItem T="BackupFrequency" Value="BackupFrequency.Weekly">Weekly</MudSelectItem>
                                    </MudSelect>
                                </MudItem>
                                @if (_settings.Server.Frequency != BackupFrequency.Hourly)
                                {
                                    <MudItem xs="12" sm="6" md="3">
                                        <MudTimePicker Label="Time of day" @bind-Time="_serverTimeOfDay"
                                                       Variant="Variant.Outlined" Disabled="!_settings.Server.Enabled" />
                                    </MudItem>
                                }
                                @if (_settings.Server.Frequency == BackupFrequency.Weekly)
                                {
                                    <MudItem xs="12" sm="6" md="3">
                                        <MudSelect T="DayOfWeek" @bind-Value="_settings.Server.DayOfWeek" Label="Day of week"
                                                   Variant="Variant.Outlined" Disabled="!_settings.Server.Enabled">
                                            @foreach (var day in Enum.GetValues<DayOfWeek>())
                                            {
                                                <MudSelectItem T="DayOfWeek" Value="day">@day</MudSelectItem>
                                            }
                                        </MudSelect>
                                    </MudItem>
                                }
                                <MudItem xs="12" sm="6" md="3">
                                    <MudNumericField T="int" @bind-Value="_settings.Server.RetentionCount" Label="Keep last N per server"
                                                     Min="QuasarBackupSettings.MinRetentionCount"
                                                     Max="QuasarBackupSettings.MaxRetentionCount"
                                                     Variant="Variant.Outlined" Disabled="!_settings.Server.Enabled" />
                                </MudItem>
                            </MudGrid>
                        </MudStack>
                    </MudExpansionPanel>

                    <MudExpansionPanel Text="Worlds" Expanded="@_settings.World.Enabled">
                        <MudStack Spacing="3">
                            <MudSwitch @bind-Value="_settings.World.Enabled" Color="Color.Primary" Label="Enable world backups" />
                            <MudGrid>
                                <MudItem xs="12" sm="6" md="3">
                                    <MudSelect T="BackupFrequency" @bind-Value="_settings.World.Frequency" Label="Frequency"
                                               Variant="Variant.Outlined" Disabled="!_settings.World.Enabled">
                                        <MudSelectItem T="BackupFrequency" Value="BackupFrequency.Hourly">Hourly</MudSelectItem>
                                        <MudSelectItem T="BackupFrequency" Value="BackupFrequency.Daily">Daily</MudSelectItem>
                                        <MudSelectItem T="BackupFrequency" Value="BackupFrequency.Weekly">Weekly</MudSelectItem>
                                    </MudSelect>
                                </MudItem>
                                @if (_settings.World.Frequency != BackupFrequency.Hourly)
                                {
                                    <MudItem xs="12" sm="6" md="3">
                                        <MudTimePicker Label="Time of day" @bind-Time="_worldTimeOfDay"
                                                       Variant="Variant.Outlined" Disabled="!_settings.World.Enabled" />
                                    </MudItem>
                                }
                                @if (_settings.World.Frequency == BackupFrequency.Weekly)
                                {
                                    <MudItem xs="12" sm="6" md="3">
                                        <MudSelect T="DayOfWeek" @bind-Value="_settings.World.DayOfWeek" Label="Day of week"
                                                   Variant="Variant.Outlined" Disabled="!_settings.World.Enabled">
                                            @foreach (var day in Enum.GetValues<DayOfWeek>())
                                            {
                                                <MudSelectItem T="DayOfWeek" Value="day">@day</MudSelectItem>
                                            }
                                        </MudSelect>
                                    </MudItem>
                                }
                                <MudItem xs="12" sm="6" md="3">
                                    <MudNumericField T="int" @bind-Value="_settings.World.RetentionCount" Label="Keep last N per server"
                                                     Min="QuasarBackupSettings.MinRetentionCount"
                                                     Max="QuasarBackupSettings.MaxRetentionCount"
                                                     Variant="Variant.Outlined" Disabled="!_settings.World.Enabled" />
                                </MudItem>
                            </MudGrid>
                        </MudStack>
                    </MudExpansionPanel>
                </MudExpansionPanels>

                <MudStack Row="true" Spacing="2">
                    <MudButton Variant="Variant.Filled" Color="Color.Primary"
                               StartIcon="@Icons.Material.Filled.Save" OnClick="SaveSettingsAsync" Disabled="_busy">
                        Save rules
                    </MudButton>
                    <MudButton Variant="Variant.Outlined" Color="Color.Primary"
                               StartIcon="@Icons.Material.Filled.BackupTable" OnClick="MakeBackupNowAsync" Disabled="_busy">
                        Run enabled rules now
                    </MudButton>
                </MudStack>
            </MudStack>
        </MudPaper>
    </MudItem>

    <MudItem xs="12">
        <MudPaper Class="pa-4">
            <MudStack Spacing="2">
                <MudText Typo="Typo.h6">Stored backups</MudText>
                @if (_backups.Count == 0)
                {
                    <MudText Typo="Typo.body2">No backups in the Backups folder yet.</MudText>
                }
                else
                {
                    <MudTable Items="_backups" Hover="true" Dense="true">
                        <HeaderContent>
                            <MudTh Style="width:1px; white-space:nowrap">Actions</MudTh>
                            <MudTh Style="width:1px; white-space:nowrap"><MudTableSortLabel InitialDirection="SortDirection.Descending" SortBy="new Func<QuasarBackupFileInfo, object>(x => x.CreatedAtUtc)">Created</MudTableSortLabel></MudTh>
                            <MudTh Style="width:1px; white-space:nowrap"><MudTableSortLabel SortBy="new Func<QuasarBackupFileInfo, object>(x => FormatBackupType(x))">Type</MudTableSortLabel></MudTh>
                            <MudTh Style="width:1px; white-space:nowrap"><MudTableSortLabel SortBy="new Func<QuasarBackupFileInfo, object>(x => x.ServerDisplayName ?? x.ServerUniqueName ?? string.Empty)">Server</MudTableSortLabel></MudTh>
                            <MudTh Style="width:1px; white-space:nowrap"><MudTableSortLabel SortBy="new Func<QuasarBackupFileInfo, object>(x => x.SizeBytes)">Size</MudTableSortLabel></MudTh>
                            <MudTh Style="width:100%"><MudTableSortLabel SortBy="new Func<QuasarBackupFileInfo, object>(x => x.Name)">Name</MudTableSortLabel></MudTh>
                        </HeaderContent>
                        <RowTemplate>
                            <MudTd DataLabel="Actions" Style="width:1px; white-space:nowrap">
                                <MudTooltip Text="Download">
                                    <MudIconButton Icon="@Icons.Material.Filled.Download"
                                                   Href="@($"/api/backup/download/{context.Name}")"
                                                   Size="Size.Small" />
                                </MudTooltip>
                                <MudTooltip Text="Restore">
                                    <MudIconButton Icon="@Icons.Material.Filled.Restore"
                                                   OnClick="@(() => RestoreFromStoredAsync(context))"
                                                   Disabled="_busy" Size="Size.Small" />
                                </MudTooltip>
                                <MudTooltip Text="Delete">
                                    <MudIconButton Icon="@Icons.Material.Filled.Delete"
                                                   OnClick="@(() => DeleteAsync(context.Name))"
                                                   Disabled="_busy" Size="Size.Small" Color="Color.Error" />
                                </MudTooltip>
                            </MudTd>
                            <MudTd DataLabel="Created" Style="width:1px; white-space:nowrap">@context.CreatedAtUtc.ToLocalTime().ToString("yyyy-MM-dd HH:mm")</MudTd>
                            <MudTd DataLabel="Type" Style="width:1px; white-space:nowrap">@FormatBackupType(context)</MudTd>
                            <MudTd DataLabel="Server" Style="width:1px; white-space:nowrap">@(context.ServerDisplayName ?? context.ServerUniqueName ?? "-")</MudTd>
                            <MudTd DataLabel="Size" Style="width:1px; white-space:nowrap">@FormatSize(context.SizeBytes)</MudTd>
                            <MudTd DataLabel="Name" Style="width:100%">@context.Name</MudTd>
                        </RowTemplate>
                    </MudTable>
                }
            </MudStack>
        </MudPaper>
    </MudItem>
</MudGrid>

@code {
    private const long MaxUploadBytes = 10L * 1024 * 1024 * 1024;

    private QuasarBackupSettings _settings = new();
    private TimeSpan? _configurationTimeOfDay;
    private TimeSpan? _serverTimeOfDay;
    private TimeSpan? _worldTimeOfDay;
    private IReadOnlyList<QuasarBackupFileInfo> _backups = [];
    private IReadOnlyList<DedicatedServerDefinition> _servers = [];
    private QuasarRestoreReport? _lastReport;
    private bool _busy;

    protected override void OnInitialized()
    {
        LoadSettingsDraft();
        RefreshServers();
        RefreshBackups();
        BackupSettingsService.Changed += OnSettingsChanged;
        ServerCatalog.Changed += OnServersChanged;
        BackupService.Changed += OnBackupsChanged;
        AutomaticBackup.QueuedBackupCompleted += OnQueuedBackupCompleted;
    }

    public void Dispose()
    {
        BackupSettingsService.Changed -= OnSettingsChanged;
        ServerCatalog.Changed -= OnServersChanged;
        BackupService.Changed -= OnBackupsChanged;
        AutomaticBackup.QueuedBackupCompleted -= OnQueuedBackupCompleted;
    }

    private void LoadSettingsDraft()
    {
        _settings = BackupSettingsService.GetSettings();
        _configurationTimeOfDay = _settings.Configuration.TimeOfDay.ToTimeSpan();
        _serverTimeOfDay = _settings.Server.TimeOfDay.ToTimeSpan();
        _worldTimeOfDay = _settings.World.TimeOfDay.ToTimeSpan();
    }

    private void RefreshBackups() => _backups = BackupService.ListBackups()
        .OrderByDescending(backup => backup.CreatedAtUtc)
        .ThenBy(backup => backup.Name, StringComparer.OrdinalIgnoreCase)
        .ToList();

    private void RefreshServers()
    {
        _servers = ServerCatalog.GetServers()
            .OrderBy(server => server.DisplayName, StringComparer.OrdinalIgnoreCase)
            .ThenBy(server => server.UniqueName, StringComparer.OrdinalIgnoreCase)
            .ToList();
    }

    private void OnSettingsChanged() => InvokeAsync(() =>
    {
        RefreshBackups();
        StateHasChanged();
    });

    private void OnServersChanged() => InvokeAsync(() =>
    {
        RefreshServers();
        StateHasChanged();
    });

    private void OnBackupsChanged() => InvokeAsync(() =>
    {
        RefreshBackups();
        StateHasChanged();
    });

    private void OnQueuedBackupCompleted(QueuedBackupJobResult result) => InvokeAsync(() =>
    {
        RefreshBackups();
        Snackbar.Add(result.Message, result.Success ? Severity.Success : Severity.Error);
        StateHasChanged();
    });

    private async Task SaveSettingsAsync()
    {
        _settings.Configuration.TimeOfDay = _configurationTimeOfDay is { } configurationTime
            ? TimeOnly.FromTimeSpan(configurationTime)
            : new TimeOnly(3, 0);
        _settings.Server.TimeOfDay = _serverTimeOfDay is { } serverTime
            ? TimeOnly.FromTimeSpan(serverTime)
            : new TimeOnly(3, 0);
        _settings.World.TimeOfDay = _worldTimeOfDay is { } worldTime
            ? TimeOnly.FromTimeSpan(worldTime)
            : new TimeOnly(3, 0);

        _busy = true;
        try
        {
            await BackupSettingsService.SaveAsync(_settings);
            Snackbar.Add("Backup rules saved.", Severity.Success);
        }
        catch (Exception exception)
        {
            Snackbar.Add($"Failed to save schedule: {exception.Message}", Severity.Error);
        }
        finally
        {
            _busy = false;
        }
    }

    private void MakeBackupNowAsync()
    {
        try
        {
            AutomaticBackup.QueueEnabledBackupsNow();
            Snackbar.Add("Enabled backup rules queued.", Severity.Info);
        }
        catch (Exception exception)
        {
            Snackbar.Add($"Failed to queue automatic backup: {exception.Message}", Severity.Error);
        }
    }

    private void MakeServerBackupNowAsync(string uniqueName)
    {
        if (string.IsNullOrWhiteSpace(uniqueName))
            return;

        try
        {
            AutomaticBackup.QueueServerBackup(uniqueName);
            Snackbar.Add("Server backup queued.", Severity.Info);
        }
        catch (Exception exception)
        {
            Snackbar.Add($"Failed to queue server backup: {exception.Message}", Severity.Error);
        }
    }

    private void MakeWorldBackupNowAsync(string uniqueName)
    {
        if (string.IsNullOrWhiteSpace(uniqueName))
            return;

        try
        {
            AutomaticBackup.QueueWorldBackup(uniqueName);
            Snackbar.Add("World backup queued.", Severity.Info);
        }
        catch (Exception exception)
        {
            Snackbar.Add($"Failed to queue world backup: {exception.Message}", Severity.Error);
        }
    }

    private Task RestoreLatestServerBackupAsync(string uniqueName) =>
        RestoreLatestBackupAsync(uniqueName, QuasarBackupKind.Server);

    private Task RestoreLatestWorldBackupAsync(string uniqueName) =>
        RestoreLatestBackupAsync(uniqueName, QuasarBackupKind.World);

    private async Task RestoreLatestBackupAsync(string uniqueName, QuasarBackupKind kind)
    {
        var backup = FindLatestBackup(uniqueName, kind);
        if (backup is null)
        {
            Snackbar.Add($"No {FormatBackupKind(kind).ToLowerInvariant()} backup exists for that server.", Severity.Info);
            return;
        }

        await RestoreFromStoredAsync(backup);
    }

    private async Task RestoreFromUploadAsync(IBrowserFile? file)
    {
        if (file is null || !await ConfirmRestoreAsync())
            return;

        _busy = true;
        try
        {
            await using var stream = file.OpenReadStream(MaxUploadBytes);
            _lastReport = await BackupService.RestoreAsync(stream);
            ReportRestore();
        }
        catch (Exception exception)
        {
            Snackbar.Add($"Restore failed: {exception.Message}", Severity.Error);
        }
        finally
        {
            _busy = false;
        }
    }

    private async Task RestoreFromStoredAsync(QuasarBackupFileInfo backup)
    {
        if (!await ConfirmRestoreAsync(backup))
            return;

        _busy = true;
        try
        {
            _lastReport = await BackupService.RestoreFromFileAsync(backup.Name);
            ReportRestore();
        }
        catch (Exception exception)
        {
            Snackbar.Add($"Restore failed: {exception.Message}", Severity.Error);
        }
        finally
        {
            _busy = false;
        }
    }

    private async Task DeleteAsync(string name)
    {
        var confirmed = await DialogService.ShowMessageBoxAsync(
            "Delete backup?",
            $"Permanently delete '{name}'?",
            yesText: "Delete",
            cancelText: "Cancel");
        if (confirmed != true)
            return;

        try
        {
            BackupService.DeleteBackup(name);
            RefreshBackups();
            Snackbar.Add("Backup deleted.", Severity.Success);
        }
        catch (Exception exception)
        {
            Snackbar.Add($"Failed to delete backup: {exception.Message}", Severity.Error);
        }
    }

    private async Task<bool> ConfirmRestoreAsync()
    {
        var confirmed = await DialogService.ShowMessageBoxAsync(
            "Restore backup?",
            "This restores the selected ZIP according to its backup type. Configuration backups merge by ID; server and world backups overwrite files for their target server. Continue?",
            yesText: "Restore",
            cancelText: "Cancel");
        return confirmed == true;
    }

    private async Task<bool> ConfirmRestoreAsync(QuasarBackupFileInfo backup)
    {
        var message = backup.Kind switch
        {
            QuasarBackupKind.Server =>
                $"This overwrites server files, world files and config for '{backup.ServerDisplayName ?? backup.ServerUniqueName ?? backup.Name}'. Continue?",
            QuasarBackupKind.World =>
                $"This overwrites world files for '{backup.ServerDisplayName ?? backup.ServerUniqueName ?? backup.Name}' but keeps existing config. Continue?",
            _ =>
                "This overwrites Quasar settings that share an ID with the backup. Items with different IDs are kept (merge). Continue?",
        };

        var confirmed = await DialogService.ShowMessageBoxAsync(
            "Restore backup?",
            message,
            yesText: "Restore",
            cancelText: "Cancel");
        return confirmed == true;
    }

    private void ReportRestore()
    {
        RefreshBackups();
        if (_lastReport is null)
            return;

        Snackbar.Add(_lastReport.Message, _lastReport.Success ? Severity.Success : Severity.Error);
    }

    private static string FormatSize(long bytes)
    {
        string[] units = ["B", "KB", "MB", "GB"];
        double size = bytes;
        var unit = 0;
        while (size >= 1024 && unit < units.Length - 1)
        {
            size /= 1024;
            unit++;
        }

        return $"{size:0.#} {units[unit]}";
    }

    private static string FormatBackupType(QuasarBackupFileInfo backup)
    {
        var kind = FormatBackupKind(backup.Kind);
        return backup.Automatic ? $"{kind} (auto)" : kind;
    }

    private static string FormatBackupKind(QuasarBackupKind kind) =>
        kind switch
        {
            QuasarBackupKind.Server => "Server",
            QuasarBackupKind.World => "World",
            _ => "Quasar config",
        };

    private QuasarBackupFileInfo? FindLatestBackup(string uniqueName, QuasarBackupKind kind) =>
        _backups
            .Where(backup => backup.Kind == kind &&
                             string.Equals(backup.ServerUniqueName, uniqueName, StringComparison.OrdinalIgnoreCase))
            .OrderByDescending(backup => backup.CreatedAtUtc)
            .ThenBy(backup => backup.Name, StringComparer.OrdinalIgnoreCase)
            .FirstOrDefault();
}
