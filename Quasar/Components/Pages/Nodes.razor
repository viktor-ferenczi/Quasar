@page "/nodes"
@implements IDisposable
@inject AgentRegistry Registry

<PageTitle>Nodes</PageTitle>

<MudText Typo="Typo.h4" GutterBottom="true">Nodes</MudText>
<MudText Typo="Typo.body2" Class="mb-4">Each node can host many server and plugin instances behind one shared Quasar supervisor endpoint.</MudText>

<MudTable T="NodeRow" Dense="true" Hover="true" Items="NodeRows">
    <HeaderContent>
        <MudTh>Node</MudTh>
        <MudTh>Servers</MudTh>
        <MudTh>Connected Agents</MudTh>
        <MudTh>Players</MudTh>
    </HeaderContent>
    <RowTemplate>
        <MudTd DataLabel="Node">@context.NodeName</MudTd>
        <MudTd DataLabel="Servers">@context.ServerCount</MudTd>
        <MudTd DataLabel="Connected Agents">@context.ConnectedAgents</MudTd>
        <MudTd DataLabel="Players">@context.PlayersOnline</MudTd>
    </RowTemplate>
</MudTable>

@code
{
    private IReadOnlyList<NodeRow> NodeRows => Registry
        .GetAgents()
        .GroupBy(agent => agent.NodeKey, StringComparer.OrdinalIgnoreCase)
        .Select(group => new NodeRow
        {
            NodeName = group.First().NodeDisplayName,
            ServerCount = group.Select(agent => agent.ServerKey).Distinct(StringComparer.OrdinalIgnoreCase).Count(),
            ConnectedAgents = group.Count(agent => agent.IsConnected),
            PlayersOnline = group.Sum(agent => agent.Snapshot?.Metrics.PlayersOnline ?? 0),
        })
        .OrderBy(row => row.NodeName, StringComparer.OrdinalIgnoreCase)
        .ToList();

    protected override void OnInitialized()
    {
        Registry.Changed += HandleRegistryChanged;
    }

    public void Dispose()
    {
        Registry.Changed -= HandleRegistryChanged;
    }

    private void HandleRegistryChanged()
    {
        _ = InvokeAsync(StateHasChanged);
    }

    private sealed class NodeRow
    {
        public string NodeName { get; set; } = string.Empty;

        public int ServerCount { get; set; }

        public int ConnectedAgents { get; set; }

        public int PlayersOnline { get; set; }
    }
}
