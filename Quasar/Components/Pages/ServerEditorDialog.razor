    private string SelectedProfileName =>
        string.IsNullOrWhiteSpace(_editor.ConfigProfileId)
            ? string.Empty
            : ConfigProfiles.GetProfile(_editor.ConfigProfileId)?.Name ?? string.Empty;

    private IReadOnlyList<QuasarModSelection> TemplateModsMissingFromProfile
    {
        get
        {
            if (string.IsNullOrWhiteSpace(_editor.WorldTemplateId) ||
                string.IsNullOrWhiteSpace(_editor.ConfigProfileId))
            {
                return Array.Empty<QuasarModSelection>();
            }

            var profile = ConfigProfiles.GetProfile(_editor.ConfigProfileId);
            if (profile is null)
                return Array.Empty<QuasarModSelection>();

            var sandboxConfigPath = Path.Combine(
                WorldTemplates.GetWorldDirectory(_editor.WorldTemplateId),
                WorldSandboxConfigEditor.SandboxConfigFileName);

            IReadOnlyList<QuasarModSelection> templateMods;
            try
            {
                templateMods = WorldSandboxConfigEditor.ReadMods(sandboxConfigPath);
            }
            catch
            {
                return Array.Empty<QuasarModSelection>();
            }

            if (templateMods.Count == 0)
                return Array.Empty<QuasarModSelection>();

            var profileIds = profile.Mods.Select(mod => mod.WorkshopId).ToHashSet();
            return templateMods
                .Where(mod => !profileIds.Contains(mod.WorkshopId))
                .ToArray();
        }
    }

    private async Task MergeSelectedWorldTemplateModsIntoProfileAsync()
    {
        if (string.IsNullOrWhiteSpace(_editor.ConfigProfileId))
            return;

        var profile = ConfigProfiles.GetProfile(_editor.ConfigProfileId);
        if (profile is null)
            return;

        var missingMods = TemplateModsMissingFromProfile;
        if (missingMods.Count == 0)
        {
            Snackbar.Add("Selected profile already has all template mods.", Severity.Info);
            return;
        }

        var existing = profile.Mods.Select(mod => mod.WorkshopId).ToHashSet();
        var added = 0;
        foreach (var mod in missingMods)
        {
            if (mod.WorkshopId <= 0 || !existing.Add(mod.WorkshopId))
                continue;

            profile.Mods.Add(new QuasarModSelection
            {
                WorkshopId = mod.WorkshopId,
                DisplayName = mod.DisplayName,
            });
            added++;
        }

        profile.Mods = profile.Mods
            .OrderBy(mod => mod.DisplayName, StringComparer.OrdinalIgnoreCase)
            .ThenBy(mod => mod.WorkshopId)
            .ToList();

        await ConfigProfiles.UpsertAsync(profile);
        Snackbar.Add($"Merged {added} mod(s) into config profile '{profile.Name}'.", Severity.Success);
        await InvokeAsync(StateHasChanged);
    }

    private static string NormalizeWhitespace(string? value) =>
        System.Text.RegularExpressions.Regex.Replace(value?.Trim() ?? string.Empty, @"\s+", " ");
