    private string? ValidateUniqueNameField(string? value)
    {
        if (string.IsNullOrEmpty(value))
            return null;

        var trimmed = value.Trim();
        if (!UniqueNameRegex.IsMatch(trimmed))
            return "Only letters, numbers, underscore, and hyphen are allowed.";

        var originalUniqueName = _editor.OriginalUniqueName?.Trim() ?? string.Empty;
        var duplicateExists = ServerCatalog.GetServers().Any(server =>
            string.Equals(server.UniqueName, trimmed, StringComparison.OrdinalIgnoreCase) &&
            !string.Equals(server.UniqueName, originalUniqueName, StringComparison.OrdinalIgnoreCase));

        return duplicateExists ? $"A server named '{trimmed}' already exists." : null;
    }

    private static string? ValidateCpuAffinityField(string? value) =>
        CpuAffinitySpec.TryParse(value, Environment.ProcessorCount, out _, out var error) ? null : error;

