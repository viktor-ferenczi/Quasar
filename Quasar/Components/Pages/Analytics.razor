@page "/analytics"
@implements IDisposable
@using ApexCharts
@using Microsoft.JSInterop
@inject MetricsStoreService MetricsStore
@inject DedicatedServerCatalog ServerCatalog
@inject AgentRegistry Registry
@inject ISnackbar Snackbar
@inject ILocalStorageService LocalStorage
@inject IDialogService DialogService
@inject ThemePreferenceService ThemePreference
@inject IJSRuntime JS

<PageTitle>Analytics</PageTitle>

<MudText Typo="Typo.h5" Class="mb-2">Analytics</MudText>
<MudText Typo="Typo.body2" Class="mb-4">Rolling server metrics with time-series charts, persisted filters, and configurable layout.</MudText>

<MudStack Row="true" Wrap="Wrap.Wrap" Spacing="2" AlignItems="AlignItems.Center" Class="mb-4">
    <div style="flex: 1 1 200px; min-width: 200px;">
        <MudSelect T="string" Label="Time range" Value="_config.SelectedRangeKey" ValueChanged="HandleRangeChanged" Variant="Variant.Outlined">
            @foreach (var option in RangeOptions)
            {
                <MudSelectItem T="string" Value="@option.Key">@option.Label</MudSelectItem>
            }
        </MudSelect>
    </div>
    <div style="flex: 1 1 180px; min-width: 180px;">
        <MudSelect T="int" Label="Auto refresh" Value="_config.AutoRefreshSeconds" ValueChanged="HandleAutoRefreshChanged" Variant="Variant.Outlined">
            <MudSelectItem T="int" Value="0">Off</MudSelectItem>
            <MudSelectItem T="int" Value="5">5s</MudSelectItem>
            <MudSelectItem T="int" Value="15">15s</MudSelectItem>
            <MudSelectItem T="int" Value="30">30s</MudSelectItem>
            <MudSelectItem T="int" Value="60">60s</MudSelectItem>
        </MudSelect>
    </div>
    <MudSpacer />
    <MudStack Row="true"
              Spacing="1"
              Wrap="Wrap.Wrap"
              AlignItems="AlignItems.Center"
              Justify="Justify.FlexEnd">
        <MudStack Row="true"
                  Spacing="1"
                  Wrap="Wrap.Wrap"
                  Justify="Justify.FlexEnd"
                  AlignItems="AlignItems.Center">
            <MudButton Variant="Variant.Outlined" Color="MudBlazor.Color.Default" StartIcon="@Icons.Material.Filled.Refresh" OnClick="@(() => RefreshAsync())">
                Refresh
            </MudButton>
            <MudButton Variant="Variant.Filled" Color="MudBlazor.Color.Primary" StartIcon="@Icons.Material.Filled.Download" OnClick="ExportAsync">
                Export
            </MudButton>
            <MudButton Variant="Variant.Filled" Color="MudBlazor.Color.Primary" StartIcon="@Icons.Material.Filled.SettingsBackupRestore" OnClick="ResetLayoutAsync">
                Reset layout
            </MudButton>
            <MudMenu StartIcon="@Icons.Material.Filled.Visibility"
                     Label="Add panel"
                     Variant="Variant.Outlined"
                     Color="MudBlazor.Color.Default"
                     Dense="true"
                     Disabled="@(HiddenPanels.Count == 0)">
                @foreach (var panel in HiddenPanels)
                {
                    <MudMenuItem OnClick="@(() => RestorePanelAsync(panel))">@ResolveMetricTitle(panel.Key)</MudMenuItem>
                }
            </MudMenu>
        </MudStack>
    </MudStack>
</MudStack>

@if (IsCustomRange)
{
    <MudGrid Class="mb-4">
        <MudItem xs="12" sm="6" lg="3">
            <MudDatePicker Label="From date" Date="_config.CustomFromDate" DateChanged="HandleCustomFromDateChanged" Variant="Variant.Outlined" />
        </MudItem>
        <MudItem xs="12" sm="6" lg="3">
            <MudTimePicker Label="From time" Time="_config.CustomFromTime" TimeChanged="HandleCustomFromTimeChanged" Variant="Variant.Outlined" Editable="true" />
        </MudItem>
        <MudItem xs="12" sm="6" lg="3">
            <MudDatePicker Label="To date" Date="_config.CustomToDate" DateChanged="HandleCustomToDateChanged" Variant="Variant.Outlined" />
        </MudItem>
        <MudItem xs="12" sm="6" lg="3">
            <MudTimePicker Label="To time" Time="_config.CustomToTime" TimeChanged="HandleCustomToTimeChanged" Variant="Variant.Outlined" Editable="true" />
        </MudItem>
    </MudGrid>
}

<MudPaper Class="pa-4 mb-4">
    <MudGrid>
        <MudItem xs="12" xl="8">
            <MudStack Spacing="2">
                <MudStack Row="true" AlignItems="AlignItems.Center" Justify="Justify.SpaceBetween">
                    <MudText Typo="Typo.h6">Servers</MudText>
                    <MudButton Variant="Variant.Text" Size="MudBlazor.Size.Small" OnClick="SelectAllServersAsync">Select all</MudButton>
                </MudStack>
                @if (_serverOptions.Count == 0)
                {
                    <MudAlert Severity="Severity.Info" Variant="Variant.Outlined">No servers known yet.</MudAlert>
                }
                else
                {
                    <MudGrid>
                        @foreach (var option in _serverOptions)
                        {
                            <MudItem xs="12" sm="6">
                                <MudCheckBox T="bool"
                                             Value="@IsServerSelected(option.UniqueName)"
                                             ValueChanged="@(value => HandleServerToggled(option.UniqueName, value))"
                                             Label="@option.DisplayName" />
                            </MudItem>
                        }
                    </MudGrid>
                }
            </MudStack>
        </MudItem>
        <MudItem xs="12" xl="4">
            <MudStack Spacing="2">
                <MudStack Row="true" AlignItems="AlignItems.Center" Justify="Justify.SpaceBetween">
                    <MudText Typo="Typo.h6">Grid</MudText>
                    <MudButton Variant="Variant.Text" Size="MudBlazor.Size.Small" OnClick="ResetPanelsAsync">Reset panels</MudButton>
                </MudStack>
                <MudNumericField T="int" Label="Columns" Value="_config.GridColumns" ValueChanged="HandleGridColumnsChanged" Variant="Variant.Outlined" Min="1" Max="6" />
                <MudNumericField T="int" Label="Rows" Value="_config.GridRows" ValueChanged="HandleGridRowsChanged" Variant="Variant.Outlined" Min="1" Max="12" />
                <MudNumericField T="int" Label="Row height (px)" Value="_config.RowHeightPx" ValueChanged="HandleRowHeightChanged" Variant="Variant.Outlined" Min="180" Max="960" />
                <MudNumericField T="int" Label="Max visible lines" Value="_config.MaxVisibleServersForCharts" ValueChanged="HandleMaxVisibleServersChanged" Variant="Variant.Outlined" Min="1" Max="40" Disabled="_config.ShowAllServers" />
                <MudCheckBox T="bool" Label="Show all selected server lines" Value="_config.ShowAllServers" ValueChanged="HandleShowAllServersChanged" />
            </MudStack>
        </MudItem>
    </MudGrid>
</MudPaper>

<MudStack Row="true" Spacing="1" Class="mb-4 analytics-chip-row">
    @foreach (var chip in _summaryChips)
    {
        <MudChip T="string" Color="MudBlazor.Color.Primary" Variant="Variant.Outlined">@chip.Label: @chip.Value</MudChip>
    }
</MudStack>

@if (_charts.Count == 0)
{
    <MudAlert Severity="Severity.Info" Variant="Variant.Outlined">
        No analytics samples match current filters yet.
    </MudAlert>
}
else
{
    <div class="analytics-chart-grid" style="@ChartGridStyle">
        @foreach (var chart in _charts)
        {
            <div class="analytics-chart-card" style="@chart.LayoutStyle">
                <MudPaper Class="pa-4 analytics-chart-paper">
                    <MudStack Row="true" AlignItems="AlignItems.Center" Justify="Justify.SpaceBetween" Class="mb-2">
                        <MudStack Spacing="0">
                            <MudText Typo="Typo.h6">@chart.Title</MudText>
                            <MudText Typo="Typo.caption">@chart.Subtitle</MudText>
                        </MudStack>
                        <MudTooltip Text="Panel settings">
                            <MudIconButton Icon="@Icons.Material.Filled.Tune"
                                           Size="MudBlazor.Size.Small"
                                           Color="MudBlazor.Color.Default"
                                           OnClick="@(() => OpenPanelDialogAsync(chart.Panel))" />
                        </MudTooltip>
                    </MudStack>
                    <div class="analytics-apex-chart">
                        <ApexChart TItem="AnalyticsChartPoint"
                                   @key="chart.RenderKey"
                                   @ref="chart.ChartRef"
                                   Options="@chart.Options"
                                   Width="@("100%")"
                                   Height="@chart.Height">
                            @foreach (var series in chart.Series)
                            {
                                <ApexPointSeries TItem="AnalyticsChartPoint"
                                                 Items="@series.Points"
                                                 Name="@series.Name"
                                                 SeriesType="SeriesType.Line"
                                                 XValue="@(point => point.Timestamp)"
                                                 YValue="@(point => point.Value)"
                                                 OrderBy="@(point => point.X)" />
                            }
                        </ApexChart>
                    </div>
                </MudPaper>
            </div>
        }
    </div>
}

@code
{
    private const string StorageKey = "quasar.analytics.view.v2";
    private const string ViewportWidthFunction = "quasarConfigs.getViewportWidth";
    private const int DefaultViewportWidthPx = 1280;
    private const int MinSeriesPoints = 300;
    private const int MaxSeriesPoints = 1000;

    private static readonly (string Key, string Label)[] RangeOptions =
    [
        ("30s", "30s"),
        ("1m", "1m"),
        ("2m", "2m"),
        ("5m", "5m"),
        ("15m", "15m"),
        ("30m", "30m"),
        ("1h", "1h"),
        ("6h", "6h"),
        ("24h", "24h"),
        ("7d", "7d"),
        ("30d", "30d"),
        ("custom", "Custom"),
    ];

    private static readonly MetricDefinition[] MetricDefinitions =
    [
        new("simspeed", "SimSpeed", "Simulation ratio", sample => sample.SimSpeed, sample => true, RequiresZero: false),
        new("cpu", "CPU %", "Server process load", sample => sample.CpuPercent, sample => true, RequiresZero: true),
        new("memory", "Memory MB", "Working set", sample => sample.MemoryMb, sample => sample.MemoryMb > 0f, RequiresZero: false),
        new("players", "Player Count", "Players online", sample => sample.PlayersOnline, sample => true, RequiresZero: true),
        new("frametime", "Frame Time ms", "Derived from sim speed", sample => sample.FrameTimeMs, sample => sample.FrameTimeMs > 0f, RequiresZero: true),
        new("pcu", "PCU Used", "Used PCU", sample => sample.UsedPcu, sample => true, RequiresZero: true),
        new("grids", "Active Grids", "Entity grids", sample => sample.ActiveGridCount, sample => sample.ActiveGridCount >= 0, RequiresZero: true),
        new("entities", "Active Entities", "Entity count", sample => sample.ActiveEntityCount, sample => sample.ActiveEntityCount >= 0, RequiresZero: true),
    ];

    private readonly List<ChartModel> _charts = [];
    private readonly List<SummaryChipModel> _summaryChips = [];
    private AnalyticsViewConfig _config = CreateDefaultConfig();
    private IReadOnlyList<ServerOption> _serverOptions = [];
    private CancellationTokenSource _refreshCts = new();
    private bool _disposed;
    private bool _configLoaded;
    private bool _selectionInitialized;
    private bool _pendingChartUpdate;
    private int _refreshing;
    private int _refreshRequested;
    private long _chartRenderVersion;
    private bool _isDarkTheme = true;
    private int _cachedViewportWidthPx = DefaultViewportWidthPx;

    private bool IsCustomRange => string.Equals(_config.SelectedRangeKey, "custom", StringComparison.OrdinalIgnoreCase);

    private IReadOnlyList<AnalyticsPanelConfig> HiddenPanels => _config.Panels
        .Where(panel => !panel.Visible)
        .OrderBy(panel => panel.Order)
        .ToList();

    private string ChartGridStyle =>
        $"--analytics-grid-columns: {Math.Max(1, _config.GridColumns)}; --analytics-grid-rows: {Math.Max(1, _config.GridRows)}; --analytics-row-height: {Math.Max(180, _config.RowHeightPx)}px;";

    protected override void OnInitialized()
    {
        MetricsStore.Changed += HandleSourceChanged;
        Registry.Changed += HandleSourceChanged;
        ServerCatalog.Changed += HandleSourceChanged;
        ThemePreference.ThemeModeChanged += HandleThemeModeChanged;
        _ = RefreshViewAsync(remountCharts: true);
        UpdateRefreshTimer();
    }

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (firstRender)
        {
        await ThemePreference.InitializeAsync();
        _isDarkTheme = ThemePreference.IsDarkMode;
        await LoadConfigAsync();
        await RefreshViewAsync(remountCharts: true);
        UpdateRefreshTimer();
        await InvokeAsync(StateHasChanged);
        return;
        }

        if (_pendingChartUpdate)
        {
            _pendingChartUpdate = false;
            await UpdateRenderedChartsAsync();
        }
    }

    public void Dispose()
    {
        _disposed = true;
        MetricsStore.Changed -= HandleSourceChanged;
        Registry.Changed -= HandleSourceChanged;
        ServerCatalog.Changed -= HandleSourceChanged;
        ThemePreference.ThemeModeChanged -= HandleThemeModeChanged;
        _refreshCts.Cancel();
        _refreshCts.Dispose();
    }

    private async Task LoadConfigAsync()
    {
        try
        {
            var stored = await LocalStorage.GetItemAsync<AnalyticsViewConfig>(StorageKey);
            _config = NormalizeConfig(stored);
            _configLoaded = true;
        }
        catch (InvalidOperationException)
        {
            _config = NormalizeConfig(null);
        }
        catch (JSDisconnectedException)
        {
            _config = NormalizeConfig(null);
        }
    }

    private async Task PersistConfigAsync()
    {
        if (!_configLoaded)
            return;

        try
        {
            await LocalStorage.SetItemAsync(StorageKey, _config);
        }
        catch (InvalidOperationException)
        {
        }
        catch (JSDisconnectedException)
        {
        }
    }

    private async Task RefreshAsync(bool remountCharts = false)
    {
        await RefreshViewAsync(remountCharts);
        if (!remountCharts)
            RequestChartUpdate();

        await PersistConfigAsync();
        StateHasChanged();
    }

    private async Task ExportAsync()
    {
        try
        {
            await MetricsStore.PersistAllAsync();
            Snackbar.Add("Analytics persisted to disk.", Severity.Success);
        }
        catch (Exception exception)
        {
            Snackbar.Add(exception.Message, Severity.Error);
        }
    }

    private async Task ResetLayoutAsync()
    {
        _config.GridColumns = 2;
        _config.GridRows = 4;
        _config.RowHeightPx = 320;
        await RefreshAsync(remountCharts: true);
    }

    private async Task ResetPanelsAsync()
    {
        _config.Panels = CreateDefaultPanels();
        await RefreshAsync(remountCharts: true);
    }

    private async Task SelectAllServersAsync()
    {
        _config.SelectedUniqueNames = _serverOptions.Select(option => option.UniqueName).ToList();
        _selectionInitialized = true;
        await RefreshAsync(remountCharts: true);
    }

    private async Task HandleServerToggled(string uniqueName, bool value)
    {
        if (value)
        {
            if (!_config.SelectedUniqueNames.Any(id => string.Equals(id, uniqueName, StringComparison.OrdinalIgnoreCase)))
                _config.SelectedUniqueNames.Add(uniqueName);
        }
        else
        {
            _config.SelectedUniqueNames.RemoveAll(id => string.Equals(id, uniqueName, StringComparison.OrdinalIgnoreCase));
        }

        _selectionInitialized = true;
        await RefreshAsync(remountCharts: true);
    }

    private Task HandleRangeChanged(string value)
    {
        _config.SelectedRangeKey = string.IsNullOrWhiteSpace(value) ? "1h" : value;
        UpdateRefreshTimer();
        return RefreshAsync(remountCharts: true);
    }

    private Task HandleAutoRefreshChanged(int value)
    {
        _config.AutoRefreshSeconds = Math.Max(0, value);
        UpdateRefreshTimer();
        return PersistConfigAsync();
    }

    private Task HandleCustomFromDateChanged(DateTime? value)
    {
        _config.CustomFromDate = value;
        return RefreshAsync(remountCharts: true);
    }

    private Task HandleCustomFromTimeChanged(TimeSpan? value)
    {
        _config.CustomFromTime = value;
        return RefreshAsync(remountCharts: true);
    }

    private Task HandleCustomToDateChanged(DateTime? value)
    {
        _config.CustomToDate = value;
        return RefreshAsync(remountCharts: true);
    }

    private Task HandleCustomToTimeChanged(TimeSpan? value)
    {
        _config.CustomToTime = value;
        return RefreshAsync(remountCharts: true);
    }

    private Task HandleGridColumnsChanged(int value)
    {
        _config.GridColumns = Math.Clamp(value, 1, 6);
        foreach (var panel in _config.Panels)
            panel.ColumnSpan = Math.Clamp(panel.ColumnSpan, 1, _config.GridColumns);

        return RefreshAsync(remountCharts: true);
    }

    private Task HandleGridRowsChanged(int value)
    {
        _config.GridRows = Math.Clamp(value, 1, 12);
        foreach (var panel in _config.Panels)
            panel.RowSpan = Math.Clamp(panel.RowSpan, 1, _config.GridRows);

        return RefreshAsync(remountCharts: true);
    }

    private Task HandleRowHeightChanged(int value)
    {
        _config.RowHeightPx = Math.Clamp(value, 180, 960);
        return RefreshAsync(remountCharts: true);
    }

    private Task HandleMaxVisibleServersChanged(int value)
    {
        _config.MaxVisibleServersForCharts = Math.Clamp(value, 1, 40);
        return RefreshAsync(remountCharts: true);
    }

    private Task HandleShowAllServersChanged(bool value)
    {
        _config.ShowAllServers = value;
        return RefreshAsync(remountCharts: true);
    }

    private async Task RestorePanelAsync(AnalyticsPanelConfig panel)
    {
        panel.Visible = true;
        await RefreshAsync(remountCharts: true);
    }

    private void HandleSourceChanged()
    {
        if (_disposed)
            return;

        Interlocked.Exchange(ref _refreshRequested, 1);
        _ = InvokeAsync(ProcessQueuedRefreshAsync);
    }

    private async Task ProcessQueuedRefreshAsync()
    {
        if (_disposed)
            return;

        if (Interlocked.Exchange(ref _refreshing, 1) == 1)
            return;

        try
        {
            while (!_disposed && Interlocked.Exchange(ref _refreshRequested, 0) == 1)
            {
                await RefreshViewAsync();
                RequestChartUpdate();
                StateHasChanged();
            }
        }
        finally
        {
            Interlocked.Exchange(ref _refreshing, 0);
            if (!_disposed && Volatile.Read(ref _refreshRequested) == 1)
                _ = InvokeAsync(ProcessQueuedRefreshAsync);
        }
    }

    private void HandleThemeModeChanged(bool isDark)
    {
        if (_disposed)
            return;

        _isDarkTheme = isDark;
        _ = InvokeAsync(async () =>
        {
            await RefreshViewAsync(remountCharts: true);
            await InvokeAsync(StateHasChanged);
        });
    }

    private void UpdateRefreshTimer()
    {
        _refreshCts.Cancel();
        _refreshCts.Dispose();
        _refreshCts = new CancellationTokenSource();

        if (_config.AutoRefreshSeconds <= 0 || _disposed)
            return;

        var interval = TimeSpan.FromSeconds(_config.AutoRefreshSeconds);
        var token = _refreshCts.Token;
        _ = RunAutoRefreshLoopAsync(interval, token);
    }

    private async Task RunAutoRefreshLoopAsync(TimeSpan interval, CancellationToken cancellationToken)
    {
        try
        {
            using var timer = new PeriodicTimer(interval);
            while (await timer.WaitForNextTickAsync(cancellationToken))
            {
                if (_disposed || cancellationToken.IsCancellationRequested)
                    return;

                await InvokeAsync(() =>
                    _disposed || cancellationToken.IsCancellationRequested
                        ? Task.CompletedTask
                        : RefreshAsync());
            }
        }
        catch (OperationCanceledException)
        {
        }
        catch (ObjectDisposedException)
        {
        }
    }

    private void RequestChartUpdate()
    {
        _pendingChartUpdate = true;
    }

    private async Task UpdateRenderedChartsAsync()
    {
        var charts = _charts.ToArray();
        await Task.Yield();

        foreach (var chart in charts)
        {
            if (_disposed)
                return;

            var chartRef = chart.ChartRef;
            if (chartRef is null)
                continue;

            try
            {
                await chartRef.UpdateOptionsAsync(redrawPaths: false, animate: false, updateSyncedCharts: false, zoom: null);
                await chartRef.UpdateSeriesAsync(animate: false);
                await chartRef.ZoomXAsync(chart.XMin, chart.XMax);
            }
            catch (Exception exception) when (exception is InvalidOperationException or ObjectDisposedException)
            {
            }
        }
    }

    private async Task RefreshViewAsync(bool remountCharts = false)
    {
        _serverOptions = BuildServerOptions();
        NormalizeSelection();

        var (fromUnix, toUnix) = ResolveRange();
        var spanSeconds = toUnix - fromUnix;
        var selectedServers = GetSelectedUniqueNames();
        var maxChartPoints = await ResolveChartTargetPointsAsync(spanSeconds);
        var effectiveServers = ResolveChartServers(selectedServers);
        var samplesByServer = new Dictionary<string, MetricSample[]>(StringComparer.OrdinalIgnoreCase);
        var renderSamplesByServer = new Dictionary<string, MetricSample[]>(StringComparer.OrdinalIgnoreCase);
        var maxPointsPerSeries = ResolveMaxPointsPerSeries(maxChartPoints, effectiveServers.Count);
        if (remountCharts)
            _chartRenderVersion = unchecked(_chartRenderVersion + 1);

        var chartRenderVersion = _chartRenderVersion;

        foreach (var uniqueName in effectiveServers)
        {
            var store = MetricsStore.GetStore(uniqueName);
            if (store is null)
                continue;

            var samples = ReadSamplesForRange(store, fromUnix, toUnix, spanSeconds);
            if (samples.Length == 0)
                continue;

            samplesByServer[uniqueName] = samples;
        }

        foreach (var pair in samplesByServer)
        {
            renderSamplesByServer[pair.Key] = DownsampleToPointLimit(pair.Value, maxPointsPerSeries);
        }

        var pointCache = new Dictionary<SeriesTransformCacheKey, IReadOnlyList<AnalyticsChartPoint>>();
        BuildSummary(selectedServers, samplesByServer, effectiveServers.Count);
        BuildCharts(renderSamplesByServer, toUnix - fromUnix, fromUnix, toUnix, maxChartPoints, chartRenderVersion, remountCharts, pointCache);
    }

    private IReadOnlyList<ServerOption> BuildServerOptions()
    {
        var names = new Dictionary<string, string>(StringComparer.OrdinalIgnoreCase);

        foreach (var server in ServerCatalog.GetServers())
            names[server.UniqueName] = server.UniqueName;

        foreach (var agent in Registry.GetAgents())
        {
            var uniqueName = agent.UniqueNameKey;
            if (string.IsNullOrWhiteSpace(uniqueName))
                continue;

            var displayName = agent.ServerDisplayName;
            if (string.IsNullOrWhiteSpace(displayName) || string.Equals(displayName, "Unknown server", StringComparison.OrdinalIgnoreCase))
                displayName = uniqueName;

            names.TryAdd(uniqueName, displayName);
        }

        foreach (var uniqueName in MetricsStore.GetUniqueNames())
            names.TryAdd(uniqueName, uniqueName);

        return names
            .OrderBy(pair => pair.Value, StringComparer.OrdinalIgnoreCase)
            .ThenBy(pair => pair.Key, StringComparer.OrdinalIgnoreCase)
            .Select(pair => new ServerOption(pair.Key, pair.Value))
            .ToList();
    }

    private void NormalizeSelection()
    {
        var validIds = _serverOptions.Select(option => option.UniqueName).ToHashSet(StringComparer.OrdinalIgnoreCase);
        _config.SelectedUniqueNames = _config.SelectedUniqueNames
            .Where(validIds.Contains)
            .Distinct(StringComparer.OrdinalIgnoreCase)
            .ToList();

        if (!_selectionInitialized && _config.SelectedUniqueNames.Count == 0 && _serverOptions.Count > 0)
        {
            _config.SelectedUniqueNames = _serverOptions.Select(option => option.UniqueName).ToList();
            _selectionInitialized = true;
        }
    }

    private bool IsServerSelected(string uniqueName)
    {
        return _config.SelectedUniqueNames.Any(id => string.Equals(id, uniqueName, StringComparison.OrdinalIgnoreCase));
    }

    private IReadOnlyList<string> GetSelectedUniqueNames()
    {
        return _config.SelectedUniqueNames.Count > 0
            ? _config.SelectedUniqueNames
            : [];
    }

    private IReadOnlyList<string> ResolveChartServers(IReadOnlyList<string> selectedServers)
    {
        if (_config.ShowAllServers || selectedServers.Count <= _config.MaxVisibleServersForCharts)
            return selectedServers;

        var limit = Math.Clamp(_config.MaxVisibleServersForCharts, 1, 40);
        if (selectedServers.Count <= limit)
            return selectedServers;

        if (_serverOptions.Count == 0)
            return selectedServers.Take(limit).ToList();

        var selectedSet = selectedServers.ToHashSet(StringComparer.OrdinalIgnoreCase);
        var visible = _serverOptions
            .Where(option => selectedSet.Contains(option.UniqueName))
            .Select(option => option.UniqueName)
            .Take(limit)
            .ToList();

        return visible.Count > 0
            ? visible
            : selectedServers.Take(limit).ToList();
    }

    private async Task<int> ResolveChartTargetPointsAsync(long spanSeconds)
    {
        var viewportWidth = await ResolveViewportWidthAsync();
        var chartWidth = ResolveChartWidth(viewportWidth, _config.GridColumns);

        var target = (int)Math.Round(chartWidth * 1.5);
        if (spanSeconds > 6 * 3600)
            target = (int)(target * 0.95);

        if (spanSeconds > 24 * 3600)
            target = (int)(target * 0.8);

        if (spanSeconds > 7 * 86400)
            target = (int)(target * 0.5);

        if (spanSeconds > 30 * 86400)
            target = (int)(target * 0.35);

        return Math.Clamp(target, MinSeriesPoints, MaxSeriesPoints);
    }

    private int ResolveChartWidth(int viewportWidth, int gridColumns)
    {
        var columns = Math.Max(1, gridColumns);
        var available = Math.Max(0, viewportWidth - 48);
        var gap = 16;
        var width = (available - gap * (columns - 1)) / columns;
        return Math.Max(260, width);
    }

    private async Task<int> ResolveViewportWidthAsync()
    {
        try
        {
            var width = await JS.InvokeAsync<double>(ViewportWidthFunction);
            if (width > 0)
            {
                _cachedViewportWidthPx = (int)Math.Round(width);
                return _cachedViewportWidthPx;
            }
        }
        catch (InvalidOperationException)
        {
        }
        catch (JSDisconnectedException)
        {
        }

        return _cachedViewportWidthPx > 0
            ? _cachedViewportWidthPx
            : DefaultViewportWidthPx;
    }

    private static int ResolveMaxPointsPerSeries(int chartTargetPoints, int visibleSeriesCount)
        => Math.Max(1, chartTargetPoints / Math.Max(1, visibleSeriesCount));

    private (long FromUnix, long ToUnix) ResolveRange()
    {
        var nowUtc = DateTimeOffset.UtcNow;
        if (string.Equals(_config.SelectedRangeKey, "30s", StringComparison.OrdinalIgnoreCase))
            return (nowUtc.AddSeconds(-30).ToUnixTimeSeconds(), nowUtc.ToUnixTimeSeconds());

        if (string.Equals(_config.SelectedRangeKey, "1m", StringComparison.OrdinalIgnoreCase))
            return (nowUtc.AddMinutes(-1).ToUnixTimeSeconds(), nowUtc.ToUnixTimeSeconds());

        if (string.Equals(_config.SelectedRangeKey, "2m", StringComparison.OrdinalIgnoreCase))
            return (nowUtc.AddMinutes(-2).ToUnixTimeSeconds(), nowUtc.ToUnixTimeSeconds());

        if (string.Equals(_config.SelectedRangeKey, "5m", StringComparison.OrdinalIgnoreCase))
            return (nowUtc.AddMinutes(-5).ToUnixTimeSeconds(), nowUtc.ToUnixTimeSeconds());

        if (string.Equals(_config.SelectedRangeKey, "15m", StringComparison.OrdinalIgnoreCase))
            return (nowUtc.AddMinutes(-15).ToUnixTimeSeconds(), nowUtc.ToUnixTimeSeconds());

        if (string.Equals(_config.SelectedRangeKey, "30m", StringComparison.OrdinalIgnoreCase))
            return (nowUtc.AddMinutes(-30).ToUnixTimeSeconds(), nowUtc.ToUnixTimeSeconds());

        if (string.Equals(_config.SelectedRangeKey, "1h", StringComparison.OrdinalIgnoreCase))
            return (nowUtc.AddHours(-1).ToUnixTimeSeconds(), nowUtc.ToUnixTimeSeconds());

        if (string.Equals(_config.SelectedRangeKey, "6h", StringComparison.OrdinalIgnoreCase))
            return (nowUtc.AddHours(-6).ToUnixTimeSeconds(), nowUtc.ToUnixTimeSeconds());

        if (string.Equals(_config.SelectedRangeKey, "24h", StringComparison.OrdinalIgnoreCase))
            return (nowUtc.AddHours(-24).ToUnixTimeSeconds(), nowUtc.ToUnixTimeSeconds());

        if (string.Equals(_config.SelectedRangeKey, "7d", StringComparison.OrdinalIgnoreCase))
            return (nowUtc.AddDays(-7).ToUnixTimeSeconds(), nowUtc.ToUnixTimeSeconds());

        if (string.Equals(_config.SelectedRangeKey, "30d", StringComparison.OrdinalIgnoreCase))
            return (nowUtc.AddDays(-30).ToUnixTimeSeconds(), nowUtc.ToUnixTimeSeconds());

        var fromDate = (_config.CustomFromDate ?? DateTime.Now.Date.AddDays(-1)).Date;
        var toDate = (_config.CustomToDate ?? DateTime.Now.Date).Date;
        var fromLocal = DateTime.SpecifyKind(fromDate.Add(_config.CustomFromTime ?? TimeSpan.Zero), DateTimeKind.Local);
        var toLocal = DateTime.SpecifyKind(toDate.Add(_config.CustomToTime ?? new TimeSpan(23, 59, 0)), DateTimeKind.Local);
        if (toLocal < fromLocal)
            toLocal = fromLocal.AddHours(1);

        return (new DateTimeOffset(fromLocal).ToUnixTimeSeconds(), new DateTimeOffset(toLocal).ToUnixTimeSeconds());
    }

    private static MetricSample[] ReadSamplesForRange(ServerMetricsStore store, long fromUnix, long toUnix, long spanSeconds)
    {
        if (spanSeconds <= 2 * 3600)
            return store.Raw.Read(fromUnix, toUnix);

        if (spanSeconds <= 24 * 3600)
            return store.OneMinute.Read(fromUnix, toUnix);

        return store.OneHour.Read(fromUnix, toUnix);
    }

    private static MetricSample[] DownsampleToPointLimit(MetricSample[] samples, int maxPoints)
    {
        if (samples.Length <= maxPoints)
            return samples;

        var chunkSize = Math.Max(1, (int)Math.Ceiling(samples.Length / (double)maxPoints));
        var chunkCount = (int)Math.Ceiling(samples.Length / (double)chunkSize);
        if (chunkCount == 0)
            return [];

        var result = new MetricSample[chunkCount];
        for (var chunkIndex = 0; chunkIndex < chunkCount; chunkIndex++)
        {
            var offset = chunkIndex * chunkSize;
            var count = Math.Min(chunkSize, samples.Length - offset);
            result[chunkIndex] = AverageSamples(samples, offset, count);
        }

        return result;
    }

    private static MetricSample AverageSamples(MetricSample[] samples, int offset, int count)
    {
        var end = offset + count;
        long timestampTotal = 0;
        var simSpeedTotal = 0.0;
        var cpuTotal = 0.0;
        var memoryTotal = 0.0;
        var frameTimeTotal = 0.0;
        var playersTotal = 0.0;
        var usedPcuTotal = 0.0;
        long activeGridTotal = 0;
        long activeEntityTotal = 0;
        var activeGridSamples = 0;
        var activeEntitySamples = 0;

        for (var i = offset; i < end; i++)
        {
            var sample = samples[i];
            timestampTotal += sample.TimestampUnixSeconds;
            simSpeedTotal += sample.SimSpeed;
            cpuTotal += sample.CpuPercent;
            memoryTotal += sample.MemoryMb;
            frameTimeTotal += sample.FrameTimeMs;
            playersTotal += sample.PlayersOnline;
            usedPcuTotal += sample.UsedPcu;

            if (sample.ActiveGridCount >= 0)
            {
                activeGridTotal += sample.ActiveGridCount;
                activeGridSamples++;
            }

            if (sample.ActiveEntityCount >= 0)
            {
                activeEntityTotal += sample.ActiveEntityCount;
                activeEntitySamples++;
            }
        }

        var activeGridCount = activeGridSamples > 0
            ? (int)Math.Round((double)activeGridTotal / activeGridSamples)
            : -1;

        var activeEntityCount = activeEntitySamples > 0
            ? (int)Math.Round((double)activeEntityTotal / activeEntitySamples)
            : -1;

        var averageTimestamp = timestampTotal / count;
        return new MetricSample(
            timestampUnixSeconds: averageTimestamp,
            simSpeed: (float)(simSpeedTotal / count),
            cpuPercent: (float)(cpuTotal / count),
            memoryMb: (float)(memoryTotal / count),
            frameTimeMs: (float)(frameTimeTotal / count),
            playersOnline: (int)Math.Round(playersTotal / count),
            usedPcu: (int)Math.Round(usedPcuTotal / count),
            activeGridCount: activeGridCount,
            activeEntityCount: activeEntityCount);
    }

    private void BuildSummary(
        IReadOnlyList<string> selectedServers,
        IReadOnlyDictionary<string, MetricSample[]> samplesByServer,
        int visibleServerCount)
    {
        _summaryChips.Clear();

        var latestSamples = new List<MetricSample>();
        foreach (var uniqueName in selectedServers)
        {
            var latest = MetricsStore.GetStore(uniqueName)?.Raw.ReadLatest(1);
            if (latest is { Length: > 0 })
                latestSamples.Add(latest[0]);
        }

        if (selectedServers.Count == visibleServerCount)
        {
            _summaryChips.Add(new SummaryChipModel("Servers", selectedServers.Count.ToString()));
        }
        else
        {
            _summaryChips.Add(new SummaryChipModel("Servers", $"{visibleServerCount} of {selectedServers.Count}"));
        }

        if (latestSamples.Count == 0)
        {
            _summaryChips.Add(new SummaryChipModel("SimSpeed", "-"));
            _summaryChips.Add(new SummaryChipModel("CPU", "-"));
            _summaryChips.Add(new SummaryChipModel("Memory", "-"));
            _summaryChips.Add(new SummaryChipModel("Players", "-"));
            _summaryChips.Add(new SummaryChipModel("PCU", "-"));
            _summaryChips.Add(new SummaryChipModel("Grids", "-"));
            _summaryChips.Add(new SummaryChipModel("Entities", "-"));
            return;
        }

        var simSpeed = latestSamples.Average(sample => sample.SimSpeed);
        var cpu = latestSamples.Average(sample => sample.CpuPercent);
        var memory = latestSamples.Sum(sample => sample.MemoryMb > 0f ? sample.MemoryMb : 0f);
        var players = latestSamples.Sum(sample => sample.PlayersOnline);
        var pcu = latestSamples.Sum(sample => sample.UsedPcu);
        var grids = latestSamples.Where(sample => sample.ActiveGridCount >= 0).Sum(sample => sample.ActiveGridCount);
        var entities = latestSamples.Where(sample => sample.ActiveEntityCount >= 0).Sum(sample => sample.ActiveEntityCount);

        _summaryChips.Add(new SummaryChipModel("SimSpeed", simSpeed.ToString("0.000")));
        _summaryChips.Add(new SummaryChipModel("CPU", $"{cpu:0.0}%"));
        _summaryChips.Add(new SummaryChipModel("Memory", $"{memory:0} MB"));
        _summaryChips.Add(new SummaryChipModel("Players", players.ToString()));
        _summaryChips.Add(new SummaryChipModel("PCU", pcu.ToString()));
        _summaryChips.Add(new SummaryChipModel("Grids", grids > 0 ? grids.ToString() : "-"));
        _summaryChips.Add(new SummaryChipModel("Entities", entities > 0 ? entities.ToString() : "-"));

        if (samplesByServer.Values.SelectMany(sampleSet => sampleSet).Any())
        {
            var rangeSimAverage = samplesByServer.Values
                .SelectMany(sampleSet => sampleSet)
                .Average(sample => sample.SimSpeed);
            _summaryChips.Add(new SummaryChipModel("Range Avg Sim", rangeSimAverage.ToString("0.000")));
        }
    }

    private void BuildCharts(
        IReadOnlyDictionary<string, MetricSample[]> samplesByServer,
        long spanSeconds,
        long fromUnix,
        long toUnix,
        int denseThreshold,
        long chartRenderVersion,
        bool remountCharts,
        Dictionary<SeriesTransformCacheKey, IReadOnlyList<AnalyticsChartPoint>> pointCache)
    {
        if (samplesByServer.Count == 0)
        {
            _charts.Clear();
            return;
        }

        var orderedSamplesByServer = samplesByServer
            .OrderBy(pair => ResolveDisplayName(pair.Key), StringComparer.OrdinalIgnoreCase)
            .ToList();
        var existingCharts = remountCharts
            ? []
            : _charts.ToDictionary(chart => chart.Panel.Key, StringComparer.OrdinalIgnoreCase);
        var nextCharts = new List<ChartModel>();

        foreach (var panel in _config.Panels
                     .Where(panel => panel.Visible)
                     .OrderBy(panel => panel.Order)
                     .ThenBy(panel => ResolveMetricTitle(panel.Key), StringComparer.OrdinalIgnoreCase))
        {
            var definition = MetricDefinitions.FirstOrDefault(metric =>
                string.Equals(metric.Key, panel.Key, StringComparison.OrdinalIgnoreCase));
            if (definition is null)
                continue;

            var series = new List<AnalyticsChartSeries>();
            foreach (var pair in orderedSamplesByServer)
            {
                var gapThresholdSeconds = ResolveGapThresholdSeconds(pair.Value);
                var cacheKey = new SeriesTransformCacheKey(pair.Key, definition.Key, fromUnix, toUnix);
                if (!pointCache.TryGetValue(cacheKey, out var values))
                {
                    values = BuildSeriesPoints(pair.Value, definition, gapThresholdSeconds);
                    pointCache[cacheKey] = values;
                }

                if (values.Count == 0 || values.All(point => point.Value is null))
                    continue;

                series.Add(new AnalyticsChartSeries(ResolveDisplayName(pair.Key), values));
            }

            if (series.Count == 0)
                continue;

            var isDenseChart = series.Sum(s => s.Points.Count) >= denseThreshold;
            var options = CreateChartOptions(definition, spanSeconds, fromUnix, toUnix, isDenseChart);
            var height = ResolveChartHeight(panel);
            var layoutStyle = $"grid-column: span {Math.Clamp(panel.ColumnSpan, 1, _config.GridColumns)}; grid-row: span {Math.Clamp(panel.RowSpan, 1, Math.Max(1, _config.GridRows))};";
            var xMin = DateTimeOffset.FromUnixTimeSeconds(fromUnix).ToUnixTimeMilliseconds();
            var xMax = DateTimeOffset.FromUnixTimeSeconds(toUnix).ToUnixTimeMilliseconds();

            if (!remountCharts && existingCharts.TryGetValue(panel.Key, out var existing))
            {
                existing.Update(
                    title: definition.Title,
                    subtitle: definition.Subtitle,
                    series: series,
                    options: options,
                    height: height,
                    layoutStyle: layoutStyle,
                    xMin: xMin,
                    xMax: xMax,
                    panel: panel);
                nextCharts.Add(existing);
            }
            else
            {
                nextCharts.Add(new ChartModel(
                    RenderKey: $"{panel.Key}:{chartRenderVersion}",
                    Title: definition.Title,
                    Subtitle: definition.Subtitle,
                    Series: series,
                    Options: options,
                    Height: height,
                    LayoutStyle: layoutStyle,
                    XMin: xMin,
                    XMax: xMax,
                    Panel: panel));
            }
        }

        _charts.Clear();
        _charts.AddRange(nextCharts);
    }

    private async Task OpenPanelDialogAsync(AnalyticsPanelConfig panel)
    {
        var parameters = new DialogParameters
        {
            ["Title"] = ResolveMetricTitle(panel.Key),
            ["Subtitle"] = "Panel display and layout",
            ["Visible"] = panel.Visible,
            ["Order"] = panel.Order,
            ["ColumnSpan"] = panel.ColumnSpan,
            ["RowSpan"] = panel.RowSpan,
            ["GridColumns"] = _config.GridColumns,
            ["GridRows"] = _config.GridRows,
        };

        var options = new DialogOptions
        {
            CloseOnEscapeKey = true,
            MaxWidth = MaxWidth.ExtraSmall,
            FullWidth = true,
        };

        var dialog = await DialogService.ShowAsync<AnalyticsPanelDialog>(ResolveMetricTitle(panel.Key), parameters, options);
        var result = await dialog.Result;
        if (result is null || result.Canceled || result.Data is not AnalyticsPanelDialogResult updated)
            return;

        panel.Visible = updated.Visible;
        panel.Order = Math.Clamp(updated.Order, 0, 99);
        panel.ColumnSpan = Math.Clamp(updated.ColumnSpan, 1, _config.GridColumns);
        panel.RowSpan = Math.Clamp(updated.RowSpan, 1, Math.Max(1, _config.GridRows));
        await RefreshAsync(remountCharts: true);
    }

