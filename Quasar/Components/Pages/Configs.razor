@page "/configs"
@implements IDisposable
@using System.IO
@using System.Text.Json
@inject QuasarConfigProfileCatalog ConfigProfiles
@inject QuasarDevFolderCatalog DevFolderCatalog
@inject QuasarPluginCatalogService PluginCatalog
@inject QuasarWorkshopModResolver WorkshopMods
@inject SteamWorkshopCredentialsCatalog WorkshopCredentials
@inject DedicatedServerCatalog ServerCatalog
@inject ISnackbar Snackbar
@inject IJSRuntime JS
@inject IDialogService DialogService

<PageTitle>Config Profiles</PageTitle>

<MudGrid Class="configs-page-shell">
    <MudItem xs="12" lg="3">
        <MudPaper Class="server-card pa-4 configs-sidebar">
            <MudStack Spacing="2" Class="configs-sidebar-inner">
                <div>
                    <MudText Typo="Typo.h6">Config Profiles</MudText>
                    <MudText Typo="Typo.body2" Class="mb-4">
                        Reusable Magnetar config profiles. Applied to the assigned servers when they start.
                    </MudText>
                </div>
                
                <MudTextField
                    @bind-Value="_newProfileName"
                    Label="New profile name"
                    Variant="Variant.Outlined"
                    Immediate="true"
                    OnKeyDown="HandleNewProfileKeyDown" />

                <MudButton Variant="Variant.Filled" Color="Color.Primary" OnClick="CreateProfileAsync" Disabled="@string.IsNullOrWhiteSpace(_newProfileName)">
                    Create Profile
                </MudButton>

                <MudDivider />

                @if (Templates.Count == 0)
                {
                    <MudAlert Severity="Severity.Info" Variant="Variant.Outlined">
                        No config profiles yet.
                    </MudAlert>
                }
                else
                {
                    <MudStack Spacing="1" Class="configs-profile-list">
                        @foreach (var template in Templates)
                        {
                            var isSelected = string.Equals(_selectedProfileId, template.ConfigProfileId, StringComparison.OrdinalIgnoreCase);
                            var profileTileClass = GetProfileTileCssClass(isSelected);
                            var profileButtonClass = isSelected
                                ? "config-profile-button config-profile-button-selected"
                                : "config-profile-button";
                            <MudPaper Class="@profileTileClass" @key="template.ConfigProfileId">
                                <MudStack Row="true" AlignItems="AlignItems.Start" Justify="Justify.SpaceBetween" Spacing="1" Class="config-profile-row">
                                    <MudButton Variant="Variant.Text" Color="Color.Inherit" Class="@profileButtonClass" Style="flex: 1 1 auto; min-width: 0;" OnClick="@(() => SelectProfileFromListAsync(template.ConfigProfileId))">
                                        <MudStack AlignItems="AlignItems.Start" Spacing="0">
                                            <MudText Typo="Typo.subtitle2">@template.Name</MudText>
                                            <MudText Typo="Typo.caption" Class="config-secondary">
                                                @GetProfileSummary(template)
                                            </MudText>
                                        </MudStack>
                                    </MudButton>
                                    <MudIconButton
                                        Icon="@Icons.Material.Filled.ContentCopy"
                                        Color="Color.Default"
                                        Size="Size.Small"
                                        OnClick="@(() => CloneProfileAsync(template.ConfigProfileId))" />
                                    <MudIconButton
                                        Icon="@Icons.Material.Filled.DeleteOutline"
                                        Color="Color.Error"
                                        Size="Size.Small"
                                        Class="config-profile-delete"
                                        OnClick="@(() => DeleteProfileAsync(template.ConfigProfileId))" />
                                </MudStack>
                            </MudPaper>
                        }
                    </MudStack>
                }
            </MudStack>
        </MudPaper>
    </MudItem>

    <MudItem xs="12" lg="9" Class="configs-main-column">
        <div class="configs-editor-scroll">
        @if (_editor is null)
        {
            <MudAlert Severity="Severity.Info" Variant="Variant.Outlined">
                Select profile or create new one to start editing.
            </MudAlert>
        }
        else
        {
            <MudStack Spacing="3">
                <MudPaper Class="server-card pa-4">
                    <MudGrid>
                        <MudItem xs="12" md="6">
                            <MudTextField @bind-Value="_editor.Name" Label="Profile name" Variant="Variant.Outlined" Immediate="true" />
                        </MudItem>
                        <MudItem xs="12" md="6">
                            <MudTextField @bind-Value="_editor.Description" Label="Description" Variant="Variant.Outlined" Immediate="true" />
                        </MudItem>
                    </MudGrid>

                    <MudStack Row="true" Wrap="Wrap.Wrap" Spacing="1" Class="mt-3">
                        <MudChip T="string" Variant="Variant.Outlined">Plugins @(_editor.Plugins.Count)</MudChip>
                        <MudChip T="string" Variant="Variant.Outlined">Mods @(_editor.Mods.Count)</MudChip>
                        <MudChip T="string" Variant="Variant.Outlined">Assigned Servers @GetAssignedServers(_editor.ConfigProfileId).Count</MudChip>
                        @if (!string.IsNullOrWhiteSpace(PluginCatalog.LastError))
                        {
                            <MudChip T="string" Variant="Variant.Outlined" Color="Color.Warning">Catalog stale</MudChip>
                        }
                    </MudStack>

                    @if (GetAssignedServers(_editor.ConfigProfileId).Count > 0)
                    {
                        <MudText Typo="Typo.caption" Class="d-block mt-2 config-secondary">
                            Applied to: @string.Join(", ", GetAssignedServers(_editor.ConfigProfileId).Select(server => server.UniqueName))
                        </MudText>
                    }

                    <MudStack Row="true" Wrap="Wrap.Wrap" Spacing="1" Class="mt-4">
                        <MudButton Variant="Variant.Filled" Color="Color.Primary" OnClick="SaveTemplateAsync">Save Profile</MudButton>
                        <MudButton Variant="Variant.Outlined" Color="Color.Warning" OnClick="ResetEditorAsync">Reset</MudButton>
                    </MudStack>
                </MudPaper>

                <MudTabs Rounded="true" ApplyEffectsToContainer="true" >
                    <MudTabPanel Text="World">
                        <MudPaper Class="server-card pa-4" Square="true">
                            <MudStack Row="true" Wrap="Wrap.Wrap" AlignItems="AlignItems.Center" Spacing="2" Class="mb-4">
                            <MudTextField
                                @bind-Value="_worldSearch"
                                Label="Search world options"
                                Variant="Variant.Outlined"
                                Immediate="true"
                                Adornment="Adornment.Start"
                                AdornmentIcon="@Icons.Material.Filled.Search"
                                Class="configs-search-field"/>
                            <MudButton Variant="Variant.Outlined" Color="Color.Default" Disabled="@string.IsNullOrWhiteSpace(FirstMatchingOptionId)" OnClick="JumpToFirstOptionAsync">
                                Jump to First Match
                            </MudButton>
                            <MudChip T="string" Variant="Variant.Outlined">
                                Matches @VisibleWorldMatchCount
                            </MudChip>
                        </MudStack>

                        @if (!HasVisibleWorldContent)
                        {
                            <MudAlert Severity="Severity.Info" Variant="Variant.Outlined">
                                No world options match current search.
                            </MudAlert>
                        }
                        else
                        {
                            <MudExpansionPanels MultiExpansion="false" Elevation="0" Outlined="true" Dense="true" Class="configs-expansion-panels">
                                @if (TryGetVisibleCategory(ServerCategoryKey, out var serverCategory))
                                {
                                    var serverOptions = GetCategoryOptions(serverCategory.Key);
                                    <MudExpansionPanel Class="configs-expansion-panel" Expanded="@IsCategoryExpanded(serverCategory.Key)" ExpandedChanged="@(expanded => SetCategoryExpanded(serverCategory.Key, expanded))" @key="serverCategory.Key">
                                        <TitleContent>
                                            <MudStack Row="true" AlignItems="AlignItems.Center" Justify="Justify.SpaceBetween" Class="w-100">
                                                <MudStack Spacing="0">
                                                    <MudText Typo="Typo.subtitle1">@serverCategory.Title</MudText>
                                                    <MudText Typo="Typo.caption" Class="config-secondary">@serverCategory.Description</MudText>
                                                </MudStack>
                                                <MudChip T="string" Variant="Variant.Outlined" Size="Size.Small">@serverOptions.Count</MudChip>
                                            </MudStack>
                                        </TitleContent>
                                        <ChildContent>
                                            <MudStack Spacing="2" Class="mt-2">
                                                @foreach (var option in serverOptions)
                                                {
                                                    var optionCardClass = GetOptionCssClass(option);
                                                    <MudTooltip Placement="Placement.Top" Arrow="true" Delay="350" Inline="false">
                                                        <TooltipContent>
                                                            <div style="@ConfigOptionTooltipStyle">@GetOptionTooltipText(option)</div>
                                                        </TooltipContent>
                                                        <ChildContent>
                                                            <MudPaper Class="@optionCardClass" id="@GetOptionAnchorId(option)" tabindex="-1" @key="option.PropertyName">
                                                                @switch (option.Kind)
                                                                {
                                                                    case QuasarConfigOptionKind.Boolean:
                                                                        <MudCheckBox T="bool" Value="GetBoolOption(option)" ValueChanged="@(value => SetBoolOption(option, value))" Label="@option.Label"/>
                                                                        break;
                                                                    case QuasarConfigOptionKind.Integer:
                                                                        <MudNumericField T="int" Value="GetIntOption(option)" ValueChanged="@(value => SetIntOption(option, value))" Label="@option.Label" Variant="Variant.Outlined" Min="@ToIntOrDefault(option.Min, int.MinValue)" Max="@ToIntOrDefault(option.Max, int.MaxValue)" Step="@ToIntOrDefault(option.Step, 1)"/>
                                                                        break;
                                                                    case QuasarConfigOptionKind.Decimal:
                                                                        <MudNumericField T="double" Value="GetDoubleOption(option)" ValueChanged="@(value => SetDoubleOption(option, value))" Label="@option.Label" Variant="Variant.Outlined" Min="@ToDoubleOrDefault(option.Min, double.MinValue)" Max="@ToDoubleOrDefault(option.Max, double.MaxValue)" Step="@ToDoubleOrDefault(option.Step, 1d)"/>
                                                                        break;
                                                                    case QuasarConfigOptionKind.SelectInteger:
                                                                        <MudSelect T="int" Value="GetIntOption(option)" ValueChanged="@(value => SetIntOption(option, value))" Label="@option.Label" Variant="Variant.Outlined">
                                                                            @foreach (var choice in option.SelectOptions)
                                                                            {
                                                                                <MudSelectItem T="int" Value="@choice.Value">@choice.Label</MudSelectItem>
                                                                            }
                                                                        </MudSelect>
                                                                        break;
                                                                    case QuasarConfigOptionKind.SelectText:
                                                                        <MudSelect T="string" Value="GetStringOption(option)" ValueChanged="@(value => SetStringOption(option, value ?? string.Empty))" Label="@option.Label" Variant="Variant.Outlined">
                                                                            @foreach (var choice in option.SelectTextOptions)
                                                                            {
                                                                                <MudSelectItem T="string" Value="@choice.Value">@choice.Label</MudSelectItem>
                                                                            }
                                                                        </MudSelect>
                                                                        break;
                                                                    case QuasarConfigOptionKind.LongText:
                                                                        <MudTextField T="string" Value="GetStringOption(option)" ValueChanged="@(value => SetStringOption(option, value ?? string.Empty))" Label="@option.Label" Variant="Variant.Outlined" Lines="3"/>
                                                                        break;
                                                                    default:
                                                                        <MudTextField T="string" Value="GetStringOption(option)" ValueChanged="@(value => SetStringOption(option, value ?? string.Empty))" Label="@option.Label" Variant="Variant.Outlined"/>
                                                                        break;
                                                                }

                                                                @if (!string.IsNullOrWhiteSpace(option.HelperText))
                                                                {
                                                                    <MudText Typo="Typo.caption" Class="d-block mt-2 config-secondary">@option.HelperText</MudText>
                                                                }
                                                            </MudPaper>
                                                        </ChildContent>
                                                    </MudTooltip>
                                                }
                                            </MudStack>
                                        </ChildContent>
                                    </MudExpansionPanel>
                                }

                                @if (IsAccessSectionVisible)
                                {
                                    <MudExpansionPanel Class="configs-expansion-panel" Expanded="@IsCategoryExpanded(AccessCategoryKey)" ExpandedChanged="@(expanded => SetCategoryExpanded(AccessCategoryKey, expanded))" @key="AccessCategoryKey">
                                        <TitleContent>
                                            <MudStack Row="true" AlignItems="AlignItems.Center" Justify="Justify.SpaceBetween" Class="w-100">
                                                <MudStack Spacing="0">
                                                    <MudText Typo="Typo.subtitle1">Access</MudText>
                                                    <MudText Typo="Typo.caption" Class="config-secondary">Group whitelist, reserved slots, admin IDs, and banned IDs.</MudText>
                                                </MudStack>
                                                <MudChip T="string" Variant="Variant.Outlined" Size="Size.Small">@GetAccessEntryCount()</MudChip>
                                            </MudStack>
                                        </TitleContent>
                                        <ChildContent>
                                            <MudStack Spacing="2" Class="mt-2">
                                                <MudTooltip Placement="Placement.Top" Arrow="true" Delay="350" Inline="false">
                                                    <TooltipContent>
                                                        <div style="@ConfigOptionTooltipStyle">@GetAccessTooltipText("Limits joining to members of one Steam group. Use 0 to disable the group whitelist.")</div>
                                                    </TooltipContent>
                                                    <ChildContent>
                                                        <MudNumericField T="ulong" Value="_editor.RootSettings.GroupId" ValueChanged="SetGroupId" Label="Whitelist Group ID" Variant="Variant.Outlined" Min="0" HelperText="Dedicated server supports one group ID here. Use 0 to disable." id="@AccessGroupIdAnchorId"/>
                                                    </ChildContent>
                                                </MudTooltip>
                                                <MudTooltip Placement="Placement.Top" Arrow="true" Delay="350" Inline="false">
                                                    <TooltipContent>
                                                        <div style="@ConfigOptionTooltipStyle">@GetAccessTooltipText("Steam IDs that receive administrator rights on this server.")</div>
                                                    </TooltipContent>
                                                    <ChildContent>
                                                        <MudTextField T="string" Value="GetAdministratorText()" ValueChanged="@(v => SetAdministratorText(FilterNumericListInput(v)))" Label="Admin User IDs" Variant="Variant.Outlined" Lines="4" HelperText="Comma, space, or newline separated Steam IDs (numeric only)." id="@AccessAdministratorsAnchorId"/>
                                                    </ChildContent>
                                                </MudTooltip>
                                                <MudTooltip Placement="Placement.Top" Arrow="true" Delay="350" Inline="false">
                                                    <TooltipContent>
                                                        <div style="@ConfigOptionTooltipStyle">@GetAccessTooltipText("Steam IDs allowed to use reserved player slots.")</div>
                                                    </TooltipContent>
                                                    <ChildContent>
                                                        <MudTextField T="string" Value="GetReservedText()" ValueChanged="@(v => SetReservedText(FilterNumericListInput(v)))" Label="Reserved Slot User IDs" Variant="Variant.Outlined" Lines="4" HelperText="Comma, space, or newline separated numeric IDs." id="@AccessReservedAnchorId"/>
                                                    </ChildContent>
                                                </MudTooltip>
                                                <MudTooltip Placement="Placement.Top" Arrow="true" Delay="350" Inline="false">
                                                    <TooltipContent>
                                                        <div style="@ConfigOptionTooltipStyle">@GetAccessTooltipText("Steam IDs blocked from joining this server.")</div>
                                                    </TooltipContent>
                                                    <ChildContent>
                                                        <MudTextField T="string" Value="GetBannedText()" ValueChanged="@(v => SetBannedText(FilterNumericListInput(v)))" Label="Banned / Blacklisted User IDs" Variant="Variant.Outlined" Lines="4" HelperText="Comma, space, or newline separated numeric IDs." id="@AccessBannedAnchorId"/>
                                                    </ChildContent>
                                                </MudTooltip>
                                            </MudStack>
                                        </ChildContent>
                                    </MudExpansionPanel>
                                }

                                @foreach (var category in RemainingVisibleCategories)
                                {
                                    var categoryOptions = GetCategoryOptions(category.Key);
                                    <MudExpansionPanel Class="configs-expansion-panel" Expanded="@IsCategoryExpanded(category.Key)" ExpandedChanged="@(expanded => SetCategoryExpanded(category.Key, expanded))" @key="category.Key">
                                        <TitleContent>
                                            <MudStack Row="true" AlignItems="AlignItems.Center" Justify="Justify.SpaceBetween" Class="w-100">
                                                <MudStack Spacing="0">
                                                    <MudText Typo="Typo.subtitle1">@category.Title</MudText>
                                                    <MudText Typo="Typo.caption" Class="config-secondary">@category.Description</MudText>
                                                </MudStack>
                                                <MudChip T="string" Variant="Variant.Outlined" Size="Size.Small">@categoryOptions.Count</MudChip>
                                            </MudStack>
                                        </TitleContent>
                                        <ChildContent>
                                            <MudStack Spacing="2" Class="mt-2">
                                                @foreach (var option in categoryOptions)
                                                {
                                                    var optionCardClass = GetOptionCssClass(option);
                                                    <MudTooltip Placement="Placement.Top" Arrow="true" Delay="350" Inline="false">
                                                        <TooltipContent>
                                                            <div style="@ConfigOptionTooltipStyle">@GetOptionTooltipText(option)</div>
                                                        </TooltipContent>
                                                        <ChildContent>
                                                            <MudPaper Class="@optionCardClass" id="@GetOptionAnchorId(option)" tabindex="-1" @key="option.PropertyName">
                                                                @switch (option.Kind)
                                                                {
                                                                    case QuasarConfigOptionKind.Boolean:
                                                                        <MudCheckBox T="bool" Value="GetBoolOption(option)" ValueChanged="@(value => SetBoolOption(option, value))" Label="@option.Label"/>
                                                                        break;
                                                                    case QuasarConfigOptionKind.Integer:
                                                                        <MudNumericField T="int" Value="GetIntOption(option)" ValueChanged="@(value => SetIntOption(option, value))" Label="@option.Label" Variant="Variant.Outlined" Min="@ToIntOrDefault(option.Min, int.MinValue)" Max="@ToIntOrDefault(option.Max, int.MaxValue)" Step="@ToIntOrDefault(option.Step, 1)"/>
                                                                        break;
                                                                    case QuasarConfigOptionKind.Decimal:
                                                                        <MudNumericField T="double" Value="GetDoubleOption(option)" ValueChanged="@(value => SetDoubleOption(option, value))" Label="@option.Label" Variant="Variant.Outlined" Min="@ToDoubleOrDefault(option.Min, double.MinValue)" Max="@ToDoubleOrDefault(option.Max, double.MaxValue)" Step="@ToDoubleOrDefault(option.Step, 1d)"/>
                                                                        break;
                                                                    case QuasarConfigOptionKind.SelectInteger:
                                                                        <MudSelect T="int" Value="GetIntOption(option)" ValueChanged="@(value => SetIntOption(option, value))" Label="@option.Label" Variant="Variant.Outlined">
                                                                            @foreach (var choice in option.SelectOptions)
                                                                            {
                                                                                <MudSelectItem T="int" Value="@choice.Value">@choice.Label</MudSelectItem>
                                                                            }
                                                                        </MudSelect>
                                                                        break;
                                                                    case QuasarConfigOptionKind.SelectText:
                                                                        <MudSelect T="string" Value="GetStringOption(option)" ValueChanged="@(value => SetStringOption(option, value ?? string.Empty))" Label="@option.Label" Variant="Variant.Outlined">
                                                                            @foreach (var choice in option.SelectTextOptions)
                                                                            {
                                                                                <MudSelectItem T="string" Value="@choice.Value">@choice.Label</MudSelectItem>
                                                                            }
                                                                        </MudSelect>
                                                                        break;
                                                                    case QuasarConfigOptionKind.LongText:
                                                                        <MudTextField T="string" Value="GetStringOption(option)" ValueChanged="@(value => SetStringOption(option, value ?? string.Empty))" Label="@option.Label" Variant="Variant.Outlined" Lines="3"/>
                                                                        break;
                                                                    default:
                                                                        <MudTextField T="string" Value="GetStringOption(option)" ValueChanged="@(value => SetStringOption(option, value ?? string.Empty))" Label="@option.Label" Variant="Variant.Outlined"/>
                                                                        break;
                                                                }

                                                                @if (!string.IsNullOrWhiteSpace(option.HelperText))
                                                                {
                                                                    <MudText Typo="Typo.caption" Class="d-block mt-2 config-secondary">@option.HelperText</MudText>
                                                                }
                                                            </MudPaper>
                                                        </ChildContent>
                                                    </MudTooltip>
                                                }
                                            </MudStack>
                                        </ChildContent>
                                    </MudExpansionPanel>
                                }
                            </MudExpansionPanels>
                        }
                        </MudPaper>
                    </MudTabPanel>

                    <MudTabPanel Text="Plugins">
                        <MudPaper Class="server-card pa-4" Square="true">
                        <MudExpansionPanels MultiExpansion="false" Elevation="0" Outlined="true" Dense="true" Class="configs-expansion-panels mb-4">
                            <MudExpansionPanel Class="configs-expansion-panel" Expanded="@IsPluginPanelExpanded(PluginListPanelKey)" ExpandedChanged="@(expanded => SetPluginPanelExpandedAsync(PluginListPanelKey, expanded))">
                                <TitleContent>
                                    <MudStack Row="true" AlignItems="AlignItems.Center" Spacing="1">
                                        <MudText Typo="Typo.subtitle2">Plugins to load</MudText>
                                        <MudChip T="string" Size="Size.Small" Variant="Variant.Outlined">@_editor.Plugins.Count</MudChip>
                                    </MudStack>
                                </TitleContent>
                                <ChildContent>
                                    <MudStack Row="true" Wrap="Wrap.Wrap" AlignItems="AlignItems.Center" Spacing="2" Class="mb-3 mt-2">
                                        <MudTextField
                                            @bind-Value="_pluginSearch"
                                            Label="Filter selected plugins"
                                            Variant="Variant.Outlined"
                                            Immediate="true"
                                            Adornment="Adornment.Start"
                                            AdornmentIcon="@Icons.Material.Filled.Search"
                                            Class="configs-search-field" />
                                    </MudStack>

                                    <MudTable T="QuasarPluginSelection" Dense="true" Hover="true" Breakpoint="Breakpoint.Sm" Items="FilteredPlugins">
                                        <HeaderContent>
                                            <MudTh>Name</MudTh>
                                            <MudTh Style="width:96px;"></MudTh>
                                        </HeaderContent>
                                        <RowTemplate>
                                            <MudTd DataLabel="Name">
                                                <MudStack Spacing="0">
                                                    <MudText Typo="Typo.subtitle2">@context.DisplayName</MudText>
                                                    <MudText Typo="Typo.caption" Class="config-secondary mono">@context.PluginId</MudText>
                                                </MudStack>
                                            </MudTd>
                                            <MudTd>
                                                <div class="plugin-actions">
                                                    @if (!string.IsNullOrWhiteSpace(GetPluginSourceUrl(context)))
                                                    {
                                                        <MudIconButton Icon="@Icons.Material.Filled.OpenInNew" Color="Color.Default" Href="@GetPluginSourceUrl(context)" Target="_blank" Size="Size.Small" title="Open GitHub repository" />
                                                    }
                                                    <MudIconButton Icon="@Icons.Material.Filled.DeleteOutline" Color="Color.Error" OnClick="@(() => RemovePlugin(context.PluginId))" Size="Size.Small" title="Remove plugin" />
                                                </div>
                                            </MudTd>
                                        </RowTemplate>
                                        <NoRecordsContent>
                                            <MudAlert Severity="Severity.Info" Variant="Variant.Outlined" Class="ma-4">
                                                @(_editor.Plugins.Count == 0 ? "No plugins selected." : "No plugins match current search.")
                                            </MudAlert>
                                        </NoRecordsContent>
                                    </MudTable>
                                </ChildContent>
                            </MudExpansionPanel>

                            <MudExpansionPanel Class="configs-expansion-panel" Expanded="@IsPluginPanelExpanded(PluginCatalogPanelKey)" ExpandedChanged="@(expanded => SetPluginPanelExpandedAsync(PluginCatalogPanelKey, expanded))">
                                <TitleContent>
                                    <MudStack Row="true" AlignItems="AlignItems.Center" Spacing="1">
                                        <MudText Typo="Typo.subtitle2">Plugin catalog</MudText>
                                        <MudChip T="string" Size="Size.Small" Variant="Variant.Outlined">@FilteredCatalogEntries.Count</MudChip>
                                    </MudStack>
                                </TitleContent>
                                <ChildContent>
                                    <MudStack Row="true" Wrap="Wrap.Wrap" AlignItems="AlignItems.Center" Spacing="2" Class="mb-4 mt-2">
                                        <MudTextField
                                            @bind-Value="_pluginSearch"
                                            Label="Search plugin catalog"
                                            Variant="Variant.Outlined"
                                            Immediate="true"
                                            Adornment="Adornment.Start"
                                            AdornmentIcon="@Icons.Material.Filled.Search"
                                            Class="configs-search-field" />
                                        <MudButton Variant="Variant.Outlined" Color="Color.Default" OnClick="@(() => RefreshPluginCatalogAsync())" Disabled="@_catalogRefreshing">
                                            @(_catalogRefreshing ? "Refreshing..." : "Refresh Catalog")
                                        </MudButton>
                                        <MudChip T="string" Variant="Variant.Outlined">Selected @_editor.Plugins.Count</MudChip>
                                    </MudStack>

                                    @if (CatalogEntries.Count == 0)
                                    {
                                        <MudAlert Severity="Severity.Info" Variant="Variant.Outlined">
                                            Plugin catalog empty. Refresh to download MagnetarHub.
                                        </MudAlert>
                                    }
                                    else if (SelectableCatalogEntryCount == 0 && HasHiddenCatalogEntries)
                                    {
                                        <MudAlert Severity="Severity.Info" Variant="Variant.Outlined">
                                            MagnetarHub currently exposes only hidden or automatic plugins. They are not selectable manually.
                                        </MudAlert>
                                    }
                                    else
                                    {
                                        <MudTable T="QuasarPluginCatalogEntry" Dense="true" Hover="true" Breakpoint="Breakpoint.Md" Items="FilteredCatalogEntries">
                                            <HeaderContent>
                                                <MudTh>Use</MudTh>
                                                <MudTh>Name</MudTh>
                                                <MudTh>Author</MudTh>
                                                <MudTh>Description</MudTh>
                                                <MudTh Style="width:48px;"></MudTh>
                                                <MudTh Style="width:48px;"></MudTh>
                                            </HeaderContent>
                                            <RowTemplate>
                                                <MudTd DataLabel="Use">
                                                    <MudCheckBox T="bool" Value="IsPluginSelected(context.PluginId)" ValueChanged="@(value => SetPluginSelection(context, value))" />
                                                </MudTd>
                                                <MudTd DataLabel="Name">
                                                    <MudStack Spacing="0">
                                                        <MudText Typo="Typo.subtitle2">@context.FriendlyName</MudText>
                                                        <MudText Typo="Typo.caption" Class="config-secondary mono">@context.PluginId</MudText>
                                                        @if (context.IsLocalDevFolder)
                                                        {
                                                            <MudText Typo="Typo.caption" Class="config-secondary">Local dev folder</MudText>
                                                        }
                                                        else if (context.Hidden)
                                                        {
                                                            <MudText Typo="Typo.caption" Class="config-secondary">Hidden in hub</MudText>
                                                        }
                                                    </MudStack>
                                                </MudTd>
                                                <MudTd DataLabel="Author">@context.Author</MudTd>
                                                <MudTd DataLabel="Description">
                                                    <MudText Typo="Typo.body2" Class="plugin-description-line">@GetPluginTooltipText(context)</MudText>
                                                </MudTd>
                                                <MudTd Style="text-align:right;">
                                                    @if (ShouldShowPluginDescriptionDialog(context))
                                                    {
                                                        <MudIconButton
                                                            Icon="@Icons.Material.Filled.MoreHoriz"
                                                            Color="Color.Default"
                                                            Size="Size.Small"
                                                            Class="plugin-description-more"
                                                            OnClick="@(() => ShowPluginDescriptionAsync(context))"
                                                            title="Show full description" />
                                                    }
                                                </MudTd>
                                                <MudTd Style="text-align:right;">
                                                    @if (!string.IsNullOrWhiteSpace(GetPluginSourceUrl(context)))
                                                    {
                                                        <MudIconButton Icon="@Icons.Material.Filled.OpenInNew" Color="Color.Default" Href="@GetPluginSourceUrl(context)" Target="_blank" Size="Size.Small" title="Open GitHub repository" />
                                                    }
                                                </MudTd>
                                            </RowTemplate>
                                            <NoRecordsContent>
                                                <MudAlert Severity="Severity.Info" Variant="Variant.Outlined" Class="ma-4">
                                                    No plugin catalog entries match current search.
                                                </MudAlert>
                                            </NoRecordsContent>
                                        </MudTable>
                                    }
                                </ChildContent>
                            </MudExpansionPanel>

                            <MudExpansionPanel Class="configs-expansion-panel" Text="Advanced/manual plugin setup" Expanded="@IsPluginPanelExpanded(AdvancedPluginsPanelKey)" ExpandedChanged="@(expanded => SetPluginPanelExpandedAsync(AdvancedPluginsPanelKey, expanded))">
                                <ChildContent>
                                    <MudStack Row="true" Wrap="Wrap.Wrap" AlignItems="AlignItems.End" Spacing="1" Class="mt-2">
                                        <MudTextField @bind-Value="_customPluginId" Label="Add custom plugin ID" Variant="Variant.Outlined" Immediate="true" />
                                        <MudButton Variant="Variant.Outlined" Color="Color.Default" OnClick="AddCustomPlugin" Disabled="@string.IsNullOrWhiteSpace(_customPluginId)">
                                            Add Custom
                                        </MudButton>
                                    </MudStack>
                                </ChildContent>
                            </MudExpansionPanel>
                        </MudExpansionPanels>
                        </MudPaper>
                    </MudTabPanel>

                    <MudTabPanel Text="Mods">
                        <MudPaper Class="server-card pa-4" Square="true">
                        <MudExpansionPanels MultiExpansion="false" Elevation="0" Outlined="true" Dense="true" Class="configs-expansion-panels mb-4">
                            <MudExpansionPanel Class="configs-expansion-panel" Expanded="@IsModPanelExpanded(ModListPanelKey)" ExpandedChanged="@(expanded => SetModPanelExpanded(ModListPanelKey, expanded))">
                                <TitleContent>
                                    <MudStack Row="true" AlignItems="AlignItems.Center" Spacing="1">
                                        <MudText Typo="Typo.subtitle2">Mod list</MudText>
                                        <MudChip T="string" Size="Size.Small" Variant="Variant.Outlined">@FilteredMods.Count</MudChip>
                                    </MudStack>
                                </TitleContent>
                                <ChildContent>
                                <MudStack Row="true" Wrap="Wrap.Wrap" AlignItems="AlignItems.Center" Spacing="2" Class="mb-3 mt-2">
                                    <MudTextField
                                        @bind-Value="_modSearch"
                                        Label="Filter selected mods"
                                        Variant="Variant.Outlined"
                                        Immediate="true"
                                        Adornment="Adornment.Start"
                                        AdornmentIcon="@Icons.Material.Filled.Search"
                                        Class="configs-search-field" />
                                    <MudChip T="string" Variant="Variant.Outlined">Selected mods @FilteredMods.Count</MudChip>
                                    <MudButton Variant="Variant.Outlined"
                                               Color="Color.Primary"
                                               StartIcon="@Icons.Material.Filled.MergeType"
                                               OnClick="MergeModsFromWorldTemplateAsync">
                                        Merge from World Template
                                    </MudButton>
                                    <MudButton Variant="Variant.Outlined"
                                               Color="Color.Warning"
                                               StartIcon="@Icons.Material.Filled.DeleteSweep"
                                               OnClick="RemoveDeadModsAsync"
                                               Disabled="@(_deadModCleanupRunning || _editor?.Mods.Count == 0)">
                                        @(_deadModCleanupRunning ? "Checking Mods..." : "Remove Dead Mods")
                                    </MudButton>
                                </MudStack>

                                @if (!string.IsNullOrWhiteSpace(_deadModCleanupSummary))
                                {
                                    <MudAlert Severity="@(_deadModCleanupRemoved.Count > 0 ? Severity.Success : Severity.Info)"
                                              Variant="Variant.Outlined"
                                              Class="mb-3">
                                        <MudText Typo="Typo.body2">@_deadModCleanupSummary</MudText>
                                        @if (_deadModCleanupRemoved.Count > 0)
                                        {
                                            <MudText Typo="Typo.caption" Class="mt-1">
                                                Removed: @FormatModListSummary(_deadModCleanupRemoved)
                                            </MudText>
                                        }
                                    </MudAlert>
                                }

                                <MudTable T="QuasarModSelection" Dense="true" Hover="true" Breakpoint="Breakpoint.Sm" Items="FilteredMods">
                                    <HeaderContent>
                                        <MudTh>Name</MudTh>
                                        <MudTh>Workshop ID</MudTh>
                                        <MudTh></MudTh>
                                    </HeaderContent>
                                    <RowTemplate>
                                        <MudTd DataLabel="Name">@context.DisplayName</MudTd>
                                        <MudTd DataLabel="Workshop ID" Class="mono">@context.WorkshopId</MudTd>
                                        <MudTd Style="text-align:right;">
                                            <MudIconButton Icon="@Icons.Material.Filled.DeleteOutline" Color="Color.Error" OnClick="@(() => RemoveMod(context.WorkshopId))" />
                                        </MudTd>
                                    </RowTemplate>
                                    <NoRecordsContent>
                                        <MudAlert Severity="Severity.Info" Variant="Variant.Outlined" Class="ma-4">
                                            No mods match current search.
                                        </MudAlert>
                                    </NoRecordsContent>
                                </MudTable>
                                </ChildContent>
                            </MudExpansionPanel>

                            <MudExpansionPanel Class="configs-expansion-panel" Expanded="@IsModPanelExpanded(WorkshopPanelKey)" ExpandedChanged="@(expanded => SetModPanelExpanded(WorkshopPanelKey, expanded))">
                                <TitleContent>
                                    <MudStack Row="true" AlignItems="AlignItems.Center" Spacing="1">
                                        <MudText Typo="Typo.subtitle2">Steam Workshop</MudText>
                                        <MudChip T="string" Size="Size.Small" Variant="Variant.Outlined">@_workshopResults.Count result(s)</MudChip>
                                    </MudStack>
                                </TitleContent>
                                <ChildContent>
                                <MudStack Row="true" Wrap="Wrap.Wrap" AlignItems="AlignItems.Center" Spacing="2" Class="mb-4 mt-2">
                                    <MudTextField
                                        @bind-Value="_workshopSearchText"
                                        Label="Search Steam Workshop mods"
                                        Variant="Variant.Outlined"
                                        Immediate="true"
                                        Adornment="Adornment.Start"
                                        AdornmentIcon="@Icons.Material.Filled.Search"
                                        OnKeyDown="HandleWorkshopSearchKeyDown"
                                        Class="configs-search-field" />
                                    <MudButton Variant="Variant.Filled" Color="Color.Primary" OnClick="SearchWorkshopModsAsync" Disabled="@(!WorkshopCredentials.HasWebApiKey || _workshopSearchLoading)" StartIcon="@Icons.Material.Filled.Search">
                                        @(_workshopSearchLoading ? "Searching..." : "Search Workshop")
                                    </MudButton>
                                    <MudButton Variant="Variant.Outlined" Color="Color.Default" OnClick="LoadPopularWorkshopModsAsync" Disabled="@(!WorkshopCredentials.HasWebApiKey || _workshopSearchLoading)" StartIcon="@Icons.Material.Filled.Whatshot">
                                        Popular Mods
                                    </MudButton>
                                    <MudChip T="string" Variant="Variant.Outlined" Color="@(WorkshopCredentials.HasWebApiKey ? Color.Success : Color.Warning)" Icon="@(WorkshopCredentials.HasWebApiKey ? Icons.Material.Filled.Key : Icons.Material.Filled.KeyOff)">
                                        @(WorkshopCredentials.HasWebApiKey ? "Workshop API key set" : "Workshop API key needed")
                                    </MudChip>
                                    <MudButton Variant="Variant.Outlined" Color="Color.Default" OnClick="OpenWorkshopApiKeyDialogAsync" StartIcon="@Icons.Material.Filled.Key">
                                        @(WorkshopCredentials.HasWebApiKey ? "Update API Key" : "Add API Key")
                                    </MudButton>
                                </MudStack>

                                @if (!string.IsNullOrWhiteSpace(_workshopSearchError))
                                {
                                    <MudAlert Severity="Severity.Warning" Variant="Variant.Outlined" Class="mb-4">
                                        @_workshopSearchError
                                    </MudAlert>
                                }
                                else if (_workshopSearchLoading)
                                {
                                    <MudProgressLinear Color="Color.Primary" Indeterminate="true" Class="mb-4" />
                                }
                                else if (_workshopResultsLoaded && _workshopResults.Count == 0)
                                {
                                    <MudAlert Severity="Severity.Info" Variant="Variant.Outlined" Class="mb-4">
                                        No Steam Workshop mods found.
                                    </MudAlert>
                                }

                                @if (_workshopResults.Count > 0)
                                {
                                    <MudTable T="QuasarWorkshopSearchResult" Dense="true" Hover="true" Breakpoint="Breakpoint.Sm" Items="_workshopResults" Class="mb-4">
                                        <HeaderContent>
                                            <MudTh Style="width:56px;">Use</MudTh>
                                            <MudTh Style="width:96px;"></MudTh>
                                            <MudTh>Workshop mod</MudTh>
                                            <MudTh>Tags</MudTh>
                                            <MudTh></MudTh>
                                        </HeaderContent>
                                        <RowTemplate>
                                            <MudTd DataLabel="Use">
                                                <MudCheckBox T="bool"
                                                             Dense="true"
                                                             Value="@IsModSelected(context.WorkshopId)"
                                                             ValueChanged="@(selected => SetWorkshopResultSelection(context, selected))" />
                                            </MudTd>
                                            <MudTd DataLabel="Preview">
                                                @if (!string.IsNullOrWhiteSpace(context.PreviewUrl))
                                                {
                                                    <MudLink Href="@GetWorkshopUrl(context.WorkshopId)" Target="_blank" Underline="Underline.None">
                                                        <img src="@context.PreviewUrl" alt="@context.Title" loading="lazy" class="workshop-thumbnail" />
                                                    </MudLink>
                                                }
                                            </MudTd>
                                            <MudTd DataLabel="Workshop mod">
                                                <MudStack Spacing="0">
                                                    <MudText Typo="Typo.subtitle2">@context.Title</MudText>
                                                    <MudText Typo="Typo.caption" Class="mono">@context.WorkshopId</MudText>
                                                    @if (!string.IsNullOrWhiteSpace(context.Description))
                                                    {
                                                        <MudText Typo="Typo.caption" Class="config-secondary">@context.Description</MudText>
                                                    }
                                                </MudStack>
                                            </MudTd>
                                            <MudTd DataLabel="Tags">@GetWorkshopTagText(context)</MudTd>
                                            <MudTd Style="text-align:right;">
                                                <MudIconButton Icon="@Icons.Material.Filled.OpenInNew" Color="Color.Default" Href="@GetWorkshopUrl(context.WorkshopId)" Target="_blank" />
                                            </MudTd>
                                        </RowTemplate>
                                    </MudTable>
                                }
                                </ChildContent>
                            </MudExpansionPanel>

                            <MudExpansionPanel Class="configs-expansion-panel" Text="Advanced/manual mod setup" Expanded="@IsModPanelExpanded(AdvancedModsPanelKey)" ExpandedChanged="@(expanded => SetModPanelExpanded(AdvancedModsPanelKey, expanded))">
                                <ChildContent>
                                <MudGrid Class="mt-2">
                                    <MudItem xs="12">
                                        <MudTextField
                                            T="string"
                                            @bind-Value="_workshopInput"
                                            Label="Workshop URLs, IDs, or collection"
                                            Variant="Variant.Outlined"
                                            Lines="4"
                                            Immediate="true"
                                            HelperText="Paste single Steam Workshop URL, collection URL/ID, or bulk list of IDs. Collections expand into individual workshop items." />
                                    </MudItem>
                                    <MudItem xs="12">
                                        <MudButton Variant="Variant.Filled" Color="Color.Primary" OnClick="ResolveWorkshopModsAsync" Disabled="@(_modResolving || string.IsNullOrWhiteSpace(_workshopInput))">
                                            @(_modResolving ? "Resolving Workshop Items..." : "Resolve and Add Workshop Mods")
                                        </MudButton>
                                    </MudItem>
                                    <MudItem xs="12" md="5">
                                        <MudTextField @bind-Value="_newModName" Label="Mod name" Variant="Variant.Outlined" Immediate="true" />
                                    </MudItem>
                                    <MudItem xs="12" md="4">
                                        <MudNumericField T="long" @bind-Value="_newModWorkshopId" Label="Workshop ID" Variant="Variant.Outlined" Min="1" />
                                    </MudItem>
                                    <MudItem xs="12" md="3">
                                        <MudButton Variant="Variant.Outlined" Color="Color.Default" FullWidth="true" Class="configs-add-button" OnClick="AddMod" Disabled="@(_newModWorkshopId <= 0 || string.IsNullOrWhiteSpace(_newModName))">
                                            Add Mod
                                        </MudButton>
                                    </MudItem>
                                </MudGrid>
                                </ChildContent>
                            </MudExpansionPanel>
                        </MudExpansionPanels>
                        </MudPaper>
                    </MudTabPanel>
                </MudTabs>

                <MudExpansionPanels MultiExpansion="false" Elevation="0" Outlined="true" Dense="true" Class="configs-expansion-panels mt-4">
                    <MudExpansionPanel Class="configs-expansion-panel" Text="Developer" Expanded="false">
                        <ChildContent>
                        <MudText Typo="Typo.body2" Class="mb-3 mt-2">
                            Register local plugin source folders so they appear in the plugin catalog. Enable them per config profile before Magnetar loads them.
                        </MudText>

                        <MudTable T="QuasarDevFolderSelection" Dense="true" Hover="true" Breakpoint="Breakpoint.Sm" Items="GlobalDevFolders">
                            <HeaderContent>
                                <MudTh>Name</MudTh>
                                <MudTh>Folder</MudTh>
                                <MudTh>Manifest</MudTh>
                                <MudTh>Debug</MudTh>
                                <MudTh></MudTh>
                            </HeaderContent>
                            <RowTemplate>
                                <MudTd DataLabel="Name">
                                    <MudStack AlignItems="AlignItems.Start" Spacing="0">
                                        <MudText Typo="Typo.subtitle2">@context.Name</MudText>
                                        <MudText Typo="Typo.caption" Class="config-secondary">@context.PluginId</MudText>
                                    </MudStack>
                                </MudTd>
                                <MudTd DataLabel="Folder" Class="mono">@context.FolderPath</MudTd>
                                <MudTd DataLabel="Manifest" Class="mono">@context.DataFile</MudTd>
                                <MudTd DataLabel="Debug">
                                    <MudSwitch T="bool" Value="@context.DebugBuild" ValueChanged="@(value => SetDevFolderDebugAsync(context, value))" Color="Color.Primary" />
                                </MudTd>
                                <MudTd Style="text-align:right;">
                                    <MudIconButton Icon="@Icons.Material.Filled.DeleteOutline" Color="Color.Error" OnClick="@(() => RemoveDevFolder(context))" />
                                </MudTd>
                            </RowTemplate>
                            <NoRecordsContent>
                                <MudAlert Severity="Severity.Info" Variant="Variant.Outlined" Class="ma-4">
                                    No dev folders registered.
                                </MudAlert>
                            </NoRecordsContent>
                        </MudTable>

                        <div class="mt-3 mb-3">
                            <MudButton Variant="Variant.Outlined" Color="Color.Default" Class="configs-add-button" StartIcon="@Icons.Material.Filled.Description" OnClick="AddDevFolderAsync">
                                Add dev folder...
                            </MudButton>
                        </div>
                        </ChildContent>
                    </MudExpansionPanel>
                </MudExpansionPanels>
            </MudStack>
        }
        </div>
    </MudItem>
</MudGrid>

@code
{
    private const string AccessCategoryKey = "access";
    private const string ServerCategoryKey = "server";
    private const string AccessGroupIdAnchorId = "config-access-group-id";
    private const string AccessAdministratorsAnchorId = "config-access-administrators";
    private const string AccessReservedAnchorId = "config-access-reserved";
    private const string AccessBannedAnchorId = "config-access-banned";
    private const string ModListPanelKey = "mod-list";
    private const string WorkshopPanelKey = "workshop";
    private const string AdvancedModsPanelKey = "advanced-mods";
    private const string PluginListPanelKey = "plugin-list";
    private const string PluginCatalogPanelKey = "plugin-catalog";
    private const string AdvancedPluginsPanelKey = "advanced-plugins";
    private const int PluginDescriptionFallbackMaxLength = 50;
    private const string ConfigOptionTooltipStyle = "white-space: pre-line; max-width: 34rem; text-align: left; line-height: 1.35; font-size: 0.78rem;";
    private string _selectedProfileId = string.Empty;
    private QuasarConfigProfile? _editor;
    private string _newProfileName = string.Empty;
    private string _worldSearch = string.Empty;
    private string _pluginSearch = string.Empty;
    private string _modSearch = string.Empty;
    private string _workshopSearchText = string.Empty;
    private string _customPluginId = string.Empty;
    private string _workshopInput = string.Empty;
    private string _newModName = string.Empty;
    private long _newModWorkshopId;
    private string _lastDevFolderPath = string.Empty;
    private List<QuasarWorkshopSearchResult> _workshopResults = [];
    private bool _catalogRefreshing;
    private bool _workshopSearchLoading;
    private bool _workshopResultsLoaded;
    private bool _modResolving;
    private bool _deadModCleanupRunning;
    private string _deadModCleanupSummary = string.Empty;
    private List<QuasarModSelection> _deadModCleanupRemoved = [];
    private string? _workshopSearchError;
    private string? _expandedCategoryKey;
    private string _expandedModPanelKey = ModListPanelKey;
    private string _expandedPluginPanelKey = PluginListPanelKey;
    private string _selectedProfileSnapshot = string.Empty;
    private bool _hasExplicitCategoryExpansion;

    [Parameter]
    public string? InitialProfileId { get; set; }

    [Parameter]
    [SupplyParameterFromQuery(Name = "profileId")]
    public string? RequestedProfileId { get; set; }

    private IReadOnlyList<QuasarConfigProfile> Templates => ConfigProfiles.GetProfiles();
    private IReadOnlyList<QuasarDevFolderSelection> GlobalDevFolders => DevFolderCatalog.GetDevFolders();
    private IReadOnlyList<QuasarPluginCatalogEntry> CatalogEntries => PluginCatalog.GetEntries();

    private List<QuasarConfigOptionDefinition> VisibleWorldOptions => QuasarConfigMetadata.Options
        .Where(option => option.Matches(_worldSearch))
        .OrderBy(option => QuasarConfigMetadata.Categories.First(category => category.Key == option.CategoryKey).Order)
        .ThenBy(option => option.Order)
        .ToList();

    private List<QuasarConfigOptionCategory> VisibleCategories => QuasarConfigMetadata.Categories
        .Where(category => GetCategoryOptions(category.Key).Count > 0)
        .OrderBy(category => category.Order)
        .ToList();

    private List<QuasarConfigOptionCategory> RemainingVisibleCategories => VisibleCategories
        .Where(category => !string.Equals(category.Key, ServerCategoryKey, StringComparison.OrdinalIgnoreCase))
        .ToList();

    private bool IsAccessSectionVisible => string.IsNullOrWhiteSpace(_worldSearch)
        || TryGetFirstAccessAnchorId(out _);

    private bool HasVisibleWorldContent => IsAccessSectionVisible || VisibleCategories.Count > 0;

    private int VisibleWorldMatchCount => VisibleWorldOptions.Count + GetAccessMatchCount();

    private string? FirstMatchingOptionId
    {
        get
        {
            if (VisibleWorldOptions.Count > 0)
                return GetOptionAnchorId(VisibleWorldOptions[0]);

            return TryGetFirstAccessAnchorId(out var accessAnchorId)
                ? accessAnchorId
                : null;
        }
    }

    private List<QuasarPluginCatalogEntry> FilteredCatalogEntries => CatalogEntries
        .Where(IsCatalogEntryVisible)
        .Where(MatchesPluginSearch)
        .ToList();

    private int SelectableCatalogEntryCount => CatalogEntries.Count(entry => !entry.Hidden);

    private bool HasHiddenCatalogEntries => CatalogEntries.Any(entry => entry.Hidden);

    private bool IsCatalogEntryVisible(QuasarPluginCatalogEntry entry) =>
        !entry.Hidden ||
        IsPluginSelected(entry.PluginId) ||
        !string.IsNullOrWhiteSpace(_pluginSearch);

    private List<QuasarPluginSelection> FilteredPlugins => (_editor?.Plugins ?? [])
        .Where(plugin => MatchesPluginSearch(plugin))
        .OrderBy(plugin => plugin.DisplayName, StringComparer.OrdinalIgnoreCase)
        .ThenBy(plugin => plugin.PluginId, StringComparer.OrdinalIgnoreCase)
        .ToList();

    private List<QuasarModSelection> FilteredMods => (_editor?.Mods ?? [])
        .Where(mod => MatchesModSearch(mod))
        .OrderBy(mod => mod.DisplayName, StringComparer.OrdinalIgnoreCase)
        .ThenBy(mod => mod.WorkshopId)
        .ToList();

    protected override void OnInitialized()
    {
        ConfigProfiles.Changed += HandleProfilesChanged;
        DevFolderCatalog.Changed += HandleProfilesChanged;
        ServerCatalog.Changed += HandleServersChanged;
        WorkshopCredentials.Changed += HandleWorkshopCredentialsChanged;
        SelectProfile(GetInitialProfileId());
    }

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (!firstRender)
            return;

        if (CatalogEntries.Count == 0)
            await RefreshPluginCatalogAsync();

        if (WorkshopCredentials.HasWebApiKey)
            await LoadPopularWorkshopModsAsync();
    }

    public void Dispose()
    {
        ConfigProfiles.Changed -= HandleProfilesChanged;
        DevFolderCatalog.Changed -= HandleProfilesChanged;
        ServerCatalog.Changed -= HandleServersChanged;
        WorkshopCredentials.Changed -= HandleWorkshopCredentialsChanged;
    }

    private async Task CreateProfileAsync()
    {
        var name = _newProfileName.Trim();
        if (string.IsNullOrWhiteSpace(name))
        {
            Snackbar.Add("Profile name required.", Severity.Warning);
            return;
        }

        var template = new QuasarConfigProfile
        {
            Name = name,
        };

        await ConfigProfiles.UpsertAsync(template);
        _newProfileName = string.Empty;
        SelectProfile(template.ConfigProfileId);
        Snackbar.Add("Config profile created.", Severity.Success);
    }

    private async Task SaveTemplateAsync()
    {
        await SaveTemplateInternalAsync(reselectAfterSave: true);
    }

    private async Task<bool> SaveTemplateInternalAsync(bool reselectAfterSave)
    {
        if (_editor is null)
            return true;

        if (string.IsNullOrWhiteSpace(_editor.Name))
        {
            Snackbar.Add("Profile name required.", Severity.Warning);
            return false;
        }

        await ConfigProfiles.UpsertAsync(_editor);
        if (reselectAfterSave)
            SelectProfile(_editor.ConfigProfileId);
        else
            _selectedProfileSnapshot = CreateProfileSnapshot(_editor);

        Snackbar.Add("Config profile saved.", Severity.Success);
        return true;
    }

    private async Task CloneProfileAsync(string configProfileId)
    {
        var template = ConfigProfiles.GetProfile(configProfileId);
        if (template is null)
            return;

        template.ConfigProfileId = string.Empty;
        template.Name = $"{template.Name} (Copy)";
        await ConfigProfiles.UpsertAsync(template);
        SelectProfile(template.ConfigProfileId);
        Snackbar.Add("Config profile cloned.", Severity.Success);
    }

    private async Task DeleteProfileAsync(string configProfileId)
    {
        var assignedServers = GetAssignedServers(configProfileId);
        if (assignedServers.Count > 0)
        {
            Snackbar.Add("Profile still assigned to servers. Reassign or clear them first.", Severity.Warning);
            return;
        }

        var profile = ConfigProfiles.GetProfile(configProfileId);
        var profileName = profile?.Name ?? configProfileId;
        var confirmed = await DialogService.ShowMessageBoxAsync(
            "Delete config profile?",
            $"'{profileName}' will be permanently removed. This cannot be undone.",
            yesText: "Delete",
            cancelText: "Cancel");

        if (confirmed != true)
            return;

        await ConfigProfiles.DeleteAsync(configProfileId);
        if (string.Equals(_selectedProfileId, configProfileId, StringComparison.OrdinalIgnoreCase))
            SelectProfile(Templates.FirstOrDefault(template => !string.Equals(template.ConfigProfileId, configProfileId, StringComparison.OrdinalIgnoreCase))?.ConfigProfileId ?? string.Empty);

        Snackbar.Add("Config profile deleted.", Severity.Info);
    }

    private async Task ResetEditorAsync()
    {
        var confirmed = await DialogService.ShowMessageBoxAsync(
            "Reset config profile?",
            "Pending editor changes will be discarded and the profile will be reloaded from disk.",
            yesText: "Reset",
            cancelText: "Cancel");

        if (confirmed != true)
            return;

        SelectProfile(_selectedProfileId);
    }

    private async Task SelectProfileFromListAsync(string configProfileId)
    {
        if (string.Equals(_selectedProfileId, configProfileId, StringComparison.OrdinalIgnoreCase))
            return;

        if (!await ConfirmPendingChangesBeforeSwitchAsync())
            return;

        SelectProfile(configProfileId);
    }

    private async Task<bool> ConfirmPendingChangesBeforeSwitchAsync()
    {
        if (!HasPendingChanges())
            return true;

        var dialog = await DialogService.ShowAsync<ConfigProfilePendingChangesDialog>(
            "Unsaved config changes",
            new DialogOptions { CloseOnEscapeKey = true, FullWidth = true, MaxWidth = MaxWidth.Small });

        var result = await dialog.Result;
        if (result is null ||
            result.Canceled ||
            result.Data is not ConfigProfilePendingChangesDialog.PendingChangesAction action ||
            action == ConfigProfilePendingChangesDialog.PendingChangesAction.Cancel)
        {
            return false;
        }

        if (action == ConfigProfilePendingChangesDialog.PendingChangesAction.Save)
            return await SaveTemplateInternalAsync(reselectAfterSave: false);

        return true;
    }

    private void SelectProfile(string configProfileId)
    {
        _selectedProfileId = configProfileId?.Trim() ?? string.Empty;
        _editor = string.IsNullOrWhiteSpace(_selectedProfileId)
            ? null
            : ConfigProfiles.GetProfile(_selectedProfileId);
        _selectedProfileSnapshot = CreateProfileSnapshot(_editor);
        _deadModCleanupSummary = string.Empty;
        _deadModCleanupRemoved = [];
        _hasExplicitCategoryExpansion = true;
        _expandedCategoryKey = null;
    }

    private string GetInitialProfileId()
    {
        var requested = FirstExistingProfileId(InitialProfileId) ?? FirstExistingProfileId(RequestedProfileId);
        return requested ?? Templates.FirstOrDefault()?.ConfigProfileId ?? string.Empty;
    }

    private string? FirstExistingProfileId(string? configProfileId)
    {
        if (string.IsNullOrWhiteSpace(configProfileId))
