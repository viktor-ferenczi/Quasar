@implements IDisposable
@inject AgentRegistry Registry

<PageTitle>Hosts</PageTitle>

<MudText Typo="Typo.h5" Class="mb-2">Hosts</MudText>
<MudText Typo="Typo.body2" Class="mb-4">Each host can run many dedicated servers and plugin agents behind one shared Quasar supervisor endpoint.</MudText>

<MudPaper Class="server-card">
    <MudTable T="HostRow" Dense="true" Hover="true" Breakpoint="Breakpoint.Sm" Items="HostRows">
        <HeaderContent>
            <MudTh><MudTableSortLabel SortBy="new Func<HostRow, object>(x => x.HostName)">Host</MudTableSortLabel></MudTh>
            <MudTh><MudTableSortLabel SortBy="new Func<HostRow, object>(x => x.ServerCount)">Servers</MudTableSortLabel></MudTh>
            <MudTh><MudTableSortLabel SortBy="new Func<HostRow, object>(x => x.ConnectedAgents)">Connected Agents</MudTableSortLabel></MudTh>
            <MudTh><MudTableSortLabel SortBy="new Func<HostRow, object>(x => x.PlayersOnline)">Players</MudTableSortLabel></MudTh>
        </HeaderContent>
        <RowTemplate>
            <MudTd DataLabel="Host">@context.HostName</MudTd>
            <MudTd DataLabel="Servers">@context.ServerCount</MudTd>
            <MudTd DataLabel="Connected Agents">@context.ConnectedAgents</MudTd>
            <MudTd DataLabel="Players">@context.PlayersOnline</MudTd>
        </RowTemplate>
        <NoRecordsContent>
            <MudAlert Severity="Severity.Info" Variant="Variant.Outlined" Class="ma-4">
                No host data yet.
            </MudAlert>
        </NoRecordsContent>
    </MudTable>
</MudPaper>

@code
{
    private IReadOnlyList<HostRow> HostRows => Registry
        .GetAgents()
        .GroupBy(agent => agent.HostKey, StringComparer.OrdinalIgnoreCase)
        .Select(group => new HostRow
        {
            HostName = group.First().HostDisplayName,
            ServerCount = group.Select(agent => agent.ServerKey).Distinct(StringComparer.OrdinalIgnoreCase).Count(),
            ConnectedAgents = group.Count(agent => agent.IsConnected),
            PlayersOnline = group.Sum(agent => agent.Snapshot?.Metrics.PlayersOnline ?? 0),
        })
        .OrderBy(row => row.HostName, StringComparer.OrdinalIgnoreCase)
        .ToList();

    protected override void OnInitialized()
    {
        Registry.Changed += HandleRegistryChanged;
    }

    public void Dispose()
    {
        Registry.Changed -= HandleRegistryChanged;
    }

    private void HandleRegistryChanged()
    {
        _ = InvokeAsync(StateHasChanged);
    }

    private sealed class HostRow
    {
        public string HostName { get; set; } = string.Empty;

        public int ServerCount { get; set; }

        public int ConnectedAgents { get; set; }

        public int PlayersOnline { get; set; }
    }
}
