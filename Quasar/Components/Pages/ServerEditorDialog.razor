    private string GetDefaultWorldPath()
    {
        var dsPath = string.IsNullOrWhiteSpace(_editor.DedicatedServerAppDataPath)
            ? GetDefaultDedicatedServerAppDataPath()
            : _editor.DedicatedServerAppDataPath;

        var worldName = GetUniqueNamePreview();

        foreach (var ch in Path.GetInvalidFileNameChars())
            worldName = worldName.Replace(ch, '-');

        return Path.Combine(dsPath, "Saves", worldName);
    }

    private string GetDefaultConfigFilePath()
    {
        var dsPath = string.IsNullOrWhiteSpace(_editor.DedicatedServerAppDataPath)
            ? GetDefaultDedicatedServerAppDataPath()
            : _editor.DedicatedServerAppDataPath;

        return Path.Combine(dsPath, "SpaceEngineers-Dedicated.cfg");
    }

