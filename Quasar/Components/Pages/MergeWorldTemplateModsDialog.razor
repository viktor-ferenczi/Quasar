@using Quasar.Models
@using Quasar.Services
@inject QuasarWorldTemplateCatalog WorldTemplates

<MudDialog>
    <DialogContent>
        <MudStack Spacing="3">
            <MudText Typo="Typo.body2">
                Pick a world template to merge its mods into this config profile. Only mods that aren't already in the profile will be added.
            </MudText>

            <MudSelect T="string"
                       Value="@_selectedTemplateId"
                       ValueChanged="OnTemplateChanged"
                       Label="World template"
                       Variant="Variant.Outlined"
                       Required="true"
                       RequiredError="World template required.">
                @foreach (var template in _templates)
                {
                    <MudSelectItem T="string" Value="@template.WorldTemplateId">@template.Name</MudSelectItem>
                }
            </MudSelect>

            @if (!string.IsNullOrWhiteSpace(_loadError))
            {
                <MudAlert Severity="Severity.Warning" Variant="Variant.Outlined">@_loadError</MudAlert>
            }
            else if (!string.IsNullOrWhiteSpace(_selectedTemplateId))
            {
                <MudAlert Severity="Severity.Info" Variant="Variant.Outlined">
                    @_newMods.Count new mod(s) will be added. @_duplicateCount already in profile.
                </MudAlert>

                @if (_newMods.Count > 0)
                {
                    <MudTable T="QuasarModSelection" Items="_newMods" Dense="true" Hover="true" Breakpoint="Breakpoint.Sm">
                        <HeaderContent>
                            <MudTh>Name</MudTh>
                            <MudTh>Workshop ID</MudTh>
                        </HeaderContent>
                        <RowTemplate>
                            <MudTd DataLabel="Name">@context.DisplayName</MudTd>
                            <MudTd DataLabel="Workshop ID" Class="mono">@context.WorkshopId</MudTd>
                        </RowTemplate>
                    </MudTable>
                }
            }
        </MudStack>
    </DialogContent>
    <DialogActions>
        <MudButton Variant="Variant.Text" Color="Color.Default" OnClick="Cancel">Cancel</MudButton>
        <MudButton Variant="Variant.Filled"
                   Color="Color.Primary"
                   OnClick="Confirm"
                   Disabled="@(_newMods.Count == 0 || !string.IsNullOrWhiteSpace(_loadError))">
            Merge @_newMods.Count mod(s)
        </MudButton>
    </DialogActions>
</MudDialog>

@code
{
    [CascadingParameter]
    private IMudDialogInstance MudDialog { get; set; } = default!;

    [Parameter]
    public IReadOnlyCollection<long> ExistingWorkshopIds { get; set; } = Array.Empty<long>();

    private string _selectedTemplateId = string.Empty;
    private List<QuasarModSelection> _newMods = [];
    private int _duplicateCount;
    private string? _loadError;
    private IReadOnlyList<QuasarWorldTemplate> _templates = Array.Empty<QuasarWorldTemplate>();

    protected override void OnInitialized()
    {
        _templates = WorldTemplates.GetTemplates();
    }

    private void OnTemplateChanged(string value)
    {
        _selectedTemplateId = value ?? string.Empty;
        LoadDiff();
    }

    private void LoadDiff()
    {
        _newMods = [];
        _duplicateCount = 0;
        _loadError = null;

        if (string.IsNullOrWhiteSpace(_selectedTemplateId))
            return;

        var worldDirectory = WorldTemplates.GetWorldDirectory(_selectedTemplateId);
        var sandboxConfigPath = Path.Combine(worldDirectory, WorldSandboxConfigEditor.SandboxConfigFileName);

        IReadOnlyList<QuasarModSelection> templateMods;
        try
        {
            templateMods = WorldSandboxConfigEditor.ReadMods(sandboxConfigPath);
        }
        catch (Exception exception)
        {
            _loadError = exception.Message;
            return;
        }

        var existing = new HashSet<long>(ExistingWorkshopIds);
        foreach (var mod in templateMods)
        {
            if (existing.Contains(mod.WorkshopId))
                _duplicateCount++;
            else
                _newMods.Add(mod);
        }
    }

    private void Cancel() => MudDialog.Cancel();

    private void Confirm()
    {
        MudDialog.Close(DialogResult.Ok(_newMods));
    }
}
