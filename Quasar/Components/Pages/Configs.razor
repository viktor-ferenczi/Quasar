        return tags.Count == 0 ? "-" : string.Join(", ", tags);
    }

    // The catalog column shows the full Tooltip (short, usually single line). When the
    // Tooltip is empty it falls back to a short word-boundary preview of the Description.
    private string GetPluginTooltipText(QuasarPluginCatalogEntry entry)
    {
        if (!string.IsNullOrWhiteSpace(entry.Tooltip))
            return NormalizePluginDescription(entry.Tooltip);

        if (string.IsNullOrWhiteSpace(entry.Description))
            return "-";

        var description = NormalizePluginDescription(entry.Description);
        return description.Length <= PluginDescriptionFallbackMaxLength
            ? description
            : TruncateAtWordBoundary(description, PluginDescriptionFallbackMaxLength);
    }

    private bool ShouldShowPluginDescriptionDialog(QuasarPluginCatalogEntry entry)
    {
        // The dialog shows the full Description, so there must be one to show.
        if (string.IsNullOrWhiteSpace(entry.Description))
            return false;

        // When a Tooltip is shown inline the full Description is not visible, so always offer it.
        if (!string.IsNullOrWhiteSpace(entry.Tooltip))
            return true;

        // Otherwise the Description is shown inline; only offer the dialog when it was truncated.
        return NormalizePluginDescription(entry.Description).Length > PluginDescriptionFallbackMaxLength;
    }

    private static string NormalizePluginDescription(string description) =>
        string.Join(' ', description
            .Split(["\r\n", "\n", "\r"], StringSplitOptions.None)
            .Select(line => line.Trim())
            .Where(line => !string.IsNullOrWhiteSpace(line)));

    private static string TruncateAtWordBoundary(string text, int maxLength)
    {
        if (text.Length <= maxLength)
            return text;

        var cutoff = text.LastIndexOf(' ', maxLength - 1);
        if (cutoff <= 0)
            cutoff = maxLength;

        return $"{text[..cutoff].TrimEnd()}...";
    }

    private async Task ShowPluginDescriptionAsync(QuasarPluginCatalogEntry entry)
    {
        var parameters = new DialogParameters
        {
            [nameof(PluginCatalogDescriptionDialog.DisplayName)] = string.IsNullOrWhiteSpace(entry.FriendlyName) ? entry.PluginId : entry.FriendlyName,
            [nameof(PluginCatalogDescriptionDialog.PluginId)] = entry.PluginId,
            [nameof(PluginCatalogDescriptionDialog.Description)] = string.IsNullOrWhiteSpace(entry.Description) ? "-" : entry.Description,
        };

        await DialogService.ShowAsync<PluginCatalogDescriptionDialog>(
            "Plugin description",
            parameters,
            new DialogOptions { CloseOnEscapeKey = true, MaxWidth = MaxWidth.Small, FullWidth = true });
    }

    private string GetPluginSourceUrl(QuasarPluginSelection plugin)
    {
        var entry = CatalogEntries.FirstOrDefault(catalogEntry =>
            string.Equals(catalogEntry.PluginId, plugin.PluginId, StringComparison.OrdinalIgnoreCase));

        return entry is null
