@page "/discord"
@implements IDisposable
@inject DiscordOptionsCatalog DiscordOptionsCatalog
@inject DeathMessagesCatalog DeathMessagesCatalog
@inject DedicatedServerInstanceCatalog InstanceCatalog
@inject DiscordBotService DiscordBotService
@inject ISnackbar Snackbar

<PageTitle>Discord</PageTitle>

<MudText Typo="Typo.h4" GutterBottom="true">Discord</MudText>
<MudText Typo="Typo.body2" Class="mb-4">One bot, many Quasar servers. Bind command, chat, log, and analytics channels per server.</MudText>

<MudGrid>
    <MudItem xs="12" xl="4">
        <MudPaper Class="pa-4 summary-card">
            <MudStack Spacing="2">
                <MudStack Row="true" AlignItems="AlignItems.Center" Justify="Justify.SpaceBetween">
                    <MudText Typo="Typo.h6">Bot Settings</MudText>
                    <MudChip T="string" Color="@GetStatusColor()" Variant="Variant.Outlined">
                        @GetStatusLabel()
                    </MudChip>
                </MudStack>

                @if (!string.IsNullOrWhiteSpace(BotStatus.LastError))
                {
                    <MudAlert Severity="Severity.Error" Variant="Variant.Outlined">
                        @BotStatus.LastError
                    </MudAlert>
                }

                <MudAlert Severity="Severity.Info" Variant="Variant.Outlined" Dense="true">
                    Create a Discord app and bot in the Developer Portal, copy the bot token here, enable Message Content Intent if using text commands, then invite the bot with bot scope. Required channel permissions: View Channel, Send Messages, Read Message History, Attach Files, and Embed Links.
                    <MudLink Href="https://docs.discord.com/developers/docs/getting-started" Target="_blank">Bot setup</MudLink>
                    ·
                    <MudLink Href="https://docs.discord.com/developers/platform/oauth2-and-permissions" Target="_blank">OAuth2 permissions</MudLink>
                </MudAlert>

                <MudCheckBox T="bool" @bind-Value="_options.Enabled" Label="Enabled" />
                <MudTextField @bind-Value="_options.BotToken"
                              Label="Bot token"
                              Variant="Variant.Outlined"
                              InputType="InputType.Password" />
                <MudNumericField T="ulong"
                                 Value="_options.GuildId"
                                 ValueChanged="HandleGuildIdChanged"
                                 Label="Guild ID"
                                 Variant="Variant.Outlined"
                                 Min="0" />

                <MudButton Variant="Variant.Filled" Color="Color.Primary" OnClick="SaveBotSettingsAsync">
                    Save Bot Settings
                </MudButton>
            </MudStack>
        </MudPaper>
    </MudItem>

    <MudItem xs="12" xl="8">
        <MudPaper Class="pa-4 server-card">
            <MudStack Row="true" AlignItems="AlignItems.Center" Justify="Justify.SpaceBetween" Class="mb-2">
                <MudText Typo="Typo.h6">Per-Server Bindings</MudText>
                <MudText Typo="Typo.caption">@($"{InstanceDefinitions.Count} server(s)")</MudText>
            </MudStack>

            @if (InstanceDefinitions.Count == 0)
            {
                <MudAlert Severity="Severity.Info" Variant="Variant.Outlined">
                    No Quasar servers defined yet.
                </MudAlert>
            }
            else
            {
                <MudExpansionPanels MultiExpansion="true" Elevation="0" Outlined="true" Dense="true">
                    @foreach (var definition in InstanceDefinitions)
                    {
                        var instanceOptions = GetInstanceOptions(definition.UniqueName);

                        <MudExpansionPanel Text="@definition.UniqueName" @key="definition.UniqueName">
                            <MudStack Spacing="2" Class="pt-2">
                                <MudText Typo="Typo.caption" Class="mono">@definition.UniqueName</MudText>

                                <MudTextField @bind-Value="instanceOptions.CommandPrefix"
                                              Label="Command prefix"
                                              Variant="Variant.Outlined" />
                                <MudNumericField T="ulong?"
                                                 @bind-Value="instanceOptions.CommandChannelId"
                                                 Label="Command channel ID"
                                                 Variant="Variant.Outlined"
                                                 Min="0" />
                                <MudNumericField T="ulong?"
                                                 @bind-Value="instanceOptions.ChatRelayChannelId"
                                                 Label="Chat relay channel ID"
                                                 Variant="Variant.Outlined"
                                                 Min="0" />
                                <MudNumericField T="ulong?"
                                                 @bind-Value="instanceOptions.LogChannelId"
                                                 Label="Log channel ID"
                                                 Variant="Variant.Outlined"
                                                 Min="0" />
                                <MudNumericField T="ulong?"
                                                 @bind-Value="instanceOptions.AnalyticsChannelId"
                                                 Label="Analytics channel ID"
                                                 Variant="Variant.Outlined"
                                                 Min="0" />
                                <MudNumericField T="ulong?"
                                                 @bind-Value="instanceOptions.DeathChannelId"
                                                 Label="Death messages channel ID"
                                                 Variant="Variant.Outlined"
                                                 Min="0" />
                                <MudNumericField T="int"
                                                 @bind-Value="instanceOptions.LogExportIntervalMinutes"
                                                 Label="Log export interval (minutes)"
                                                 Variant="Variant.Outlined"
                                                 Min="1" />
                                <MudNumericField T="int"
                                                 @bind-Value="instanceOptions.AnalyticsExportIntervalMinutes"
                                                 Label="Analytics export interval (minutes)"
                                                 Variant="Variant.Outlined"
                                                 Min="1" />

                                <MudCheckBox T="bool" @bind-Value="instanceOptions.EnableChatRelay" Label="Enable chat relay" />
                                <MudCheckBox T="bool" @bind-Value="instanceOptions.EnableLogExport" Label="Enable log export" />
                                <MudCheckBox T="bool" @bind-Value="instanceOptions.EnableAnalyticsExport" Label="Enable analytics export" />
                                <MudCheckBox T="bool" @bind-Value="instanceOptions.EnableDeathMessages" Label="Enable death messages" />
                                <MudTextField @bind-Value="instanceOptions.DeathMessageEmotes"
                                              Label="Death emotes (comma-separated)"
                                              Variant="Variant.Outlined" />
                                <MudCheckBox T="bool" @bind-Value="instanceOptions.RelayNonCommandMessages" Label="Relay non-command Discord messages to game chat" />

                                <MudButton Variant="Variant.Filled" Color="Color.Primary" OnClick="@(() => SaveInstanceAsync(definition.UniqueName))">
                                    Save Server
                                </MudButton>
                            </MudStack>
                        </MudExpansionPanel>
                    }
                </MudExpansionPanels>
            }
        </MudPaper>
    </MudItem>
</MudGrid>

<MudPaper Class="pa-4 mt-4">
    @{
        var deathTemplateCategories = GetDeathMessageCategories();
        var deathTemplateCount = deathTemplateCategories.Sum(category => CountDeathMessageLines(category.EditorText));
    }
    <MudStack Spacing="2">
        <MudText Typo="Typo.h6">Death Message Templates</MudText>
        <MudText Typo="Typo.body2">
            Edit <span class="mono">@MagnetarPaths.GetQuasarDeathMessagesPath()</span> for custom per-death-type templates using <code>{victim}</code>, <code>{killer}</code>, and <code>{weapon}</code>.
        </MudText>
        <MudText Typo="Typo.caption">
            Current Quasar categories and full template lines shown below.
        </MudText>
        <MudStack Row="true" Wrap="Wrap.Wrap" Spacing="1">
            <MudButton Variant="Variant.Filled" Color="Color.Primary" OnClick="SaveDeathTemplatesAsync">
                Save Death Templates
            </MudButton>
            <MudButton Variant="Variant.Outlined" Color="Color.Default" OnClick="ResetDeathTemplatesAsync">
                Reset to Defaults
            </MudButton>
        </MudStack>

        <MudExpansionPanels MultiExpansion="true" Elevation="0" Outlined="true" Dense="true">
            <MudExpansionPanel>
                <TitleContent>
                    <MudStack Row="true" AlignItems="AlignItems.Center" Justify="Justify.SpaceBetween" Class="w-100">
                        <MudStack Spacing="0">
                            <MudText Typo="Typo.subtitle1">Quasar Defaults</MudText>
                            <MudText Typo="Typo.caption">
                                One line per template. Press Enter for another line.
                            </MudText>
                        </MudStack>
                        <MudStack Row="true" Wrap="Wrap.Wrap" Spacing="1">
                            <MudChip T="string" Variant="Variant.Outlined" Size="Size.Small">@deathTemplateCategories.Count categories</MudChip>
                            <MudChip T="string" Variant="Variant.Outlined" Size="Size.Small">@deathTemplateCount lines</MudChip>
                        </MudStack>
                    </MudStack>
                </TitleContent>
                <ChildContent>
                    <MudGrid Class="mt-2">
                        @foreach (var category in deathTemplateCategories)
                        {
                            <MudItem xs="12" md="6">
                                <MudPaper Class="pa-3" Outlined="true" @key="category.Key">
                                    <MudStack Spacing="2">
                                        <MudStack Row="true" AlignItems="AlignItems.Start" Justify="Justify.SpaceBetween">
                                            <MudStack Spacing="0">
                                                <MudText Typo="Typo.subtitle1">@category.Title</MudText>
                                                <MudText Typo="Typo.caption">@category.Description</MudText>
                                            </MudStack>
                                            <MudChip T="string" Variant="Variant.Outlined" Size="Size.Small">@CountDeathMessageLines(category.EditorText)</MudChip>
                                        </MudStack>

                                        <MudTextField T="string"
                                                      Value="@category.EditorText"
                                                      ValueChanged="@(value => SetDeathMessageEditorText(category.Key, value ?? string.Empty))"
                                                      Label="@($"{category.Title} templates")"
                                                      Variant="Variant.Outlined"
                                                      Lines="6"
                                                      Immediate="true"
                                                      HelperText="One non-empty line per message template." />
                                    </MudStack>
                                </MudPaper>
                            </MudItem>
                        }
                    </MudGrid>
                </ChildContent>
            </MudExpansionPanel>
        </MudExpansionPanels>
    </MudStack>
</MudPaper>

@code
{
    private DiscordOptions _options = new();
    private DeathMessagesConfig _deathMessageConfig = DeathMessagesConfig.CreateDefault();

    private IReadOnlyList<DedicatedServerInstanceDefinition> InstanceDefinitions => InstanceCatalog.GetInstances();

    private DiscordBotStatusSnapshot BotStatus => DiscordBotService.GetStatus();

    protected override void OnInitialized()
    {
        ReloadOptions();
        ReloadDeathMessageEditors();
        DiscordOptionsCatalog.Changed += HandleOptionsChanged;
        DeathMessagesCatalog.Changed += HandleDeathMessagesChanged;
        InstanceCatalog.Changed += HandleInstanceCatalogChanged;
        DiscordBotService.Changed += HandleBotStatusChanged;
    }

    public void Dispose()
    {
        DiscordOptionsCatalog.Changed -= HandleOptionsChanged;
        DeathMessagesCatalog.Changed -= HandleDeathMessagesChanged;
        InstanceCatalog.Changed -= HandleInstanceCatalogChanged;
        DiscordBotService.Changed -= HandleBotStatusChanged;
    }

    private async Task SaveBotSettingsAsync()
    {
        await SaveAsync("Discord bot settings saved.");
    }

    private async Task SaveInstanceAsync(string uniqueName)
    {
        if (string.IsNullOrWhiteSpace(uniqueName))
            return;

        await SaveAsync($"Discord settings saved for {GetInstanceName(uniqueName)}.");
    }

    private async Task SaveAsync(string successMessage)
    {
        try
        {
            SyncInstanceOptions();
            await DiscordOptionsCatalog.SaveAsync(_options);
            ReloadOptions();
            Snackbar.Add(successMessage, Severity.Success);
        }
        catch (Exception exception)
        {
            Snackbar.Add(exception.Message, Severity.Error);
        }
    }

    private async Task ResetDeathTemplatesAsync()
    {
        try
        {
            await DeathMessagesCatalog.ResetAsync();
            ReloadDeathMessageEditors();
            Snackbar.Add("Death message templates reset.", Severity.Success);
        }
        catch (Exception exception)
        {
            Snackbar.Add(exception.Message, Severity.Error);
        }
    }

    private async Task SaveDeathTemplatesAsync()
    {
        try
        {
            await DeathMessagesCatalog.SaveAsync(_deathMessageConfig.Clone());
            ReloadDeathMessageEditors();
            Snackbar.Add("Death message templates saved.", Severity.Success);
        }
        catch (Exception exception)
        {
            Snackbar.Add(exception.Message, Severity.Error);
        }
    }

    private void HandleGuildIdChanged(ulong value)
    {
        _options.GuildId = value;
    }

    private DiscordInstanceOptions GetInstanceOptions(string uniqueName)
    {
        return _options.Instances.First(instance =>
            string.Equals(instance.UniqueName, uniqueName, StringComparison.OrdinalIgnoreCase));
    }

    private string GetInstanceName(string uniqueName)
    {
        return InstanceDefinitions
            .FirstOrDefault(item => string.Equals(item.UniqueName, uniqueName, StringComparison.OrdinalIgnoreCase))
            ?.UniqueName ?? uniqueName;
    }

    private void ReloadOptions()
    {
        _options = DiscordOptionsCatalog.GetOptions();
        SyncInstanceOptions();
    }

    private void ReloadDeathMessageEditors()
    {
        _deathMessageConfig = DeathMessagesCatalog.GetConfig();
    }

    private IReadOnlyList<DeathMessageCategoryView> GetDeathMessageCategories()
    {
        return
        [
            new("Suicide", "Suicide", "Self-inflicted and respawn deaths.", JoinDeathMessageLines(_deathMessageConfig.SuicideMessages)),
            new("PvP", "PvP", "Player-vs-player kills with named killer and weapon.", JoinDeathMessageLines(_deathMessageConfig.PvPMessages)),
            new("Turret", "Turret", "Turret or automated weapon kills.", JoinDeathMessageLines(_deathMessageConfig.TurretMessages)),
            new("Grid", "Grid", "Ship, grid, or landing gear impact deaths.", JoinDeathMessageLines(_deathMessageConfig.GridMessages)),
            new("Oxygen", "Oxygen", "No-air and suffocation deaths.", JoinDeathMessageLines(_deathMessageConfig.OxygenMessages)),
            new("Pressure", "Pressure", "Environmental pressure and decompression deaths.", JoinDeathMessageLines(_deathMessageConfig.PressureMessages)),
            new("Collision", "Collision", "Falls, crashes, and high-speed impacts.", JoinDeathMessageLines(_deathMessageConfig.CollisionMessages)),
            new("Accident", "Accident", "Fallback accidental deaths.", JoinDeathMessageLines(_deathMessageConfig.AccidentMessages)),
        ];
    }

    private void SetDeathMessageEditorText(string key, string value)
    {
        var lines = ParseDeathMessageLines(value);

        switch (key)
        {
            case "Suicide":
                _deathMessageConfig.SuicideMessages = lines;
                break;
            case "PvP":
                _deathMessageConfig.PvPMessages = lines;
                break;
            case "Turret":
                _deathMessageConfig.TurretMessages = lines;
                break;
            case "Grid":
                _deathMessageConfig.GridMessages = lines;
                break;
            case "Oxygen":
                _deathMessageConfig.OxygenMessages = lines;
                break;
            case "Pressure":
                _deathMessageConfig.PressureMessages = lines;
                break;
            case "Collision":
                _deathMessageConfig.CollisionMessages = lines;
                break;
            case "Accident":
                _deathMessageConfig.AccidentMessages = lines;
                break;
        }
    }

    private static string JoinDeathMessageLines(IEnumerable<string> values)
    {
        return string.Join(Environment.NewLine, values);
    }

    private static List<string> ParseDeathMessageLines(string value)
    {
        return value
            .Replace("\r\n", "\n", StringComparison.Ordinal)
            .Split('\n', StringSplitOptions.TrimEntries | StringSplitOptions.RemoveEmptyEntries)
            .ToList();
    }

    private static int CountDeathMessageLines(string value)
    {
        return ParseDeathMessageLines(value).Count;
    }

    private void SyncInstanceOptions()
    {
        foreach (var definition in InstanceDefinitions)
        {
            if (_options.Instances.Any(instance =>
                    string.Equals(instance.UniqueName, definition.UniqueName, StringComparison.OrdinalIgnoreCase)))
            {
                continue;
            }

            _options.Instances.Add(new DiscordInstanceOptions
            {
                UniqueName = definition.UniqueName,
            });
        }

        _options = DiscordOptions.Normalize(_options);
    }

    private Color GetStatusColor()
    {
        if (!string.IsNullOrWhiteSpace(BotStatus.LastError))
            return Color.Error;

        if (BotStatus.Enabled && BotStatus.IsRunning)
            return Color.Success;

        if (!BotStatus.Enabled)
            return Color.Default;

        return Color.Warning;
    }

    private string GetStatusLabel()
    {
        if (string.IsNullOrWhiteSpace(BotStatus.StateText))
            return "Unknown";

        return BotStatus.StateText;
    }

    private void HandleOptionsChanged()
    {
        ReloadOptions();
        _ = InvokeAsync(StateHasChanged);
    }

    private void HandleDeathMessagesChanged()
    {
        ReloadDeathMessageEditors();
        _ = InvokeAsync(StateHasChanged);
    }

    private void HandleInstanceCatalogChanged()
    {
        ReloadOptions();
        _ = InvokeAsync(StateHasChanged);
    }

    private void HandleBotStatusChanged()
    {
        _ = InvokeAsync(StateHasChanged);
    }

    private sealed record DeathMessageCategoryView(string Key, string Title, string Description, string EditorText);
}
