    private async Task MergeModsFromWorldTemplateAsync()
    {
        if (_editor is null)
            return;

        var parameters = new DialogParameters
        {
            [nameof(MergeWorldTemplateModsDialog.ExistingWorkshopIds)] =
                _editor.Mods.Select(mod => mod.WorkshopId).ToArray(),
        };

        var options = new DialogOptions
        {
            CloseOnEscapeKey = true,
            FullWidth = true,
            MaxWidth = MaxWidth.Medium,
        };

        var dialog = await DialogService.ShowAsync<MergeWorldTemplateModsDialog>(
            "Merge mods from world template",
            parameters,
            options);

        var result = await dialog.Result;
        if (result is null || result.Canceled || result.Data is not List<QuasarModSelection> mergedMods)
            return;

        if (mergedMods.Count == 0)
            return;

        var existing = _editor.Mods
            .Select(mod => mod.WorkshopId)
            .ToHashSet();

        var added = 0;
        foreach (var mod in mergedMods)
        {
            if (mod.WorkshopId <= 0 || !existing.Add(mod.WorkshopId))
                continue;

            _editor.Mods.Add(mod);
            added++;
        }

        _editor.Mods = _editor.Mods
            .OrderBy(mod => mod.DisplayName, StringComparer.OrdinalIgnoreCase)
            .ThenBy(mod => mod.WorkshopId)
            .ToList();

        if (added > 0)
            Snackbar.Add($"Merged {added} mod(s) from world template.", Severity.Success);
        else
            Snackbar.Add("All template mods were already in this profile.", Severity.Info);
    }

    private string GetProfileSummary(QuasarConfigProfile template)
    {
        return $"{template.Plugins.Count} plugins, {template.Mods.Count} mods, {GetAssignedServers(template.ConfigProfileId).Count} servers";
    }

    private static string FormatModListSummary(IReadOnlyList<QuasarModSelection> mods)
    {
        var names = mods
            .Take(8)
            .Select(mod => string.IsNullOrWhiteSpace(mod.DisplayName)
                ? mod.WorkshopId.ToString(System.Globalization.CultureInfo.InvariantCulture)
                : $"{mod.DisplayName} ({mod.WorkshopId})");

        var summary = string.Join(", ", names);
        return mods.Count > 8
            ? $"{summary}, +{mods.Count - 8} more"
            : summary;
    }

    private List<DedicatedServerDefinition> GetAssignedServers(string configProfileId)
    {
        return ServerCatalog.GetServers()
            .Where(server => string.Equals(server.ConfigProfileId, configProfileId, StringComparison.OrdinalIgnoreCase))
            .OrderBy(server => server.UniqueName, StringComparer.OrdinalIgnoreCase)
            .ToList();
    }

