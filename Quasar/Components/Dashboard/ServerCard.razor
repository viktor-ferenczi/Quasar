<MudCard Class="server-card">
    <MudCardHeader>
        <CardHeaderContent>
            <MudStack Row="true" Wrap="Wrap.Wrap" AlignItems="AlignItems.Center" Justify="Justify.SpaceBetween" Spacing="1">
                <MudStack Row="true" AlignItems="AlignItems.Center" Spacing="1">
                    <MudText Typo="Typo.h6">@GetDisplayName()</MudText>
                    <MudChip T="string" Size="Size.Small" Color="@GetStatusColor()">
                        @GetStatusLabel()
                    </MudChip>
                </MudStack>
                <MudStack Row="true" Wrap="Wrap.Wrap" Spacing="1">
                    @if (CanStart)
                    {
                        <MudButton Variant="Variant.Filled"
                                   Color="Color.Success"
                                   Size="Size.Small"
                                   StartIcon="@Icons.Material.Filled.PlayArrow"
                                   OnClick="StartAsync">
                            Start
                        </MudButton>
                    }
                    @if (CanRestart)
                    {
                        <MudButton Variant="Variant.Outlined"
                                   Color="Color.Primary"
                                   Size="Size.Small"
                                   StartIcon="@Icons.Material.Filled.RestartAlt"
                                   OnClick="RestartAsync">
                            Restart
                        </MudButton>
                    }
                    @if (CanStop)
                    {
                        <MudButton Variant="Variant.Filled"
                                   Color="Color.Error"
                                   Size="Size.Small"
                                   StartIcon="@Icons.Material.Filled.Stop"
                                   OnClick="StopAsync">
                            Stop
                        </MudButton>
                    }
                </MudStack>
            </MudStack>
            <MudStack Spacing="0">
                <MudText Typo="Typo.caption">@GetHostLabel() · @GetWorldLabel()</MudText>
                <MudText Typo="Typo.caption" Class="mono">@Server.UniqueName</MudText>
                @if (!string.IsNullOrWhiteSpace(Runtime?.LastMessage))
                {
                    <MudText Typo="Typo.caption">@Runtime.LastMessage</MudText>
                }
                @if (!string.IsNullOrWhiteSpace(Runtime?.HealthSummary))
                {
                    <MudText Typo="Typo.caption">@Runtime.HealthSummary</MudText>
                }
            </MudStack>
        </CardHeaderContent>
    </MudCardHeader>

    <MudCardContent>
        <ServerDetailPanel Server="@Server" Runtime="@Runtime" Agent="@Agent" />
    </MudCardContent>
</MudCard>

@code
{
    [Parameter, EditorRequired]
    public DedicatedServerDefinition Server { get; set; } = default!;

    [Parameter]
    public DedicatedServerRuntimeSnapshot? Runtime { get; set; }

    [Parameter]
    public AgentRuntimeState? Agent { get; set; }

    [Parameter]
    public EventCallback<string> StartRequested { get; set; }

    [Parameter]
    public EventCallback<string> StopRequested { get; set; }

    [Parameter]
    public EventCallback<string> RestartRequested { get; set; }

    private DedicatedServerProcessState ProcessState => Runtime?.State ?? DedicatedServerProcessState.Stopped;

    private bool IsProcessActive => ProcessState is DedicatedServerProcessState.Starting
        or DedicatedServerProcessState.Running
        or DedicatedServerProcessState.Restarting
        or DedicatedServerProcessState.Stopping;

    private bool CanStart => !IsProcessActive;

    private bool CanStop => ProcessState is DedicatedServerProcessState.Starting
        or DedicatedServerProcessState.Running
        or DedicatedServerProcessState.Restarting;

    private bool CanRestart => IsProcessActive;

    private Task StartAsync() => StartRequested.InvokeAsync(Server.UniqueName);

    private Task StopAsync() => StopRequested.InvokeAsync(Server.UniqueName);

    private Task RestartAsync() => RestartRequested.InvokeAsync(Server.UniqueName);

    private string GetDisplayName()
    {
        if (!string.IsNullOrWhiteSpace(Server.DisplayName))
            return Server.DisplayName.Trim();

        return Agent?.ServerDisplayName ?? Server.UniqueName;
    }

    private string GetHostLabel()
    {
        if (!string.IsNullOrWhiteSpace(Agent?.HostDisplayName) &&
            !string.Equals(Agent.HostDisplayName, "Unknown host", StringComparison.OrdinalIgnoreCase))
        {
            return Agent.HostDisplayName;
        }

        return "Local host";
    }

    private string GetWorldLabel()
    {
        if (!string.IsNullOrWhiteSpace(Agent?.WorldDisplayName) &&
            !string.Equals(Agent.WorldDisplayName, "Unknown world", StringComparison.OrdinalIgnoreCase))
        {
            return Agent.WorldDisplayName;
        }

        if (!string.IsNullOrWhiteSpace(Server.WorldPath))
            return Path.GetFileName(Server.WorldPath.TrimEnd(Path.DirectorySeparatorChar, Path.AltDirectorySeparatorChar));

        return "World pending";
    }

    private string GetStatusLabel()
    {
        if (ProcessState == DedicatedServerProcessState.Stopping)
            return "STOPPING";

        if (!IsProcessActive)
            return "OFF";

        if (ProcessState == DedicatedServerProcessState.Running && Agent?.IsConnected == true && Agent.Snapshot is not null)
            return "OPEN";

        // Process is up but the agent link isn't established yet — e.g. just after a
        // Quasar restart that adopted a running process, or a transient agent drop.
        if (ProcessState == DedicatedServerProcessState.Running)
            return "CONNECTING";

        return "STARTING";
    }

    private Color GetStatusColor()
    {
        if (ProcessState is DedicatedServerProcessState.Crashed or DedicatedServerProcessState.Faulted)
            return Color.Error;

        return GetStatusLabel() switch
        {
            "OPEN" => Color.Success,
            "CONNECTING" => Color.Info,
            "STARTING" => Color.Warning,
            "STOPPING" => Color.Warning,
            "OFF" => Color.Error,
            _ => Color.Default,
        };
    }
}
