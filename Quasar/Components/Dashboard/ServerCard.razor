@inject ServerManagementActions ServerActions
@inject QuasarConfigProfileCatalog ConfigProfiles
@inject IJSRuntime JS
@inject ISnackbar Snackbar
@inject NavigationManager Navigation

<MudCard Class="server-card">
    <MudCardHeader>
        <CardHeaderContent>
            <MudStack Row="true" Wrap="Wrap.Wrap" AlignItems="AlignItems.Center" Justify="Justify.SpaceBetween" Spacing="1">
                <MudStack Row="true" AlignItems="AlignItems.Center" Spacing="1">
                    <MudText Typo="Typo.h6">@GetDisplayName()</MudText>
                    <MudChip T="string" Size="Size.Small" Color="@GetStatusColor()">
                        @GetStatusLabel()
                    </MudChip>
                </MudStack>
                <MudStack Row="true" Wrap="Wrap.Wrap" Spacing="1">
                    <MudTooltip Text="Open console output">
                        <MudIconButton Icon="@Icons.Material.Filled.Terminal"
                                       Color="Color.Default"
                                       Size="Size.Small"
                                       OnClick="OpenConsoleAsync" />
                    </MudTooltip>
                    <MudTooltip Text="Clone server">
                        <MudIconButton Icon="@Icons.Material.Filled.ContentCopy"
                                       Color="Color.Default"
                                       Size="Size.Small"
                                       OnClick="CloneAsync" />
                    </MudTooltip>
                    <MudTooltip Text="Create world template">
                        <MudIconButton Icon="@Icons.Material.Filled.Public"
                                       Color="Color.Default"
                                       Size="Size.Small"
                                       Disabled="@(!CanCreateTemplate)"
                                       OnClick="CreateTemplateAsync" />
                    </MudTooltip>
                    <MudTooltip Text="Edit server">
                        <MudIconButton Icon="@Icons.Material.Filled.Edit"
                                       Color="Color.Default"
                                       Size="Size.Small"
                                       OnClick="EditAsync" />
                    </MudTooltip>
                    <MudTooltip Text="Delete server">
                        <MudIconButton Icon="@Icons.Material.Filled.Delete"
                                       Color="Color.Error"
                                       Size="Size.Small"
                                       Disabled="@IsProcessActive"
                                       OnClick="DeleteAsync" />
                    </MudTooltip>
                    @if (CanStart)
                    {
                        <MudButton Variant="Variant.Filled"
                                   Color="Color.Success"
                                   Size="Size.Small"
                                   Disabled="@LaunchBlocked"
                                   StartIcon="@Icons.Material.Filled.PlayArrow"
                                   OnClick="StartAsync">
                            Start
                        </MudButton>
                    }
                    @if (CanRestart)
                    {
                        <MudButton Variant="Variant.Outlined"
                                   Color="Color.Primary"
                                   Size="Size.Small"
                                   StartIcon="@Icons.Material.Filled.RestartAlt"
                                   OnClick="RestartAsync">
                            Restart
                        </MudButton>
                    }
                    @if (CanStop)
                    {
                        <MudButton Variant="Variant.Filled"
                                   Color="Color.Error"
                                   Size="Size.Small"
                                   StartIcon="@Icons.Material.Filled.Stop"
                                   OnClick="StopAsync">
                            Stop
                        </MudButton>
                    }
                    @if (CanKillStarting)
                    {
                        <MudButton Variant="Variant.Outlined"
                                   Color="Color.Error"
                                   Size="Size.Small"
                                   StartIcon="@Icons.Material.Filled.StopCircle"
                                   OnClick="KillStartingAsync">
                            Kill
                        </MudButton>
                    }
                </MudStack>
            </MudStack>
            <MudStack Spacing="0">
                <MudText Typo="Typo.caption">@GetHostLabel() · @GetWorldLabel()</MudText>
                <MudText Typo="Typo.caption" Class="mono">@Server.UniqueName</MudText>
                @if (!string.IsNullOrWhiteSpace(Runtime?.LastMessage))
                {
                    <MudText Typo="Typo.caption">@Runtime.LastMessage</MudText>
                }
                @if (!string.IsNullOrWhiteSpace(Runtime?.HealthSummary))
                {
                    <MudText Typo="Typo.caption">@Runtime.HealthSummary</MudText>
                }
                <MudStack Row="true" Wrap="Wrap.Wrap" Spacing="1" Class="mt-1">
                    <MudTooltip Text="@GetDirectConnectTooltip()">
                        <MudChip T="string"
                                 Variant="Variant.Outlined"
                                 Icon="@Icons.Material.Filled.ContentCopy"
                                 OnClick="CopyDirectConnectAsync">
                            Port @Server.ServerPort
                        </MudChip>
                    </MudTooltip>
                    @if (CanOpenConfigProfile)
                    {
                        <MudTooltip Text="Open config profile">
                            <MudChip T="string"
                                     Variant="Variant.Outlined"
                                     Color="Color.Primary"
                                     Icon="@Icons.Material.Filled.Tune"
                                     OnClick="OpenConfigProfileAsync">
                                Config @GetConfigProfileName()
                            </MudChip>
                        </MudTooltip>
                    }
                    else
                    {
                        <MudChip T="string" Variant="Variant.Outlined" Icon="@Icons.Material.Filled.Tune">
                            Config @GetConfigProfileName()
                        </MudChip>
                    }
                </MudStack>
            </MudStack>
        </CardHeaderContent>
    </MudCardHeader>

    <MudCardContent>
        <ServerDetailPanel Server="@Server" Runtime="@Runtime" Agent="@Agent" />
    </MudCardContent>
</MudCard>

@code
{
    [Parameter, EditorRequired]
    public DedicatedServerDefinition Server { get; set; } = default!;

    [Parameter]
    public DedicatedServerRuntimeSnapshot? Runtime { get; set; }

    [Parameter]
    public AgentRuntimeState? Agent { get; set; }

    [Parameter]
    public bool LaunchBlocked { get; set; }

    [Parameter]
    public EventCallback<string> StartRequested { get; set; }

    [Parameter]
    public EventCallback<string> StopRequested { get; set; }

    [Parameter]
    public EventCallback<string> KillStartingRequested { get; set; }

    [Parameter]
    public EventCallback<string> RestartRequested { get; set; }

    [Parameter]
    public EventCallback<string> ConfigProfileSelected { get; set; }

    private DedicatedServerProcessState ProcessState => Runtime?.State ?? DedicatedServerProcessState.Stopped;

    private bool IsProcessActive => ProcessState is DedicatedServerProcessState.Starting
        or DedicatedServerProcessState.Running
        or DedicatedServerProcessState.Restarting
        or DedicatedServerProcessState.Stopping;

    private bool CanStart => ProcessState is DedicatedServerProcessState.Stopped
        or DedicatedServerProcessState.Crashed
        or DedicatedServerProcessState.Faulted;

    private bool CanStop => ProcessState == DedicatedServerProcessState.Running;

    private bool CanKillStarting => ProcessState is DedicatedServerProcessState.Starting
        or DedicatedServerProcessState.Restarting;

    private bool CanRestart => ProcessState == DedicatedServerProcessState.Running;

    private bool CanCreateTemplate => ServerActions.CanCreateWorldTemplate(Server);

    private bool CanOpenConfigProfile =>
        !string.IsNullOrWhiteSpace(Server.ConfigProfileId) &&
        ConfigProfiles.GetProfile(Server.ConfigProfileId) is not null;

    private Task StartAsync() => StartRequested.InvokeAsync(Server.UniqueName);

    private Task StopAsync() => StopRequested.InvokeAsync(Server.UniqueName);

    private Task KillStartingAsync() => KillStartingRequested.InvokeAsync(Server.UniqueName);

    private Task RestartAsync() => RestartRequested.InvokeAsync(Server.UniqueName);

    private Task OpenConsoleAsync() => ServerActions.OpenConsoleDialogAsync(Server.UniqueName);

    private Task CloneAsync() => ServerActions.OpenCloneDialogAsync(Server);

    private Task CreateTemplateAsync() => ServerActions.CreateWorldTemplateAsync(Server);

    private Task EditAsync() => ServerActions.OpenEditDialogAsync(Server);

    private Task DeleteAsync() => ServerActions.DeleteAsync(Server.UniqueName);

    private async Task OpenConfigProfileAsync()
    {
        if (!CanOpenConfigProfile)
            return;

        await ConfigProfileSelected.InvokeAsync(Server.ConfigProfileId);
    }

    private async Task CopyDirectConnectAsync()
    {
        var address = GetDirectConnectAddress();
        var ok = await JS.InvokeAsync<bool>("quasarConfigs.copyText", address);
        Snackbar.Add(
            ok ? $"Copied {address} to clipboard." : "Copy failed - select and copy the port manually.",
            ok ? Severity.Info : Severity.Warning);
    }

    private string GetDisplayName()
    {
        if (!string.IsNullOrWhiteSpace(Server.DisplayName))
            return Server.DisplayName.Trim();

        return Agent?.ServerDisplayName ?? Server.UniqueName;
    }

    private string GetHostLabel()
    {
        if (!string.IsNullOrWhiteSpace(Agent?.HostDisplayName) &&
            !string.Equals(Agent.HostDisplayName, "Unknown host", StringComparison.OrdinalIgnoreCase))
        {
            return Agent.HostDisplayName;
        }

        return "Local host";
    }

    private string GetWorldLabel()
    {
        if (!string.IsNullOrWhiteSpace(Agent?.WorldDisplayName) &&
            !string.Equals(Agent.WorldDisplayName, "Unknown world", StringComparison.OrdinalIgnoreCase))
        {
            return Agent.WorldDisplayName;
        }

        if (!string.IsNullOrWhiteSpace(Server.WorldPath))
            return Path.GetFileName(Server.WorldPath.TrimEnd(Path.DirectorySeparatorChar, Path.AltDirectorySeparatorChar));

        return "World pending";
    }

    private string GetConfigProfileName()
    {
        if (string.IsNullOrWhiteSpace(Server.ConfigProfileId))
            return "-";

        return ConfigProfiles.GetProfile(Server.ConfigProfileId)?.Name ?? $"Missing: {Server.ConfigProfileId}";
    }

    private string GetDirectConnectTooltip() => $"Copy direct connect address {GetDirectConnectAddress()}";

    private string GetDirectConnectAddress()
    {
        var fallbackHost = Navigation.ToAbsoluteUri(Navigation.BaseUri).Host;
        var host = ResolveDirectConnectHost(Server.ServerIP, fallbackHost);
        if (host.Contains(':', StringComparison.Ordinal) &&
            !host.StartsWith("[", StringComparison.Ordinal) &&
            !host.EndsWith("]", StringComparison.Ordinal))
        {
            host = $"[{host}]";
        }

        return $"{host}:{Server.ServerPort}";
    }

    private static string ResolveDirectConnectHost(string? configuredHost, string fallbackHost)
    {
        var host = configuredHost?.Trim() ?? string.Empty;
        if (IsAnyAddress(host))
            host = fallbackHost?.Trim() ?? string.Empty;

        if (IsAnyAddress(host) || string.IsNullOrWhiteSpace(host))
            return "127.0.0.1";

        return host;
    }

    private static bool IsAnyAddress(string value)
    {
        var normalized = value.Trim().Trim('[', ']');
        return string.IsNullOrWhiteSpace(normalized) ||
               string.Equals(normalized, "0.0.0.0", StringComparison.Ordinal) ||
               string.Equals(normalized, "::", StringComparison.Ordinal) ||
               string.Equals(normalized, "*", StringComparison.Ordinal) ||
               string.Equals(normalized, "+", StringComparison.Ordinal);
    }

    private string GetStatusLabel()
    {
        if (ProcessState == DedicatedServerProcessState.Stopping)
            return "STOPPING";

        if (ProcessState == DedicatedServerProcessState.Restarting)
            return "RESTARTING";

        if (ProcessState == DedicatedServerProcessState.Crashed)
            return "CRASHED";

        if (ProcessState == DedicatedServerProcessState.Faulted)
            return "FAULTED";

        if (!IsProcessActive)
            return "OFF";

        if (ProcessState == DedicatedServerProcessState.Running && Agent?.IsConnected == true && Agent.Snapshot is not null)
            return "OPEN";

        // Process is up but the agent link isn't established yet — e.g. just after a
        // Quasar restart that adopted a running process, or a transient agent drop.
        if (ProcessState == DedicatedServerProcessState.Running)
            return "CONNECTING";

        return "STARTING";
    }

    private Color GetStatusColor()
    {
        if (ProcessState is DedicatedServerProcessState.Crashed or DedicatedServerProcessState.Faulted)
            return Color.Error;

        return GetStatusLabel() switch
        {
            "OPEN" => Color.Success,
            "CONNECTING" => Color.Info,
            "STARTING" => Color.Warning,
            "RESTARTING" => Color.Warning,
            "STOPPING" => Color.Warning,
            "OFF" => Color.Error,
            _ => Color.Default,
        };
    }
}
