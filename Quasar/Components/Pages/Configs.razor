    private void SetStringOption(QuasarConfigOptionDefinition option, string value)
    {
        var property = QuasarConfigMetadata.GetProperty(option);
        if (property.PropertyType == typeof(QuasarNetworkType))
        {
            if (Enum.TryParse<QuasarNetworkType>(value, ignoreCase: true, out var networkType))
                SetPropertyValue(option, networkType);

            return;
        }

        SetPropertyValue(option, value);
    }

    private object? GetPropertyValue(QuasarConfigOptionDefinition option)
    {
        var target = GetOptionTarget(option);
        if (target is null)
            return null;

        return QuasarConfigMetadata.GetProperty(option).GetValue(target);
    }

    private void SetPropertyValue(QuasarConfigOptionDefinition option, object value)
    {
        var target = GetOptionTarget(option);
        if (target is null)
            return;

        QuasarConfigMetadata.GetProperty(option).SetValue(target, value);
    }

    private object? GetOptionTarget(QuasarConfigOptionDefinition option)
    {
        if (_editor is null)
            return null;

        return option.Scope == QuasarConfigOptionScope.Root
            ? _editor.RootSettings
            : _editor.SessionSettings;
    }

    private string GetOptionTooltipText(QuasarConfigOptionDefinition option)
    {
        var lines = new List<string>
        {
            GetOptionExplanation(option),
        };

        if (!string.IsNullOrWhiteSpace(option.HelperText))
            lines.Add(option.HelperText.Trim());

        return string.Join(Environment.NewLine, lines);
    }

    private static string GetAccessTooltipText(string explanation)
    {
        return explanation;
    }

    private static string GetOptionExplanation(QuasarConfigOptionDefinition option)
    {
        var subject = GetTooltipSubject(option.Label);
        return option.Kind switch
        {
            QuasarConfigOptionKind.Boolean when option.Label.StartsWith("Enable ", StringComparison.OrdinalIgnoreCase) =>
                $"Turns {GetTooltipSubject(option.Label["Enable ".Length..])} on or off.",
            QuasarConfigOptionKind.Boolean =>
                $"Toggles {subject}.",
            QuasarConfigOptionKind.Integer or QuasarConfigOptionKind.Decimal =>
                $"Sets {subject}.",
            QuasarConfigOptionKind.Text or QuasarConfigOptionKind.LongText =>
                $"Sets {subject}.",
            QuasarConfigOptionKind.SelectInteger or QuasarConfigOptionKind.SelectText =>
                $"Chooses {subject}.",
            _ =>
                $"Controls {subject}.",
        };
    }

    private static string GetTooltipSubject(string label)
    {
        if (string.IsNullOrWhiteSpace(label))
            return "this setting";

        return string.Concat(char.ToLowerInvariant(label[0]), label[1..]);
    }

    private int GetAccessEntryCount()
    {
        if (_editor is null)
            return 0;

        return (_editor.RootSettings.GroupId > 0 ? 1 : 0)
            + _editor.RootSettings.Administrators.Count
            + _editor.RootSettings.Reserved.Count
            + _editor.RootSettings.Banned.Count;
    }

    private int GetAccessMatchCount()
    {
        if (_editor is null || string.IsNullOrWhiteSpace(_worldSearch))
            return string.IsNullOrWhiteSpace(_worldSearch) && _editor is not null ? 4 : 0;

        var count = 0;
        if (MatchesSearchTerms(_worldSearch, "access whitelist group steam friends clan", "Whitelist Group ID", _editor.RootSettings.GroupId.ToString()))
            count++;
        if (MatchesSearchTerms(_worldSearch, "administrators admins moderators", "Admin User IDs", string.Join(' ', _editor.RootSettings.Administrators)))
            count++;
        if (MatchesSearchTerms(_worldSearch, "reserved reserve slots whitelist", "Reserved Slot User IDs", string.Join(' ', _editor.RootSettings.Reserved.Select(value => value.ToString(System.Globalization.CultureInfo.InvariantCulture)))))
            count++;
        if (MatchesSearchTerms(_worldSearch, "banned blacklist blacklisted blocked", "Banned Blacklisted User IDs", string.Join(' ', _editor.RootSettings.Banned.Select(value => value.ToString(System.Globalization.CultureInfo.InvariantCulture)))))
            count++;

        return count;
    }

