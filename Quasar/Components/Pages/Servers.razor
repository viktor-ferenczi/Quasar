@page "/servers"
@implements IDisposable
@inject DedicatedServerCatalog ServerCatalog
@inject DedicatedServerSupervisor Supervisor
@inject AgentRegistry Registry
@inject QuasarConfigProfileCatalog ConfigProfiles
@inject QuasarWorldTemplateCatalog WorldTemplates
@inject IDialogService DialogService
@inject WebServiceOptions Options
@inject ISnackbar Snackbar
@inject NavigationManager Navigation

<PageTitle>Servers</PageTitle>

<MudText Typo="Typo.h5" Class="mb-2">Servers</MudText>
<MudText Typo="Typo.body2">Persistent dedicated servers. Quasar launches, stops, and restarts processes from these definitions, and Quasar.Agent attaches once the server is up for live data. Expand a row to see live agent data: players, chat, plugins, command results.</MudText>

<MudPaper Class="pa-4 server-card mt-2">
    <MudStack Row="true" Wrap="Wrap.Wrap" AlignItems="AlignItems.Center" Justify="Justify.SpaceBetween" Spacing="2" Class="mb-4">
        <MudStack Row="true" Wrap="Wrap.Wrap" AlignItems="AlignItems.Center" Spacing="1">
            <MudChip T="string" Variant="Variant.Outlined">@($"{ServerDefinitions.Count} server(s)")</MudChip>
            <MudButton Variant="Variant.Filled" Color="Color.Primary" StartIcon="@Icons.Material.Filled.Add" OnClick="OpenCreateDialogAsync">
                Create Server
            </MudButton>
        </MudStack>
    </MudStack>

    @if (ServerDefinitions.Count == 0)
    {
        <MudAlert Severity="Severity.Info" Variant="Variant.Outlined">
            No servers defined yet.
        </MudAlert>
    }
    else
    {
        <MudTable T="DedicatedServerDefinition" Dense="true" Hover="true" Breakpoint="Breakpoint.Md" Items="ServerDefinitions">
            <HeaderContent>
                <MudTh Style="width: 36px;"></MudTh>
                <MudTh><MudTableSortLabel SortBy="new Func<DedicatedServerDefinition, object>(x => GetStateText(x.UniqueName))">Status</MudTableSortLabel></MudTh>
                <MudTh><MudTableSortLabel SortBy="new Func<DedicatedServerDefinition, object>(x => GetDisplayName(x))">Name</MudTableSortLabel></MudTh>
                <MudTh><MudTableSortLabel SortBy="new Func<DedicatedServerDefinition, object>(x => x.ServerPort)">Port</MudTableSortLabel></MudTh>
                <MudTh Style="text-align: center;"><MudTableSortLabel SortBy="new Func<DedicatedServerDefinition, object>(x => GetConfigProfileName(x.ConfigProfileId))">Config</MudTableSortLabel></MudTh>
                <MudTh><MudTableSortLabel SortBy="new Func<DedicatedServerDefinition, object>(x => GetPlayerSortValue(x.UniqueName))">Players</MudTableSortLabel></MudTh>
                <MudTh><MudTableSortLabel SortBy="new Func<DedicatedServerDefinition, object>(x => GetProcessSortValue(x.UniqueName))">Process</MudTableSortLabel></MudTh>
                <MudTh><MudTableSortLabel SortBy="new Func<DedicatedServerDefinition, object>(x => GetAttachmentStatus(x.UniqueName))">Agent</MudTableSortLabel></MudTh>
                <MudTh></MudTh>
            </HeaderContent>
            <RowTemplate>
                <MudTd>
                    <MudIconButton Size="Size.Small"
                                   Icon="@(IsExpanded(context.UniqueName) ? Icons.Material.Filled.ExpandLess : Icons.Material.Filled.ExpandMore)"
                                   OnClick="@(() => ToggleExpanded(context.UniqueName))"
                                   title="Show live data" />
                </MudTd>
                <MudTd DataLabel="Status">
                    <MudStack Row="true" AlignItems="AlignItems.Center" Spacing="1">
                        <MudChip T="string" Color="@GetStateColor(context.UniqueName)" Variant="Variant.Outlined">
                            @GetStateText(context.UniqueName)
                        </MudChip>
                        @if (context.GoalState == DedicatedServerGoalState.On)
                        {
                            <MudButton Variant="Variant.Filled" Size="Size.Small" Color="Color.Warning" OnClick="@(() => StopAsync(context.UniqueName))">Stop</MudButton>
                        }
                        else
                        {
                            <MudButton Variant="Variant.Filled" Size="Size.Small" Color="Color.Success" OnClick="@(() => StartAsync(context.UniqueName))">Start</MudButton>
                        }
                    </MudStack>
                </MudTd>
                <MudTd DataLabel="Name">
                    <MudText Typo="Typo.body2">@GetDisplayName(context)</MudText>
                    <MudText Typo="Typo.caption" Class="mono">@context.UniqueName</MudText>
                </MudTd>
                <MudTd DataLabel="Port" Class="mono">@context.ServerPort</MudTd>
                <MudTd DataLabel="Config" Style="text-align: center;">
                    @if (CanOpenConfigProfile(context.ConfigProfileId))
                    {
                        <MudLink Typo="Typo.body2"
                                 Color="Color.Primary"
                                 Underline="Underline.Hover"
                                 @onclick="@(() => OpenConfigProfileAsync(context.ConfigProfileId))">
                            @GetConfigProfileName(context.ConfigProfileId)
                        </MudLink>
                    }
                    else
                    {
                        <MudText Typo="Typo.body2">@GetConfigProfileName(context.ConfigProfileId)</MudText>
                    }
                </MudTd>
                <MudTd DataLabel="Players">@GetPlayerCount(context.UniqueName)</MudTd>
                <MudTd DataLabel="Process" Class="mono">@GetProcessDisplay(context.UniqueName)</MudTd>
                <MudTd DataLabel="Agent">@GetAttachmentStatus(context.UniqueName)</MudTd>
                <MudTd Style="text-align: right;">
                    <MudStack Row="true" Wrap="Wrap.Wrap" Justify="Justify.FlexEnd" Spacing="0">
                        @if (context.GoalState == DedicatedServerGoalState.On)
                        {
                            @if (IsRunning(context.UniqueName))
                            {
                                <MudButton Variant="Variant.Text" Size="Size.Small" Color="Color.Primary" OnClick="@(() => RestartAsync(context.UniqueName))">Restart</MudButton>
                            }
                        }
                        <MudIconButton Size="Size.Small" Icon="@Icons.Material.Filled.Terminal" Color="Color.Default" title="Show console output" OnClick="@(() => OpenConsoleDialogAsync(context.UniqueName))" />
                        <MudButton Variant="Variant.Text" Size="Size.Small" OnClick="@(() => OpenCloneDialogAsync(context))">Clone</MudButton>
                        <MudButton Variant="Variant.Text" Size="Size.Small" Disabled="@(!CanCreateWorldTemplate(context))" OnClick="@(() => CreateWorldTemplateAsync(context))">Template</MudButton>
                        <MudButton Variant="Variant.Text" Size="Size.Small" OnClick="@(() => OpenEditDialogAsync(context))">Edit</MudButton>
                        <MudButton Variant="Variant.Text" Size="Size.Small" Color="Color.Error" OnClick="@(() => DeleteAsync(context.UniqueName))">Delete</MudButton>
                    </MudStack>
                </MudTd>
            </RowTemplate>
            <ChildRowContent>
                @if (IsExpanded(context.UniqueName))
                {
                    <MudTr>
                        <td colspan="9" style="padding: 0.75rem 1rem; background: var(--mud-palette-background);">
                            <ServerDetailPanel Agent="@GetAgent(context.UniqueName)" />
                        </td>
                    </MudTr>
                }
            </ChildRowContent>
        </MudTable>
    }
</MudPaper>

@if (UnmanagedAgents.Count > 0)
{
    <MudPaper Class="pa-4 server-card mt-4">
        <MudStack Row="true" Wrap="Wrap.Wrap" AlignItems="AlignItems.Center" Justify="Justify.SpaceBetween" Spacing="2" Class="mb-3">
            <div>
                <MudText Typo="Typo.h6">Unmanaged Agents</MudText>
                <MudText Typo="Typo.body2">Quasar.Agent processes reporting in without a matching server definition.</MudText>
            </div>
            <MudChip T="string" Variant="Variant.Outlined" Color="Color.Warning">@($"{UnmanagedAgents.Count} unmanaged")</MudChip>
        </MudStack>

        @foreach (var agent in UnmanagedAgents)
        {
            <MudExpansionPanel Text="@($"{agent.ServerDisplayName} · {agent.UniqueNameKey}")" Dense="true">
                <ServerDetailPanel Agent="@agent" />
            </MudExpansionPanel>
        }
    </MudPaper>
}

@code
{
    private readonly HashSet<string> _expanded = new(StringComparer.OrdinalIgnoreCase);
    private bool _creatingWorldTemplate;

    [Parameter]
    public EventCallback<string> ConfigProfileSelected { get; set; }

    private IReadOnlyList<DedicatedServerDefinition> ServerDefinitions => ServerCatalog.GetServers();

    private IReadOnlyDictionary<string, DedicatedServerRuntimeSnapshot> RuntimeSnapshots => Supervisor
        .GetSnapshots()
        .ToDictionary(snapshot => snapshot.UniqueName, StringComparer.OrdinalIgnoreCase);

    private IReadOnlyDictionary<string, AgentRuntimeState> AgentsByUniqueName => Registry
        .GetAgents()
        .Where(agent => agent.IsConnected)
        .Where(agent => !string.IsNullOrWhiteSpace(agent.UniqueNameKey))
        .GroupBy(agent => agent.UniqueNameKey, StringComparer.OrdinalIgnoreCase)
        .ToDictionary(group => group.Key, group => group.OrderByDescending(a => a.LastSeenUtc).First(), StringComparer.OrdinalIgnoreCase);

    private IReadOnlyList<AgentRuntimeState> UnmanagedAgents
    {
        get
        {
            var defined = ServerDefinitions
                .Select(definition => definition.UniqueName)
                .ToHashSet(StringComparer.OrdinalIgnoreCase);

            return Registry.GetAgents()
                .Where(agent => agent.IsConnected)
                .Where(agent => !string.IsNullOrWhiteSpace(agent.UniqueNameKey))
                .Where(agent => !defined.Contains(agent.UniqueNameKey))
                .ToList();
        }
    }

    protected override void OnInitialized()
    {
        ServerCatalog.Changed += HandleChanged;
        Supervisor.Changed += HandleChanged;
        Registry.Changed += HandleChanged;
        ConfigProfiles.Changed += HandleChanged;
        WorldTemplates.Changed += HandleChanged;
    }

    public void Dispose()
    {
        ServerCatalog.Changed -= HandleChanged;
        Supervisor.Changed -= HandleChanged;
        Registry.Changed -= HandleChanged;
        ConfigProfiles.Changed -= HandleChanged;
        WorldTemplates.Changed -= HandleChanged;
    }

    private bool IsExpanded(string uniqueName) => _expanded.Contains(uniqueName);

    private void ToggleExpanded(string uniqueName)
    {
        if (!_expanded.Add(uniqueName))
            _expanded.Remove(uniqueName);
    }

    private AgentRuntimeState? GetAgent(string uniqueName)
    {
        AgentsByUniqueName.TryGetValue(uniqueName, out var agent);
        return agent;
    }

    private async Task OpenCreateDialogAsync()
    {
        var definition = await ShowEditorDialogAsync(CreateBlank(), isEditing: false);
        if (definition is null)
            return;

        await SaveDefinitionAsync(definition, "Server created.");
    }

    private async Task OpenCloneDialogAsync(DedicatedServerDefinition definition)
    {
        var cloned = definition.Clone();
        cloned.DisplayName = NormalizeWhitespace($"{GetDisplayName(definition)} Copy");
        cloned.UniqueName = MakeCopyIdentifier(definition.UniqueName);
        cloned.OriginalUniqueName = string.Empty;
        var created = await ShowEditorDialogAsync(cloned, isEditing: false);
        if (created is null)
            return;

        await SaveDefinitionAsync(created, "Server cloned.");
    }

    private async Task OpenEditDialogAsync(DedicatedServerDefinition definition)
    {
        var updated = await ShowEditorDialogAsync(definition, isEditing: true);
        if (updated is null)
            return;

        await SaveDefinitionAsync(updated, "Server saved.");
    }

    private async Task OpenConfigProfileAsync(string configProfileId)
    {
        if (!CanOpenConfigProfile(configProfileId))
            return;

        if (ConfigProfileSelected.HasDelegate)
        {
            await ConfigProfileSelected.InvokeAsync(configProfileId);
            return;
        }

        Navigation.NavigateTo($"/configs?profileId={Uri.EscapeDataString(configProfileId)}");
    }

    private async Task OpenConsoleDialogAsync(string uniqueName)
    {
        var parameters = new DialogParameters
        {
            [nameof(ServerConsoleDialog.UniqueName)] = uniqueName,
        };

        var options = new DialogOptions
        {
            CloseOnEscapeKey = true,
            FullWidth = true,
            MaxWidth = MaxWidth.Large,
        };

        await DialogService.ShowAsync<ServerConsoleDialog>($"Console — {uniqueName}", parameters, options);
    }

    private async Task CreateWorldTemplateAsync(DedicatedServerDefinition definition)
    {
        if (!CanCreateWorldTemplate(definition))
        {
            Snackbar.Add("Stop the server before creating a world template from its current state.", Severity.Warning);
            return;
        }

        var worldPath = definition.WorldPath?.Trim() ?? string.Empty;
        if (string.IsNullOrWhiteSpace(worldPath) || !Directory.Exists(worldPath))
        {
            Snackbar.Add($"World path not found for '{definition.UniqueName}'.", Severity.Error);
            return;
        }

        if (!File.Exists(Path.Combine(worldPath, "Sandbox.sbc")))
        {
            Snackbar.Add($"World path '{worldPath}' does not contain Sandbox.sbc.", Severity.Error);
            return;
        }

        var defaultName = $"{GetDisplayName(definition)} Snapshot {DateTime.Now:yyyy-MM-dd HHmm}";
        var parameters = new DialogParameters
        {
            [nameof(WorldTemplateFromServerDialog.DefaultName)] = defaultName,
            [nameof(WorldTemplateFromServerDialog.DefaultDescription)] = $"Created from stopped server '{definition.UniqueName}'.",
            [nameof(WorldTemplateFromServerDialog.WorldPath)] = worldPath,
        };

        var dialog = await DialogService.ShowAsync<WorldTemplateFromServerDialog>(
            "Create World Template",
            parameters,
            new DialogOptions { CloseOnEscapeKey = true, FullWidth = true, MaxWidth = MaxWidth.Small });

        var result = await dialog.Result;
        if (result is null || result.Canceled || result.Data is not WorldTemplateFromServerDialog.TemplateRequest request)
            return;

        _creatingWorldTemplate = true;
        try
        {
            var template = await WorldTemplates.ImportAsync(request.Name, request.Description, worldPath);
            Snackbar.Add($"World template '{template.Name}' created.", Severity.Success);
        }
        catch (Exception exception)
        {
            Snackbar.Add(exception.Message, Severity.Error);
        }
        finally
        {
            _creatingWorldTemplate = false;
        }
    }

    private async Task<DedicatedServerDefinition?> ShowEditorDialogAsync(DedicatedServerDefinition definition, bool isEditing)
    {
        var parameters = new DialogParameters
        {
            [nameof(ServerEditorDialog.Definition)] = definition.Clone(),
            [nameof(ServerEditorDialog.IsEditing)] = isEditing,
            [nameof(ServerEditorDialog.UniqueNameLocked)] = isEditing && IsRunning(definition.UniqueName),
        };

        var options = new DialogOptions
        {
            CloseOnEscapeKey = true,
            FullWidth = true,
            MaxWidth = MaxWidth.ExtraLarge,
        };

        var dialog = await DialogService.ShowAsync<ServerEditorDialog>(isEditing ? "Edit Server" : "Create Server", parameters, options);
        var result = await dialog.Result;
        if (result is null || result.Canceled || result.Data is not DedicatedServerDefinition updated)
            return null;

        return updated;
    }

    private async Task SaveDefinitionAsync(DedicatedServerDefinition definition, string successMessage)
    {
        var previousUniqueName = definition.OriginalUniqueName;
        if (!string.IsNullOrWhiteSpace(previousUniqueName) &&
            !string.Equals(previousUniqueName, definition.UniqueName, StringComparison.OrdinalIgnoreCase) &&
            IsRunning(previousUniqueName))
        {
            Snackbar.Add("Stop the server before renaming it.", Severity.Warning);
            return;
        }

        try
        {
            await ServerCatalog.UpsertAsync(definition);
            Snackbar.Add(successMessage, Severity.Success);
        }
        catch (Exception exception)
        {
            Snackbar.Add(exception.Message, Severity.Error);
        }
    }

    private async Task StartAsync(string uniqueName)
    {
        try
        {
            await Supervisor.SetGoalStateAsync(uniqueName, DedicatedServerGoalState.On);
            Snackbar.Add("Server start requested.", Severity.Success);
        }
        catch (Exception exception)
        {
            Snackbar.Add(exception.Message, Severity.Error);
        }
    }

    private async Task StopAsync(string uniqueName)
    {
        try
        {
            await Supervisor.SetGoalStateAsync(uniqueName, DedicatedServerGoalState.Off);
            Snackbar.Add("Server stop requested.", Severity.Info);
        }
        catch (Exception exception)
        {
            Snackbar.Add(exception.Message, Severity.Error);
        }
    }

    private async Task RestartAsync(string uniqueName)
    {
        try
        {
            await Supervisor.RestartServerAsync(uniqueName);
            Snackbar.Add("Server restart requested.", Severity.Info);
        }
        catch (Exception exception)
        {
            Snackbar.Add(exception.Message, Severity.Error);
        }
    }

    private async Task DeleteAsync(string uniqueName)
    {
        if (IsRunning(uniqueName))
        {
            Snackbar.Add("Stop the server before deleting its definition.", Severity.Warning);
            return;
        }

        var confirmed = await DialogService.ShowMessageBoxAsync(
            "Delete server?",
            $"Server definition '{uniqueName}' will be removed from the active catalog and archived in the server history folder as a deleted JSON snapshot. World files, rendered server config, logs, and server folders stay on disk; Quasar does not move them to the OS Trash yet.",
            yesText: "Delete",
            cancelText: "Cancel");

        if (confirmed != true)
            return;

        await ServerCatalog.DeleteAsync(uniqueName);
        Registry.PruneDisconnectedByUniqueName(uniqueName);
        Snackbar.Add("Server removed.", Severity.Info);
    }

    private string GetAttachmentStatus(string uniqueName)
    {
        var runtime = GetRuntime(uniqueName);
        if (runtime is null)
            return "not attached";

        return runtime.AgentAttached ? "attached" : "not attached";
    }

    private static string GetDisplayName(DedicatedServerDefinition definition)
    {
        return string.IsNullOrWhiteSpace(definition.DisplayName) ? definition.UniqueName : definition.DisplayName;
    }

    private string GetPlayerCount(string uniqueName)
    {
        var snapshot = GetAgent(uniqueName)?.Snapshot;
        if (snapshot is null)
            return "-";

        var server = ServerCatalog
            .GetServers()
            .FirstOrDefault(item => string.Equals(item.UniqueName, uniqueName, StringComparison.OrdinalIgnoreCase));
        var configuredMaxPlayers = string.IsNullOrWhiteSpace(server?.ConfigProfileId)
            ? null
            : ConfigProfiles.GetProfile(server.ConfigProfileId)?.SessionSettings.MaxPlayers;
        var maxPlayers = configuredMaxPlayers is > 0
            ? configuredMaxPlayers.GetValueOrDefault()
            : snapshot.Metrics.MaxPlayers;

        return $"{snapshot.Metrics.PlayersOnline}/{maxPlayers}";
    }

    private int GetPlayerSortValue(string uniqueName) =>
        GetAgent(uniqueName)?.Snapshot?.Metrics.PlayersOnline ?? -1;

    private string GetProcessDisplay(string uniqueName)
    {
        var runtime = GetRuntime(uniqueName);
        return runtime?.ProcessId?.ToString() ?? "stopped";
    }

    private int GetProcessSortValue(string uniqueName) =>
        GetRuntime(uniqueName)?.ProcessId ?? -1;

    private string GetConfigProfileName(string configProfileId)
    {
        if (string.IsNullOrWhiteSpace(configProfileId))
            return "-";

        return ConfigProfiles.GetProfile(configProfileId)?.Name ?? $"Missing: {configProfileId}";
    }

    private bool CanOpenConfigProfile(string configProfileId) =>
        !string.IsNullOrWhiteSpace(configProfileId) &&
        ConfigProfiles.GetProfile(configProfileId) is not null;

    private string GetStateText(string uniqueName)
    {
        var runtime = GetRuntime(uniqueName);
        return runtime?.State.ToString().ToLowerInvariant() ?? "stopped";
    }

    private Color GetStateColor(string uniqueName)
    {
        var state = GetRuntime(uniqueName)?.State ?? DedicatedServerProcessState.Stopped;
        return state switch
        {
            DedicatedServerProcessState.Running => Color.Success,
            DedicatedServerProcessState.Starting => Color.Info,
            DedicatedServerProcessState.Restarting => Color.Warning,
            DedicatedServerProcessState.Stopping => Color.Warning,
            DedicatedServerProcessState.Crashed => Color.Error,
            DedicatedServerProcessState.Faulted => Color.Error,
            _ => Color.Default,
        };
    }

    private bool IsRunning(string uniqueName)
    {
        var state = GetRuntime(uniqueName)?.State ?? DedicatedServerProcessState.Stopped;
        return state is DedicatedServerProcessState.Starting
            or DedicatedServerProcessState.Running
            or DedicatedServerProcessState.Restarting
            or DedicatedServerProcessState.Stopping;
    }

    private bool CanCreateWorldTemplate(DedicatedServerDefinition definition)
    {
        if (_creatingWorldTemplate || definition.GoalState != DedicatedServerGoalState.Off)
            return false;

        var state = GetRuntime(definition.UniqueName)?.State ?? DedicatedServerProcessState.Stopped;
        return state == DedicatedServerProcessState.Stopped;
    }

    private DedicatedServerRuntimeSnapshot? GetRuntime(string uniqueName)
    {
        RuntimeSnapshots.TryGetValue(uniqueName, out var runtime);
        return runtime;
    }

    private void HandleChanged()
    {
        _ = InvokeAsync(StateHasChanged);
    }

    private DedicatedServerDefinition CreateBlank()
    {
        var healthMonitoringEnabled = !Options.DisableServerHealthMonitoring;
        return new DedicatedServerDefinition
        {
            GoalState = DedicatedServerGoalState.Off,
            ServerPort = AllocateNextPort(),
            ServerIP = "0.0.0.0",
            EnableHealthMonitoring = healthMonitoringEnabled,
            AutoRestartOnUnhealthy = healthMonitoringEnabled,
            AgentStartupGraceSeconds = 180,
            AgentHeartbeatTimeoutSeconds = 20,
            SimulationProgressWindowSeconds = 30,
            MinimumSimulationProgressScore = 0.05f,
            WarnAfterUptimeHours = 12,
            RestartDelaySeconds = 5,
            RestartOnCrash = true,
        };
    }

    private string MakeCopyIdentifier(string uniqueName)
    {
        var baseName = string.IsNullOrWhiteSpace(uniqueName) ? "server" : uniqueName.Trim();
        var candidate = $"{baseName}-copy";
        var used = ServerCatalog.GetServers()
            .Select(server => server.UniqueName)
            .ToHashSet(StringComparer.OrdinalIgnoreCase);
        var suffix = 2;

        while (used.Contains(candidate))
            candidate = $"{baseName}-copy-{suffix++}";

        return candidate;
    }

    private static string NormalizeWhitespace(string value) =>
        System.Text.RegularExpressions.Regex.Replace(value.Trim(), @"\s+", " ");

    private int AllocateNextPort()
    {
        var used = ServerCatalog.GetServers()
            .Select(server => server.ServerPort)
            .Where(port => port > 0)
            .ToHashSet();

        var port = 27016;
        while (used.Contains(port) && port < 65535)
            port++;

        return port;
    }
}
