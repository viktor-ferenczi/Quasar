@page "/plugins"
@implements IDisposable
@inject AgentRegistry Registry
@inject DedicatedServerCatalog ServerCatalog
@inject PluginConfigService ConfigService
@inject QuasarPluginCatalogService PluginCatalog

<PageTitle>Plugins</PageTitle>

<MudText Typo="Typo.h5" Class="mb-2">Plugin inventory</MudText>
<MudText Typo="Typo.body2" Class="mb-4">Plugin inventory across all connected servers.</MudText>
<MudPaper Class="server-card">
    <MudTable T="PluginRow" Dense="true" Hover="true" Breakpoint="Breakpoint.Sm" Items="PluginRows">
        <HeaderContent>
            <MudTh><MudTableSortLabel SortBy="new Func<PluginRow, object>(x => x.DisplayName)">Plugin</MudTableSortLabel></MudTh>
            <MudTh><MudTableSortLabel SortBy="new Func<PluginRow, object>(x => x.Version)">Version</MudTableSortLabel></MudTh>
            <MudTh><MudTableSortLabel SortBy="new Func<PluginRow, object>(x => x.ServerName)">Server</MudTableSortLabel></MudTh>
            <MudTh><MudTableSortLabel SortBy="new Func<PluginRow, object>(x => x.HostName)">Host</MudTableSortLabel></MudTh>
            <MudTh><MudTableSortLabel SortBy="new Func<PluginRow, object>(x => x.IsLoaded)">Status</MudTableSortLabel></MudTh>
            <MudTh Style="width:48px;"></MudTh>
        </HeaderContent>
        <RowTemplate>
            <MudTd DataLabel="Plugin">@context.DisplayName</MudTd>
            <MudTd DataLabel="Version">@context.Version</MudTd>
            <MudTd DataLabel="Server">@context.ServerName</MudTd>
            <MudTd DataLabel="Host">@context.HostName</MudTd>
            <MudTd DataLabel="Status">@(context.IsLoaded ? "loaded" : "declared")</MudTd>
            <MudTd Style="text-align:right;">
                @if (!string.IsNullOrWhiteSpace(context.SourceUrl))
                {
                    <MudIconButton Icon="@Icons.Material.Filled.OpenInNew" Color="Color.Default" Href="@context.SourceUrl" Target="_blank" Size="Size.Small" title="Open GitHub repository" />
                }
            </MudTd>
        </RowTemplate>
        <NoRecordsContent>
            <MudAlert Severity="Severity.Info" Variant="Variant.Outlined" Class="ma-4">
                No plugin inventory yet.
            </MudAlert>
        </NoRecordsContent>
    </MudTable>
</MudPaper>

<MudText Typo="Typo.h5" Class="mt-8 mb-2">Plugin configuration</MudText>
<MudText Typo="Typo.body2" Class="mb-4 mud-text-secondary">
    Live configuration for plugins that expose a Quasar config provider.
</MudText>

@if (ConfigAgents.Count == 0)
{
    <MudAlert Severity="Severity.Info" Variant="Variant.Outlined">
        No connected server is exposing editable plugin configuration.
    </MudAlert>
}
else
{
    var selectedAgent = GetSelectedConfigAgent();

    <MudSelect T="string"
               Label="Server"
               Value="@selectedAgent?.AgentId"
               ValueChanged="HandleConfigAgentChanged"
               Variant="Variant.Outlined"
               Dense="true"
               Class="mb-4"
               Style="max-width: 24rem;">
        @foreach (var agent in ConfigAgents)
        {
            <MudSelectItem T="string" Value="@agent.AgentId">@ResolveServerName(agent)</MudSelectItem>
        }
    </MudSelect>

    @if (selectedAgent is not null)
    {
        <MudPaper Class="server-card mb-4 pa-4">
            <MudText Typo="Typo.h6">@ResolveServerName(selectedAgent)</MudText>
            <MudText Typo="Typo.caption" Class="mud-text-secondary d-block mb-3">@selectedAgent.HostDisplayName</MudText>
            @foreach (var plugin in ConfigService.GetConfigsForAgent(selectedAgent.AgentId))
            {
                <MudExpansionPanels Class="mb-2" MultiExpansion="true">
                    <MudExpansionPanel Text="@plugin.DisplayName">
                        <PluginConfigEditor AgentId="@selectedAgent.AgentId" Plugin="@plugin" />
                    </MudExpansionPanel>
                </MudExpansionPanels>
            }
        </MudPaper>
    }
}

<MudText Typo="Typo.h5" Class="mt-8 mb-2">Plugin logs</MudText>
<MudText Typo="Typo.body2" Class="mb-4 mud-text-secondary">
    Structured logs emitted by plugins through the PluginSdk, captured from managed dedicated servers.
</MudText>

<PluginLogPanel />

@code
{
    private string? _selectedConfigAgentId;

    private IReadOnlyList<PluginRow> PluginRows => Registry
        .GetAgents()
        .SelectMany(agent => (agent.Snapshot?.Plugins ?? new List<PluginRuntimeInfo>())
            .Select(plugin => new PluginRow
            {
                DisplayName = plugin.DisplayName,
                Version = plugin.Version,
                ServerName = ResolveServerName(agent),
                HostName = agent.HostDisplayName,
                IsLoaded = plugin.IsLoaded,
                SourceUrl = GetPluginSourceUrl(plugin),
            }))
        .OrderBy(row => row.DisplayName, StringComparer.OrdinalIgnoreCase)
        .ThenBy(row => row.ServerName, StringComparer.OrdinalIgnoreCase)
        .ToList();

    private List<AgentRuntimeState> ConfigAgents => Registry
        .GetAgents()
        .Where(agent => agent.IsConnected && ConfigService.HasConfigs(agent.AgentId))
        .ToList();

    protected override void OnInitialized()
    {
        Registry.Changed += HandleRegistryChanged;
        ServerCatalog.Changed += HandleRegistryChanged;
        ConfigService.Changed += HandleRegistryChanged;
    }

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (!firstRender || PluginCatalog.GetEntries().Count > 0)
            return;

        try
        {
            await PluginCatalog.RefreshAsync();
            await InvokeAsync(StateHasChanged);
        }
        catch
        {
        }
    }

    public void Dispose()
    {
        Registry.Changed -= HandleRegistryChanged;
        ServerCatalog.Changed -= HandleRegistryChanged;
        ConfigService.Changed -= HandleRegistryChanged;
    }

    private void HandleRegistryChanged()
    {
        _ = InvokeAsync(StateHasChanged);
    }

    // Prefer the name configured for the server in Quasar over the agent's in-game
    // server name (ConfigDedicated.ServerName, often blank and falling back to
    // "Space Engineers {pid}"). Matches how the Servers/dashboard cards resolve it.
    private string ResolveServerName(AgentRuntimeState agent)
    {
        var configuredName = ServerCatalog.GetServer(agent.UniqueNameKey)?.DisplayName;
        return string.IsNullOrWhiteSpace(configuredName) ? agent.ServerDisplayName : configuredName;
    }

    // The selected server falls back to the first available one so the panel always
    // shows a server's plugins even before the user picks one (or after the selected
    // server disconnects).
    private AgentRuntimeState? GetSelectedConfigAgent()
    {
        var agents = ConfigAgents;
        if (agents.Count == 0)
            return null;

        return agents.FirstOrDefault(agent =>
            string.Equals(agent.AgentId, _selectedConfigAgentId, StringComparison.OrdinalIgnoreCase))
            ?? agents[0];
    }

    private void HandleConfigAgentChanged(string agentId)
    {
        _selectedConfigAgentId = agentId;
    }

    private string GetPluginSourceUrl(PluginRuntimeInfo plugin)
    {
        var catalogEntry = PluginCatalog.GetEntries().FirstOrDefault(entry =>
            IsPluginMatch(entry, plugin.PluginId) ||
            IsPluginMatch(entry, plugin.DisplayName) ||
            IsPluginMatch(entry, System.IO.Path.GetFileNameWithoutExtension(plugin.PluginId)));

        return catalogEntry is null
            ? string.Empty
            : QuasarPluginCatalogService.GetRepositoryUrl(catalogEntry.SourceRepo);
    }

    private static bool IsPluginMatch(QuasarPluginCatalogEntry entry, string value) =>
        !string.IsNullOrWhiteSpace(value) &&
        (string.Equals(entry.PluginId, value, StringComparison.OrdinalIgnoreCase) ||
         string.Equals(entry.FriendlyName, value, StringComparison.OrdinalIgnoreCase));

    private sealed class PluginRow
    {
        public string DisplayName { get; set; } = string.Empty;

        public string Version { get; set; } = string.Empty;

        public string ServerName { get; set; } = string.Empty;

        public string HostName { get; set; } = string.Empty;

        public bool IsLoaded { get; set; }

        public string SourceUrl { get; set; } = string.Empty;
    }
}
