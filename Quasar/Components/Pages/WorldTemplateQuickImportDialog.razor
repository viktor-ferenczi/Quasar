<MudDialog>
    <DialogContent>
        @if (_step == ImportStep.Details)
        {
            <MudTabs Elevation="0"
                     Rounded="true"
                     Outlined="true"
                     ApplyEffectsToContainer="true"
                     KeepPanelsAlive="false"
                     TabPanelsClass="pa-4"
                     @bind-ActivePanelIndex="_activeDetailsTabIndex">
                <MudTabPanel Text="Predefined worlds" Icon="@Icons.Material.Filled.Public">
                    <MudStack Spacing="2">
                        <MudStack Row="true" AlignItems="AlignItems.Center" Justify="Justify.SpaceBetween" Wrap="Wrap.Wrap">
                            <div>
                                <MudText Typo="Typo.subtitle1">Predefined Worlds</MudText>
                                <MudText Typo="Typo.body2">
                                    Add a template from Dedicated Server content without entering a name or path.
                                </MudText>
                            </div>
                            <MudChip T="string" Size="Size.Small" Variant="Variant.Outlined">@_installedTemplates.Count</MudChip>
                        </MudStack>

                        <MudStack Row="true" Wrap="Wrap.Wrap" AlignItems="AlignItems.Center" Spacing="1">
                            <MudTextField
                                @bind-Value="_installedTemplateSearch"
                                Label="Search installed templates"
                                Variant="Variant.Outlined"
                                Immediate="true"
                                Adornment="Adornment.Start"
                                AdornmentIcon="@Icons.Material.Filled.Search"
                                Class="flex-grow-1" />
                            <MudButton Variant="Variant.Outlined" Color="Color.Default" StartIcon="@Icons.Material.Filled.Refresh" OnClick="RefreshInstalledTemplates">
                                Refresh
                            </MudButton>
                        </MudStack>

                        @if (_installedTemplates.Count == 0)
                        {
                            <MudAlert Severity="Severity.Info" Variant="Variant.Outlined">
                                No installed Dedicated Server world or scenario templates found.
                            </MudAlert>
                        }
                        else
                        {
                            <MudTable T="InstalledWorldTemplateSource" Dense="true" Hover="true" Items="FilteredInstalledTemplates" Breakpoint="Breakpoint.Sm" Class="installed-world-template-table">
                                <HeaderContent>
                                    <MudTh Class="installed-world-template-name-cell">Name</MudTh>
                                    <MudTh Class="installed-world-template-source-cell">Source</MudTh>
                                    <MudTh Class="installed-world-template-action-cell"></MudTh>
                                </HeaderContent>
                                <RowTemplate>
                                    <MudTd DataLabel="Name" Class="installed-world-template-name-cell">
                                        <MudText Typo="Typo.body2" Class="installed-world-template-name-text">@context.DisplayName</MudText>
                                    </MudTd>
                                    <MudTd DataLabel="Source" Class="installed-world-template-source-cell">
                                        <MudStack Spacing="0" Class="installed-world-template-source-stack">
                                            <MudText Typo="Typo.caption" Class="installed-world-template-source-text">@context.Category</MudText>
                                            <MudText Typo="Typo.caption" Class="mono installed-world-template-source-text">@context.SourcePath</MudText>
                                        </MudStack>
                                    </MudTd>
                                    <MudTd Class="installed-world-template-action-cell">
                                        <MudButton Variant="Variant.Outlined"
                                                   Color="Color.Primary"
                                                   Size="Size.Small"
                                                   Disabled="_importing"
                                                   OnClick="@(() => ImportPredefinedTemplateAsync(context))">
                                            Add
                                        </MudButton>
                                    </MudTd>
                                </RowTemplate>
                                <NoRecordsContent>
                                    <MudAlert Severity="Severity.Info" Variant="Variant.Outlined" Class="ma-4">
                                        No installed templates match current search.
                                    </MudAlert>
                                </NoRecordsContent>
                            </MudTable>
                        }
                    </MudStack>
                </MudTabPanel>

                <MudTabPanel Text="Custom import" Icon="@Icons.Material.Filled.FolderOpen">
                    <MudForm @ref="_form" @bind-IsValid="_formIsValid">
                    <MudStack Spacing="3">
                        <MudText Typo="Typo.body2">
                            Import an existing Space Engineers save folder as a reusable world template, then select it in the server editor.
                        </MudText>

                        <MudTextField
                            @bind-Value="_name"
                            Label="Template name"
                            Variant="Variant.Outlined"
                            Immediate="true"
                            AutoFocus="true"
                            Required="true"
                            RequiredError="Template name required." />

                        <MudTextField
                            @bind-Value="_description"
                            Label="Description"
                            Variant="Variant.Outlined"
                            Immediate="true"
                            Lines="3"
                            Sizing="InputSizing.Auto"
                            MaxLines="10000" />

                        <MudStack Row="true" Spacing="1" AlignItems="AlignItems.Start">
                            <MudTextField
                                @bind-Value="_sourcePath"
                                Label="Source world path"
                                Variant="Variant.Outlined"
                                Immediate="true"
                                Class="flex-grow-1"
                                Required="true"
                                RequiredError="Source world path required."
                                HelperText="Absolute path to an existing SE save folder containing Sandbox.sbc." />
                            <MudButton Variant="Variant.Outlined"
                                       Color="Color.Default"
                                       StartIcon="@Icons.Material.Filled.FolderOpen"
                                       Class="world-template-browse-button"
                                       OnClick="OpenFolderPickerAsync">
                                Browse
                            </MudButton>
                        </MudStack>
                    </MudStack>
                    </MudForm>
                </MudTabPanel>
            </MudTabs>
        }
        else
        {
            <MudStack Spacing="3">
                <MudText Typo="Typo.subtitle2">Template mods</MudText>
                <MudAlert Severity="Severity.Info" Variant="Variant.Outlined">
                    Found @_sourceMods.Count mod(s) in the source world's <code>Sandbox_config.sbc</code>. Quasar writes the selected config profile's session settings and mods into the active world on server start.
                </MudAlert>

                <MudRadioGroup T="WorldImportModAction" @bind-Value="_modAction">
                    <MudStack Spacing="1">
                        <MudRadio T="WorldImportModAction" Value="WorldImportModAction.CreateProfile" Color="Color.Primary">
                            Create new config profile from these mods
                        </MudRadio>
                        <MudRadio T="WorldImportModAction" Value="WorldImportModAction.ExistingProfile" Color="Color.Primary" Disabled="@(ConfigProfiles.GetProfiles().Count == 0)">
                            Import mods into existing config profile
                        </MudRadio>
                        <MudRadio T="WorldImportModAction" Value="WorldImportModAction.None" Color="Color.Primary">
                            Do nothing with template mods
                        </MudRadio>
                    </MudStack>
                </MudRadioGroup>

                @if (_modAction == WorldImportModAction.CreateProfile)
                {
                    <MudTextField
                        @bind-Value="_newProfileName"
                        Label="Profile name"
                        Variant="Variant.Outlined"
                        Immediate="true"
                        Required="true"
                        RequiredError="Profile name required." />

                    <MudTextField
                        @bind-Value="_newProfileDescription"
                        Label="Description"
                        Variant="Variant.Outlined"
                        Immediate="true"
                        Lines="3"
                        Sizing="InputSizing.Auto"
                        MaxLines="10000" />
                }
                else if (_modAction == WorldImportModAction.ExistingProfile)
                {
                    <MudSelect T="string"
                               @bind-Value="_selectedConfigProfileId"
                               Label="Config profile"
                               Variant="Variant.Outlined"
                               Required="true"
                               RequiredError="Config profile required.">
                        @foreach (var profile in ConfigProfiles.GetProfiles())
                        {
                            <MudSelectItem T="string" Value="@profile.ConfigProfileId">@profile.Name</MudSelectItem>
                        }
                    </MudSelect>
                }

                <MudTable T="QuasarModSelection" Items="_sourceMods" Dense="true" Hover="true" Breakpoint="Breakpoint.Sm">
                    <HeaderContent>
                        <MudTh>Name</MudTh>
                        <MudTh>Workshop ID</MudTh>
                    </HeaderContent>
                    <RowTemplate>
                        <MudTd DataLabel="Name">@context.DisplayName</MudTd>
                        <MudTd DataLabel="Workshop ID" Class="mono">@context.WorkshopId</MudTd>
                    </RowTemplate>
                </MudTable>
            </MudStack>
        }
    </DialogContent>
    <DialogActions>
        @if (_step == ImportStep.Mods)
        {
            <MudButton Variant="Variant.Text" Color="Color.Default" OnClick="BackToDetails" Disabled="@_importing">Back</MudButton>
        }
        <MudButton Variant="Variant.Text" Color="Color.Default" OnClick="Cancel" Disabled="@_importing">Cancel</MudButton>
        @if (_step == ImportStep.Mods || IsCustomImportTabActive)
        {
            <MudButton Variant="Variant.Filled" Color="Color.Primary" OnClick="ContinueAsync" Disabled="@_importing">
                @GetPrimaryButtonText()
            </MudButton>
        }
    </DialogActions>
</MudDialog>

@code
{
    [CascadingParameter]
    private IMudDialogInstance MudDialog { get; set; } = default!;

    [Inject]
    private QuasarWorldTemplateCatalog WorldTemplates { get; set; } = default!;

    [Inject]
    private QuasarConfigProfileCatalog ConfigProfiles { get; set; } = default!;

    [Inject]
    private ISnackbar Snackbar { get; set; } = default!;

    [Inject]
    private IDialogService DialogService { get; set; } = default!;

    [Inject]
    private WorldTemplateImportLocationService ImportLocations { get; set; } = default!;

    [Parameter]
    public string? InitialConfigProfileId { get; set; }

    private MudForm? _form;
    private bool _formIsValid;
    private string _name = string.Empty;
    private string _description = string.Empty;
    private string _sourcePath = string.Empty;
    private string _installedTemplateSearch = string.Empty;
    private string _selectedConfigProfileId = string.Empty;
    private string _newProfileName = string.Empty;
    private string _newProfileDescription = string.Empty;
    private List<QuasarModSelection> _sourceMods = [];
    private IReadOnlyList<InstalledWorldTemplateSource> _installedTemplates = [];
    private ImportStep _step = ImportStep.Details;
    private int _activeDetailsTabIndex;
    private WorldImportModAction _modAction = WorldImportModAction.CreateProfile;
    private bool _importing;

    private bool IsCustomImportTabActive => _activeDetailsTabIndex == CustomImportTabIndex;

    private IReadOnlyList<InstalledWorldTemplateSource> FilteredInstalledTemplates =>
        _installedTemplates
            .Where(MatchesInstalledTemplateSearch)
            .ToList();

    protected override void OnInitialized()
    {
        RefreshInstalledTemplates();
        _selectedConfigProfileId = GetInitialConfigProfileId();
        if (!string.IsNullOrWhiteSpace(_selectedConfigProfileId))
            _modAction = WorldImportModAction.ExistingProfile;
    }

    private void Cancel()
    {
        MudDialog.Cancel();
    }

    private void BackToDetails()
    {
        _step = ImportStep.Details;
    }

    private async Task OpenFolderPickerAsync()
    {
        var initialPath = await ImportLocations.GetInitialPathAsync(_sourcePath);
        var parameters = new DialogParameters
        {
            [nameof(FolderPickerDialog.InitialPath)] = initialPath,
            [nameof(FolderPickerDialog.AdditionalShortcuts)] = ImportLocations.GetContentShortcuts(),
        };

        var dialog = await DialogService.ShowAsync<FolderPickerDialog>(
            "Pick world folder",
            parameters,
            new DialogOptions { CloseOnEscapeKey = true, MaxWidth = MaxWidth.Medium, FullWidth = true });

        var result = await dialog.Result;
        if (result is { Canceled: false, Data: string path })
        {
            _sourcePath = path;
            await ImportLocations.RememberAsync(path);
        }
    }

    private async Task ContinueAsync()
    {
        if (_step == ImportStep.Mods)
        {
            await ImportAsync();
            return;
        }

        if (_form is null)
        {
            Snackbar.Add("Choose a predefined world or open Custom import.", Severity.Info);
            return;
        }

        await _form!.ValidateAsync();
        if (!_formIsValid)
            return;

        await ContinueFromDetailsAsync();
    }

    private async Task ImportPredefinedTemplateAsync(InstalledWorldTemplateSource source)
    {
        _name = source.DisplayName;
        _description = source.Description;
        _sourcePath = source.SourcePath;
        await ContinueFromDetailsAsync();
    }

    private async Task ContinueFromDetailsAsync()
    {
        _sourceMods = LoadSourceMods();
        if (_sourceMods.Count > 0)
        {
            _newProfileName = string.IsNullOrWhiteSpace(_newProfileName)
                ? $"{_name.Trim()} Config"
                : _newProfileName;
            _newProfileDescription = string.IsNullOrWhiteSpace(_newProfileDescription)
                ? $"Created from imported world template '{_name.Trim()}'."
                : _newProfileDescription;

            _selectedConfigProfileId = FirstExistingProfileId(_selectedConfigProfileId) ?? ConfigProfiles.GetProfiles().FirstOrDefault()?.ConfigProfileId ?? string.Empty;
            if (ConfigProfiles.GetProfiles().Count == 0 && _modAction == WorldImportModAction.ExistingProfile)
                _modAction = WorldImportModAction.CreateProfile;

            _step = ImportStep.Mods;
            return;
        }

        await ImportAsync();
    }

    private void RefreshInstalledTemplates()
    {
        _installedTemplates = ImportLocations.GetInstalledWorldTemplates();
    }

    private bool MatchesInstalledTemplateSearch(InstalledWorldTemplateSource template)
    {
        var search = _installedTemplateSearch?.Trim();
        if (string.IsNullOrWhiteSpace(search))
            return true;

        return Contains(template.DisplayName, search) ||
               Contains(template.Category, search) ||
               Contains(template.SourcePath, search);
    }

    private static bool Contains(string value, string search) =>
        !string.IsNullOrWhiteSpace(value) &&
        value.Contains(search, StringComparison.OrdinalIgnoreCase);

    private async Task ImportAsync()
    {
        if (_modAction == WorldImportModAction.CreateProfile && _step == ImportStep.Mods && string.IsNullOrWhiteSpace(_newProfileName))
        {
            Snackbar.Add("Profile name required.", Severity.Warning);
            return;
        }

        if (_modAction == WorldImportModAction.ExistingProfile &&
            _step == ImportStep.Mods &&
            string.IsNullOrWhiteSpace(_selectedConfigProfileId))
        {
            Snackbar.Add("Config profile required.", Severity.Warning);
            return;
        }

        _importing = true;
        try
        {
            var template = await WorldTemplates.ImportAsync(_name.Trim(), _description?.Trim() ?? string.Empty, _sourcePath.Trim());
            var configProfileId = await ApplyModActionAsync();
            MudDialog.Close(DialogResult.Ok(new WorldTemplateQuickImportResult(template, configProfileId)));
        }
        catch (Exception exception)
        {
            Snackbar.Add(exception.Message, Severity.Error);
        }
        finally
        {
            _importing = false;
        }
    }

    private async Task<string?> ApplyModActionAsync()
    {
        if (_step != ImportStep.Mods || _sourceMods.Count == 0 || _modAction == WorldImportModAction.None)
            return null;

        if (_modAction == WorldImportModAction.ExistingProfile)
        {
            var profile = ConfigProfiles.GetProfile(_selectedConfigProfileId)
                ?? throw new InvalidOperationException("Selected config profile no longer exists.");
            var added = MergeMods(profile, _sourceMods);
            await ConfigProfiles.UpsertAsync(profile);
            Snackbar.Add(added > 0
                ? $"Imported {added} mod(s) into config profile '{profile.Name}'."
                : $"Config profile '{profile.Name}' already has these mods.",
                added > 0 ? Severity.Success : Severity.Info);
            return profile.ConfigProfileId;
        }

        var newProfile = new QuasarConfigProfile
        {
            Name = _newProfileName.Trim(),
            Description = _newProfileDescription?.Trim() ?? string.Empty,
            Mods = _sourceMods.ToList(),
        };

        await ConfigProfiles.UpsertAsync(newProfile);
        await OpenConfigProfileEditorAsync(newProfile.ConfigProfileId);
        return newProfile.ConfigProfileId;
    }

    private async Task OpenConfigProfileEditorAsync(string configProfileId)
    {
        var parameters = new DialogParameters
        {
            [nameof(ConfigsPageDialog.InitialProfileId)] = configProfileId,
        };

        var dialog = await DialogService.ShowAsync<ConfigsPageDialog>(
            "Config Profiles",
            parameters,
            new DialogOptions
            {
                CloseOnEscapeKey = true,
                FullScreen = true,
            });

        await dialog.Result;
    }

    private List<QuasarModSelection> LoadSourceMods()
    {
        var sandboxConfigPath = Path.Combine(_sourcePath.Trim(), WorldSandboxConfigEditor.SandboxConfigFileName);
        try
        {
            return WorldSandboxConfigEditor.ReadMods(sandboxConfigPath).ToList();
        }
        catch (Exception exception)
        {
            Snackbar.Add($"Could not read template mods. Continuing without mod handling. {exception.Message}", Severity.Warning);
            return [];
        }
    }

    private string GetInitialConfigProfileId() =>
        FirstExistingProfileId(InitialConfigProfileId) ?? ConfigProfiles.GetProfiles().FirstOrDefault()?.ConfigProfileId ?? string.Empty;

    private string? FirstExistingProfileId(string? configProfileId)
    {
        if (string.IsNullOrWhiteSpace(configProfileId))
            return null;

        var trimmed = configProfileId.Trim();
        return ConfigProfiles.GetProfile(trimmed) is null ? null : trimmed;
    }

    private string GetPrimaryButtonText() =>
        _importing
            ? "Importing..."
            : _step == ImportStep.Mods
                ? "Import World Template"
                : "Continue";

    private static int MergeMods(QuasarConfigProfile profile, IEnumerable<QuasarModSelection> mods)
    {
        var existing = profile.Mods.Select(mod => mod.WorkshopId).ToHashSet();
        var added = 0;
        foreach (var mod in mods)
        {
            if (mod.WorkshopId <= 0 || !existing.Add(mod.WorkshopId))
                continue;

            profile.Mods.Add(new QuasarModSelection
            {
                WorkshopId = mod.WorkshopId,
                DisplayName = mod.DisplayName,
            });
            added++;
        }

        profile.Mods = profile.Mods
            .OrderBy(mod => mod.DisplayName, StringComparer.OrdinalIgnoreCase)
            .ThenBy(mod => mod.WorkshopId)
            .ToList();

        return added;
    }

    public sealed record WorldTemplateQuickImportResult(QuasarWorldTemplate Template, string? ConfigProfileId);

    private enum ImportStep
    {
        Details,
        Mods,
    }

    private const int CustomImportTabIndex = 1;

    private enum WorldImportModAction
    {
        CreateProfile,
        ExistingProfile,
        None,
    }
}
