    private void AddWorkshopResult(QuasarWorkshopSearchResult result, bool showSnackbar = true)
    {
        if (_editor is null)
            return;

        if (IsModSelected(result.WorkshopId))
        {
            if (showSnackbar)
                Snackbar.Add("Mod already selected.", Severity.Info);
            return;
        }

        _editor.Mods.Add(new QuasarModSelection
        {
            WorkshopId = result.WorkshopId,
            DisplayName = string.IsNullOrWhiteSpace(result.Title)
                ? result.WorkshopId.ToString(System.Globalization.CultureInfo.InvariantCulture)
                : result.Title.Trim(),
        });
        _editor.Mods = _editor.Mods
            .OrderBy(mod => mod.DisplayName, StringComparer.OrdinalIgnoreCase)
            .ThenBy(mod => mod.WorkshopId)
            .ToList();

        if (showSnackbar)
            Snackbar.Add("Workshop mod added.", Severity.Success);
    }

    private async Task ResolveWorkshopModsAsync()
    {
        if (_editor is null)
            return;

        var input = _workshopInput.Trim();
        if (string.IsNullOrWhiteSpace(input))
        {
            Snackbar.Add("Workshop input required.", Severity.Warning);
            return;
        }

        _modResolving = true;
        try
        {
            var result = await WorkshopMods.ResolveAsync(input);
            var added = 0;
            var duplicates = 0;

            foreach (var mod in result.Mods)
            {
                if (_editor.Mods.Any(existing => existing.WorkshopId == mod.WorkshopId))
                {
                    duplicates++;
                    continue;
                }

                _editor.Mods.Add(mod);
                added++;
            }

            _editor.Mods = _editor.Mods
                .OrderBy(mod => mod.DisplayName, StringComparer.OrdinalIgnoreCase)
                .ThenBy(mod => mod.WorkshopId)
                .ToList();

            _workshopInput = string.Empty;

            if (added > 0)
            {
                var detail = duplicates > 0
                    ? $"Added {added} workshop mod(s). {duplicates} already selected."
                    : $"Added {added} workshop mod(s).";
                Snackbar.Add(detail, Severity.Success);
            }
            else if (duplicates > 0)
            {
                Snackbar.Add("All resolved workshop mods already selected.", Severity.Info);
            }

            if (result.Warnings.Count > 0)
                Snackbar.Add(SummarizeWarnings(result.Warnings), Severity.Warning);
        }
        catch (Exception exception)
        {
            Snackbar.Add(exception.Message, Severity.Error);
        }
        finally
        {
            _modResolving = false;
            await InvokeAsync(StateHasChanged);
        }
    }

    private void RemoveMod(long workshopId)
    {
        if (_editor is null)
            return;

        _editor.Mods.RemoveAll(mod => mod.WorkshopId == workshopId);
    }

    private async Task AddDevFolderAsync()
    {
        var parameters = new DialogParameters
        {
            [nameof(PluginManifestPickerDialog.InitialPath)] = _lastDevFolderPath,
            [nameof(PluginManifestPickerDialog.DialogTitle)] = "Pick plugin manifest",
        };

        var dialog = await DialogService.ShowAsync<PluginManifestPickerDialog>(
            "Pick plugin manifest",
            parameters,
            new DialogOptions { CloseOnEscapeKey = true, MaxWidth = MaxWidth.Medium, FullWidth = true });

        var result = await dialog.Result;
        if (result is not { Canceled: false, Data: string xmlPath })
            return;

        var folderPath = (Path.GetDirectoryName(xmlPath) ?? string.Empty).Trim();
        var dataFile = Path.GetFileName(xmlPath).Trim();
        _lastDevFolderPath = folderPath;

        if (string.IsNullOrWhiteSpace(folderPath) || string.IsNullOrWhiteSpace(dataFile))
            return;

        if (GlobalDevFolders.Any(devFolder =>
                string.Equals(devFolder.FolderPath, folderPath, StringComparison.OrdinalIgnoreCase) &&
                string.Equals(devFolder.DataFile, dataFile, StringComparison.OrdinalIgnoreCase)))
        {
            Snackbar.Add("Dev folder already registered.", Severity.Info);
            return;
        }

        try
        {
            PluginManifestReader.ValidateManifest(Path.Combine(folderPath, dataFile));
        }
        catch (InvalidOperationException exception)
        {
            Snackbar.Add(exception.Message, Severity.Error);
            return;
        }

        var folderName = QuasarDevFolderSelection.GetSourceFolderName(folderPath);
        var metadata = PluginManifestReader.ReadMetadata(Path.Combine(folderPath, dataFile));
        var displayName = string.IsNullOrWhiteSpace(metadata.FriendlyName) ? folderName : metadata.FriendlyName;

        var devFolder = new QuasarDevFolderSelection
        {
            Name = displayName,
            FolderPath = folderPath,
            DataFile = dataFile,
            PluginId = folderName,
            DebugBuild = true,
        };

        await DevFolderCatalog.UpsertAsync(devFolder);
        Snackbar.Add("Dev folder added.", Severity.Success);
    }

